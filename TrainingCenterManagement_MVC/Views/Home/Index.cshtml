    <script>
        // simple accordion
        document.querySelectorAll('.faq-btn').forEach(function(btn){
            btn.addEventListener('click', function(){
                var expanded = this.getAttribute('aria-expanded') === 'true';
                this.setAttribute('aria-expanded', String(!expanded));
                var panel = this.parentElement.querySelector('.faq-panel');
                panel.classList.toggle('open');
            });
        });
   
    
    </script>


   
    <section class="u-backlink u-clearfix u-grey-80"></section>
    <script>
        document.getElementById('current-year').textContent = new Date().getFullYear();

        const mobileMenuButton = document.querySelector('.mobile-menu-button');
        const mobileMenu = document.querySelector('.mobile-menu');

        mobileMenuButton.addEventListener('click', () => {
          mobileMenu.classList.toggle('active');
          if (mobileMenu.classList.contains('active')) {
            mobileMenuButton.innerHTML = '<i class="fas fa-times"></i>';
          } else {
            mobileMenuButton.innerHTML = '<i class="fas fa-bars"></i>';
          }
        });

        const themeToggle = document.querySelector('.theme-toggle');
        const prefersDarkScheme = window.matchMedia('(prefers-color-scheme: dark)');

        const currentTheme = localStorage.getItem('theme') || (prefersDarkScheme.matches ? 'dark' : 'light');

        if (currentTheme === 'dark') {
          document.body.classList.add('dark-theme');
        }

        themeToggle.addEventListener('click', () => {
          document.body.classList.toggle('dark-theme');
          const theme = document.body.classList.contains('dark-theme') ? 'dark' : 'light';
          localStorage.setItem('theme', theme);
        });
    </script>
    @section Scripts {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script>
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .build();



            connection.start()
                .then(() => console.log("SignalR Connected"))
                .catch(err => {
                    console.error("SignalR Connection Error:", err);
                    $("#status").text("Failed to connect to chat server");
                });
                                // معالج استقبال الإشعارات للرسائل الخاصة
                connection.on("ReceiveNotification", (sender, message) => {
                    if (Notification.permission === "granted") {
                        new Notification(`رسالة جديدة من ${sender}`, {
                            body: message,
                                icon: 'success' // استبدل بمسار أيقونة فعلي
                        });
                    }
                });

        </script>
    }
    </script>
