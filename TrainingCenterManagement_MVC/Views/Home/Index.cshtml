@model TrainingCenterManagement_MVC.ViewModels.HomeViewModel
@using TrainingCenterManagement_MVC.Models
@{
    ViewData["Title"] = "Training Center | منصة التدريب الحديثة";
    ViewData["Description"] = "مركز تدريب حديث يقدم كورسات عملية، مدربين محترفين، اختبارات، شهادات، ولوحة متابعة واضحة للمتدربين.";
    Layout = "_Layout";

    var heroCourse = Model.FeaturedCourses.FirstOrDefault();
}

@section Styles {
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Tajawal:wght@400;500;700;800;900&display=swap');

    :root {
        --home-bg: #07111f;
        --home-bg-2: #0b1830;
        --home-surface: rgba(10, 20, 39, 0.78);
        --home-surface-strong: rgba(10, 20, 39, 0.92);
        --home-border: rgba(148, 163, 184, 0.18);
        --home-text: #f8fbff;
        --home-muted: #a9b8d4;
        --home-primary: #39c6f4;
        --home-primary-2: #67e8f9;
        --home-secondary: #2563eb;
        --home-accent: #f59e0b;
        --home-shadow: 0 24px 60px rgba(0, 0, 0, 0.30);
        --home-radius-xl: 30px;
        --home-radius-lg: 24px;
        --home-radius-md: 18px;
        --home-max: 1240px;
    }

    body {
        margin: 0;
        color: var(--home-text);
        font-family: 'Tajawal', sans-serif;
        background:
            radial-gradient(circle at top right, rgba(37, 99, 235, 0.20), transparent 30%),
            radial-gradient(circle at 10% 25%, rgba(57, 198, 244, 0.18), transparent 24%),
            linear-gradient(180deg, #07111f 0%, #0b1730 45%, #07111f 100%);
        overflow-x: hidden;
    }

    .home-page,
    .home-page * {
        box-sizing: border-box;
    }

    .home-page {
        position: relative;
        direction: rtl;
        isolation: isolate;
    }

    .home-page::before,
    .home-page::after {
        content: "";
        position: fixed;
        width: 32vw;
        height: 32vw;
        border-radius: 50%;
        filter: blur(90px);
        z-index: -2;
        pointer-events: none;
        opacity: 0.42;
    }

    .home-page::before {
        top: -8vw;
        right: -12vw;
        background: rgba(37, 99, 235, 0.24);
        animation: blobShift 16s ease-in-out infinite;
    }

    .home-page::after {
        bottom: -10vw;
        left: -10vw;
        background: rgba(57, 198, 244, 0.18);
        animation: blobShift 18s ease-in-out infinite reverse;
    }

    .home-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 70px 70px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.92), transparent 95%);
        pointer-events: none;
        z-index: -1;
    }

    .home-container {
        width: min(calc(100% - 32px), var(--home-max));
        margin: 0 auto;
    }

    .home-topbar-wrap {
        position: sticky;
        top: 0;
        z-index: 40;
        padding: 18px 0 0;
        backdrop-filter: blur(12px);
    }

    .home-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 20px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.40);
        background: rgba(247, 249, 253, 0.92);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.10);
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: #08111f;
        text-decoration: none;
        font-weight: 800;
        font-size: 1.08rem;
    }

    .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--home-primary), var(--home-secondary));
        color: #ffffff;
        box-shadow: 0 10px 24px rgba(57, 198, 244, 0.28);
    }

    .topbar-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .topbar-nav a,
    .topbar-action {
        color: #243246;
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 999px;
        font-size: 0.92rem;
        font-weight: 700;
        transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    }

    .topbar-nav a:hover,
    .topbar-action:hover {
        transform: translateY(-1px);
        color: #08111f;
        background: rgba(8, 17, 31, 0.06);
    }

    .topbar-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .topbar-action.primary {
        color: #05111d;
        background: linear-gradient(135deg, var(--home-primary-2), var(--home-primary));
        box-shadow: 0 10px 30px rgba(57, 198, 244, 0.24);
    }

    .topbar-action.register-action {
        color: #ffffff;
        background: linear-gradient(135deg, #0f172a, #1d4ed8 72%, #38bdf8 100%);
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.24);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 9px 16px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #d7e8ff;
        font-size: 0.86rem;
        font-weight: 700;
    }

    .section-shell {
        padding: 102px 0;
    }

    .section-head {
        max-width: 760px;
        margin-bottom: 34px;
    }

    .section-head h2 {
        margin: 18px 0 14px;
        font-size: clamp(2rem, 3.2vw, 3.25rem);
        line-height: 1.1;
        font-weight: 900;
    }

    .section-head p {
        margin: 0;
        color: var(--home-muted);
        font-size: 1.02rem;
        line-height: 1.9;
    }

    .hero {
        position: relative;
        min-height: calc(100vh - 84px);
        display: flex;
        align-items: center;
        padding: 44px 0 56px;
        overflow: hidden;
        background: linear-gradient(180deg, #edf2f7 0%, #f8fafc 100%);
        margin-top: 18px;
        border-radius: 40px;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.12);
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 18% 20%, rgba(57, 198, 244, 0.18), transparent 20%),
            radial-gradient(circle at 88% 22%, rgba(37, 99, 235, 0.10), transparent 22%);
        pointer-events: none;
    }

    .hero-inner {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(380px, 0.95fr);
        gap: 58px;
        align-items: center;
    }

    .hero-copy {
        position: relative;
        z-index: 2;
        color: #0b1320;
    }

    .hero-title {
        margin: 22px 0 22px;
        font-size: clamp(3rem, 6vw, 6rem);
        line-height: 0.98;
        font-weight: 900;
        letter-spacing: -0.04em;
    }

    .hero-title .accent {
        display: block;
        background: linear-gradient(90deg, #0f172a 0%, #1e40af 22%, #38bdf8 60%, #0f172a 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-text {
        max-width: 650px;
        color: #6b7b94;
        line-height: 1.95;
        font-size: 1.06rem;
        margin-bottom: 30px;
    }

    .hero-kicker {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .hero-ai-button {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 999px;
        text-decoration: none;
        color: #fff;
        background: #0c1422;
        box-shadow: 0 18px 30px rgba(12, 20, 34, 0.16);
        border: 1px solid rgba(12, 20, 34, 0.08);
        transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .hero-ai-button:hover {
        transform: translateY(-2px) scale(1.02);
        color: #fff;
        box-shadow: 0 22px 34px rgba(12, 20, 34, 0.2);
    }

    .hero-ai-orb {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, #e0fbff, #38bdf8 55%, #2563eb 100%);
        box-shadow: 0 0 0 8px rgba(56, 189, 248, 0.12);
        animation: orbPulse 2.8s ease-in-out infinite;
    }

    .hero-ai-label {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .hero-ai-label strong {
        font-size: 0.86rem;
    }

    .hero-ai-label span {
        color: rgba(255,255,255,0.64);
        font-size: 0.72rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 34px;
    }

    .hero-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 22px;
        border-radius: 999px;
        border: 1px solid transparent;
        text-decoration: none;
        font-weight: 800;
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .hero-btn:hover {
        transform: translateY(-2px);
        color: inherit;
    }

    .hero-btn.primary {
        color: #05111d;
        background: linear-gradient(135deg, var(--home-primary-2), var(--home-primary));
        box-shadow: 0 16px 38px rgba(57, 198, 244, 0.24);
    }

    .hero-btn.secondary {
        color: #ffffff;
        background: linear-gradient(135deg, #020617, #1e3a8a 62%, #38bdf8 100%);
        border-color: rgba(15, 23, 42, 0.18);
        box-shadow: 0 24px 42px rgba(29, 78, 216, 0.28);
    }

    .hero-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        max-width: 760px;
    }

    .stat-card {
        position: relative;
        overflow: hidden;
        padding: 20px 18px;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 24px 38px rgba(15, 23, 42, 0.10);
    }

    .stat-card::before {
        content: "";
        position: absolute;
        top: -25px;
        left: -25px;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: rgba(57, 198, 244, 0.12);
        filter: blur(16px);
    }

    .stat-value {
        display: block;
        margin-bottom: 8px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        line-height: 1;
        color: #0f172a;
    }

    .stat-label {
        color: #64748b;
        line-height: 1.75;
        font-size: 0.9rem;
    }

    .hero-visual {
        position: relative;
        min-height: 650px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-rings,
    .hero-rings::before,
    .hero-rings::after {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-rings {
        width: 520px;
        height: 520px;
        animation: spin 28s linear infinite;
    }

    .hero-rings::before,
    .hero-rings::after {
        content: "";
        inset: 36px;
    }

    .hero-rings::after {
        inset: 100px;
    }

    .hero-stack {
        position: relative;
        width: min(100%, 510px);
        animation: driftField 10s ease-in-out infinite;
        transform-style: preserve-3d;
    }

    .hero-main-card,
    .floating-card {
        border-radius: var(--home-radius-xl);
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: linear-gradient(180deg, rgba(17, 29, 52, 0.98), rgba(8, 16, 31, 0.96));
        box-shadow: 0 40px 80px rgba(15, 23, 42, 0.28);
        backdrop-filter: blur(18px);
        transition: transform 240ms ease-out, box-shadow 240ms ease-out, filter 240ms ease-out;
    }

    .hero-main-card {
        position: relative;
        overflow: hidden;
        padding: 28px;
        min-height: 540px;
        transform: rotate(-4deg);
        animation: heroCardFloat 8s ease-in-out infinite;
        will-change: transform;
    }

    .hero-main-card::before {
        content: "";
        position: absolute;
        top: -80px;
        right: -80px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(57, 198, 244, 0.34), transparent 70%);
    }

    .hero-main-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.08) 45%, transparent 70%);
        transform: translateX(-120%);
        animation: shine 6s ease-in-out infinite;
    }

    .hero-main-card > * {
        position: relative;
        z-index: 1;
    }

    .hero-card-tag {
        font-family: 'Space Grotesk', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #84e8ff;
        font-size: 0.75rem;
        margin-bottom: 16px;
    }

    .hero-main-card h3 {
        margin: 0 0 14px;
        font-size: 2rem;
        line-height: 1.18;
    }

    .hero-main-card p {
        margin: 0 0 22px;
        color: #c0cfe8;
        line-height: 1.95;
        font-size: 0.98rem;
    }

    .progress-panel,
    .mini-panel {
        padding: 18px;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.05);
        margin-bottom: 16px;
    }

    .progress-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .progress-top span {
        color: #dbe9ff;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .progress-top small {
        color: #8fa7cd;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
    }

    .progress-track {
        width: 100%;
        height: 10px;
        border-radius: 999px;
        background: rgba(255,255,255,0.08);
        overflow: hidden;
    }

    .progress-track span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--home-primary), var(--home-secondary), var(--home-accent));
        animation: progressPulse 4s ease-in-out infinite;
    }

    .mini-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .mini-panel strong {
        display: block;
        margin-bottom: 7px;
        font-size: 1rem;
    }

    .mini-panel span {
        color: var(--home-muted);
        line-height: 1.7;
        font-size: 0.86rem;
    }

    .floating-orbit {
        position: absolute;
        z-index: 3;
        will-change: transform;
        pointer-events: none;
    }

    .floating-orbit.top {
        top: -26px;
        right: -24px;
        animation: orbitTop 8s ease-in-out infinite;
    }

    .floating-orbit.left {
        top: 126px;
        left: -38px;
        animation: orbitLeft 9s ease-in-out infinite;
    }

    .floating-orbit.bottom {
        bottom: -24px;
        left: 24px;
        animation: orbitBottom 7.5s ease-in-out infinite;
    }

    .floating-card {
        padding: 16px;
        min-width: 178px;
        position: relative;
        will-change: transform;
    }

    .floating-card strong {
        display: block;
        margin-bottom: 4px;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.15rem;
    }

    .floating-card span {
        color: var(--home-muted);
        font-size: 0.84rem;
        line-height: 1.6;
    }

    .hero-stack.is-interacting .floating-card {
        box-shadow: 0 28px 70px rgba(15, 23, 42, 0.34);
        filter: saturate(1.08);
    }

    .floating-card.is-repelled {
        transition: transform 120ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 180ms ease, filter 180ms ease;
        box-shadow: 0 28px 70px rgba(15, 23, 42, 0.34);
        filter: saturate(1.08) brightness(1.04);
    }

    .ticker-shell {
        margin-top: 10px;
        overflow: hidden;
        border-block: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
    }

    .ticker-track {
        display: flex;
        gap: 18px;
        width: max-content;
        padding: 16px 0;
        animation: marquee 28s linear infinite;
    }

    .ticker-item {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,0.05);
        color: #d9e8ff;
        white-space: nowrap;
        font-weight: 700;
    }

    .ticker-item i {
        color: #7be9ff;
    }

    .signal-grid,
    .path-grid,
    .courses-grid,
    .feature-grid,
    .trainers-grid,
    .quote-grid {
        display: grid;
        gap: 22px;
    }

    .signal-grid {
        grid-template-columns: 1.2fr 1fr 1fr;
    }

    .signal-card,
    .path-card,
    .course-card,
    .feature-card,
    .trainer-card,
    .quote-card,
    .cta-shell {
        border-radius: var(--home-radius-lg);
        border: 1px solid rgba(255,255,255,0.10);
        background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
        box-shadow: var(--home-shadow);
        backdrop-filter: blur(18px);
    }

    .signal-card {
        padding: 24px;
    }

    .signal-card h3,
    .path-card h3,
    .course-card h3,
    .feature-card h3,
    .trainer-card h3 {
        margin: 0 0 10px;
    }

    .signal-card p,
    .path-card p,
    .feature-card p,
    .trainer-card p,
    .quote-card p {
        margin: 0;
        color: var(--home-muted);
        line-height: 1.9;
    }

    .signal-number {
        display: block;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .path-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .path-card {
        padding: 24px;
        position: relative;
        overflow: hidden;
    }

    .path-card::before {
        content: "";
        position: absolute;
        inset: auto auto -30px -20px;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: rgba(57, 198, 244, 0.14);
        filter: blur(18px);
    }

    .path-icon,
    .feature-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        border-radius: 18px;
        margin-bottom: 18px;
        background: linear-gradient(135deg, rgba(57,198,244,0.20), rgba(37,99,235,0.22));
        color: #8feaff;
        font-size: 1.2rem;
    }

    .path-card ul {
        margin: 18px 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 10px;
    }

    .path-card li {
        color: #dce9ff;
        font-size: 0.9rem;
        position: relative;
        padding-right: 18px;
    }

    .path-card li::before {
        content: "";
        position: absolute;
        right: 0;
        top: 10px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--home-primary);
        box-shadow: 0 0 0 6px rgba(57,198,244,0.10);
    }

    .courses-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .course-card {
        overflow: hidden;
        transition: transform 220ms ease, border-color 220ms ease;
        animation: cardDrift 7.5s ease-in-out infinite;
    }

    .course-card:nth-child(2) { animation-delay: -1.4s; }
    .course-card:nth-child(3) { animation-delay: -2.7s; }
    .course-card:nth-child(4) { animation-delay: -3.9s; }
    .course-card:nth-child(5) { animation-delay: -1.9s; }
    .course-card:nth-child(6) { animation-delay: -3.2s; }

    .course-card:hover,
    .feature-card:hover,
    .trainer-card:hover,
    .quote-card:hover,
    .path-card:hover {
        transform: translateY(-6px);
        border-color: rgba(57, 198, 244, 0.26);
    }

    .course-media {
        position: relative;
        min-height: 230px;
        background:
            linear-gradient(140deg, rgba(57,198,244,0.22), rgba(37,99,235,0.20)),
            #0c1730;
    }

    .course-media img {
        width: 100%;
        height: 230px;
        object-fit: cover;
        display: block;
        opacity: 0.88;
    }

    .course-fallback {
        min-height: 230px;
        display: grid;
        place-items: center;
        font-size: 2.8rem;
        color: rgba(255,255,255,0.80);
    }

    .course-badge-wrap {
        position: absolute;
        top: 18px;
        right: 18px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .course-badge {
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(5, 12, 24, 0.76);
        border: 1px solid rgba(255,255,255,0.10);
        color: #eef6ff;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .course-content {
        padding: 24px;
    }

    .course-content p {
        color: var(--home-muted);
        line-height: 1.9;
        min-height: 88px;
        margin: 0 0 18px;
    }

    .course-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .course-meta span {
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,0.05);
        color: #e2eeff;
        font-size: 0.82rem;
    }

    .course-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
    }

    .course-price {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.45rem;
        font-weight: 700;
    }

    .course-link {
        color: #94ecff;
        text-decoration: none;
        font-weight: 800;
    }

    .feature-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .feature-card,
    .trainer-card,
    .quote-card {
        padding: 24px;
        transition: transform 220ms ease, border-color 220ms ease;
    }

    .feature-card strong {
        display: block;
        margin-top: 2px;
        margin-bottom: 10px;
        font-size: 1.05rem;
    }

    .trainers-grid,
    .quote-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .trainer-card {
        animation: cardDrift 8.2s ease-in-out infinite;
    }

    .trainer-card:nth-child(2) { animation-delay: -1.7s; }
    .trainer-card:nth-child(3) { animation-delay: -3.4s; }
    .trainer-card:nth-child(4) { animation-delay: -2.2s; }
    .trainer-card:nth-child(5) { animation-delay: -4.1s; }
    .trainer-card:nth-child(6) { animation-delay: -3.1s; }

    .trainer-avatar {
        width: 78px;
        height: 78px;
        border-radius: 22px;
        object-fit: cover;
        display: block;
        margin-bottom: 18px;
        border: 1px solid rgba(255,255,255,0.10);
    }

    .trainer-specialty {
        display: inline-flex;
        margin-bottom: 14px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(57,198,244,0.12);
        color: #96eeff;
        font-size: 0.84rem;
        font-weight: 700;
    }

    .trainer-foot {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 18px;
        color: #dce9ff;
        font-size: 0.9rem;
    }

    .quote-mark {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 3.8rem;
        line-height: 1;
        color: rgba(57,198,244,0.22);
        margin-bottom: 10px;
    }

    .quote-card p {
        margin-bottom: 18px;
        color: #dce8f7;
    }

    .quote-carousel {
        position: relative;
        max-width: 880px;
        min-height: 320px;
        margin: 0 auto;
    }

    .quote-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transform: translateY(18px) scale(0.98);
        pointer-events: none;
        transition: opacity 700ms ease, transform 700ms ease;
    }

    .quote-slide.is-active {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    .quote-card.single-spotlight {
        min-height: 320px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 36px;
        background:
            radial-gradient(circle at top left, rgba(56, 189, 248, 0.10), transparent 26%),
            linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    }

    .quote-card.single-spotlight p {
        font-size: 1.2rem;
        line-height: 2;
        margin-bottom: 24px;
    }

    .quote-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 24px;
    }

    .quote-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        background: rgba(148, 163, 184, 0.36);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.14);
        transition: transform 180ms ease, background 180ms ease;
    }

    .quote-dot.is-active {
        background: linear-gradient(135deg, #67e8f9, #2563eb);
        transform: scale(1.18);
    }

    .quote-person {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .quote-avatar {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,0.10);
    }

    .quote-name {
        display: block;
        margin-bottom: 4px;
        font-weight: 800;
    }

    .quote-role {
        color: var(--home-muted);
        font-size: 0.84rem;
    }

    .cta-shell {
        position: relative;
        overflow: hidden;
        padding: 34px;
    }

    .cta-shell::before {
        content: "";
        position: absolute;
        top: -100px;
        left: -60px;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: rgba(57,198,244,0.18);
        filter: blur(18px);
    }

    .cta-shell::after {
        content: "";
        position: absolute;
        bottom: -120px;
        right: -80px;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: rgba(245,158,11,0.14);
        filter: blur(18px);
    }

    .cta-layout {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
        align-items: center;
    }

    .cta-shell h2 {
        margin: 18px 0 14px;
        font-size: clamp(2rem, 3.2vw, 3.5rem);
        line-height: 1.08;
    }

    .cta-shell p {
        margin: 0;
        color: #cad7ef;
        line-height: 1.95;
    }

    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .fade-up {
        opacity: 0;
        transform: translateY(26px);
        transition: opacity 700ms ease, transform 700ms ease;
    }

    .fade-up.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@keyframes shine {
        0%, 100% { transform: translateX(-120%); }
        40%, 60% { transform: translateX(120%); }
    }

    @@keyframes floatY {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-14px); }
    }

    @@keyframes heroCardFloat {
        0%, 100% { transform: rotate(-4deg) translate3d(0, 0, 0); }
        50% { transform: rotate(-2deg) translate3d(10px, -12px, 0); }
    }

    @@keyframes driftField {
        0%, 100% { transform: translate3d(0, 0, 0); }
        50% { transform: translate3d(-10px, 8px, 0); }
    }

    @@keyframes orbitTop {
        0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
        25% { transform: translate3d(24px, -14px, 0) rotate(4deg); }
        50% { transform: translate3d(10px, -28px, 0) rotate(0deg); }
        75% { transform: translate3d(-18px, -10px, 0) rotate(-4deg); }
    }

    @@keyframes orbitLeft {
        0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
        25% { transform: translate3d(-16px, 18px, 0) rotate(-5deg); }
        50% { transform: translate3d(14px, 30px, 0) rotate(2deg); }
        75% { transform: translate3d(26px, 4px, 0) rotate(5deg); }
    }

    @@keyframes orbitBottom {
        0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
        25% { transform: translate3d(22px, 10px, 0) rotate(4deg); }
        50% { transform: translate3d(40px, -8px, 0) rotate(0deg); }
        75% { transform: translate3d(12px, -18px, 0) rotate(-4deg); }
    }

    @@keyframes marquee {
        from { transform: translateX(0); }
        to { transform: translateX(50%); }
    }

    @@keyframes progressPulse {
        0%, 100% { filter: saturate(1); }
        50% { filter: saturate(1.4); }
    }

    @@keyframes orbPulse {
        0%, 100% { transform: scale(1); box-shadow: 0 0 0 8px rgba(56, 189, 248, 0.12); }
        50% { transform: scale(1.12); box-shadow: 0 0 0 14px rgba(56, 189, 248, 0.08); }
    }

    @@keyframes blobShift {
        0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
        50% { transform: translate3d(18px, -12px, 0) scale(1.08); }
    }

    @@keyframes cardDrift {
        0%, 100% { transform: translate3d(0, 0, 0); }
        50% { transform: translate3d(0, -12px, 0); }
    }

    @@media (max-width: 1180px) {
        .hero-inner,
        .signal-grid,
        .cta-layout {
            grid-template-columns: 1fr;
        }

        .path-grid,
        .courses-grid,
        .feature-grid,
        .trainers-grid,
        .quote-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 860px) {
        .home-topbar {
            border-radius: 28px;
            flex-direction: column;
            align-items: stretch;
        }

        .topbar-nav,
        .topbar-actions {
            justify-content: center;
        }

        .hero {
            padding-top: 32px;
        }

        .hero-inner,
        .path-grid,
        .courses-grid,
        .feature-grid,
        .trainers-grid,
        .quote-grid,
        .hero-stats {
            grid-template-columns: 1fr;
        }

        .hero-visual {
            min-height: 540px;
        }

        .hero-rings {
            width: 360px;
            height: 360px;
        }

        .hero-main-card {
            transform: none;
            min-height: 500px;
        }

        .floating-orbit.top,
        .floating-orbit.left {
            display: none;
        }

        .mini-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 560px) {
        .home-container {
            width: min(calc(100% - 20px), var(--home-max));
        }

        .hero-title {
            font-size: 2.65rem;
        }

        .hero-actions,
        .cta-actions {
            flex-direction: column;
        }

        .hero-btn,
        .topbar-action {
            width: 100%;
        }

        .topbar-nav a {
            width: 100%;
            text-align: center;
        }

        .course-content p {
            min-height: auto;
        }
    }
</style>
}

<div class="home-page">
    <div class="home-grid"></div>

    <div class="home-topbar-wrap">
        <div class="home-container">
            <header class="home-topbar">
                <a asp-controller="Home" asp-action="Index" class="brand">
                    <span class="brand-mark"><i class="fas fa-graduation-cap"></i></span>
                    <span>Training Center</span>
                </a>

                <nav class="topbar-nav">
                    <a asp-controller="Home" asp-action="Index">الرئيسية</a>
                    <a asp-controller="Courses" asp-action="Index">الكورسات</a>
                    <a asp-controller="Chat" asp-action="CustomerSupportChat">تواصل معنا</a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Dashboard" asp-action="Index">لوحة التحكم</a>
                    }
                </nav>

                <div class="topbar-actions">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Chat" asp-action="Index" class="topbar-action">المحادثات</a>
                        <a asp-controller="Account" asp-action="Logout" class="topbar-action primary">تسجيل الخروج</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="topbar-action">تسجيل الدخول</a>
                        <a asp-controller="Account" asp-action="SignUp" class="topbar-action primary register-action">إنشاء حساب</a>
                    }
                </div>
            </header>
        </div>
    </div>

    <section class="hero">
        <div class="home-container hero-inner">
            <div class="hero-copy fade-up">
                <div class="hero-kicker">
                    <span class="eyebrow">
                        <i class="fas fa-sparkles"></i>
                        تجربة تدريب احترافية ومتكاملة
                    </span>
                    <a href="#ai-assistant-coming-soon" class="hero-ai-button" aria-label="AI Assistant Coming Soon">
                        <span class="hero-ai-orb"></span>
                        <span class="hero-ai-label">
                            <strong>AI Assistant</strong>
                           
                        </span>
                    </a>
                </div>

                <h1 class="hero-title">
                    تعلّم بوضوح.
                    <span class="accent">تدرّب بعمق.</span>
                    وانطلق إلى سوق العمل.
                </h1>

                <p class="hero-text">
                    منصة مركز التدريب تجمع بين الكورسات العملية، المدربين المتخصصين، المحاضرات المسجلة، الاختبارات،
                    الشهادات، والمتابعة المستمرة في مكان واحد. الفكرة ليست عرض دورات فقط، بل بناء رحلة تعلم واضحة
                    تساعد المتدرب على اكتساب المهارة وتطبيقها والتقدم بثقة.
                </p>

                <div class="hero-actions">
                    <a asp-controller="Courses" asp-action="Index" class="hero-btn primary">
                        <i class="fas fa-arrow-left"></i>
                        استكشف الكورسات
                    </a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="hero-btn secondary">
                            <i class="fas fa-tachometer-alt"></i>
                            لوحة التحكم
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="SignUp" class="hero-btn secondary">
                            <i class="fas fa-user-plus"></i>
                            ابدأ رحلتك الآن
                        </a>
                    }
                </div>

                <div class="hero-stats">
                    <article class="stat-card">
                        <span class="stat-value count-up" data-count="@Model.TotalCourses">0</span>
                        <span class="stat-label">كورسات في مجالات تقنية ومهنية مصممة لتناسب مستوى البداية والتقدم.</span>
                    </article>
                    <article class="stat-card">
                        <span class="stat-value count-up" data-count="@Model.TotalTrainers">0</span>
                        <span class="stat-label">مدربون بخبرة عملية يربطون الشرح بالممارسة والمشاريع الواقعية.</span>
                    </article>
                    <article class="stat-card">
                        <span class="stat-value count-up" data-count="@Model.TotalCertificates">0</span>
                        <span class="stat-label">شهادات تدعم الملف المهني وتوثق التقدم بعد إتمام المسارات بنجاح.</span>
                    </article>
                </div>
            </div>

            <div class="hero-visual fade-up">
                <div class="hero-rings"></div>
                <div class="hero-stack" id="heroStack">
                    <div class="floating-orbit top">
                        <div class="floating-card" data-float-card data-repel-strength="1.1">
                            <strong>@Model.TotalTrainees+</strong>
                            <span>متدربون يتابعون رحلتهم التعليمية داخل المنصة.</span>
                        </div>
                    </div>

                    <div class="floating-orbit left">
                        <div class="floating-card" data-float-card data-repel-strength="1.25">
                            <strong>@Model.TotalLectures</strong>
                            <span>محاضرات وجلسات تعلم منظمة داخل الكورسات.</span>
                        </div>
                    </div>

                    <article class="hero-main-card" data-hero-core>
                        <div class="hero-card-tag">training center dashboard</div>
                        <h3>كل ما يحتاجه المتدرب في شاشة واحدة واضحة ومنظمة</h3>
                        <p>
                            من تسجيل الكورس إلى متابعة المحاضرات والاختبارات والشهادة، تم تصميم الصفحة الرئيسية
                            لتعكس ما يقدمه المشروع فعلًا: تعليم منظم، تتبع للتقدم، ومدخل سريع إلى الكورسات الأكثر أهمية.
                        </p>

                        <div class="progress-panel">
                            <div class="progress-top">
                                <span>@(heroCourse?.CourseName ?? "مسار تدريبي متكامل")</span>
                                <small>featured course</small>
                            </div>
                            <div class="progress-track">
                                <span style="width: 76%;"></span>
                            </div>
                        </div>

                        <div class="progress-panel">
                            <div class="progress-top">
                                <span>اختبارات وتقييمات دورية</span>
                                <small>assessment flow</small>
                            </div>
                            <div class="progress-track">
                                <span style="width: 88%;"></span>
                            </div>
                        </div>

                        <div class="mini-grid">
                            <div class="mini-panel">
                                <strong>محاضرات مرتبة</strong>
                                <span>الوصول السريع إلى المحتوى والدروس والمواد المساندة.</span>
                            </div>
                            <div class="mini-panel">
                                <strong>تقدم قابل للمتابعة</strong>
                                <span>رؤية واضحة للحضور، الإنجاز، والشهادات المكتسبة.</span>
                            </div>
                            <div class="mini-panel">
                                <strong>مدربون متخصصون</strong>
                                <span>تعلم مباشر من أصحاب الخبرة في مجالاتهم.</span>
                            </div>
                            <div class="mini-panel">
                                <strong>شهادات معتمدة</strong>
                                <span>إثبات ملموس لإنهاء المسار التدريبي بنجاح.</span>
                            </div>
                        </div>
                    </article>

                    <div class="floating-orbit bottom">
                        <div class="floating-card" data-float-card data-repel-strength="1.15">
                            <strong>دعم ومتابعة</strong>
                            <span>قنوات تواصل ومساندة تساعد المتدرب أثناء رحلته التعليمية.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="ticker-shell">
        <div class="ticker-track">
            <div class="ticker-item"><i class="fas fa-book-open"></i> كورسات تقنية ومهنية</div>
            <div class="ticker-item"><i class="fas fa-video"></i> محاضرات مرتبة وسهلة الوصول</div>
            <div class="ticker-item"><i class="fas fa-file-signature"></i> شهادات بعد الإتمام</div>
            <div class="ticker-item"><i class="fas fa-chart-line"></i> متابعة للتقدم والأداء</div>
            <div class="ticker-item"><i class="fas fa-comments"></i> تواصل مباشر ودعم</div>
            <div class="ticker-item"><i class="fas fa-book-open"></i> كورسات تقنية ومهنية</div>
            <div class="ticker-item"><i class="fas fa-video"></i> محاضرات مرتبة وسهلة الوصول</div>
            <div class="ticker-item"><i class="fas fa-file-signature"></i> شهادات بعد الإتمام</div>
            <div class="ticker-item"><i class="fas fa-chart-line"></i> متابعة للتقدم والأداء</div>
            <div class="ticker-item"><i class="fas fa-comments"></i> تواصل مباشر ودعم</div>
        </div>
    </section>

    <section class="section-shell">
        <div class="home-container">
            <div class="signal-grid">
                <article class="signal-card fade-up">
                    <h3>منصة واحدة لمسار تعليمي كامل</h3>
                    <p>
                        يبدأ المتدرب من اكتشاف الكورس المناسب، ثم ينتقل إلى المحاضرات والتكليفات والاختبارات،
                        ويصل في النهاية إلى الشهادة والمتابعة المستمرة. هذا هو جوهر المشروع الذي أردنا أن يظهر
                        بوضوح منذ أول قسم في الصفحة.
                    </p>
                </article>
                <article class="signal-card fade-up">
                    <span class="signal-number count-up" data-count="@Model.TotalTrainees">0</span>
                    <p>عدد المتدربين الذين يستفيدون من المنصة ويطوّرون مهاراتهم فيها.</p>
                </article>
                <article class="signal-card fade-up">
                    <span class="signal-number count-up" data-count="@Model.TotalLectures">0</span>
                    <p>محاضرات ومحتوى تدريبي يساعد على بناء فهم تدريجي وتطبيق فعلي.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section-shell">
        <div class="home-container">
            <div class="section-head fade-up">
                <span class="eyebrow">
                    <i class="fas fa-route"></i>
                    كيف تخدم المنصة المتدرب؟
                </span>
                <h2>المشروع لا يقدّم كورسًا فقط، بل يقدّم رحلة تعلّم كاملة</h2>
                <p>
                    كل جزء في المنصة مصمم ليقرب المتدرب من هدفه: اختيار المسار المناسب، متابعة المحاضرات، التفاعل مع
                    المدرب، اجتياز الاختبارات، ثم الحصول على شهادة تعبّر عن الإنجاز.
                </p>
            </div>

            <div class="path-grid">
                <article class="path-card fade-up">
                    <div class="path-icon"><i class="fas fa-compass"></i></div>
                    <h3>اختيار المسار المناسب</h3>
                    <p>عرض الكورسات المميزة والأحدث بطريقة تساعد المتدرب على اكتشاف المجال الذي يناسبه بسرعة.</p>
                    <ul>
                        <li>تفاصيل واضحة لكل كورس</li>
                        <li>معلومات عن المحاضرات والتكلفة</li>
                        <li>عرض أحدث المسارات المتاحة</li>
                    </ul>
                </article>

                <article class="path-card fade-up">
                    <div class="path-icon"><i class="fas fa-laptop-code"></i></div>
                    <h3>تعلم منظم وقابل للمتابعة</h3>
                    <p>المحتوى التدريبي منظم داخل محاضرات واختبارات ومتابعة مستمرة حتى لا يضيع المتدرب بين الخطوات.</p>
                    <ul>
                        <li>محاضرات مرتبة داخل كل كورس</li>
                        <li>تتبع للتقدم والحضور</li>
                        <li>اختبارات وتقييمات مرحلية</li>
                    </ul>
