        <!-- COURSES -->
        <section id="courses" class="stack">
            <h2 class="section-title">@SharedResource.CuttingEdgePrograms</h2>
            <div class="courses">
                @foreach (var course in Model.Courses.Where(c => c != null ).OrderByDescending(c => c.CreatedDate).Take(6))
                {
                    <article class="course">
                        <div class="thumb" style="background-image:url('@(string.IsNullOrEmpty(course.ThumbnailUrl) ? Url.Content("~/images/course-placeholder.jpg") : course.ThumbnailUrl)');"></div>
                        <h4>@(string.IsNullOrEmpty(course.CourseName) ? SharedResource.DiverseCourses : course.CourseName)</h4>
                        <p>@(string.IsNullOrWhiteSpace(course.Description) ? SharedResource.LifelongLearning : course.Description)</p>
                        <span class="price">@(course.Price > 0 ? "$" + course.Price.ToString("F2") : SharedResource.Free)</span>
                        <div class="meta">
                            @if(course.BatchNumber > 0){<span>@SharedResource.Batch: @course.BatchNumber</span>}<br />
                            @if(course.NumberOfLectures > 0){<span>@SharedResource.Lectures: @course.NumberOfLectures</span>}<br />
                            @if(course.ReleaseDate != default(DateTime)){<span>@SharedResource.ReleaseDate: @course.ReleaseDate.ToShortDateString()</span>}
                        </div>
                    </article>
                }
            </div>
