@using System.Globalization
@using TrainingCenterManagement_MVC.Resources
@using TrainingCenterManagement_MVC.ViewModels
@model HomeViewModel
@{
    Layout = null; // remove if you want to use your _Layout
    var dir = (CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft) ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@SharedResource.EmpowerFuture</title>
    <!-- No external libraries; all styling below -->
    <style>
        :root {
            --bg: #ffffff;
            --text: #111418;
            --muted: #60758a;
            --line: #dbe0e6;
            --soft: #f0f2f5;
            --brand: #0d80f2;
            --brand-600: #0b70d3;
            --radius: 16px;
            --radius-lg: 20px;
            --shadow: 0 6px 24px rgba(17,20,24,0.08);
            --shadow-lg: 0 18px 60px rgba(17,20,24,0.12);
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans", "Helvetica Neue", Arial, "Apple Color Emoji", "Segoe UI Emoji";
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .container {
            width: 100%;
            max-width: 1120px;
            margin-inline: auto;
            padding-inline: 16px;
        }

        header.site-header {
            position: sticky;
            top: 0;
            z-index: 50;
            background: rgba(255,255,255,.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #f0f2f5;
            padding: 12px 20px;
        }

        .nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
        }

        .dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--text);
            display: inline-block;
        }

        .menu {
            display: flex;
            align-items: center;
            gap: 24px;
            font-weight: 600;
            font-size: 14px;
        }

        .right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .search {
            display: flex;
            align-items: center;
            height: 40px;
            background: var(--soft);
            border-radius: 12px;
            padding: 0 12px;
            min-width: 220px;
        }

            .search input {
                border: 0;
                outline: 0;
                background: transparent;
                font-size: 14px;
                width: 180px;
                color: var(--text);
            }

        .icon-btn {
            height: 40px;
            min-width: 40px;
            display: grid;
            place-items: center;
            background: var(--soft);
            border: 0;
            border-radius: 12px;
            cursor: pointer;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #ccc url('~/images/avatar-placeholder.png') center/cover no-repeat;
        }

        /* hero */
        .hero {
            position: relative;
            min-height: 58vh;
            display: flex;
            align-items: flex-end;
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

            .hero::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg, rgba(0,0,0,.12), rgba(0,0,0,.55));
            }

            .hero .bg {
                position: absolute;
                inset: 0;
               /*  background: url('~/images/banner.jpg') center/cover no-repeat; */
                transform: scale(1.02);
            }

            .hero .content {
                position: relative;
                z-index: 1;
                padding: 28px 28px 40px;
                max-width: 720px;
                color: #fff;
            }

            .hero h1 {
                margin: 0 0 8px;
                font-size: clamp(28px, 4vw, 44px);
                line-height: 1.1;
                font-weight: 900;
                letter-spacing: -.02em;
            }

            .hero p {
                margin: 0 0 18px;
                font-size: clamp(14px, 2vw, 18px);
                opacity: .95;
            }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 44px;
            padding: 0 16px;
            border-radius: 12px;
            font-weight: 800;
            border: 0;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--brand);
            color: #fff;
            box-shadow: 0 6px 16px rgba(13,128,242,.35);
        }

            .btn-primary:hover {
                background: var(--brand-600);
            }

        /* sections */
        section {
            padding: 48px 0;
        }

        .stack {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .section-title {
            font-size: clamp(24px, 3vw, 32px);
            font-weight: 900;
            letter-spacing: -.02em;
            margin: 0;
        }

        .section-sub {
            color: var(--muted);
            margin: 0;
            max-width: 720px;
        }

        /* feature cards */
        .grid {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .card {
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fff;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            box-shadow: var(--shadow);
        }

            .card .ico {
                width: 28px;
                height: 28px;
                color: var(--text);
                opacity: .9;
            }

            .card h3 {
                font-size: 16px;
                margin: 0;
            }

            .card p {
                font-size: 14px;
                margin: 0;
                color: var(--muted);
            }

        /* courses */
        .courses {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .course {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .thumb {
            aspect-ratio: 1 / 1;
            width: 100%;
            border-radius: 16px;
            background: #e6ebf1 center/cover no-repeat;
            box-shadow: var(--shadow);
        }

        .course h4 {
            margin: 0;
            font-weight: 700;
        }

        .course p {
            margin: 0;
            color: var(--muted);
            font-size: 14px;
        }

        /* testimonials horizontal scroll */
        .scroll-x {
            display: flex;
            overflow: auto;
            gap: 12px;
            padding: 12px 0;
            scroll-snap-type: x mandatory;
        }

        .testi {
            min-width: 260px;
            scroll-snap-align: start;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* FAQ (accordion) */
        .faq {
            border-top: 1px solid var(--line);
        }

        .faq-item {
            border-bottom: 1px solid var(--line);
        }

        .faq-btn {
            width: 100%;
            text-align: inherit;
            background: #fff;
            border: 0;
            padding: 16px;
            font: inherit;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

        .faq-panel {
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows .3s ease;
        }

            .faq-panel.open {
                grid-template-rows: 1fr;
            }

        .faq-inner {
            overflow: hidden;
            padding: 0 16px 16px;
            color: var(--muted);
        }

        .chev {
            transition: transform .25s ease;
        }

        .faq-panel.open + .chev, .faq-btn[aria-expanded="true"] .chev {
            transform: rotate(180deg);
        }

        /* responsive helpers */
        .pad {
            padding-inline: 16px;
        }

        /* RTL tweaks */
        [dir="rtl"] .menu {
            flex-direction: row-reverse;
        }

        [dir="rtl"] .right {
            flex-direction: row-reverse;
        }

        [dir="rtl"] .faq-btn {
            text-align: right;
        }


        .courses { display:grid; gap:12px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
.course { display:flex; flex-direction:column; gap:12px; border:1px solid var(--line); border-radius:16px; padding:12px; background:#fff; box-shadow:var(--shadow); transition:transform .2s ease; }
.course:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
.thumb { aspect-ratio: 16/9; width:100%; border-radius:12px; background:#e6ebf1 center/cover no-repeat; }
.course h4 { margin:0; font-weight:700; font-size:16px; }
.course p { margin:0; color:var(--muted); font-size:14px; line-height:1.4; }
.price { font-weight:800; color:var(--brand); font-size:14px; }



.testimonial-container { position:relative; width:100%; max-width:600px; margin:auto; overflow:hidden; }
.testi { opacity:0; transform:translateY(20px); transition:all .6s ease; position:absolute; top:0; left:0; right:0; display:flex; flex-direction:column; gap:12px; border:1px solid var(--line); border-radius:16px; background:#fff; padding:20px; box-shadow:var(--shadow-lg); align-items:center; text-align:center; }
.testi.active { opacity:1; transform:translateY(0); position:relative; }
.testi .thumb { width:90px; height:90px; border-radius:50%; background:#e6ebf1 center/cover no-repeat; }
.testi p { margin:0; font-size:15px; line-height:1.6; }
.testi .name { color:var(--muted); font-size:14px; }
.stars { color:#f5b50a; font-size:18px; }
    </style>
