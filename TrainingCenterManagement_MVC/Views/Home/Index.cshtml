@section Scripts {
<script>
    (function () {
        const revealItems = document.querySelectorAll('.fade-up');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12 });

        revealItems.forEach((item) => revealObserver.observe(item));

        const statItems = document.querySelectorAll('.count-up');
        const statObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (!entry.isIntersecting) {
                    return;
                }

                const el = entry.target;
                const target = parseInt(el.getAttribute('data-count') || '0', 10);
                const duration = 1400;
                const start = performance.now();

                function tick(now) {
                    const progress = Math.min((now - start) / duration, 1);
                    const value = Math.floor(progress * target);
                    el.textContent = target > 0 ? value + '+' : '0';

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    } else {
                        el.textContent = target > 0 ? target + '+' : '0';
                    }
                }

                requestAnimationFrame(tick);
                statObserver.unobserve(el);
            });
        }, { threshold: 0.35 });

        statItems.forEach((item) => statObserver.observe(item));

        const quoteSlides = Array.from(document.querySelectorAll('#quoteCarousel .quote-slide'));
        const quoteDots = Array.from(document.querySelectorAll('#quoteControls .quote-dot'));
        let activeQuote = 0;
        let quoteTimer = null;

        function showQuote(index) {
            activeQuote = index;
            quoteSlides.forEach((slide, i) => {
                slide.classList.toggle('is-active', i === index);
            });
            quoteDots.forEach((dot, i) => {
                dot.classList.toggle('is-active', i === index);
            });
        }

        function scheduleQuotes() {
            if (quoteTimer) {
                clearInterval(quoteTimer);
            }
            quoteTimer = setInterval(() => {
                const nextIndex = (activeQuote + 1) % quoteSlides.length;
                showQuote(nextIndex);
            }, 4200);
        }

        if (quoteSlides.length && quoteDots.length) {
            quoteDots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    showQuote(index);
                    scheduleQuotes();
                });
            });

            showQuote(0);
            scheduleQuotes();
        }

        const heroStack = document.getElementById('heroStack');
        const floatCards = heroStack ? Array.from(heroStack.querySelectorAll('[data-float-card]')) : [];

        if (heroStack && floatCards.length) {
            const resetFloatCards = () => {
                floatCards.forEach((card) => {
                    card.classList.remove('is-repelled');
                    card.style.transform = 'translate3d(0, 0, 0) rotate(0deg) scale(1)';
                });
            };

            resetFloatCards();

            heroStack.addEventListener('mousemove', (event) => {
                floatCards.forEach((card) => {
                    const rect = card.getBoundingClientRect();
                    const cardCenterX = rect.left + rect.width / 2;
                    const cardCenterY = rect.top + rect.height / 2;
                    const dx = cardCenterX - event.clientX;
                    const dy = cardCenterY - event.clientY;
                    const distance = Math.hypot(dx, dy);
                    const triggerRadius = Math.max(rect.width, rect.height) + 120;
                    const baseStrength = parseFloat(card.getAttribute('data-repel-strength') || '1');

                    if (distance < triggerRadius) {
                        const normalized = 1 - (distance / triggerRadius);
                        const force = normalized * 145 * baseStrength;
                        const angle = Math.atan2(dy, dx);
                        const moveX = Math.cos(angle) * force;
                        const moveY = Math.sin(angle) * force;
                        const rotate = Math.max(-12, Math.min(12, moveX * 0.10));
                        const scale = 1 + (normalized * 0.04);

                        card.classList.add('is-repelled');
                        card.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) rotate(${rotate}deg) scale(${scale})`;
                    } else {
                        card.classList.remove('is-repelled');
                        card.style.transform = 'translate3d(0, 0, 0) rotate(0deg) scale(1)';
                    }
                });
            });

            heroStack.addEventListener('mouseleave', resetFloatCards);
        }
    })();
</script>
