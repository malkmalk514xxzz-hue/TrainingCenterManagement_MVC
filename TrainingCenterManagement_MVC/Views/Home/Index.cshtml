            </div>
            <div class="trainers-grid">
                @foreach (var trainer in Model.FeaturedTrainers)
                {
                    var isFemale = trainer.User?.Gender == Gender.Female;
                    var pic = !string.IsNullOrEmpty(trainer.User?.ProfilePictureUrl)
                        ? trainer.User.ProfilePictureUrl
                        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(trainer.User?.FullName ?? "T")}&background={(isFemale ? "ec4899" : "4f46e5")}&color=fff&size=128&rounded=true";
                    var courseCount = trainer.CourseTrainers?.Count ?? 0;
                    <div class="trainer-card">
                        <img src="@pic" class="trainer-avatar" alt="@trainer.User?.FullName"
                             onerror="this.src='https://ui-avatars.com/api/?name=T&background=94a3b8&color=fff&rounded=true'" />
                        <div class="trainer-name">@trainer.User?.FullName</div>
                        @if (!string.IsNullOrEmpty(trainer.Specialty))
                        {
                            <span class="trainer-spec">@trainer.Specialty</span>
                        }
                        <div class="trainer-courses">
                            <i class="fas fa-briefcase" style="color:#94a3b8;margin-left:3px;font-size:.65rem"></i>
                            @trainer.YearsOfExperience سنوات خبرة
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

