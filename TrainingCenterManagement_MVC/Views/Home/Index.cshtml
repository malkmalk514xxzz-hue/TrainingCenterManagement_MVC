@model TrainingCenterManagement_MVC.ViewModels.HomeViewModel
@using TrainingCenterManagement_MVC.Models
@{
    ViewData["Title"] = "Training Center — منصة التدريب";
    Layout = "_Layout";
}

@section Styles {
<style>
/* ── CSS Variables ─────────────────────────────────────────── */
:root {
    --pr:#4f46e5; --pr-l:#6366f1; --pr-d:#3730a3; --pr-pale:#eef2ff;
    --gold:#f59e0b; --gold-pale:#fffbeb;
    --success:#10b981; --danger:#ef4444;
    --t1:#0f172a; --t2:#334155; --t3:#64748b; --t4:#94a3b8;
    --bg:#f8fafc; --card:#fff;
    --border:#e2e8f0; --shadow:0 4px 24px rgba(0,0,0,.07);
    --radius:16px;
}

/* ── Reset & Base ──────────────────────────────────────────── */
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body { font-family:'Segoe UI',system-ui,sans-serif; color:var(--t2); background:#fff; overflow-x:hidden; }
a { text-decoration:none; }
img { max-width:100%; }

/* ── Hero ──────────────────────────────────────────────────── */
.hero {
    position:relative; min-height:100vh; display:flex; align-items:center;
    background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 40%,#312e81 70%,#4f46e5 100%);
    overflow:hidden; direction:rtl;
}
.hero-bg-dots {
    position:absolute; inset:0; opacity:.15;
    background-image:radial-gradient(circle, #ffffff 1px, transparent 1px);
    background-size:32px 32px;
}
.hero-glow {
    position:absolute; width:600px; height:600px; border-radius:50%;
    background:radial-gradient(circle,rgba(99,102,241,.4),transparent 70%);
    top:-100px; left:-100px; pointer-events:none;
}
.hero-glow-2 {
    position:absolute; width:400px; height:400px; border-radius:50%;
    background:radial-gradient(circle,rgba(245,158,11,.2),transparent 70%);
    bottom:-100px; right:10%; pointer-events:none;
}
.hero-container { position:relative; z-index:2; max-width:1200px; margin:0 auto; padding:0 32px; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; width:100%; }
.hero-badge { display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,.1); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.2); color:#a5b4fc; font-size:.78rem; font-weight:600; padding:6px 14px; border-radius:20px; margin-bottom:20px; letter-spacing:.04em; }
.hero-title { font-size:3.2rem; font-weight:900; color:#fff; line-height:1.15; margin-bottom:20px; }
.hero-title span { background:linear-gradient(90deg,#a5b4fc,#f9a8d4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.hero-desc { font-size:1.05rem; color:#cbd5e1; line-height:1.8; margin-bottom:32px; }
.hero-btns { display:flex; gap:14px; flex-wrap:wrap; }
.hero-btn-primary { padding:13px 28px; background:linear-gradient(135deg,var(--pr),var(--pr-l)); color:#fff; border-radius:10px; font-weight:700; font-size:.95rem; transition:all .2s; display:inline-flex; align-items:center; gap:8px; box-shadow:0 4px 20px rgba(79,70,229,.4); }
.hero-btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(79,70,229,.5); color:#fff; }
.hero-btn-secondary { padding:13px 28px; background:rgba(255,255,255,.1); backdrop-filter:blur(10px); color:#fff; border-radius:10px; font-weight:600; font-size:.95rem; border:1px solid rgba(255,255,255,.25); transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
.hero-btn-secondary:hover { background:rgba(255,255,255,.2); color:#fff; transform:translateY(-2px); }
.hero-stats { display:flex; gap:28px; margin-top:40px; flex-wrap:wrap; }
.hero-stat { text-align:center; }
.hero-stat-val { font-size:1.8rem; font-weight:900; color:#fff; display:block; }
.hero-stat-lbl { font-size:.72rem; color:#94a3b8; font-weight:500; margin-top:2px; }
.hero-stat-divider { width:1px; background:rgba(255,255,255,.15); align-self:stretch; }

/* Hero visual */
.hero-visual { display:flex; justify-content:center; align-items:center; position:relative; }
.hero-card-stack { position:relative; width:380px; height:420px; }
.hcard { position:absolute; border-radius:var(--radius); overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.4); }
.hcard-main { width:280px; height:340px; top:40px; right:40px; background:linear-gradient(135deg,#1e293b,#0f172a); border:1px solid rgba(255,255,255,.1); display:flex; flex-direction:column; padding:20px; }
.hcard-thumb { width:100%; height:140px; border-radius:10px; object-fit:cover; background:linear-gradient(135deg,#4f46e5,#7c3aed); margin-bottom:14px; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.hcard-thumb img { width:100%; height:100%; object-fit:cover; }
.hcard-thumb-fallback { font-size:2.5rem; color:rgba(255,255,255,.6); }
.hcard-title { font-size:.9rem; font-weight:700; color:#f1f5f9; margin-bottom:6px; }
.hcard-sub { font-size:.72rem; color:#64748b; margin-bottom:12px; }
.hcard-price { font-size:1.1rem; font-weight:800; color:#a5b4fc; }
.hcard-float { width:160px; height:80px; top:0; right:0; background:linear-gradient(135deg,#4f46e5,#7c3aed); display:flex; align-items:center; justify-content:center; gap:10px; padding:16px; border-radius:12px; }
.hcard-float2 { width:140px; height:70px; bottom:20px; right:0; background:linear-gradient(135deg,#f59e0b,#ef4444); display:flex; align-items:center; justify-content:center; gap:10px; padding:14px; border-radius:12px; }
.hcard-float-icon { font-size:1.4rem; color:#fff; flex-shrink:0; }
.hcard-float-val { font-size:1.1rem; font-weight:800; color:#fff; line-height:1; }
.hcard-float-lbl { font-size:.65rem; color:rgba(255,255,255,.7); }

/* floating animation */
@@keyframes floatUp { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-14px)} }
.hero-visual { animation:floatUp 6s ease-in-out infinite; }

/* ── Section Shared ──────────────────────────────────────────── */
.section { padding:80px 0; }
.section-alt { background:var(--bg); }
.container { max-width:1200px; margin:0 auto; padding:0 32px; }
.section-head { text-align:center; margin-bottom:56px; direction:rtl; }
.section-tag { display:inline-flex; align-items:center; gap:6px; background:var(--pr-pale); color:var(--pr); font-size:.75rem; font-weight:700; padding:5px 14px; border-radius:20px; margin-bottom:12px; letter-spacing:.04em; }
.section-title { font-size:2.2rem; font-weight:900; color:var(--t1); margin-bottom:12px; line-height:1.25; }
.section-sub { font-size:1rem; color:var(--t3); max-width:560px; margin:0 auto; line-height:1.7; }

/* ── Stats Strip ──────────────────────────────────────────────── */
.stats-strip { background:linear-gradient(135deg,#1e1b4b,#312e81); padding:60px 0; }
.stats-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:32px; direction:rtl; }
.stat-item { text-align:center; }
.stat-num { font-size:2.6rem; font-weight:900; color:#fff; display:block; line-height:1; }
.stat-num-suffix { font-size:1.4rem; color:#a5b4fc; }
.stat-lbl { font-size:.8rem; color:#a5b4fc; font-weight:600; margin-top:8px; letter-spacing:.04em; }
.stat-icon { font-size:1.6rem; color:#6366f1; margin-bottom:10px; }

/* ── Course Cards ──────────────────────────────────────────────── */
.courses-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:24px; direction:rtl; }
.course-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; transition:all .25s; display:flex; flex-direction:column; }
.course-card:hover { transform:translateY(-6px); box-shadow:0 16px 48px rgba(79,70,229,.14); border-color:#c7d2fe; }
.course-thumb { height:180px; overflow:hidden; position:relative; }
.course-thumb img { width:100%; height:100%; object-fit:cover; transition:transform .4s; }
.course-card:hover .course-thumb img { transform:scale(1.05); }
.course-thumb-fallback { width:100%; height:100%; background:linear-gradient(135deg,var(--pr),var(--pr-l)); display:flex; align-items:center; justify-content:center; font-size:2.5rem; color:rgba(255,255,255,.4); }
.course-badge-wrap { position:absolute; top:12px; right:12px; display:flex; flex-direction:column; gap:5px; }
.c-badge { font-size:.65rem; font-weight:700; padding:3px 9px; border-radius:10px; }
.c-badge-featured { background:#f59e0b; color:#fff; }
.c-badge-new { background:var(--pr); color:#fff; }
.course-body { padding:20px; flex:1; display:flex; flex-direction:column; }
.course-category { font-size:.7rem; font-weight:700; color:var(--pr); text-transform:uppercase; letter-spacing:.06em; margin-bottom:8px; }
.course-title { font-size:1rem; font-weight:700; color:var(--t1); margin-bottom:10px; line-height:1.4; }
.course-meta { display:flex; align-items:center; gap:14px; font-size:.75rem; color:var(--t4); margin-bottom:14px; flex-wrap:wrap; }
.course-meta i { color:var(--pr); font-size:.7rem; }
.course-stars { display:flex; align-items:center; gap:3px; margin-bottom:12px; }
.star { color:#f59e0b; font-size:.75rem; }
.star-empty { color:#e2e8f0; font-size:.75rem; }
.star-count { font-size:.72rem; color:var(--t4); margin-right:5px; }
.course-footer { display:flex; align-items:center; justify-content:space-between; padding-top:14px; border-top:1px solid var(--border); margin-top:auto; }
.course-price { font-size:1.2rem; font-weight:800; color:var(--pr); }
.course-price-currency { font-size:.75rem; font-weight:600; color:var(--t4); margin-right:3px; }
.btn-enroll { padding:7px 16px; background:var(--pr-pale); color:var(--pr); border-radius:8px; font-size:.8rem; font-weight:700; transition:all .2s; }
.btn-enroll:hover { background:var(--pr); color:#fff; }

/* ── Features ──────────────────────────────────────────────── */
.features-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; direction:rtl; }
.feature-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); padding:32px 28px; text-align:center; transition:all .25s; }
.feature-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); border-color:#c7d2fe; }
.feature-icon-wrap { width:64px; height:64px; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:1.6rem; margin:0 auto 18px; }
.feature-title { font-size:1.05rem; font-weight:700; color:var(--t1); margin-bottom:10px; }
.feature-desc { font-size:.85rem; color:var(--t3); line-height:1.7; }

/* ── Trainers ──────────────────────────────────────────────── */
.trainers-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:20px; direction:rtl; }
.trainer-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); padding:28px 20px; text-align:center; transition:all .25s; }
.trainer-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); border-color:#c7d2fe; }
.trainer-avatar { width:80px; height:80px; border-radius:50%; object-fit:cover; border:3px solid var(--border); margin:0 auto 14px; transition:border-color .2s; display:block; }
.trainer-card:hover .trainer-avatar { border-color:#a5b4fc; }
.trainer-name { font-size:.95rem; font-weight:700; color:var(--t1); margin-bottom:4px; }
.trainer-spec { font-size:.75rem; color:var(--pr); font-weight:600; background:var(--pr-pale); padding:3px 10px; border-radius:10px; display:inline-block; margin-bottom:8px; }
.trainer-courses { font-size:.72rem; color:var(--t4); }

/* ── Process Steps ──────────────────────────────────────────── */
.steps-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; direction:rtl; position:relative; }
.steps-grid::before { content:''; position:absolute; top:36px; right:12.5%; left:12.5%; height:2px; background:linear-gradient(90deg,var(--pr),var(--pr-l)); opacity:.2; }
.step-card { text-align:center; position:relative; padding:0 12px; }
.step-num { width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,var(--pr),var(--pr-l)); color:#fff; font-size:1.3rem; font-weight:900; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; box-shadow:0 4px 16px rgba(79,70,229,.35); }
.step-title { font-size:.95rem; font-weight:700; color:var(--t1); margin-bottom:8px; }
.step-desc { font-size:.82rem; color:var(--t3); line-height:1.6; }

/* ── Testimonials ──────────────────────────────────────────── */
.testimonials-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; direction:rtl; }
.testimonial-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); padding:28px; box-shadow:var(--shadow); position:relative; }
.testimonial-card::before { content:'"'; position:absolute; top:16px; right:20px; font-size:4rem; color:var(--pr-pale); font-family:serif; line-height:1; }
.testimonial-text { font-size:.88rem; color:var(--t2); line-height:1.8; margin-bottom:20px; font-style:italic; }
.testimonial-author { display:flex; align-items:center; gap:12px; }
.testimonial-avatar { width:42px; height:42px; border-radius:50%; object-fit:cover; border:2px solid var(--border); }
.testimonial-name { font-size:.85rem; font-weight:700; color:var(--t1); }
.testimonial-role { font-size:.72rem; color:var(--t4); }
.testimonial-stars { display:flex; gap:2px; margin-bottom:12px; }

/* ── CTA Banner ──────────────────────────────────────────────── */
.cta-banner { background:linear-gradient(135deg,#1e1b4b 0%,#4f46e5 50%,#7c3aed 100%); border-radius:24px; padding:64px 48px; text-align:center; position:relative; overflow:hidden; direction:rtl; }
.cta-banner::before { content:''; position:absolute; inset:0; background-image:radial-gradient(circle,rgba(255,255,255,.06) 1px,transparent 1px); background-size:24px 24px; }
.cta-title { font-size:2.4rem; font-weight:900; color:#fff; margin-bottom:16px; position:relative; }
.cta-sub { font-size:1rem; color:#c7d2fe; margin-bottom:32px; position:relative; }
.cta-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; position:relative; }
.cta-btn-white { padding:13px 32px; background:#fff; color:var(--pr); border-radius:10px; font-weight:700; font-size:.95rem; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
.cta-btn-white:hover { background:#f1f5f9; transform:translateY(-2px); color:var(--pr-d); }
.cta-btn-outline { padding:13px 32px; background:transparent; color:#fff; border:2px solid rgba(255,255,255,.4); border-radius:10px; font-weight:600; font-size:.95rem; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
.cta-btn-outline:hover { background:rgba(255,255,255,.1); transform:translateY(-2px); }

/* ── Responsive ──────────────────────────────────────────────── */
@@media(max-width:900px) {
    .hero-container { grid-template-columns:1fr; gap:32px; text-align:center; }
    .hero-visual { display:none; }
    .hero-title { font-size:2.2rem; }
    .hero-btns { justify-content:center; }
    .hero-stats { justify-content:center; }
    .stats-grid { grid-template-columns:repeat(3,1fr); }
    .features-grid { grid-template-columns:1fr 1fr; }
    .steps-grid { grid-template-columns:1fr 1fr; }
    .testimonials-grid { grid-template-columns:1fr; }
    .steps-grid::before { display:none; }
}
@@media(max-width:600px) {
    .stats-grid { grid-template-columns:repeat(2,1fr); }
    .features-grid { grid-template-columns:1fr; }
    .steps-grid { grid-template-columns:1fr; }
    .hero-title { font-size:1.8rem; }
    .section-title { font-size:1.7rem; }
    .cta-banner { padding:40px 24px; }
    .cta-title { font-size:1.7rem; }
}
</style>
}

@* ─── HEADER ───────────────────────────────────── *@
@await Html.PartialAsync("_LandingHeader")

@* ─── HERO ────────────────────────────────────── *@
<section class="hero">
    <div class="hero-bg-dots"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-container">
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fas fa-graduation-cap"></i>
                <span>منصة التدريب المتكاملة #1</span>
            </div>
            <h1 class="hero-title">
                ابدأ رحلتك<br>
                نحو <span>المستقبل</span><br>
                من هنا
            </h1>
            <p class="hero-desc">
                منصة تدريبية متخصصة تجمع أفضل المدربين وأحدث المناهج.<br>
                اكتسب المهارات التي يحتاجها سوق العمل واحصل على شهادات معتمدة.
            </p>
            <div class="hero-btns">
                <a asp-action="Index" asp-controller="Courses" class="hero-btn-primary">
                    <i class="fas fa-play-circle"></i> تصفح الكورسات
                </a>
                <a asp-action="Login" asp-controller="Account" class="hero-btn-secondary">
                    <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
                </a>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-val">@Model.TotalCourses<span class="hero-stat-suffix" style="font-size:1.2rem;color:#a5b4fc">+</span></span>
                    <span class="hero-stat-lbl">كورس متاح</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-val">@Model.TotalTrainees<span style="font-size:1.2rem;color:#a5b4fc">+</span></span>
                    <span class="hero-stat-lbl">متدرب</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-val">@Model.TotalTrainers<span style="font-size:1.2rem;color:#a5b4fc">+</span></span>
                    <span class="hero-stat-lbl">مدرب خبير</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-val">@Model.TotalCertificates<span style="font-size:1.2rem;color:#a5b4fc">+</span></span>
                    <span class="hero-stat-lbl">شهادة ممنوحة</span>
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-card-stack">
                @{
                    var firstCourse = Model.FeaturedCourses.FirstOrDefault() ?? Model.Courses.FirstOrDefault();
                }
                <div class="hcard hcard-main">
                    <div class="hcard-thumb">
                        @if (firstCourse != null && !string.IsNullOrEmpty(firstCourse.ThumbnailUrl))
                        {
                            <img src="@firstCourse.ThumbnailUrl" alt="@firstCourse.CourseName" />
                        }
                        else
                        {
                            <div class="hcard-thumb-fallback"><i class="fas fa-book-open"></i></div>
                        }
                    </div>
                    <div class="hcard-title">@(firstCourse?.CourseName ?? "Python Basics")</div>
                    <div class="hcard-sub">@(firstCourse?.Description?.Length > 60 ? firstCourse.Description[..60] + "…" : firstCourse?.Description ?? "برمجة احترافية")</div>
                    <div class="hcard-price">$@(firstCourse?.Price.ToString("F0") ?? "49")</div>
                </div>
                <div class="hcard hcard-float">
                    <div class="hcard-float-icon"><i class="fas fa-users"></i></div>
                    <div>
                        <div class="hcard-float-val">@Model.TotalTrainees+</div>
                        <div class="hcard-float-lbl">طالب نشط</div>
                    </div>
                </div>
                <div class="hcard hcard-float2">
                    <div class="hcard-float-icon"><i class="fas fa-certificate"></i></div>
                    <div>
                        <div class="hcard-float-val">@Model.TotalCertificates+</div>
                        <div class="hcard-float-lbl">شهادة</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── STATS STRIP ─────────────────────────────── *@
<section class="stats-strip">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-book-open"></i></div>
                <span class="stat-num">@Model.TotalCourses<span class="stat-num-suffix">+</span></span>
                <div class="stat-lbl">كورس متاح</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-user-graduate"></i></div>
                <span class="stat-num">@Model.TotalTrainees<span class="stat-num-suffix">+</span></span>
                <div class="stat-lbl">متدرب مسجّل</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-chalkboard-teacher"></i></div>
                <span class="stat-num">@Model.TotalTrainers<span class="stat-num-suffix">+</span></span>
                <div class="stat-lbl">مدرب خبير</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-video"></i></div>
                <span class="stat-num">@Model.TotalLectures<span class="stat-num-suffix">+</span></span>
                <div class="stat-lbl">محاضرة تعليمية</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-certificate"></i></div>
                <span class="stat-num">@Model.TotalCertificates<span class="stat-num-suffix">+</span></span>
                <div class="stat-lbl">شهادة ممنوحة</div>
            </div>
        </div>
    </div>
</section>

@* ─── FEATURED COURSES ────────────────────────── *@
@if (Model.FeaturedCourses.Any())
{
    <section class="section">
        <div class="container">
            <div class="section-head">
                <div class="section-tag"><i class="fas fa-fire"></i> أبرز الكورسات</div>
                <h2 class="section-title">اختر كورسك وابدأ التعلم</h2>
                <p class="section-sub">كورسات مختارة بعناية من قِبل خبراء المجال لتضمن لك أفضل تجربة تعليمية</p>
            </div>
            <div class="courses-grid">
                @foreach (var course in Model.FeaturedCourses)
                {
                    var avgRating = course.Ratings?.Any() == true ? course.Ratings.Average(r => r.Stars) : 0;
                    var studentCount = course.CourseTrainees?.Count ?? 0;
                    var isNew = (DateTime.UtcNow - course.CreatedDate).TotalDays < 30;
                    <div class="course-card">
                        <div class="course-thumb">
                            @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                            {
                                <img src="@course.ThumbnailUrl" alt="@course.CourseName" loading="lazy" />
                            }
                            else
                            {
                                <div class="course-thumb-fallback"><i class="fas fa-book"></i></div>
                            }
                            <div class="course-badge-wrap">
                                @if (course.IsFeatured) { <span class="c-badge c-badge-featured"><i class="fas fa-star"></i> مميز</span> }
                                @if (isNew) { <span class="c-badge c-badge-new">جديد</span> }
                            </div>
                        </div>
                        <div class="course-body">
                            <div class="course-category">الدفعة @course.BatchNumber</div>
                            <div class="course-title">@course.CourseName</div>
                            <div class="course-meta">
                                <span><i class="fas fa-video"></i> @course.NumberOfLectures محاضرة</span>
                                <span><i class="fas fa-users"></i> @studentCount طالب</span>
                            </div>
                            @if (avgRating > 0)
                            {
                                <div class="course-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= avgRating ? "star" : "star-empty")"></i>
                                    }
                                    <span class="star-count">(@course.Ratings.Count)</span>
                                </div>
                            }
                            <div class="course-footer">
                                <div class="course-price">
                                    <span class="course-price-currency">@course.CourseCurrency</span>@course.Price.ToString("F0")
                                </div>
                                <a asp-action="Details" asp-controller="Courses" asp-route-id="@course.CourseId" class="btn-enroll">
                                    عرض الكورس
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div style="text-align:center;margin-top:40px">
                <a asp-action="Index" asp-controller="Courses" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;border-radius:10px;border:2px solid var(--pr);color:var(--pr);font-weight:700;font-size:.9rem;transition:all .2s">
                    <i class="fas fa-th-large"></i> عرض جميع الكورسات
                </a>
            </div>
        </div>
    </section>
}

