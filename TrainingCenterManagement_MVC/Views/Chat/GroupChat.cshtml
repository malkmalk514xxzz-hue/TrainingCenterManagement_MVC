@model List<TrainingCenterManagement_MVC.Models.GroupMessage>
@{
    ViewData["Title"] = "Group Chat";
    Guid courseId = ViewBag.CourseId;
    
}


<div class="chat-container">
    <div class="chat-header">Group Chat for Course @courseId</div>
    <div class="chat-box" id="chatBox">
        @foreach (var message in Model)
        {

            <div class="message @(message.SenderId == Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ? "sent" : "received")">
                <div class="message-sender">@message.Sender.UserName</div>
                <div>@message.Content</div>
                <div class="message-time">@message.Timestamp.ToString("hh:mm tt")</div>
            </div>
        }
    </div>
    <div class="chat-input">
        <input type="text" id="messageInput" placeholder="Type a message..." />
        <button onclick="sendGroupMessage()">Send</button>
    </div>
    <div id="status"></div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const currentUser = "@User.Identity.Name";
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

        connection.on("ReceiveGroupMessage", (user, message, timestamp) => {
           console.log(`Received message from ${user}: ${message} at ${timestamp}`);
        const chatBox = document.getElementById("chatBox");
        const msg = document.createElement("div");
        msg.className = user === currentUser ? "sent" : "received";
        msg.innerHTML = `
                    <div class="message-sender">${user}</div>
                    <div>${message}</div>
                    <div class="message-time">${new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
                `;
                chatBox.appendChild(msg);
                chatBox.scrollTop = chatBox.scrollHeight;
            });

            connection.start().then(() => {
                connection.invoke("JoinCourseGroup", "@courseId");
            }).catch(err => console.error(err));

            function sendGroupMessage() {
                const message = $("#messageInput").val();
                if (!message) {
                    $("#status").text("Message cannot be empty");
                    return;
                }

                $.ajax({
                    url: '/Chat/SendGroupMessage',
                    type: 'POST',
                    data: { courseId: "@courseId", content: message },
                    success: function (response) {
                        if (response.success) {
                            $("#messageInput").val("");
                            $("#status").text("");
                            connection.invoke("SendGroupMessage", "@courseId", "@User.Identity.Name", message)
                                .catch(err => console.error(err));
                        } else {
                            $("#status").text(response.message);
                        }
                    },
                    error: function () {
                        $("#status").text("Error sending message");
                    }
                });
            }
        </script>
    }
