@model TrainingCenterManagement_MVC.ViewModels.ChatIndexViewModel
@{
    ViewData["Title"] = "Chat";
}

<link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />

<div class="wa-directory">
    <div class="wa-directory-shell">
        <aside class="wa-directory-sidebar">
            <div class="wa-directory-header">
                <div>
                    <div class="wa-directory-kicker">Messaging</div>
                    <h1>Chats</h1>
                </div>

            </div>

            <div class="wa-directory-search">
                <i class="fas fa-search"></i>
                <input type="search" id="chatSearch" placeholder="ابحث عن محادثة أو مستخدم أو دورة" />
            </div>

            <div class="wa-directory-sections">
                <section class="wa-directory-section">
                    <div class="wa-directory-section-title">آخر المحادثات</div>
                    <div id="recentContacts" class="wa-directory-list">
                        @foreach (var contact in Model.RecentContacts)
                        {
                            <div class="wa-contact-card" data-search="@($"{contact.Username} {contact.LastMessage}".ToLowerInvariant())" onclick="location.href='@Url.Action(contact.IsGroup ? "GroupChat" : "PrivateChat", "Chat", contact.IsGroup ? new { courseId = contact.UserId } : new { receiverId = contact.UserId })'">
                                <div class="wa-contact-avatar @(contact.IsGroup ? "group" : string.Empty)">@(contact.IsGroup ? "#" : contact.Username.Substring(0, 1).ToUpperInvariant())</div>
                                @if (!contact.IsGroup)
                                {
                                    <div class="status offline wa-contact-status" data-id="@contact.UserId"></div>
                                }
                                <div class="wa-contact-main">
                                    <div class="wa-contact-row">
                                        <div class="wa-contact-name">@contact.Username</div>
                                        <div class="wa-contact-time">@contact.LastMessageTime.ToString("hh:mm tt")</div>
                                    </div>
                                    <div class="wa-contact-preview">@contact.LastMessage</div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="wa-directory-section">
                    <div class="wa-directory-section-title">مجموعات الدورات</div>
                    <div class="wa-directory-list" id="courseGroups">
                        @foreach (var course in Model.Courses)
                        {
                            <div class="wa-contact-card" data-search="@course.CourseName.ToLowerInvariant()" onclick="location.href='@Url.Action("GroupChat", "Chat", new { courseId = course.CourseId })'">
                                <div class="wa-contact-avatar group">#</div>
                                <div class="wa-contact-main">
                                    <div class="wa-contact-row">
                                        <div class="wa-contact-name">@course.CourseName</div>
                                    </div>
                                    <div class="wa-contact-preview">محادثة جماعية للدورة</div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="wa-directory-section">
                    <div class="wa-directory-section-title">كل المستخدمين</div>
                    <div class="wa-directory-list" id="allUsersList">
                        @foreach (var user in Model.AllUsers)
                        {
                            <div class="wa-contact-card" data-search="@user.UserName.ToLowerInvariant()" onclick="location.href='@Url.Action("PrivateChat", "Chat", new { receiverId = user.Id })'">
                                <div class="wa-contact-avatar">@user.UserName.Substring(0, 1).ToUpperInvariant()</div>
                                <div class="status offline wa-contact-status" data-id="@user.Id"></div>
                                <div class="wa-contact-main">
                                    <div class="wa-contact-row">
                                        <div class="wa-contact-name">@user.UserName</div>
                                        <div class="wa-contact-time">ابدأ الآن</div>
                                    </div>
                                    <div class="wa-contact-preview">افتح محادثة خاصة</div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </aside>

        <section class="wa-directory-stage">
            <div class="wa-stage-card">
                <div class="wa-stage-icon"><i class="fas fa-comments"></i></div>
                <h2>اختر محادثة للبدء</h2>
                <p>القائمة الآن محدثة بأسلوب أقرب لواتساب، مع المحادثات الحديثة، المجموعات، وحالة الاتصال المباشرة.</p>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        (() => {
            const courseIds = @Html.Raw(Json.Serialize(Model.Courses?.Select(c => c.CourseId.ToString()) ?? new List<string>()));
            const recentContactsDiv = document.getElementById('recentContacts');
            const chatSearch = document.getElementById('chatSearch');

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/chatHub')
                .withAutomaticReconnect()
                .build();

            connection.on('UserStatusChanged', (userId, isOnline) => {
                const statusElements = document.querySelectorAll(`.status[data-id='${userId}']`);
                statusElements.forEach(el => {
                    el.classList.remove('online', 'offline');
                    el.classList.add(isOnline ? 'online' : 'offline');
                });
            });

            connection.on('UpdateRecentContacts', (contacts) => {
                recentContactsDiv.innerHTML = '';
                (contacts || []).forEach(contact => {
                    if (!contact.Id) return;

                    const dataId = String(contact.Id).trim();
                    const isGroup = !!contact.IsGroup;
                    const displayName = contact.DisplayName || 'Unknown';
                    const preview = normalizePreview(contact.LastMessage || '');
                    const time = contact.LastMessageTime ? new Date(contact.LastMessageTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '';
                    const searchText = `${displayName} ${preview}`.toLowerCase();
                    const encodedId = encodeURIComponent(dataId);
                    const href = isGroup ? `/Chat/GroupChat?courseId=${encodedId}` : `/Chat/PrivateChat?receiverId=${encodedId}`;

                    const item = document.createElement('div');
                    item.className = 'wa-contact-card';
                    item.dataset.search = searchText;
                    item.onclick = () => location.href = href;
                    item.innerHTML = `
                        <div class="wa-contact-avatar ${isGroup ? 'group' : ''}">${isGroup ? '#' : escapeHtml(displayName.charAt(0).toUpperCase())}</div>
                        ${isGroup ? '' : `<div class="status offline wa-contact-status" data-id="${escapeAttr(dataId)}"></div>`}
                        <div class="wa-contact-main">
                            <div class="wa-contact-row">
                                <div class="wa-contact-name">${escapeHtml(displayName)}</div>
                                <div class="wa-contact-time">${escapeHtml(time)}</div>
                            </div>
                            <div class="wa-contact-preview">${escapeHtml(preview)}</div>
                        </div>
                    `;
                    recentContactsDiv.appendChild(item);
                });

                applySearch();
            });

            connection.start()
                .then(() => {
                    const ids = courseIds.$values && Array.isArray(courseIds.$values) ? courseIds.$values : [];
                    ids.forEach(courseId => connection.invoke('JoinCourseGroup', courseId).catch(() => {}));
                })
                .catch(err => console.error('SignalR connection failed:', err));

            chatSearch.addEventListener('input', applySearch);

            function applySearch() {
                const query = (chatSearch.value || '').trim().toLowerCase();
                document.querySelectorAll('.wa-contact-card').forEach(card => {
                    const haystack = card.dataset.search || '';
                    card.style.display = !query || haystack.includes(query) ? '' : 'none';
                });
            }

            function normalizePreview(value) {
                const mediaMatch = value.match(/^\[media:(image|video|audio):(.+)\]$/i);
                if (mediaMatch) {
                    const type = mediaMatch[1].toLowerCase();
                    if (type === 'image') return 'صورة';
                    if (type === 'video') return 'فيديو';
                    if (type === 'audio') return 'رسالة صوتية';
                }
                if (value === '[image message]') return 'صورة';
                if (value === '[video message]') return 'فيديو';
                if (value === '[audio message]') return 'رسالة صوتية';
                return value;
            }

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function escapeAttr(value) {
                return escapeHtml(value);
            }
        })();
    </script>
}
