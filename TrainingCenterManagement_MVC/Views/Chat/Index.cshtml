@model TrainingCenterManagement_MVC.ViewModels.ChatIndexViewModel
@{
    ViewData["Title"] = "Chat";
}

<div class="container">
    <div class="sidebar">
        <h2 style="padding: 15px; color: #00897b;">Chats</h2>
        <div class="chat-list">
            <h3>Recent Contacts</h3>
            <div id="recentContacts">
                @foreach (var contact in Model.RecentContacts)
                {
                    <div class="chat-item" data-id="@contact.UserId" onclick="location.href='@Url.Action(contact.IsGroup ? "GroupChat" : "PrivateChat", "Chat", contact.IsGroup ? new { courseId = contact.UserId } : new { receiverId = contact.UserId })'">
                        @if (!contact.IsGroup)
                        {
                            <div class="status offline" data-id="@contact.UserId"></div>
                        }
                        <div class="chat-info">
                            <div class="chat-name">@contact.Username</div>
                            <div class="chat-preview">@contact.LastMessage</div>
                        </div>
                        <div class="chat-time">@contact.LastMessageTime.ToString("hh:mm tt")</div>
                    </div>
                }

            </div>
            <h3>Course Groups</h3>
            @foreach (var course in Model.Courses)
            {
                <div class="chat-item" data-id="@course.CourseId" onclick="location.href='@Url.Action("GroupChat", "Chat", new { courseId = course.CourseId })'">
                    <div class="chat-info">
                        <div class="chat-name">@course.CourseName</div>
                        <div class="chat-preview">Group chat for course</div>
                    </div>
                </div>
            }
          
            <h3>All Users</h3>
            @foreach (var user in Model.AllUsers)
            {
                <div class="chat-item" onclick="location.href='@Url.Action("PrivateChat", "Chat", new { receiverId = user.Id })'">
                    <div class="status offline" data-id="@user.Id"></div>
                    <div class="chat-info">
                        <div class="chat-name">@user.UserName</div>
                        <div class="chat-preview">@user.UserName</div>
                    </div>
                    <div class="chat-time">@DateTime.Now.ToString("hh:mm tt")</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
         // قائمة معرفات الدورات من النموذج
        const courseIds = @Html.Raw(Json.Serialize(Model.Courses?.Select(c => c.CourseId.ToString()) ?? new List<string>()));


        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("UserStatusChanged", (userId, isOnline) => {
            const statusElements = document.querySelectorAll(`.status[data-id='${userId}']`);
            statusElements.forEach(el => {
                el.classList.remove("online", "offline");
                el.classList.add(isOnline ? "online" : "offline");
            });
        });

        connection.on("UpdateRecentContacts", (contacts) => {
            console.log("Received UpdateRecentContacts - Contacts:", JSON.stringify(contacts));
            const recentContactsDiv = document.getElementById("recentContacts");

            // مسح المحادثات القديمة
            recentContactsDiv.innerHTML = "";

            // إعادة بناء قائمة المحادثات
            contacts.forEach(contact => {
               // console.log(contact);
                if (!contact.Id) { // تعديل من contact.id إلى contact.Id
                    console.error("Error: contact.Id is undefined or empty", contact);
                    return;
                }
                
                const dataId = contact.Id.trim();
               // console.log(contact);
              //  console.log(dataId);
                const contactHtml = contact.IsGroup ?
                    `<div class="chat-item" data-id="${dataId}" onclick="location.href='/Chat/GroupChat?courseId=${dataId}'">
                        <div class="chat-info">
                            <div class="chat-name">${contact.DisplayName}</div>
                            <div class="chat-preview">${contact.LastMessage}</div>
                        </div>
                        <div class="chat-time">${new Date(contact.LastMessageTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
                    </div>` :
                    `<div class="chat-item" data-id="${CSS.escape(dataId)}" onclick="location.href='/Chat/PrivateChat?receiverId=${CSS.escape(dataId)}'">
                        <div class="status offline" data-id="${CSS.escape(dataId)}"></div>
                        <div class="chat-info">
                            <div class="chat-name">${contact.DisplayName}</div>
                            <div class="chat-preview">${contact.LastMessage}</div>
                        </div>
                        <div class="chat-time">${new Date(contact.LastMessageTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
                    </div>`;

                recentContactsDiv.insertAdjacentHTML("beforeend", contactHtml);
            });
        });

        connection.start()
            .then(() => {
                console.log("تم الاتصال بـ SignalR بنجاح");
                console.log("courseIds:", courseIds);
                // التأكد من أن courseIds يحتوي على $values وهي مصفوفة
                const ids = courseIds.$values && Array.isArray(courseIds.$values) ? courseIds.$values : [];
                if (ids.length > 0) {
                    ids.forEach(courseId => {
                        console.log(`الانضمام إلى المجموعة Course_${courseId}`);
                        connection.invoke("JoinCourseGroup", courseId)
                            .then(() => console.log(`تم الانضمام إلى المجموعة Course_${courseId} بنجاح`))
                            .catch(err => console.error(`خطأ في الانضمام إلى المجموعة Course_${courseId}:`, err));
                    });
                } else {
                    console.warn("لا توجد دورات للانضمام إليها:", courseIds);
                }
            })
            .catch(err => console.error("فشل الاتصال بـ SignalR: ", err));


        connection.onreconnecting(err => {
            console.warn("SignalR reconnecting: ", err);
        });

        connection.onreconnected(() => {
            console.log("SignalR reconnected successfully");
        });

        connection.onclose(err => {
            console.error("SignalR connection closed: ", err);
        });
    </script>
}