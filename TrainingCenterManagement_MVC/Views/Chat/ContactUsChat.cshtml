
@model List<TrainingCenterManagement_MVC.Models.GusetMessage>
@{
    ViewData["Title"] = ViewBag.IsGuestChat ? "دردشة التواصل معنا" : "الدردشة الخاصة";
    string receiverId = ViewBag.ReceiverId;
    string receiverUsername = ViewBag.ReceiverUsername ?? "دعم الإدارة";
    string senderId = ViewBag.SenderId;
    string senderUsername = ViewBag.SenderUsername ?? "ضيف";
   
    
}

<div class="chat-container">
    <div class="chat-header">الدردشة مع @receiverUsername</div>
    <div class="chat-box" id="chatBox">
        @foreach (var message in Model)
        {
            <div class="message @(message.SenderId == senderId ? "sent" : "received")">
                <div class="message-sender">@(message.SenderId == senderId ? senderUsername : (receiverUsername ?? "دعم الإدارة"))</div>
                <div>@message.Content</div>
                <div class="message-time">@message.Timestamp.ToString("hh:mm tt")</div>
            </div>
        }
    </div>
    <div class="chat-input">
        <input type="text" id="messageInput" placeholder="اكتب رسالة..." />
        <button onclick="sendPrivateMessage()">إرسال</button>
    </div>
    <div id="status"></div>
</div>



@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub?guestId=@senderId", { transport: signalR.HttpTransportType.LongPolling }) // استخدام Long Polling
            .withAutomaticReconnect([0, 2000, 10000, 30000]) // فترات إعادة الاتصال
            .build();

        connection.onreconnecting((error) => {
            console.warn("جاري إعادة الاتصال بـ SignalR:", error);
            $("#status").text("جاري إعادة الاتصال بخادم الدردشة...");
        });

        connection.onreconnected((connectionId) => {
            console.log("تم إعادة الاتصال بـ SignalR مع connectionId:", connectionId);
            $("#status").text("تم إعادة الاتصال بخادم الدردشة");
        });

        connection.onclose((error) => {
            console.error("تم إغلاق اتصال SignalR:", error);
            $("#status").text("تم إغلاق الاتصال: " + (error ? error.message : "غير معروف"));
        });

        connection.on("ReceivePrivateMessage", (sender, message, timestamp) => {
            console.log(`استلام رسالة من ${sender}: ${message} في ${timestamp}`);
            const chatBox = document.getElementById("chatBox");
            const msg = document.createElement("div");
            const isSent = sender === '@senderUsername';
            msg.className = `message ${isSent ? 'sent' : 'received'}`;
            msg.innerHTML = `
                <div class="message-sender">${sender}</div>
                <div>${message}</div>
                <div class="message-time">${new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
            `;
            chatBox.appendChild(msg);
            chatBox.scrollTop = chatBox.scrollHeight;
        });

        connection.on("ReceiveNotification", (sender, message) => {
            console.log(`إشعار: ${sender}: ${message}`);
            $("#status").text(`إشعار من ${sender}: ${message}`);
        });

        connection.on("ReceiveError", (errorMessage) => {
            console.error(`خطأ من الخادم: ${errorMessage}`);
            $("#status").text(errorMessage);
        });

        document.addEventListener("DOMContentLoaded", () => {
            const chatBox = document.getElementById("chatBox");
            chatBox.scrollTop = chatBox.scrollHeight;
        });

        connection.start()
            .then(() => console.log("تم الاتصال بـ SignalR"))
            .catch(err => {
                console.error("خطأ في الاتصال بـ SignalR:", err);
                $("#status").text("فشل الاتصال بخادم الدردشة");
            });

        function sendPrivateMessage() {
            const message = $("#messageInput").val();
            if (!message) {
                $("#status").text("الرسالة لا يمكن أن تكون فارغة");
                return;
            }

            $.ajax({
                url: '/Chat/SendCustomerSupportMessage',
                type: 'POST',
                data: { receiverId: '@receiverId', content: message },
                success: function (response) {
                    if (response.success) {
                        $("#messageInput").val("");
                        $("#status").text("");
                        const chatBox = document.getElementById("chatBox");
                        const msg = document.createElement("div");
                        msg.className = "message sent";
                        msg.innerHTML = `
                            <div class="message-sender">@senderUsername</div>
                            <div>${message}</div>
                            <div class="message-time">${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
                        `;
                        chatBox.appendChild(msg);
                        chatBox.scrollTop = chatBox.scrollHeight;
                    } else {
                        $("#status").text(response.message);
                    }
                },
                error: function () {
                    console.error("خطأ AJAX: فشل إرسال الرسالة");
                    $("#status").text("خطأ في إرسال الرسالة");
                }
            });
        }
    </script>
}