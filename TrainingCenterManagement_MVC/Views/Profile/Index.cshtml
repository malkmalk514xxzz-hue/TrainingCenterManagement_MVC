@model TrainingCenterManagement_MVC.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "الملف الشخصي";
    var defaultAvatar = "https://placehold.co/200/e2e8f0/60758a?text=User";
    var picSrc = string.IsNullOrEmpty(Model.ProfilePictureUrl) ? defaultAvatar : Model.ProfilePictureUrl;
    var isTrainer = User.IsInRole("Trainer");
}

<style>
    .profile-avatar-wrap {
        position: relative;
        width: 130px;
        height: 130px;
        margin: 0 auto;
        flex-shrink: 0;
    }
    .profile-avatar-wrap img {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #e2e8f0;
        display: block;
    }
    .photo-overlay {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(0,0,0,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity .2s;
        cursor: pointer;
        color: #fff;
        font-size: 1.4rem;
    }
    .profile-avatar-wrap:hover .photo-overlay { opacity: 1; }

    .profile-card {
        border-radius: 16px;
        border: 1.5px solid #e8ecef;
        background: #fff;
        padding: 28px;
    }
    .field-group label {
        font-size: .8rem;
        font-weight: 600;
        color: #64748b;
        display: block;
        margin-bottom: 4px;
    }
    .field-group input, .field-group textarea {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 9px 14px;
        font-size: .9rem;
        transition: border-color .15s;
        width: 100%;
        background: #f8fafc;
    }
    .field-group input:focus, .field-group textarea:focus {
        outline: none;
        border-color: #6366f1;
        background: #fff;
    }
    .field-group input[readonly] {
        background: #f1f5f9;
        color: #94a3b8;
        cursor: default;
    }
    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 14px;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
    }
    .role-admin        { background: #ede9fe; color: #5b21b6; }
    .role-trainer      { background: #dbeafe; color: #1d4ed8; }
    .role-trainee      { background: #d1fae5; color: #065f46; }
    .role-receptionist { background: #fef3c7; color: #92400e; }

    .section-divider {
        border: none;
        border-top: 1.5px solid #f1f5f9;
        margin: 24px 0;
    }
    .save-btn {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 28px;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity .2s;
    }
    .save-btn:hover { opacity: .88; }

    .trainer-section {
        background: linear-gradient(135deg, #eff6ff 0%, #f0fdf4 100%);
        border-radius: 16px;
        border: 1.5px solid #dbeafe;
        padding: 24px;
    }
</style>

<div class="dashboard-wrapper">
    @if (User.IsInRole("Admin"))       { @await Html.PartialAsync("_AdminSidebar") }
    else if (User.IsInRole("Trainer")) { @await Html.PartialAsync("_TrainerSidebar") }
    else if (User.IsInRole("Trainee")) { @await Html.PartialAsync("_TraineeSidebar") }
    else                               { @await Html.PartialAsync("_ReceptionistSidebar") }

    <main class="dashboard-main">
        <div class="container-fluid px-4 py-4" style="max-width:820px">

            <!-- Page Header -->
            <div class="d-flex align-items-center gap-3 mb-4">
                <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary" style="border-radius:10px">
                    <i class="fas fa-arrow-right"></i>
                </a>
                <div>
                    <h2 class="fw-bold mb-0" style="color:#1e293b">الملف الشخصي</h2>
                    <p class="text-muted mb-0 mt-1" style="font-size:.85rem">إدارة معلوماتك الشخصية وصورتك</p>
                </div>
            </div>

            <!-- Alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4 py-2" style="border-radius:10px;font-size:.88rem">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4 py-2" style="border-radius:10px;font-size:.88rem">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- ══ Photo Upload Form ══ -->
            <form asp-action="UpdatePhoto" method="post" enctype="multipart/form-data" id="photoForm">
                @Html.AntiForgeryToken()
                <input type="file" id="photoInput" name="photo" accept="image/jpeg,image/png,image/gif,image/webp" class="d-none">
            </form>

            <!-- ══ Main Profile Card ══ -->
            <div class="profile-card mb-4">
                <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start gap-4">

                    <!-- Photo -->
                    <div class="text-center">
                        <div class="profile-avatar-wrap mb-2">
                            <img id="profileImg" src="@picSrc" alt="صورة الملف الشخصي">
                            <label for="photoInput" class="photo-overlay" title="تغيير الصورة">
                                <i class="fas fa-camera"></i>
                            </label>
                        </div>
                        <label for="photoInput" class="d-block text-center" style="font-size:.75rem;color:#94a3b8;cursor:pointer">
                            انقر لتغيير الصورة
                        </label>
                        <div class="mt-2">
                            @{
                                string roleCls = Model.Role switch {
                                    "مدير النظام"   => "role-admin",
                                    "مدرّب"          => "role-trainer",
                                    "متدرّب"         => "role-trainee",
                                    _               => "role-receptionist"
                                };
                                string roleIcon = Model.Role switch {
                                    "مدير النظام"   => "fa-shield-alt",
                                    "مدرّب"          => "fa-chalkboard-teacher",
                                    "متدرّب"         => "fa-graduation-cap",
                                    _               => "fa-headset"
                                };
                            }
                            <span class="role-badge @roleCls">
                                <i class="fas @roleIcon"></i>@Model.Role
                            </span>
                        </div>
                    </div>

                    <!-- Info Form -->
                    <div class="flex-grow-1 w-100">
                        <form asp-action="UpdateInfo" method="post">
                            @Html.AntiForgeryToken()

                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="field-group">
                                        <label asp-for="FullName"><i class="fas fa-user me-1"></i>الاسم الكامل</label>
                                        <input asp-for="FullName" class="form-control" autocomplete="name">
                                        <span asp-validation-for="FullName" class="text-danger" style="font-size:.75rem"></span>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="field-group">
                                        <label><i class="fas fa-envelope me-1"></i>البريد الإلكتروني</label>
                                        <input value="@Model.Email" readonly class="form-control">
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="field-group">
                                        <label asp-for="BirthDate"><i class="fas fa-birthday-cake me-1"></i>تاريخ الميلاد</label>
                                        <input asp-for="BirthDate" type="date" class="form-control"
                                               value="@Model.BirthDate.ToString("yyyy-MM-dd")">
                                        <span asp-validation-for="BirthDate" class="text-danger" style="font-size:.75rem"></span>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="field-group">
                                        <label asp-for="PhoneNumber"><i class="fas fa-phone me-1"></i>رقم الهاتف</label>
                                        <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="مثال: 07XXXXXXXXX">
                                        <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size:.75rem"></span>
                                    </div>
                                </div>
                            </div>

                            @if (isTrainer)
                            {
                                <hr class="section-divider">
                                <div class="trainer-section mb-3">
                                    <div class="fw-bold mb-3" style="color:#1d4ed8;font-size:.9rem">
                                        <i class="fas fa-chalkboard-teacher me-2"></i>معلومات المدرّب
                                    </div>
                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <div class="field-group">
                                                <label asp-for="Specialty"><i class="fas fa-star me-1"></i>التخصص</label>
                                                <input asp-for="Specialty" class="form-control" placeholder="مثال: تطوير الويب">
                                                <span asp-validation-for="Specialty" class="text-danger" style="font-size:.75rem"></span>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="field-group">
                                                <label asp-for="YearsOfExperience"><i class="fas fa-briefcase me-1"></i>سنوات الخبرة</label>
                                                <input asp-for="YearsOfExperience" type="number" min="0" max="50" class="form-control" placeholder="0">
                                                <span asp-validation-for="YearsOfExperience" class="text-danger" style="font-size:.75rem"></span>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="field-group">
                                                <label asp-for="BusinessLink"><i class="fas fa-link me-1"></i>رابط العمل / LinkedIn</label>
                                                <input asp-for="BusinessLink" type="url" class="form-control" placeholder="https://...">
                                                <span asp-validation-for="BusinessLink" class="text-danger" style="font-size:.75rem"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="d-flex justify-content-end mt-3">
                                <button type="submit" class="save-btn">
                                    <i class="fas fa-save me-2"></i>حفظ التغييرات
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- ══ Account Info Card ══ -->
            <div class="profile-card" style="background:#f8fafc">
                <div class="fw-semibold mb-3" style="color:#475569;font-size:.88rem">
                    <i class="fas fa-info-circle me-2 text-primary"></i>معلومات الحساب
                </div>
                <div class="row g-2" style="font-size:.85rem;color:#64748b">
                    <div class="col-6 col-md-3">
                        <div style="font-size:.72rem;color:#94a3b8">البريد الإلكتروني</div>
                        <div class="fw-semibold" style="color:#334155;word-break:break-all">@Model.Email</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div style="font-size:.72rem;color:#94a3b8">الدور</div>
                        <div class="fw-semibold" style="color:#334155">@Model.Role</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="col-6 col-md-3">
                            <div style="font-size:.72rem;color:#94a3b8">رقم الهاتف</div>
                            <div class="fw-semibold" style="color:#334155">@Model.PhoneNumber</div>
                        </div>
                    }
                    @if (Model.BirthDate != default)
                    {
                        <div class="col-6 col-md-3">
                            <div style="font-size:.72rem;color:#94a3b8">تاريخ الميلاد</div>
                            <div class="fw-semibold" style="color:#334155">@Model.BirthDate.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </main>
</div>

<script>
(function () {
    var photoInput = document.getElementById('photoInput');
    var profileImg = document.getElementById('profileImg');
    var photoForm  = document.getElementById('photoForm');

    photoInput.addEventListener('change', function () {
        var file = this.files[0];
        if (!file) return;

        // Preview before upload
        var reader = new FileReader();
        reader.onload = function (e) { profileImg.src = e.target.result; };
        reader.readAsDataURL(file);

        // Auto-submit
        photoForm.submit();
    });
})();
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
