@model TrainingCenterManagement_MVC.ViewModels.CreateSalaryViewModel
@{
    ViewData["Title"] = "إضافة موظف للرواتب";
}

<style>
    .sc-card { background:#fff; border-radius:14px; box-shadow:0 4px 20px rgba(124,58,237,.09); border:1px solid #ede9fe; padding:32px; max-width:560px; margin:0 auto; }
    .sc-card h2 { font-size:1.3rem; font-weight:700; color:#1e1b4b; margin-bottom:24px; display:flex; align-items:center; gap:10px; }
    .sc-card h2 i { color:#7c3aed; }
    .sc-label { font-size:.85rem; font-weight:600; color:#374151; display:block; margin-bottom:5px; }
    .sc-control { border:1.5px solid #e2e8f0; border-radius:8px; padding:10px 14px; font-size:.92rem; width:100%; transition:border-color .2s; }
    .sc-control:focus { outline:none; border-color:#7c3aed; box-shadow:0 0 0 3px rgba(124,58,237,.1); }
    .sc-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .sc-btn { background:linear-gradient(135deg,#7c3aed,#6d28d9); color:#fff; border:none; border-radius:10px; padding:12px 28px; font-weight:700; font-size:.95rem; cursor:pointer; width:100%; margin-top:8px; transition:opacity .2s; }
    .sc-btn:hover { opacity:.9; }
    .sc-back { display:inline-flex; align-items:center; gap:6px; color:#64748b; text-decoration:none; font-size:.88rem; margin-bottom:24px; }
    .sc-back:hover { color:#7c3aed; }
</style>

<div class="dashboard-wrapper" style="display:flex;direction:rtl;min-height:100vh">
@await Html.PartialAsync("_AdminSidebar")
<main style="flex:1;padding:28px 32px;background:#faf5ff;overflow-x:hidden">

<a asp-action="Index" asp-controller="Salary" class="sc-back">
    <i class="fas fa-arrow-right"></i> العودة إلى قائمة الموظفين
</a>

<div class="sc-card">
    <h2><i class="fas fa-user-plus"></i> إضافة موظف لنظام الرواتب</h2>

    <div asp-validation-summary="All" class="alert alert-danger mb-3" style="display:none"></div>

    <form asp-action="Create" asp-controller="Salary" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="sc-label"><i class="fas fa-user me-1 text-muted"></i>الموظف</label>
            <select name="UserId" class="sc-control" required>
                <option value="">-- اختر موظفاً --</option>
                @foreach (var emp in (IEnumerable<dynamic>)ViewBag.Employees)
                {
                    <option value="@emp.Value">@emp.Text</option>
                }
            </select>
        </div>

        <div class="sc-row mb-3">
            <div>
                <label class="sc-label"><i class="fas fa-coins me-1 text-muted"></i>الراتب الشهري</label>
                <input type="number" name="MonthlySalary" class="sc-control" min="0" step="0.01" placeholder="0.00" required />
            </div>
            <div>
                <label class="sc-label"><i class="fas fa-money-bill me-1 text-muted"></i>العملة</label>
                <select name="Currency" class="sc-control">
                    <option value="1">ر.س (SAR)</option>
                    <option value="2">USD ($)</option>
                    <option value="3">EUR (€)</option>
                    <option value="4">ج.م (EGP)</option>
                </select>
            </div>
        </div>

        <div class="mb-4">
            <label class="sc-label"><i class="fas fa-sticky-note me-1 text-muted"></i>ملاحظات (اختياري)</label>
            <textarea name="Notes" class="sc-control" rows="2" placeholder="أي ملاحظات..."></textarea>
        </div>

        <button type="submit" class="sc-btn">
            <i class="fas fa-save me-2"></i>حفظ سجل الراتب
        </button>
    </form>
</div>

</main>
</div>
