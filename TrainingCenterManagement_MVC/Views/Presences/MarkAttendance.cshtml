@model TrainingCenterManagement_MVC.ViewModels.MarkAttendanceViewModel

@{
    ViewData["Title"] = "Mark Attendance";
}

<h2>Mark Attendance for: @Model.LectureTitle</h2>

<form asp-action="MarkAttendance" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="LectureId" />

    <table class="table">
        <thead>
            <tr>
                <th>Trainee</th>
                <th>Present?</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Trainees.Count; i++)
            {
                <tr>
                    <td>@Model.Trainees[i].FullName</td>
                    <td>
                        <input asp-for="Trainees[@i].IsPresent" class="form-check-input" />
                        <input type="hidden" asp-for="Trainees[@i].TraineeId" />
                        <input type="hidden" asp-for="Trainees[@i].FullName" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-success">Save Attendance</button>
</form>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}
