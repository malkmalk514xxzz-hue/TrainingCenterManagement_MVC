@model TrainingCenterManagement_MVC.Models.Presence

@{
    ViewData["Title"] = "Edit";
}

<h1 class="mb-4">Edit Presence</h1>

<h4 class="mb-3">Presence Details</h4>
<hr />

<div class="row">
    <div class="col-md-6 col-lg-4">
        <form asp-action="Edit" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input type="hidden" asp-for="PresenceId" />

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsPresent" id="IsPresent" />
                <label class="form-check-label" for="IsPresent">@Html.DisplayNameFor(model => model.IsPresent)</label>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsDeleted" id="IsDeleted" />
                <label class="form-check-label" for="IsDeleted">@Html.DisplayNameFor(model => model.IsDeleted)</label>
            </div>

            <div class="mb-3">
                <label asp-for="LectureId" class="form-label"></label>
                <select asp-for="LectureId" class="form-select" asp-items="ViewBag.LectureId"></select>
                <span asp-validation-for="LectureId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TraineeId" class="form-label"></label>
                <select asp-for="TraineeId" class="form-select" asp-items="ViewBag.TraineeId"></select>
                <span asp-validation-for="TraineeId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
