@model TrainingCenterManagement_MVC.Models.Presence

@{
    ViewData["Title"] = "Create";
}

<h1 class="mb-4">Create Presence</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-check mb-3">
                <input asp-for="IsPresent" class="form-check-input" id="IsPresent" />
                <label asp-for="IsPresent" class="form-check-label"></label>
                <span asp-validation-for="IsPresent" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsDeleted" class="form-check-input" id="IsDeleted" />
                <label asp-for="IsDeleted" class="form-check-label"></label>
                <span asp-validation-for="IsDeleted" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LectureId" class="form-label"></label>
                <select asp-for="LectureId" class="form-select" asp-items="ViewBag.LectureId">
                    <option value="">-- Select Lecture --</option>
                </select>
                <span asp-validation-for="LectureId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TraineeId" class="form-label"></label>
                <select asp-for="TraineeId" class="form-select" asp-items="ViewBag.TraineeId">
                    <option value="">-- Select Trainee --</option>
                </select>
                <span asp-validation-for="TraineeId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
