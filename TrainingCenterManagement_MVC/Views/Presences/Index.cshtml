@model IEnumerable<TrainingCenterManagement_MVC.Models.Presence>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.IsPresent)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsDeleted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lecture)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Trainee)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IsPresent)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDeleted)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lecture.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Trainee.UserId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PresenceId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.PresenceId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.PresenceId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
