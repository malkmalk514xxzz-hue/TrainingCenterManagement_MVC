@using TrainingCenterManagement_MVC.Resources
@using Newtonsoft.Json
@using TrainingCenterManagement_MVC.ViewModels
@model TrainerDashboardViewModel

@{
    ViewData["Title"] = SharedResource.TrainerDashboard_Title;
}

<!-- إضافة مكتبة FullCalendar -->
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
<!-- إضافة Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<!-- إضافة Syncfusion Grid -->
<script src="https://cdn.syncfusion.com/ej2/dist/ej2.min.js"></script>
<link href="https://cdn.syncfusion.com/ej2/material.css" rel="stylesheet" />
<!-- إضافة خط Roboto -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<!-- استدعاء ملف CSS المنفصل -->
<link href="~/css/TrainerDashboard.css" rel="stylesheet" />

<body>
    <div class="dashboard-wrapper">
        @await Html.PartialAsync("_TrainerSidebar")
        <main class="dashboard-main">
            <!-- النظرة العامة -->
            <div class="profile-section">
                <img src="@Model.ProfilePictureUrl" alt="@SharedResource.ProfilePicture" class="profile-picture" />
                <div>
                    <h2>@Model.FullName</h2>
                    <p>@SharedResource.Specialization: @Model.Specialization</p>
                    <p>@SharedResource.Availability: @Model.Availability</p>
                </div>
                <div class="overall-progress">@Model.OverallProgress%</div>
            </div>

            <!-- مؤشرات الأداء -->
            <div class="kpi-grid">
                <div class="stat-card">
                    <h4>@SharedResource.CurrentCourses</h4>
                    <div class="stat-value" id="courses-value">@Model.KPIs.CurrentCourses</div>
                </div>
                <div class="stat-card">
                    <h4>@SharedResource.EnrolledStudents</h4>
                    <div class="stat-value" id="students-value">@Model.KPIs.EnrolledStudents</div>
                </div>
                <div class="stat-card">
                    <h4>@SharedResource.AverageAttendance</h4>
                    <div class="stat-value">@Model.KPIs.AverageAttendance%</div>
                </div>
                <div class="stat-card">
                    <h4>UngradedAssignments</h4>
                    <div class="stat-value">@Model.KPIs.UngradedAssignments</div>
                </div>
                <div class="stat-card">
                    <h4>AverageRating</h4>
                    <div class="stat-value">@Model.KPIs.AverageRating</div>
                </div>
            </div>

            <!-- الإشعارات -->
            @* <div class="card">
                <h3>@SharedResource.Notifications</h3>
                <ul class="notification-list">
                    @foreach (var notif in Model.Notifications)
                    {
                        <li>@notif.Message - @notif.Time.ToString("MMM dd, yyyy HH:mm")</li>
                    }
                </ul>
            </div *@>

            <!-- التبويبات -->
            <div class="tabs">
                <button id="schedule-btn" class="tab-btn active" data-tab="schedule">@SharedResource.Schedule</button>
                <button id="students-btn" class="tab-btn" data-tab="students">@SharedResource.StudentManagement</button>
                <button id="attendance-btn" class="tab-btn" data-tab="attendance">@SharedResource.Attendance</button>
                <button id="analytics-btn" class="tab-btn" data-tab="analytics">@SharedResource.Analytics</button>
                <button id="courses-btn" class="tab-btn" data-tab="courses">@SharedResource.CurrentCourses</button>
                <button id="recommended-btn" class="tab-btn" data-tab="recommended">@SharedResource.RecommendedCourses</button>
                <button id="certificates-btn" class="tab-btn" data-tab="certificates">@SharedResource.Certificates</button>
            </div>

            <!-- محتوى التبويبات -->
            <div id="schedule" class="tab-content card active">
                <h3>@SharedResource.Schedule</h3>
                <div id="calendar"></div>
            </div>

            <div id="students" class="tab-content card">
                <h3>@SharedResource.StudentManagement</h3>
                @foreach (var course in Model.StudentsByCourse)
                {
                    <h4>@SharedResource.Course: @course.Value[0].CourseName</h4>
                    <table class="students-table">
                        <thead>
                            <tr>
                                <th>@SharedResource.StudentName</th>
                                <th>@SharedResource.Attendance</th>
                                <th>@SharedResource.Grade</th>
                                <th>@SharedResource.contact</th>
                                <th>@SharedResource.Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in course.Value)
                            {
                                <tr>
                                    <td>@student.Name</td>
                                    <td>@student.AttendanceStatus</td>
                                    <td>@student.Grade</td>
                                    <td>@student.Contact</td>
                                    <td>
                                        <button onclick="viewTraineeAttendance('@course.Key', '@student.Id')" class="btn btn-primary">@SharedResource.Attendance</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div id="attendance" class="tab-content card">
                <h3>@SharedResource.Attendance</h3>
                <div id="attendance-grid"></div>
                <div id="attendance-report" style="display: none;"></div>
            </div>

            <div id="analytics" class="tab-content card">
                <h3>@SharedResource.Analytics</h3>
                <canvas id="analytics-chart"></canvas>
            </div>

            <div id="courses" class="tab-content card">
                <h3>@SharedResource.CurrentCourses</h3>
                <ul>
                    @foreach (var course in Model.CurrentCourses)
                    {
                        <li>
                            @course.Name
                            <button onclick="manageCourse('@course.Id')" class="btn btn-primary">@SharedResource.Manage</button>
                        </li>
                    }
                </ul>
            </div>

            <div id="recommended" class="tab-content card">
                <h3>@SharedResource.RecommendedCourses</h3>
                <ul>
                    @foreach (var course in Model.RecommendedCourses)
                    {
                        <li>
                            @course.Name
                            <button onclick="assignCourse('@course.Id')" class="btn btn-primary">@SharedResource.Assign</button>
                        </li>
                    }
                </ul>
            </div>

            <div id="certificates" class="tab-content card">
                <h3>@SharedResource.Certificates</h3>
                <ul>
                    @foreach (var cert in Model.Certificates)
                    {
                        <li>
                            @cert.Name
                            <a asp-controller="Certificates" asp-action="CertificatePdf" asp-route-certificateId="@cert.Id" class="btn btn-danger btn-sm" title="@SharedResource.DownloadCertificatePDF">
                                <i class="bi bi-file-earmark-pdf"></i> @SharedResource.Download
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </main>
    </div>

    <script id="attendanceStatusTemplate" type="text/x-template">
        ${Present ? '@SharedResource.Present' : '@SharedResource.Absent'}
    </script>

    <script id="attendanceActionTemplate" type="text/x-template">
        <button onclick="viewTraineeAttendance('${CourseId}', '${StudentId}')" class="btn btn-primary">@SharedResource.Attendance</button>
    </script>

    <script>
        const translations = {
            present: '@Html.Raw(SharedResource.Present)',
            absent: '@Html.Raw(SharedResource.Absent)',
            viewAttendance: '@Html.Raw(SharedResource.Attendance)',
            noAttendanceData: '@Html.Raw(SharedResource.NoAttendanceData ?? "لا توجد بيانات حضور.")'
        };

        document.addEventListener('DOMContentLoaded', () => {
            let dashboardData;
            try {
                dashboardData = @Html.Raw(JsonConvert.SerializeObject(Model, new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore }));
                console.log('Dashboard Data:', dashboardData);
            } catch (error) {
                console.error('Error parsing dashboard data:', error);
                dashboardData = {};
            }

            // Initialize attendance grid
            function initializeAttendanceGrid() {
                let attendanceData = dashboardData.attendanceRecords || [];
                if (!Array.isArray(attendanceData) && attendanceData.$values) {
                    attendanceData = attendanceData.$values;
                }

                console.log('Attendance Data:', attendanceData);

                const flattenedData = [];
                attendanceData.forEach(record => {
                    if (record.students && record.students.$values) {
                        record.students = record.students.$values;
                    }
                    record.students.forEach(student => {
                        flattenedData.push({
                            LectureId: record.lectureId,
                            Date: new Date(record.date).toLocaleDateString(),
                            StudentId: student.studentId,
                            Present: student.present,
                            Notes: student.notes || '',
                            CourseId: record.courseId
                        });
                    });
                });

                console.log('Flattened Data:', flattenedData);

                if (flattenedData.length === 0) {
                    document.getElementById('attendance-grid').innerHTML = `<div class="alert alert-info">${translations.noAttendanceData}</div>`;
                    return;
                }

                flattenedData.forEach(record => {
                    record.PresentText = record.Present ? translations.present : translations.absent;
                });

                const grid = new ej.grids.Grid({
                    dataSource: flattenedData,
                    allowPaging: true,
                    allowSorting: true,
                    allowFiltering: true,
                    allowGrouping: true,
                    filterSettings: { type: 'Menu' },
                    pageSettings: { pageSize: 10 },
                    toolbar: ['Search'],
                    groupSettings: { showGroupedColumn: true },
                    columns: [
                        { field: 'LectureId', headerText: '@SharedResource.LectureId', width: 120 },
                        { field: 'Date', headerText: '@SharedResource.Date', width: 150 },
                        { field: 'StudentId', headerText: '@SharedResource.StudentId', width: 120 },
                        { field: 'PresentText', headerText: '@SharedResource.Attendance', width: 100, template: '#attendanceStatusTemplate' },
                        { field: 'Notes', headerText: '@SharedResource.Notes', width: 150 },
                        { headerText: '@SharedResource.Actions', width: 180, textAlign: 'Center', template: '#attendanceActionTemplate' }
                    ]
                });

                grid.appendTo('#attendance-grid');
            }

            // Initialize stats
            function updateStats(data) {
                document.getElementById('courses-value').textContent = data.currentCourses || 0;
                document.getElementById('students-value').textContent = data.enrolledStudents || 0;
            }

            // Initialize calendar
            const calendarEl = document.getElementById('calendar');
            if (calendarEl) {
                const calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    events: dashboardData.schedule || []
                });
                calendar.render();
            }

            // Tab switching
            const tabButtons = document.querySelectorAll('.tab-btn');
            const tabContents = document.querySelectorAll('.tab-content');
            tabButtons.forEach(button => {
                button.addEventListener('click', () => {
                    tabButtons.forEach(btn => btn.classList.remove('active'));
                    tabContents.forEach(content => content.classList.remove('active'));
                    button.classList.add('active');
                    const tabId = button.getAttribute('data-tab');
                    document.getElementById(tabId).classList.add('active');
                    if (tabId === 'attendance') {
                        initializeAttendanceGrid();
                    } else if (tabId === 'analytics') {
                        renderChart();
                    }
                });
            });

            // Initialize initial data
            if (dashboardData && dashboardData.kpis) {
                updateStats(dashboardData.kpis);
            }
            if (document.getElementById('attendance').classList.contains('active')) {
                initializeAttendanceGrid();
            }

            async function viewTraineeAttendance(courseId, traineeId) {
                console.log(`جلب تقرير حضور المتدرب ${traineeId} في الدورة ${courseId}`);
                const reportDiv = document.getElementById('attendance-report');
                const loader = document.createElement('div');
                loader.className = 'loader';
                reportDiv.innerHTML = '';
                reportDiv.appendChild(loader);
                reportDiv.style.display = 'block';

                try {
                    console.log(`/Presences/TraineeAttendanceInCourse/${traineeId}/${courseId}`);
                    const response = await fetch(`/Presences/TraineeAttendanceInCourse/${traineeId}/${courseId}`);

                    if (!response.ok) {
                        console.error(`فشل جلب تقرير الحضور: ${response.status} ${response.statusText}`);
                        if (response.status === 404) {
                            alert('@SharedResource.Error_CourseOrTraineeNotFound');
                        } else if (response.status === 401 || response.status === 403) {
                            alert('@SharedResource.Error_Unauthorized');
                        } else {
                            alert(`@SharedResource.Error_FetchingAttendance: ${response.statusText}`);
                        }
                        reportDiv.style.display = 'none';
                        return;
                    }

                    const data = await response.json();
                    console.log('البيانات المستلمة:', data);
                    reportDiv.innerHTML = `
                        <h4>@SharedResource.AttendanceReport</h4>
                        <p><strong>@SharedResource.Trainee:</strong> ${data.traineeName}</p>
                        <p><strong>@SharedResource.Course:</strong> ${data.courseName}</p>
                        <p><strong>@SharedResource.AttendedLectures:</strong> ${data.attended}</p>
                        <p><strong>@SharedResource.TotalLectures:</strong> ${data.totalLectures}</p>
                        <p><strong>@SharedResource.AttendancePercentage:</strong> ${data.percentage}%</p>
                    `;
                } catch (error) {
                    console.error('خطأ في جلب تقرير الحضور:', error);
                    alert('@SharedResource.Error_FetchingAttendance');
                    reportDiv.style.display = 'none';
                }
            }

            function manageCourse(id) {
                console.log(`إدارة الدورة ${id}`);
                window.location.href = `/Courses/Details/${id}`;
            }

            function assignCourse(id) {
                console.log(`تعيين الدورة ${id}`);
                window.location.href = `/Courses/Assign/${id}`;
            }

            function renderChart() {
                const ctx = document.getElementById('analytics-chart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: dashboardData.chartData?.labels || ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                        datasets: [{
                            label: '@SharedResource.Progress',
                            data: dashboardData.chartData?.values || [0, 0, 0, 0],
                            borderColor: '#007bff',
                            backgroundColor: 'rgba(0, 123, 255, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true } },
                        plugins: { legend: { display: true, position: 'top' } }
                    }
                });
            }
        });
    </script>
</body>