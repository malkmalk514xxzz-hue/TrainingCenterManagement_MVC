@using TrainingCenterManagement_MVC.Resources
@using Newtonsoft.Json
@using TrainingCenterManagement_MVC.ViewModels
@model TrainingCenterManagement_MVC.ViewModels.TraineeDashboardViewModel

@{
    ViewData["Title"] = SharedResource.TraineeDashboard_Title;
}

<link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="~/css/TraineeDashboard.css" rel="stylesheet" />

<body>
    <div class="dashboard-wrapper">
        @await Html.PartialAsync("_TraineeSidebar")
        <main class="dashboard-main">
            <!-- النظرة العامة -->
            <div class="profile-section">
                <img src="@Model.ProfilePictureUrl" alt="@SharedResource.ProfilePicture" class="profile-picture" />
                <div>
                    <h2>@Model.FullName</h2>
                    <p>@Model.WelcomeMessage</p>
                </div>
                <div class="overall-progress">@Model.OverallProgress%</div>
            </div>

            @* <!-- إحصائيات المتدرب -->
            <div class="kpi-grid">
                <div class="stat-card">
                    <h4>@SharedResource.EnrolledCourses</h4>
                    <div class="stat-value">@Model.Stats.EnrolledCourses</div>
                </div>
                <div class="stat-card">
                    <h4>@SharedResource.CompletedHours</h4>
                    <div class="stat-value">@Model.Stats.CompletedHours</div>
                </div>
                <div class="stat-card">
                    <h4>@SharedResource.CompletedExams</h4>
                    <div class="stat-value">@Model.Stats.CompletedExams</div>
                </div>
                <div class="stat-card">
                    <h4>@SharedResource.AttendanceRate</h4>
                    <div class="stat-value">@Model.Stats.AttendanceRate%</div>
                </div>
            </div> *@

            <!-- المناسبات القادمة -->
            <div class="card">
                <h3>@SharedResource.UpcomingEvents</h3>
                <ul>
                    @foreach (var ev in Model.UpcomingEvents)
                    {
                        <li>
                            <strong>@ev.Title</strong> - @ev.Date
                            @if (!string.IsNullOrWhiteSpace(ev.Link))
                            {
                                @* <a href="@ev.Link" target="_blank" class="btn btn-primary btn-sm">@SharedResource.View</a> *@
                            }
                        </li>
                    }
                </ul>
            </div>

            <!-- الرسم البياني -->
            <div class="card">
                <h3>@SharedResource.Analytics</h3>
                <canvas id="analytics-chart"></canvas>
            </div>

            <!-- الدورات الحالية -->
            <div class="card">
                <h3>@SharedResource.CurrentCourses</h3>
                <ul>
                    @foreach (var course in Model.CurrentCourses)
                    {
                        <li>
                            @course.Name - @course.Progress%
                            <span class="text-muted">(@SharedResource.Remaining: @course.Remaining)</span>
                        </li>
                    }
                </ul>
            </div>

            <!-- الدورات المقترحة -->
            <div class="card">
                <h3>@SharedResource.RecommendedCourses</h3>
                <ul>
                    @foreach (var course in Model.RecommendedCourses)
                    {
                        <li>
                            <strong>@course.Name</strong>: @course.Description
                            <button onclick="assignCourse('@course.Id')" class="btn btn-primary btn-sm">@SharedResource.Assign</button>
                        </li>
                    }
                </ul>
            </div>

            <!-- الشهادات -->
            <div class="card">
                <h3>@SharedResource.Certificates</h3>
                <ul>
                    @foreach (var cert in Model.Certificates)
                    {
                        <li>
                            @cert.Name
                            <a asp-controller="Certificates" asp-action="CertificatePdf" asp-route-certificateId="@cert.Id" class="btn btn-danger btn-sm" title="@SharedResource.DownloadCertificatePDF">
                                <i class="bi bi-file-earmark-pdf"></i> @SharedResource.Download
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const chartData = @Html.Raw(JsonConvert.SerializeObject(Model.ChartData?.Analytics ?? new object(), new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore }));

            const ctx = document.getElementById('analytics-chart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.labels || ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                    datasets: [{
                        label: '@SharedResource.Progress',
                        data: chartData.values || [0, 0, 0, 0],
                        borderColor: '#007bff',
                        backgroundColor: 'rgba(0, 123, 255, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true } },
                    plugins: { legend: { display: true, position: 'top' } }
                }
            });

            function assignCourse(id) {
                window.location.href = `/Courses/Assign/${id}`;
            }
        });
    </script>
</body>
