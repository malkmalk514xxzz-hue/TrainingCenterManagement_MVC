@{
    Layout = "_Dashboard";
    ViewBag.Title = "وصول مرفوض";
}

<style>
    .access-denied-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        direction: rtl;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
        padding: 40px 20px;
    }
    .access-denied-icon {
        width: 90px; height: 90px;
        background: #fee2e2;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.5rem;
        color: #dc2626;
        margin-bottom: 24px;
    }
    .access-denied-wrapper h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 10px;
    }
    .access-denied-wrapper p {
        font-size: 1rem;
        color: #64748b;
        margin: 0 0 28px;
        max-width: 400px;
    }
    .access-denied-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 24px;
        background: #1d4ed8;
        color: #fff;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: .95rem;
        transition: background .2s;
    }
    .access-denied-btn:hover { background: #1e40af; color: #fff; }
</style>

<div class="access-denied-wrapper">
    <div class="access-denied-icon">
        <i class="fas fa-lock"></i>
    </div>
    <h1>وصول مرفوض</h1>
    <p>ليس لديك صلاحية للوصول إلى هذه الصفحة. تواصل مع المسؤول إذا كنت تعتقد أن هذا خطأ.</p>
    <a href="/" class="access-denied-btn">
        <i class="fas fa-home"></i> العودة إلى الرئيسية
    </a>
</div>
