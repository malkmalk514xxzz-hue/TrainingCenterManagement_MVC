@model TrainingCenterManagement_MVC.Models.Lecture
@{
    ViewData["Title"] = "تعديل المحاضرة";
}

<link href="~/css/TrainerDashboard.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    :root {
        --primary: #4f46e5; --primary-light: #6366f1; --primary-pale: #eef2ff;
        --success: #10b981; --danger: #ef4444; --warning: #f59e0b;
        --body-bg: #f1f5f9; --card-bg: #ffffff;
        --text-1: #0f172a; --text-2: #475569; --text-3: #94a3b8;
        --border-color: #e2e8f0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
        --shadow-md: 0 4px 16px rgba(0,0,0,.08);
        --radius: 14px; --radius-sm: 8px;
    }

    .lc-page { padding: 28px 32px; }

    .lc-breadcrumb {
        display: flex; align-items: center; gap: 8px;
        font-size: .85rem; color: var(--text-3); margin-bottom: 20px;
    }
    .lc-breadcrumb a { color: var(--text-2); text-decoration: none; transition: color .2s; }
    .lc-breadcrumb a:hover { color: var(--primary); }
    .lc-breadcrumb i { font-size: .7rem; }

    .lc-page-header { margin-bottom: 28px; }
    .lc-page-header h1 {
        font-size: 1.6rem; font-weight: 700; color: var(--text-1);
        display: flex; align-items: center; gap: 10px; margin: 0 0 4px;
    }
    .lc-page-header h1 .icon-badge {
        width: 40px; height: 40px; border-radius: 10px;
        background: #fef3c7; color: #d97706;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
    }
    .lc-page-header p { color: var(--text-2); font-size: .9rem; margin: 0; }

    .lc-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-color);
        overflow: hidden;
        max-width: 720px;
    }

    .lc-card-header {
        padding: 20px 28px;
        border-bottom: 1px solid var(--border-color);
        background: linear-gradient(135deg, #fef9ec 0%, #ffffff 100%);
        display: flex; align-items: center; gap: 12px;
    }
    .lc-card-header i { color: #d97706; font-size: 1.1rem; }
    .lc-card-header h2 { font-size: 1rem; font-weight: 600; color: var(--text-1); margin: 0; }
    .lc-card-header .lc-id-badge {
        margin-right: auto; background: var(--body-bg);
        padding: 3px 10px; border-radius: 20px;
        font-size: .75rem; color: var(--text-3); font-family: monospace;
    }

    .lc-form-body { padding: 28px; display: flex; flex-direction: column; gap: 20px; }

    .lc-field label {
        display: block; font-size: .85rem; font-weight: 600;
        color: var(--text-2); margin-bottom: 6px;
    }
    .lc-field label span.req { color: var(--danger); margin-right: 2px; }

    .lc-input, .lc-textarea, .lc-select {
        width: 100%; padding: 10px 14px;
        border: 1.5px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: .92rem; color: var(--text-1);
        background: #fff; transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box; font-family: inherit;
    }
    .lc-input:focus, .lc-textarea:focus, .lc-select:focus {
        outline: none; border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(79,70,229,.1);
    }
    .lc-textarea { resize: vertical; min-height: 100px; }
    .lc-input::placeholder, .lc-textarea::placeholder { color: var(--text-3); }

    .lc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @@media (max-width: 600px) { .lc-row { grid-template-columns: 1fr; } }

    .lc-hint { font-size: .78rem; color: var(--text-3); margin-top: 4px; }
    .lc-error { color: var(--danger); font-size: .8rem; margin-top: 4px; }

    .lc-divider { border: none; border-top: 1px dashed var(--border-color); margin: 4px 0; }
    .lc-section-label {
        font-size: .75rem; font-weight: 700; color: var(--primary);
        text-transform: uppercase; letter-spacing: .05em;
        display: flex; align-items: center; gap: 6px; margin-bottom: 12px;
    }

    .lc-actions {
        padding: 20px 28px;
        border-top: 1px solid var(--border-color);
        display: flex; gap: 10px; justify-content: flex-end;
        background: #fafbff;
    }
    .lc-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        font-size: .9rem; font-weight: 600; cursor: pointer;
        text-decoration: none; border: none; transition: all .2s;
    }
    .lc-btn-warning { background: #d97706; color: #fff; }
    .lc-btn-warning:hover { background: #b45309; color: #fff; transform: translateY(-1px); }
    .lc-btn-ghost {
        background: transparent; color: var(--text-2);
        border: 1.5px solid var(--border-color);
    }
    .lc-btn-ghost:hover { background: var(--body-bg); color: var(--text-1); }
    .lc-btn-resources {
        background: var(--primary-pale); color: var(--primary);
        border: 1.5px solid var(--primary);
    }
    .lc-btn-resources:hover { background: var(--primary); color: #fff; }

    /* Select2 override */
    .select2-container--default .select2-selection--single {
        height: 42px !important; border: 1.5px solid var(--border-color) !important;
        border-radius: var(--radius-sm) !important; padding: 4px 10px !important;
    }
    .select2-container--default .select2-selection--single .select2-selection__arrow { height: 42px !important; }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 32px !important; color: var(--text-1) !important; font-size: .92rem !important;
    }
    .select2-container--default.select2-container--focus .select2-selection--single {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 3px rgba(79,70,229,.1) !important;
    }
</style>

<div class="dashboard-wrapper">
    @await Html.PartialAsync("_TrainerSidebar")

    <main class="dashboard-main">
        <div class="lc-page">

            <!-- Breadcrumb -->
            <nav class="lc-breadcrumb">
                <a asp-controller="Dashboard" asp-action="TrainerDashboard">لوحة التحكم</a>
                <i class="fas fa-chevron-left"></i>
                <a asp-action="Index">المحاضرات</a>
                <i class="fas fa-chevron-left"></i>
                <span>تعديل: @Model.Title</span>
            </nav>

            <!-- Page Header -->
            <div class="lc-page-header">
                <h1>
                    <span class="icon-badge"><i class="fas fa-edit"></i></span>
                    تعديل المحاضرة
                </h1>
                <p>قم بتحديث بيانات المحاضرة — سيتم حفظ التغييرات فوراً</p>
            </div>

            <!-- Form Card -->
            <div class="lc-card">
                <div class="lc-card-header">
                    <i class="fas fa-pen-to-square"></i>
                    <h2>تعديل بيانات المحاضرة</h2>
                    <span class="lc-id-badge">ID: @Model.LectureId.ToString()[..8]...</span>
                </div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="LectureId" />
                    <div asp-validation-summary="ModelOnly" class="lc-error" style="padding: 12px 28px;"></div>

                    <div class="lc-form-body">

                        <p class="lc-section-label"><i class="fas fa-info-circle"></i> المعلومات الأساسية</p>

                        <!-- Title -->
                        <div class="lc-field">
                            <label asp-for="Title">عنوان المحاضرة <span class="req">*</span></label>
                            <input asp-for="Title" class="lc-input" placeholder="مثال: مقدمة في البرمجة الكائنية" />
                            <span asp-validation-for="Title" class="lc-error"></span>
                        </div>

                        <!-- Description -->
                        <div class="lc-field">
                            <label asp-for="Description">وصف المحاضرة</label>
                            <textarea asp-for="Description" class="lc-textarea" placeholder="اكتب وصفاً موجزاً لمحتوى المحاضرة..."></textarea>
                            <span asp-validation-for="Description" class="lc-error"></span>
                        </div>

                        <hr class="lc-divider" />
                        <p class="lc-section-label"><i class="fas fa-video"></i> محتوى الفيديو</p>

                        <div class="lc-row">
                            <!-- Video URL -->
                            <div class="lc-field">
                                <label asp-for="VideoUrl">رابط YouTube</label>
                                <input asp-for="VideoUrl" class="lc-input" placeholder="https://youtube.com/watch?v=..." />
                                <p class="lc-hint"><i class="fab fa-youtube" style="color:#ef4444;"></i> رابط YouTube الكامل أو المختصر</p>
                                <span asp-validation-for="VideoUrl" class="lc-error"></span>
                            </div>
                            <!-- Thumbnail -->
                            <div class="lc-field">
                                <label asp-for="ThumbnailUrl">رابط الصورة المصغرة</label>
                                <input asp-for="ThumbnailUrl" class="lc-input" placeholder="https://..." />
                                <p class="lc-hint">اتركه فارغاً لاستخدام صورة YouTube تلقائياً</p>
                                <span asp-validation-for="ThumbnailUrl" class="lc-error"></span>
                            </div>
                        </div>

                        <hr class="lc-divider" />
                        <p class="lc-section-label"><i class="fas fa-calendar-alt"></i> الجدولة والدورة</p>

                        <div class="lc-row">
                            <!-- Date -->
                            <div class="lc-field">
                                <label asp-for="LectureDate">تاريخ المحاضرة <span class="req">*</span></label>
                                <input asp-for="LectureDate" type="datetime-local" class="lc-input" />
                                <span asp-validation-for="LectureDate" class="lc-error"></span>
                            </div>
                            <!-- Course -->
                            <div class="lc-field">
                                <label asp-for="CourseId">الدورة التدريبية <span class="req">*</span></label>
                                <select asp-for="CourseId" class="lc-select select2" asp-items="ViewBag.CourseId">
                                    <option value="">-- اختر الدورة --</option>
                                </select>
                                <span asp-validation-for="CourseId" class="lc-error"></span>
                            </div>
                        </div>

                    </div>

                    <!-- Actions -->
                    <div class="lc-actions">
                        <a asp-action="Index" class="lc-btn lc-btn-ghost">
                            <i class="fas fa-arrow-right"></i> رجوع
                        </a>
                        <a asp-controller="LectureResources" asp-action="Manage" asp-route-lectureId="@Model.LectureId" class="lc-btn lc-btn-resources">
                            <i class="fas fa-folder-open"></i> إدارة الموارد
                        </a>
                        <button type="submit" class="lc-btn lc-btn-warning">
                            <i class="fas fa-save"></i> حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </main>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2').select2({ placeholder: "-- اختر الدورة --", allowClear: true, width: '100%' });
        });
    </script>
}
