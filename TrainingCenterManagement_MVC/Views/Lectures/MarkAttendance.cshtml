@model List<TrainingCenterManagement_MVC.ViewModels.AttendanceViewModel>

@{
    ViewData["Title"] = "Mark Attendance";
}

<h2>Mark Attendance - @ViewBag.LectureTitle</h2>

<form asp-action="MarkAttendance" method="post">
    <input type="hidden" name="lectureId" value="@ViewBag.LectureId" />

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Full Name</th>
                <th>Is Present?</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>
                        @Model[i].FullName
                        <input type="hidden" asp-for="@Model[i].FullName" />
                        <input type="hidden" asp-for="@Model[i].TraineeId" />
                    </td>
                    <td class="text-center">
                        <input asp-for="@Model[i].IsPresent" class="form-check-input" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Save Attendance</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
