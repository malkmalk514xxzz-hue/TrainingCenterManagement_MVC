@model TrainingCenterManagement_MVC.Models.Lecture

@{
    ViewData["Title"] = "Lecture Details";

    string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        try
        {
            var uri = new Uri(url);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var videoId))
            {
                return videoId;
            }

            if (uri.Host.Contains("youtu.be"))
            {
                return uri.AbsolutePath.Trim('/');
            }
        }
        catch { }

        return "";
    }

    var videoId = GetYoutubeVideoId(Model.VideoUrl);
}

<!DOCTYPE html>
<html>
<head>
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="" />
    <link rel="stylesheet"
          as="style"
          onload="this.rel='stylesheet'"
          href="https://fonts.googleapis.com/css2?display=swap&family=Inter%3Awght%40400%3B500%3B700%3B900&family=Noto+Sans%3Awght%40400%3B500%3B700%3B900" />
    <title>Lecture Details</title>
    <link rel="icon" type="image/x-icon" href="data:image/x-icon;base64," />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <style>
        .layout-container {
            display: flex;
            height: 100%;
            flex-grow: 1;
            flex-direction: column;
        }

        .main-content {
            padding-left: 10rem;
            padding-right: 10rem;
            display: flex;
            flex-grow: 1;
            justify-content: center;
            padding-top: 1.25rem;
            padding-bottom: 1.25rem;
        }

        .content-container {
            display: flex;
            flex-direction: column;
            max-width: 960px;
            flex-grow: 1;
        }

        .section-title-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 1rem;
        }

        .section-title {
            display: flex;
            min-width: 18rem;
            flex-direction: column;
            gap: 0.75rem;
        }

        .title-text {
            color: #111418;
            letter-spacing: -0.015em;
            font-size: 2rem;
            font-weight: 700;
            line-height: 1.25;
        }

        .subtitle-text {
            color: #60758a;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .details-grid {
            padding: 1rem;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .details-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            border-top: 1px solid #dbe0e6;
        }

        .details-label {
            color: #60758a;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .details-value {
            color: #111418;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .video-container {
            padding: 1rem;
        }

        .video-player {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #111418;
            background-size: cover;
            background-position: center;
            aspect-ratio: 16 / 9;
            border-radius: 0.5rem;
            padding: 1rem;
        }

        .video-iframe {
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 0.5rem;
        }

        .button-group {
            display: flex;
            justify-content: stretch;
        }

        .buttons-container {
            display: flex;
            flex-grow: 1;
            gap: 0.75rem;
            flex-wrap: wrap;
            padding: 1rem;
            justify-content: flex-start;
        }

        .primary-button, .secondary-button, .link-button {
            display: flex;
            min-width: 84px;
            max-width: 480px;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: 0.5rem;
            height: 2.5rem;
            padding: 0 1rem;
            font-size: 0.875rem;
            font-weight: 700;
            line-height: 1.5;
            letter-spacing: 0.015em;
            border: none;
            text-decoration: none;
        }

        .primary-button {
            background-color: #0d80f2;
            color: #ffffff;
        }

        .secondary-button {
            background-color: #f0f2f5;
            color: #111418;
        }

        .link-button {
            background-color: transparent;
            color: #111418;
            font-weight: 700;
        }

        .truncate {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    </style>
</head>

<body>
    <div class="relative flex size-full min-h-screen flex-col bg-white overflow-x-hidden">
        @* Add your header partial view here if you have one *@
        @* @Html.Partial("_LandingHeader") *@
        @Html.Partial("_LandingHeader")
        <main class="main-content">
            <div class="content-container">
                <div class="section-title-container">
                    <div class="section-title">
                        <p class="title-text">Lecture Details</p>
                        <p class="subtitle-text">Lecture Information</p>
                    </div>
                </div>

                <div class="details-grid">
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Title)</p>
                        <p class="details-value">@Model.Title</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Course)</p>
                        <p class="details-value">@Model.Course.CourseName</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.LectureDate)</p>
                        <p class="details-value">@Model.LectureDate.ToString("MMMM dd, yyyy")</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Description)</p>
                        <p class="details-value">@Model.Description</p>
                    </div>
                    
                </div>

                <!-- Video Section -->
                @if (Model.Videos != null && Model.Videos.Any())
                {
                    <div class="video-container">
                        @foreach (var video in Model.Videos)
                        {
                            <div style="margin-bottom:1.5rem;">
                                <p style="font-weight:600;color:#111418;margin-bottom:0.5rem;">@video.VideoTitle</p>
                                @if (!string.IsNullOrEmpty(video.Description))
                                {
                                    <p style="color:#60758a;font-size:0.875rem;margin-bottom:0.5rem;">@video.Description</p>
                                }
                                @if (video.VideoSourceType == TrainingCenterManagement_MVC.Models.VideoSourceType.YouTube)
                                {
                                    <div class="video-player">
                                        <iframe class="video-iframe"
                                                src="@video.VideoUrl"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                allowfullscreen
                                                data-video-id="@video.VideoId">
                                        </iframe>
                                    </div>
                                }
                                else
                                {
                                    <div class="video-player">
                                        <video class="video-iframe" controls
                                               data-video-id="@video.VideoId"
                                               preload="metadata">
                                            <source src="@video.VideoUrl" type="video/mp4">
                                            <source src="@video.VideoUrl" type="video/webm">
                                            متصفحك لا يدعم تشغيل الفيديو.
                                        </video>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="video-container" style="text-align:center;color:#60758a;padding:2rem 1rem;">
                        <p>لا توجد فيديوهات لهذه المحاضرة بعد.</p>
                    </div>
                }

                <!-- Materials Section (legacy) -->
                @if (Model.Materials != null && Model.Materials.Any())
                {
                    <div style="padding:1rem;">
                        <p style="font-weight:700;font-size:1rem;color:#111418;margin-bottom:0.75rem;">
                            <i class="fas fa-folder-open" style="margin-left:0.4rem;color:#60758a;"></i>
                            مواد المحاضرة
                        </p>
                        <div style="display:flex;flex-direction:column;gap:0.5rem;">
                            @foreach (var mat in Model.Materials)
                            {
                                var ext2 = System.IO.Path.GetExtension(mat.FileName).ToLowerInvariant();
                                var iconColor = ext2 == ".pdf" ? "#dc2626" : ext2 is ".docx" or ".doc" ? "#2563eb" : ext2 is ".pptx" or ".ppt" ? "#d97706" : "#16a34a";
                                <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0.75rem;background:#f8f9fa;border-radius:8px;">
                                    <i class="fas fa-file" style="color:@iconColor;font-size:1.25rem;flex-shrink:0;"></i>
                                    <span style="flex-grow:1;font-size:14px;color:#111418;font-weight:500;">@mat.Title</span>
                                    <span style="font-size:12px;color:#60758a;">@((mat.FileSizeInBytes/1024.0).ToString("F0")) KB</span>
                                    <a asp-controller="LectureMaterials" asp-action="Download" asp-route-materialId="@mat.MaterialId"
                                       style="background:#e2e8f0;color:#111418;padding:0.3rem 0.75rem;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;">
                                        تحميل
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Lecture Resources Section (new system) -->
                @if (Model.Resources != null && Model.Resources.Any(r => r.IsVisible))
                {
                    <div style="padding:1rem;">
                        <p style="font-weight:700;font-size:1rem;color:#111418;margin-bottom:0.75rem;">
                            <i class="fas fa-paperclip" style="margin-left:0.4rem;color:#3b82f6;"></i>
                            الملفات الداعمة
                        </p>
                        @{
                            string ResTypeLabel(TrainingCenterManagement_MVC.Models.ResourceType t) => t switch
                            {
                                TrainingCenterManagement_MVC.Models.ResourceType.LectureSlides => "شرائح المحاضرة",
                                TrainingCenterManagement_MVC.Models.ResourceType.Notes         => "ملاحظات",
                                TrainingCenterManagement_MVC.Models.ResourceType.Assignment    => "واجب",
                                TrainingCenterManagement_MVC.Models.ResourceType.Solution      => "الحل",
                                TrainingCenterManagement_MVC.Models.ResourceType.ProjectFiles  => "ملفات المشروع",
                                TrainingCenterManagement_MVC.Models.ResourceType.Reference     => "مراجع إضافية",
                                TrainingCenterManagement_MVC.Models.ResourceType.Code          => "أكواد",
                                _                                                              => "ملفات أخرى"
                            };

                            string ExtIconColor(string ext) => ext switch
                            {
                                ".pdf"           => "#dc2626",
                                ".docx" or ".doc" => "#2563eb",
                                ".pptx" or ".ppt" => "#d97706",
                                ".xlsx" or ".xls" => "#16a34a",
                                ".zip" or ".rar"  => "#7c3aed",
                                _                => "#64748b"
                            };
                        }
                        <div style="display:flex;flex-direction:column;gap:0.5rem;">
                            @foreach (var res in Model.Resources.Where(r => r.IsVisible).OrderBy(r => r.DisplayOrder))
                            {
                                var resExt = res.FileExtension;
                                var resColor = ExtIconColor(resExt);
                                var typeLbl = ResTypeLabel(res.ResourceType);
                                <div style="display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.9rem;background:#f0f7ff;border:1.5px solid #bfdbfe;border-radius:9px;">
                                    <i class="fas fa-file" style="color:@resColor;font-size:1.25rem;flex-shrink:0;"></i>
                                    <div style="flex-grow:1;min-width:0;">
                                        <div style="font-size:14px;color:#111418;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@res.FileName</div>
                                        @if (!string.IsNullOrEmpty(res.Description))
                                        {
                                            <div style="font-size:12px;color:#60758a;">@res.Description</div>
                                        }
                                    </div>
                                    <span style="font-size:11px;background:#dbeafe;color:#1d4ed8;padding:2px 8px;border-radius:10px;font-weight:700;white-space:nowrap;">@typeLbl</span>
                                    <span style="font-size:12px;color:#60758a;white-space:nowrap;">
                                        <i class="fas fa-download fa-xs"></i> @res.DownloadCount
                                    </span>
                                    @if (User.IsInRole("Trainee"))
                                    {
                                        <a asp-controller="LectureResources" asp-action="Download" asp-route-resourceId="@res.ResourceId"
                                           style="background:#3b82f6;color:#fff;padding:0.3rem 0.8rem;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;white-space:nowrap;">
                                            <i class="fas fa-download me-1"></i>تحميل
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="LectureResources" asp-action="AdminDownload" asp-route-resourceId="@res.ResourceId"
                                           style="background:#e0f2fe;color:#0369a1;padding:0.3rem 0.8rem;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;white-space:nowrap;">
                                            <i class="fas fa-download me-1"></i>تحميل
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="button-group">
                    <div class="buttons-container">
                        <a asp-action="Edit" asp-route-id="@Model.LectureId" class="secondary-button">
                            <span class="truncate">Edit</span>
                        </a>
                        @if (User.IsInRole("Trainer") || User.IsInRole("Admin"))
                        {
                            <a asp-controller="LectureVideos" asp-action="Manage" asp-route-lectureId="@Model.LectureId" class="secondary-button">
                                <span class="truncate">إدارة الفيديوهات</span>
                            </a>
                            <a asp-controller="LectureMaterials" asp-action="Manage" asp-route-lectureId="@Model.LectureId" class="secondary-button">
                                <span class="truncate">إدارة المواد</span>
                            </a>
                            <a asp-controller="LectureResources" asp-action="Manage" asp-route-lectureId="@Model.LectureId" class="secondary-button">
                                <span class="truncate">إدارة الموارد</span>
                            </a>
                        }
                        <a asp-action="ViewLecture" asp-route-id="@Model.LectureId" class="primary-button">
                            <span class="truncate">View Lecture</span>
                        </a>
                        <a asp-action="Index" class="link-button">
                            <span class="truncate">Back to List</span>
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>