<h1>Lecture Details</h1>

<div>
    <h4>Lecture Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Video</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(videoId))
            {
                <div class="embed-responsive embed-responsive-16by9" style="max-width: 560px;">
                    <iframe id="lectureVideo"
                            class="embed-responsive-item"
                            src="https://www.youtube.com/embed/@videoId?enablejsapi=1"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                            style="width: 100%; height: 315px; border: none;">
                    </iframe>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.VideoUrl))
            {
                <video id="lectureVideo" width="560" height="315" controls>
                    <source src="@Model.VideoUrl" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            }
            else
            {
                <span class="text-muted">No video URL provided</span>
            }
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ThumbnailUrl)</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
            {
                <img src="@Model.ThumbnailUrl" alt="Thumbnail" class="img-thumbnail" style="max-width: 150px;" />
            }
            else
            {
                <span class="text-muted">No thumbnail available</span>
            }
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.LectureDate)</dt>
        <dd class="col-sm-9">@Model.LectureDate.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsDeleted)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.IsDeleted)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Course)</dt>
        <dd class="col-sm-9">@Model.Course.CourseName</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.LectureId" class="btn btn-outline-primary">Edit</a>
    <a asp-action="UploadVideo" asp-route-id="@Model.LectureId" class="btn btn-outline-secondary">Upload Video</a>
    <a asp-action="ViewLecture" asp-route-id="@Model.LectureId" class="btn btn-outline-info">View Lecture</a>
    <a asp-controller="Presences" asp-action="LectureAttendance" asp-route-lectureId="@Model.LectureId" class="btn btn-primary ms-2">عرض سجل الحضور</a>
    <a asp-action="Index" class="btn btn-link ms-2">Back to List</a>
</div>
 *@

@model TrainingCenterManagement_MVC.Models.Lecture

@{
    ViewData["Title"] = "Lecture Details";

    string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        try
        {
            var uri = new Uri(url);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var videoId))
            {
                return videoId;
            }

            if (uri.Host.Contains("youtu.be"))
            {
                return uri.AbsolutePath.Trim('/');
            }
        }
        catch { }

        return "";
    }

    var videoId = GetYoutubeVideoId(Model.VideoUrl);
}

<!DOCTYPE html>
<html>
<head>
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="" />
    <link rel="stylesheet"
          as="style"
          onload="this.rel='stylesheet'"
          href="https://fonts.googleapis.com/css2?display=swap&family=Inter%3Awght%40400%3B500%3B700%3B900&family=Noto+Sans%3Awght%40400%3B500%3B700%3B900" />
    <title>Lecture Details</title>
    <link rel="icon" type="image/x-icon" href="data:image/x-icon;base64," />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <style>
        .layout-container {
            display: flex;
            height: 100%;
            flex-grow: 1;
            flex-direction: column;
        }

        .main-content {
            padding-left: 10rem;
            padding-right: 10rem;
            display: flex;
            flex-grow: 1;
            justify-content: center;
            padding-top: 1.25rem;
            padding-bottom: 1.25rem;
        }

        .content-container {
            display: flex;
            flex-direction: column;
            max-width: 960px;
            flex-grow: 1;
        }

        .section-title-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 1rem;
        }

        .section-title {
            display: flex;
            min-width: 18rem;
            flex-direction: column;
            gap: 0.75rem;
        }

        .title-text {
            color: #111418;
            letter-spacing: -0.015em;
            font-size: 2rem;
            font-weight: 700;
            line-height: 1.25;
        }

        .subtitle-text {
            color: #60758a;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .details-grid {
            padding: 1rem;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .details-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            border-top: 1px solid #dbe0e6;
        }

        .details-label {
            color: #60758a;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .details-value {
            color: #111418;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1.5;
        }

        .video-container {
            padding: 1rem;
        }

        .video-player {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #111418;
            background-size: cover;
            background-position: center;
            aspect-ratio: 16 / 9;
            border-radius: 0.5rem;
            padding: 1rem;
        }

        .video-iframe {
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 0.5rem;
        }

        .button-group {
            display: flex;
            justify-content: stretch;
        }

        .buttons-container {
            display: flex;
            flex-grow: 1;
            gap: 0.75rem;
            flex-wrap: wrap;
            padding: 1rem;
            justify-content: flex-start;
        }

        .primary-button, .secondary-button, .link-button {
            display: flex;
            min-width: 84px;
            max-width: 480px;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: 0.5rem;
            height: 2.5rem;
            padding: 0 1rem;
            font-size: 0.875rem;
            font-weight: 700;
            line-height: 1.5;
            letter-spacing: 0.015em;
            border: none;
            text-decoration: none;
        }

        .primary-button {
            background-color: #0d80f2;
            color: #ffffff;
        }

        .secondary-button {
            background-color: #f0f2f5;
            color: #111418;
        }

        .link-button {
            background-color: transparent;
            color: #111418;
            font-weight: 700;
        }

        .truncate {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    </style>
</head>

<body>
    <div class="relative flex size-full min-h-screen flex-col bg-white overflow-x-hidden">
        @* Add your header partial view here if you have one *@
        @* @Html.Partial("_LandingHeader") *@
        @Html.Partial("_LandingHeader")
        <main class="main-content">
            <div class="content-container">
                <div class="section-title-container">
                    <div class="section-title">
                        <p class="title-text">Lecture Details</p>
                        <p class="subtitle-text">Lecture Information</p>
                    </div>
                </div>

                <div class="details-grid">
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Title)</p>
                        <p class="details-value">@Model.Title</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Course)</p>
                        <p class="details-value">@Model.Course.CourseName</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.LectureDate)</p>
                        <p class="details-value">@Model.LectureDate.ToString("MMMM dd, yyyy")</p>
                    </div>
                    <div class="details-item ">
                        <p class="details-label">@Html.DisplayNameFor(m => m.Description)</p>
                        <p class="details-value">@Model.Description</p>
                    </div>
                    
                </div>

                @* <div class="video-container">
                    @if (!string.IsNullOrEmpty(videoId))
                    {
                        <div class="video-player">
                            <iframe class="video-iframe"
                                    src="https://www.youtube.com/embed/@videoId?enablejsapi=1"
                                    allow="autoplay; encrypted-media"
                                    allowfullscreen>
                            </iframe>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.VideoUrl))
                    {
                        <div class="video-player">
                            <video id="lectureVideo" class="video-iframe" controls>
                                <source src="@Model.VideoUrl" type="video/mp4">
                                Your browser does not support the video tag.
                            </video>
                        </div>
                    }
                    else
                    {
                        <p class="text-center text-[#60758a]">No video URL provided.</p>
                    }
                </div> *@

                <div class="button-group">
                    <div class="buttons-container">
                        <a asp-action="Edit" asp-route-id="@Model.LectureId" class="secondary-button">
                            <span class="truncate">Edit</span>
                        </a>
                        <a asp-action="UploadVideo" asp-route-id="@Model.LectureId" class="secondary-button">
                            <span class="truncate">Upload Video</span>
                        </a>
                        <a asp-action="ViewLecture" asp-route-id="@Model.LectureId" class="primary-button">
                            <span class="truncate">View Lecture</span>
                        </a>
                        <a asp-action="Index" class="link-button">
                            <span class="truncate">Back to List</span>
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>