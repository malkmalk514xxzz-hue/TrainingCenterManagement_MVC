@model TrainingCenterManagement_MVC.Models.Lecture

@{
    ViewData["Title"] = "Lecture Details";

    string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        try
        {
            var uri = new Uri(url);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var videoId))
            {
                return videoId;
            }

            if (uri.Host.Contains("youtu.be"))
            {
                return uri.AbsolutePath.Trim('/');
            }
        }
        catch { }

        return "";
    }

    var videoId = GetYoutubeVideoId(Model.VideoUrl);
}

<h1>Lecture Details</h1>

<div>
    <h4>Lecture Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Description)</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Video</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(videoId))
            {
                <div class="embed-responsive embed-responsive-16by9" style="max-width: 560px;">
                    <iframe class="embed-responsive-item"
                            src="https://www.youtube.com/embed/@videoId"
                            allowfullscreen
                            style="width: 100%; height: 315px; border: none;">
                    </iframe>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.VideoUrl))
            {
                <a href="@Model.VideoUrl" target="_blank">@Model.VideoUrl</a>
            }
            else
            {
                <span class="text-muted">No video URL provided</span>
            }
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ThumbnailUrl)</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
            {
                <img src="@Model.ThumbnailUrl" alt="Thumbnail" class="img-thumbnail" style="max-width: 150px;" />
            }
            else
            {
                <span class="text-muted">No thumbnail available</span>
            }
        </dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.LectureDate)</dt>
        <dd class="col-sm-9">@Model.LectureDate.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsDeleted)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.IsDeleted)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Course)</dt>
        <dd class="col-sm-9">@Model.Course.CourseName</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.LectureId" class="btn btn-outline-primary">Edit</a>
    <a asp-action="UploadVideo" asp-route-id="@Model.LectureId" class="btn btn-outline-secondary">Upload Video</a>
    <a asp-action="ViewLecture" asp-route-id="@Model.LectureId" class="btn btn-outline-info">View Lecture</a>
    <a asp-controller="Presences" asp-action="MarkAttendance" asp-route-lectureId="@Model.LectureId" class="btn btn-primary">Mark Attendance</a>
    <a asp-controller="Presences" asp-action="LectureAttendance" asp-route-lectureId="@Model.LectureId" class="btn btn-primary ms-2">عرض سجل الحضور</a>
    <a asp-action="Index" class="btn btn-link ms-2">Back to List</a>
</div>
