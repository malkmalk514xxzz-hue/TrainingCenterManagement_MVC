@* Legacy commented-out version kept for reference. Active view starts below. *@
@model TrainingCenterManagement_MVC.Models.Lecture
@using TrainingCenterManagement_MVC.Models

@{
    ViewData["Title"] = Model.Title;

    string GetYoutubeEmbedId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        try
        {
            var uri = new Uri(url);
            if (uri.Host.Contains("youtu.be"))
                return uri.AbsolutePath.Trim('/');
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var v)) return v;
        }
        catch { }
        return "";
    }

    string ExtIcon(string ext) => ext switch
    {
        ".pdf"  => "fa-file-pdf",
        ".docx" or ".doc" => "fa-file-word",
        ".pptx" or ".ppt" => "fa-file-powerpoint",
        ".xlsx" or ".xls" => "fa-file-excel",
        ".zip" or ".rar"  => "fa-file-archive",
        ".jpg" or ".jpeg" or ".png" or ".gif" => "fa-file-image",
        ".mp4" or ".avi"  => "fa-file-video",
        ".txt"  => "fa-file-alt",
        _       => "fa-file"
    };
    string ExtColor(string ext) => ext switch
    {
        ".pdf"  => "#dc2626",
        ".docx" or ".doc" => "#2563eb",
        ".pptx" or ".ppt" => "#d97706",
        ".xlsx" or ".xls" => "#16a34a",
        ".zip" or ".rar"  => "#7c3aed",
        ".jpg" or ".jpeg" or ".png" or ".gif" => "#0891b2",
        ".mp4" or ".avi"  => "#be185d",
        _       => "#64748b"
    };
    string ResTypeLabel(ResourceType t) => t switch
    {
        ResourceType.LectureSlides => "شرائح المحاضرة",
        ResourceType.Notes         => "ملاحظات",
        ResourceType.Assignment    => "واجب",
        ResourceType.Solution      => "الحل",
        ResourceType.ProjectFiles  => "ملفات المشروع",
        ResourceType.Reference     => "مراجع إضافية",
        ResourceType.Code          => "أكواد",
        _                          => "ملفات أخرى"
    };
    string ResTypeBadgeStyle(ResourceType t) => t switch
    {
        ResourceType.LectureSlides => "background:#dbeafe;color:#1d4ed8;",
        ResourceType.Notes         => "background:#fef9c3;color:#a16207;",
        ResourceType.Assignment    => "background:#fce7f3;color:#9d174d;",
        ResourceType.Solution      => "background:#dcfce7;color:#166534;",
        ResourceType.ProjectFiles  => "background:#ede9fe;color:#5b21b6;",
        ResourceType.Reference     => "background:#ffedd5;color:#9a3412;",
        ResourceType.Code          => "background:#f1f5f9;color:#334155;",
        _                          => "background:#f3f4f6;color:#4b5563;"
    };
    string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    var visibleResources = Model.Resources?.Where(r => r.IsVisible).OrderBy(r => r.DisplayOrder).ToList()
                           ?? new List<LectureResource>();
    var videoList = Model.Videos?.Where(v => !v.IsDeleted).OrderBy(v => v.DisplayOrder).ToList() ?? new List<LectureVideo>();
    var isTrainee = User.IsInRole("Trainee");

    // Extract legacy YouTube ID from Lecture.VideoUrl (stored as bare ID, embed URL, or watch URL)
    string? legacyYtId = null;
    if (videoList.Count == 0 && !string.IsNullOrEmpty(Model.VideoUrl))
    {
        var rawUrl = Model.VideoUrl;
        if (rawUrl.Contains("v="))
        {
            try { legacyYtId = System.Web.HttpUtility.ParseQueryString(new Uri(rawUrl).Query)["v"]; } catch { }
        }
        else if (rawUrl.Contains("youtu.be/"))
        {
            legacyYtId = rawUrl.Split('/').Last().Split('?').First();
        }
        else if (rawUrl.Contains("/embed/"))
        {
            legacyYtId = rawUrl.Split("/embed/").Last().Split('?').First();
        }
        else
        {
            legacyYtId = rawUrl; // assume bare ID
        }
    }
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0; font-family: 'Noto Kufi Arabic', 'Segoe UI', sans-serif;
            background: #f1f5f9; color: #0f172a; direction: rtl;
        }

        /* ── Layout ── */
        .vl-wrap { max-width: 1060px; margin: 0 auto; padding: 24px 16px; }

        /* ── Breadcrumb ── */
        .vl-breadcrumb {
            display: flex; align-items: center; gap: 6px;
            font-size: .82rem; color: #64748b; margin-bottom: 20px; flex-wrap: wrap;
        }
        .vl-breadcrumb a { color: #3b82f6; text-decoration: none; font-weight: 600; }
        .vl-breadcrumb a:hover { text-decoration: underline; }
        .vl-breadcrumb i { font-size: .7rem; }

        /* ── Lecture Header ── */
        .vl-header {
            background: linear-gradient(135deg, #1e40af, #3b82f6);
            border-radius: 16px; padding: 28px 32px; margin-bottom: 24px;
            color: #fff; position: relative; overflow: hidden;
        }
        .vl-header::before {
            content: ''; position: absolute; top: -60px; left: -40px;
            width: 220px; height: 220px; background: rgba(255,255,255,.06); border-radius: 50%;
        }
        .vl-header-content { position: relative; z-index: 1; }
        .vl-course-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(255,255,255,.2); border-radius: 20px;
            padding: 4px 14px; font-size: .78rem; font-weight: 600;
            margin-bottom: 10px;
        }
        .vl-title { font-size: 1.7rem; font-weight: 700; margin: 0 0 8px; }
        .vl-desc { font-size: .9rem; opacity: .85; margin: 0 0 14px; line-height: 1.6; }
        .vl-meta { display: flex; gap: 18px; flex-wrap: wrap; font-size: .82rem; opacity: .9; }
        .vl-meta-item { display: flex; align-items: center; gap: 5px; }

        /* ── Alerts ── */
        .vl-alert {
            padding: 12px 18px; border-radius: 10px; margin-bottom: 18px;
            font-size: .88rem; font-weight: 600; display: flex; align-items: center; gap: 10px;
        }
        .vl-alert-success { background: #dcfce7; color: #166534; border: 1.5px solid #86efac; }
        .vl-alert-danger   { background: #fee2e2; color: #991b1b; border: 1.5px solid #fca5a5; }

        /* ── Section Card ── */
        .vl-section {
            background: #fff; border-radius: 14px; padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,.07); margin-bottom: 20px;
            border: 1px solid #e2e8f0;
        }
        .vl-section-title {
            font-size: 1rem; font-weight: 700; color: #0f172a;
            margin: 0 0 18px; display: flex; align-items: center; gap: 8px;
        }
        .vl-section-title i { color: #3b82f6; }
        .vl-section-title .cnt-badge {
            background: #eff6ff; color: #1d4ed8;
            padding: 2px 8px; border-radius: 10px; font-size: .75rem; font-weight: 700;
        }

        /* ── Video Player ── */
        .vl-video-list { display: flex; flex-direction: column; gap: 20px; }
        .vl-video-item { }
        .vl-video-title { font-size: .95rem; font-weight: 700; color: #0f172a; margin-bottom: 6px; }
        .vl-video-desc  { font-size: .82rem; color: #64748b; margin-bottom: 8px; }
        .vl-video-frame {
            position: relative; width: 100%; aspect-ratio: 16/9; border-radius: 10px;
            overflow: hidden; background: #111418;
        }
        .vl-video-frame iframe, .vl-video-frame video {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            border: none; border-radius: 10px;
        }
        .vl-no-video {
            text-align: center; padding: 48px 0; color: #94a3b8;
        }
        .vl-no-video i { font-size: 2.5rem; display: block; margin-bottom: 10px; }

        /* ── Resources ── */
        .vl-res-list { display: flex; flex-direction: column; gap: 10px; }
        .vl-res-item {
            display: flex; align-items: center; gap: 14px;
            padding: 13px 16px; border: 1.5px solid #e2e8f0; border-radius: 10px;
            background: #fafafa; transition: border-color .18s, background .18s;
        }
        .vl-res-item:hover { border-color: #93c5fd; background: #f0f7ff; }
        .vl-res-icon { font-size: 1.6rem; flex-shrink: 0; }
        .vl-res-body { flex-grow: 1; min-width: 0; }
        .vl-res-name { font-size: .9rem; font-weight: 700; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .vl-res-meta { font-size: .78rem; color: #64748b; margin-top: 3px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .vl-res-type-badge {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 2px 9px; border-radius: 10px; font-size: .72rem; font-weight: 700;
        }
        .vl-res-required {
            background: #fef3c7; color: #92400e;
            padding: 2px 8px; border-radius: 10px; font-size: .72rem; font-weight: 700;
        }
        .vl-dl-btn {
            display: inline-flex; align-items: center; gap: 6px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            color: #fff; padding: 8px 18px; border-radius: 8px;
            font-size: .82rem; font-weight: 700; text-decoration: none;
            white-space: nowrap; flex-shrink: 0; transition: opacity .18s;
        }
        .vl-dl-btn:hover { opacity: .88; color: #fff; }
        .vl-no-res {
            text-align: center; padding: 32px 0; color: #94a3b8; font-size: .9rem;
        }
        .vl-no-res i { font-size: 2rem; display: block; margin-bottom: 8px; }

        /* ── Stats Bar ── */
        .vl-stats-bar {
            display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 20px;
        }
        .vl-stat {
            background: #fff; border-radius: 10px; padding: 12px 18px;
            display: flex; align-items: center; gap: 10px;
            box-shadow: 0 1px 6px rgba(0,0,0,.07); border: 1px solid #e2e8f0; flex: 1; min-width: 120px;
        }
        .vl-stat-icon { font-size: 1.2rem; flex-shrink: 0; }
        .vl-stat-val  { font-size: 1.2rem; font-weight: 800; color: #0f172a; line-height: 1; }
        .vl-stat-lbl  { font-size: .72rem; color: #64748b; }

        /* ── Back Button ── */
        .vl-back {
            display: inline-flex; align-items: center; gap: 6px;
            color: #64748b; font-size: .85rem; text-decoration: none; font-weight: 600;
            padding: 8px 16px; border-radius: 8px; border: 1.5px solid #e2e8f0;
            background: #fff; transition: all .18s; margin-top: 8px;
        }
        .vl-back:hover { border-color: #3b82f6; color: #3b82f6; }

        @@media (max-width: 640px) {
            .vl-title { font-size: 1.3rem; }
            .vl-header { padding: 20px 18px; }
            .vl-wrap { padding: 16px 10px; }
        }
    </style>
</head>
<body>
    @Html.Partial("_LandingHeader")

    <div class="vl-wrap">

        <!-- Breadcrumb -->
        <nav class="vl-breadcrumb">
            <a asp-controller="Courses" asp-action="Index"><i class="fas fa-home"></i> الرئيسية</a>
            <i class="fas fa-chevron-left"></i>
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">@Model.Course?.CourseName</a>
            <i class="fas fa-chevron-left"></i>
            <span>@Model.Title</span>
        </nav>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="vl-alert vl-alert-success">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="vl-alert vl-alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Lecture Header -->
        <div class="vl-header">
            <div class="vl-header-content">
                <div class="vl-course-badge">
                    <i class="fas fa-book-open"></i> @Model.Course?.CourseName
                </div>
                <h1 class="vl-title">@Model.Title</h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="vl-desc">@Model.Description</p>
                }
                <div class="vl-meta">
                    <div class="vl-meta-item">
                        <i class="fas fa-calendar-day"></i>
                        @Model.LectureDate.ToString("yyyy/MM/dd")
                    </div>
                    <div class="vl-meta-item">
                        <i class="fas fa-video"></i>
                        @(videoList.Count > 0 ? videoList.Count + " فيديو" : legacyYtId != null ? "فيديو" : "لا يوجد فيديو")
                    </div>
                    <div class="vl-meta-item">
                        <i class="fas fa-paperclip"></i>
                        @visibleResources.Count ملف داعم
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="vl-stats-bar">
            <div class="vl-stat">
                <span class="vl-stat-icon" style="color:#3b82f6;"><i class="fas fa-video"></i></span>
                <div>
                    <div class="vl-stat-val">@(videoList.Count > 0 ? videoList.Count : legacyYtId != null ? 1 : 0)</div>
                    <div class="vl-stat-lbl">فيديو</div>
                </div>
            </div>
            <div class="vl-stat">
                <span class="vl-stat-icon" style="color:#10b981;"><i class="fas fa-paperclip"></i></span>
                <div>
                    <div class="vl-stat-val">@visibleResources.Count</div>
                    <div class="vl-stat-lbl">ملف داعم</div>
                </div>
            </div>
            @{
                var requiredCount = visibleResources.Count(r => r.IsRequired);
            }
            @if (requiredCount > 0)
            {
                <div class="vl-stat">
                    <span class="vl-stat-icon" style="color:#f59e0b;"><i class="fas fa-exclamation-circle"></i></span>
                    <div>
                        <div class="vl-stat-val">@requiredCount</div>
                        <div class="vl-stat-lbl">إلزامي</div>
                    </div>
                </div>
            }
        </div>

        <!-- ─── Videos Section ─────────────────────────────────────── -->
        <div class="vl-section">
            <h2 class="vl-section-title">
                <i class="fas fa-play-circle"></i>
                فيديوهات المحاضرة
                <span class="cnt-badge">@(videoList.Count > 0 ? videoList.Count : legacyYtId != null ? 1 : 0)</span>
            </h2>

            @if (videoList.Any())
            {
                <div class="vl-video-list">
                    @foreach (var video in videoList)
                    {
                        var embedId = GetYoutubeEmbedId(video.VideoUrl ?? "");
                        <div class="vl-video-item">
                            <div class="vl-video-title">@video.VideoTitle</div>
                            @if (!string.IsNullOrEmpty(video.Description))
                            {
                                <div class="vl-video-desc">@video.Description</div>
                            }
                            <div class="vl-video-frame">
                                @if (video.VideoSourceType == VideoSourceType.YouTube && !string.IsNullOrEmpty(embedId))
                                {
                                    <iframe src="https://www.youtube.com/embed/@embedId"
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                            allowfullscreen></iframe>
                                }
                                else
                                {
                                    <video controls preload="metadata">
                                        <source src="@video.VideoUrl" type="video/mp4" />
                                        <source src="@video.VideoUrl" type="video/webm" />
                                        متصفحك لا يدعم تشغيل الفيديو.
                                    </video>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else if (legacyYtId != null)
            {
                <!-- Legacy VideoUrl fallback: show embedded YouTube player -->
                <div class="vl-video-list">
                    <div class="vl-video-item">
                        <div class="vl-video-title">@Model.Title</div>
                        <div class="vl-video-frame">
                            <iframe src="https://www.youtube.com/embed/@legacyYtId"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen></iframe>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="vl-no-video">
                    <i class="fas fa-video-slash"></i>
                    لا توجد فيديوهات لهذه المحاضرة بعد.
                </div>
            }
        </div>

        <!-- ─── Resources Section ──────────────────────────────────── -->
        <div class="vl-section">
            <h2 class="vl-section-title">
                <i class="fas fa-paperclip"></i>
                الملفات الداعمة
                <span class="cnt-badge">@visibleResources.Count</span>
            </h2>

            @if (visibleResources.Any())
            {
                <div class="vl-res-list">
                    @foreach (var res in visibleResources)
                    {
                        <div class="vl-res-item">
                            <i class="fas @ExtIcon(res.FileExtension) vl-res-icon" style="color:@ExtColor(res.FileExtension);"></i>
                            <div class="vl-res-body">
                                <div class="vl-res-name" title="@res.FileName">@res.FileName</div>
                                @if (!string.IsNullOrEmpty(res.Description))
                                {
                                    <div class="vl-res-meta" style="font-style:italic;">@res.Description</div>
                                }
                                <div class="vl-res-meta">
                                    <span>@FormatSize(res.FileSizeInBytes)</span>
                                    <span>·</span>
                                    <span class="vl-res-type-badge" style="@ResTypeBadgeStyle(res.ResourceType)">
                                        @ResTypeLabel(res.ResourceType)
                                    </span>
                                    @if (res.IsRequired)
                                    {
                                        <span class="vl-res-required">
                                            <i class="fas fa-exclamation me-1"></i>إلزامي
                                        </span>
                                    }
                                    <span style="color:#94a3b8;">
                                        <i class="fas fa-download fa-xs me-1"></i>@res.DownloadCount تحميل
                                    </span>
                                </div>
                            </div>
                            @if (isTrainee)
                            {
                                <a asp-controller="LectureResources" asp-action="Download"
                                   asp-route-resourceId="@res.ResourceId"
                                   class="vl-dl-btn">
                                    <i class="fas fa-download"></i> تحميل
                                </a>
                            }
                            else
                            {
                                <a asp-controller="LectureResources" asp-action="AdminDownload"
                                   asp-route-resourceId="@res.ResourceId"
                                   class="vl-dl-btn">
                                    <i class="fas fa-download"></i> تحميل
                                </a>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="vl-no-res">
                    <i class="fas fa-inbox"></i>
                    لا توجد ملفات داعمة لهذه المحاضرة بعد.
                </div>
            }
        </div>

        <!-- ─── AI Tools (تلخيص / خريطة ذهنية / أسئلة وأجوبة) ─────── -->
        @await Html.PartialAsync("_LectureAITools", Model.LectureId)

        <!-- ─── Bottom Actions ─────────────────────────────────────── -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:32px;">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="vl-back">
                <i class="fas fa-arrow-right"></i> العودة للدورة
            </a>
            @if (User.IsInRole("Trainer") || User.IsInRole("Admin"))
            {
                <a asp-controller="LectureResources" asp-action="Manage" asp-route-lectureId="@Model.LectureId"
                   style="display:inline-flex;align-items:center;gap:6px;background:#3b82f6;color:#fff;padding:8px 18px;border-radius:8px;font-size:.85rem;font-weight:700;text-decoration:none;">
                    <i class="fas fa-folder-open"></i> إدارة الموارد
                </a>
                <a asp-controller="LectureVideos" asp-action="Manage" asp-route-lectureId="@Model.LectureId"
                   style="display:inline-flex;align-items:center;gap:6px;background:#6366f1;color:#fff;padding:8px 18px;border-radius:8px;font-size:.85rem;font-weight:700;text-decoration:none;">
                    <i class="fas fa-video"></i> إدارة الفيديوهات
                </a>
                <a asp-action="MarkAttendance" asp-route-id="@Model.LectureId"
                   style="display:inline-flex;align-items:center;gap:6px;background:#f59e0b;color:#fff;padding:8px 18px;border-radius:8px;font-size:.85rem;font-weight:700;text-decoration:none;">
                    <i class="fas fa-clipboard-check"></i> تسجيل الحضور
                </a>
            }
        </div>

    </div>
</body>
</html>
