@model TrainingCenterManagement_MVC.Models.Lecture

@{
    ViewData["Title"] = "View Lecture";

    string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        try
        {
            var uri = new Uri(url);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var videoId))
            {
                return videoId;
            }

            // دعم روابط youtu.be
            if (uri.Host.Contains("youtu.be"))
            {
                return uri.AbsolutePath.Trim('/');
            }
        }
        catch { }

        return "";
    }

    var videoId = GetYoutubeVideoId(Model.VideoUrl);
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<h2>@Model.Title</h2>

<p><strong>Description:</strong> @Model.Description</p>
<p><strong>Date:</strong> @Model.LectureDate.ToString("yyyy-MM-dd")</p>

@if (!string.IsNullOrEmpty(videoId))
{
    <div class="mt-3">
        <div class="d-flex justify-content-center mt-3">
            <div style="width: 100%; max-width: 960px;">
                <div class="ratio ratio-16x9">
                    <iframe src="https://www.youtube.com/embed/@videoId"
                            title="YouTube video"
                            allowfullscreen
                            style="border: none;">
                    </iframe>
                </div>
            </div>
        </div>

    </div>
}
else if (!string.IsNullOrEmpty(Model.VideoUrl))
{
    <div class="mt-3">
        <video width="640" height="360" controls>
            <source src="@Model.VideoUrl" type="video/mp4" />
            Your browser does not support the video tag.
        </video>
    </div>
}
else
{
    <p class="text-danger">No video uploaded for this lecture yet.</p>
}

<hr />
<h4>Attendance</h4>
@if (Model.Presences != null && Model.Presences.Any())
{
    <ul class="list-group">
        @foreach (var presence in Model.Presences)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                @presence.Trainee.User.FullName
                <span class="badge @(presence.IsPresent ? "bg-success" : "bg-danger")">
                    @(presence.IsPresent ? "Present" : "Absent")
                </span>
            </li>
        }
    </ul>
}
else
{
    <p>No attendance records available.</p>
}

<a asp-action="MarkAttendance" asp-route-id="@Model.LectureId" class="btn btn-warning mt-3">Mark Attendance</a>
