@model IEnumerable<TrainingCenterManagement_MVC.Models.Course>

@{
    ViewData["Title"] = "Lectures List";

    string GetYoutubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        try
        {
            var uri = new Uri(url);
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
            if (query.TryGetValue("v", out var videoId))
            {
                return videoId;
            }

            // دعم روابط youtu.be
            if (uri.Host.Contains("youtu.be"))
            {
                return uri.AbsolutePath.Trim('/');
            }
        }
        catch { }

        return "";
    }
}

<h1 class="mb-4">Lectures by Course</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Lecture</a>
</p>

@foreach (var course in Model)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">@course.CourseName</h5>
        </div>
        <div class="card-body p-0">
            @if (course.Lectures != null && course.Lectures.Any())
            {
                <table class="table table-striped table-bordered mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Video</th>
                            <th>Thumbnail</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th style="width:150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in course.Lectures.OrderByDescending(l => l.LectureDate))
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.Description</td>
                                <td>
                                    @{
                                        var videoId = GetYoutubeVideoId(item.VideoUrl);
                                    }
                                    @if (!string.IsNullOrEmpty(videoId))
                                    {
                                        <div style="max-width: 220px;">
                                            <iframe src="https://www.youtube.com/embed/@videoId"
                                                    allowfullscreen
                                                    style="width: 100%; height: 120px; border: none;">
                                            </iframe>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Video</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                    {
                                        <img src="@item.ThumbnailUrl" alt="Thumbnail" style="max-width:100px; max-height:60px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Thumbnail</span>
                                    }
                                </td>
                                <td>@item.LectureDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (item.IsDeleted)
                                    {
                                        <span class="badge bg-danger">Deleted</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.LectureId" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.LectureId" class="btn btn-sm btn-info ms-1">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.LectureId" class="btn btn-sm btn-danger ms-1">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-3 text-muted">No lectures available for this course.</div>
            }
        </div>
    </div>
}
