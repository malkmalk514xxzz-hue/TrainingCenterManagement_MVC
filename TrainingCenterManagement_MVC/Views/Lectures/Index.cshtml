@model IEnumerable<TrainingCenterManagement_MVC.Models.Course>
@using TrainingCenterManagement_MVC.Models
@{
    ViewData["Title"] = "المحاضرات";
    var isAdmin = User.IsInRole("Admin");
    var isTrainer = User.IsInRole("Trainer");
    var firstCourse = Model.FirstOrDefault();
    var firstCourseId = firstCourse?.CourseId.ToString() ?? "";
}

<div class="dashboard-wrapper">
    @if (User.IsInRole("Admin"))
    {
        @await Html.PartialAsync("_AdminSidebar")
    }
    else
    {
        @Html.Partial("_TrainerSidebar")
    }

    <div class="dashboard-main" style="background:#f1f5f9;direction:rtl;font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;padding:28px 32px;min-height:100vh;overflow-y:auto;">

        @if (TempData["Success"] != null)
        {
            <div style="background:#dcfce7;color:#166534;border:1.5px solid #86efac;border-radius:10px;padding:12px 18px;margin-bottom:20px;font-size:.88rem;font-weight:600;display:flex;align-items:center;gap:10px;">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="background:#fee2e2;color:#991b1b;border:1.5px solid #fca5a5;border-radius:10px;padding:12px 18px;margin-bottom:20px;font-size:.88rem;font-weight:600;display:flex;align-items:center;gap:10px;">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <!-- Page Header -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
            <div>
                <h1 style="font-size:1.5rem;font-weight:700;color:#0f172a;margin:0 0 4px;">المحاضرات</h1>
                <p style="font-size:.875rem;color:#64748b;margin:0;">
                    <i class="fas fa-graduation-cap" style="color:#4f46e5;margin-left:4px;"></i>
                    @Model.Count() دورة · @Model.Sum(c => c.Lectures?.Count(l => !l.IsDeleted) ?? 0) محاضرة
                </p>
            </div>
            @if (isAdmin || isTrainer)
            {
                <a asp-action="Create" asp-controller="Lectures"
                   style="display:inline-flex;align-items:center;gap:8px;padding:10px 22px;background:#4f46e5;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:.875rem;transition:.15s;box-shadow:0 2px 8px rgba(79,70,229,.3);">
                    <i class="fas fa-plus"></i> محاضرة جديدة
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div style="background:#fff;border-radius:14px;padding:80px 20px;text-align:center;box-shadow:0 1px 6px rgba(0,0,0,.07);">
                <i class="fas fa-chalkboard-teacher" style="font-size:4rem;color:#c7d2fe;margin-bottom:20px;display:block;"></i>
                <h2 style="font-size:1.2rem;font-weight:700;color:#0f172a;margin:0 0 8px;">لا توجد دورات مضافة</h2>
                <p style="color:#64748b;margin:0 0 20px;font-size:.9rem;">قم بإضافة دورات أولاً ثم أضف محاضراتها</p>
            </div>
        }
        else
        {
            <!-- Two-panel layout -->
            <div style="display:grid;grid-template-columns:260px 1fr;gap:20px;align-items:start;">

                <!-- Course Selector (right side in RTL) -->
                <div style="background:#fff;border-radius:12px;box-shadow:0 1px 6px rgba(0,0,0,.07);overflow:hidden;position:sticky;top:20px;">
                    <div style="padding:14px 16px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:8px;">
                        <i class="fas fa-list-ul" style="color:#4f46e5;font-size:.9rem;"></i>
                        <span style="font-weight:700;color:#0f172a;font-size:.9rem;">الدورات التدريبية</span>
                    </div>
                    <div style="max-height:calc(100vh - 220px);overflow-y:auto;">
                        @foreach (var course in Model)
                        {
                            var lecCount = course.Lectures?.Count ?? 0;
                            var isFirst = course.CourseId == firstCourse?.CourseId;
                            <div class="course-item"
                                 id="ci-@course.CourseId"
                                 onclick="selectCourse('@course.CourseId')"
                                 style="padding:12px 16px;cursor:pointer;border-bottom:1px solid #f8fafc;transition:.15s;@(isFirst ? "background:#eff6ff;border-right:3px solid #4f46e5;" : "")">
                                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                                    <span style="font-size:.85rem;font-weight:@(isFirst ? "600" : "500");color:@(isFirst ? "#4338ca" : "#374151");">@course.CourseName</span>
                                    <span style="font-size:.72rem;background:@(isFirst ? "#e0e7ff" : "#f1f5f9");color:@(isFirst ? "#4338ca" : "#6b7280");padding:2px 8px;border-radius:20px;white-space:nowrap;flex-shrink:0;">@lecCount</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Lectures Display Panel -->
                <div id="lectures-panel">
                    @foreach (var course in Model)
                    {
                        var isFirstCourse = course.CourseId == firstCourse?.CourseId;
                        var lectures = course.Lectures?
                            .Where(l => !l.IsDeleted)
                            .GroupBy(l => l.LectureId).Select(g => g.First())
                            .OrderByDescending(l => l.LectureDate).ToList() ?? new List<Lecture>();
                        var csId = course.CourseId.ToString();
                        <div class="course-section"
                             id="cs-@course.CourseId"
                             style="display:@(isFirstCourse ? "block" : "none");">

                            <!-- Section header -->
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <h2 style="font-size:1.1rem;font-weight:700;color:#0f172a;margin:0;">@course.CourseName</h2>
                                    <span id="count-@csId" style="background:#e0e7ff;color:#4338ca;padding:3px 10px;border-radius:20px;font-size:.78rem;font-weight:700;">
                                        @lectures.Count محاضرة
                                    </span>
                                </div>
                                @if (isAdmin || isTrainer)
                                {
                                    <a asp-action="Create" asp-controller="Lectures" asp-route-courseId="@course.CourseId"
                                       style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#4f46e5;color:#fff;border-radius:8px;text-decoration:none;font-size:.8rem;font-weight:600;">
                                        <i class="fas fa-plus"></i> إضافة محاضرة
                                    </a>
                                }
                            </div>

                            <!-- Search -->
                            <div style="margin-bottom:16px;position:relative;">
                                <i class="fas fa-search" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.85rem;pointer-events:none;"></i>
                                <input type="text" placeholder="ابحث في محاضرات @course.CourseName..."
                                       oninput="filterLectures('@csId', this.value)"
                                       style="width:100%;padding:9px 36px 9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.85rem;outline:none;font-family:inherit;background:#fff;direction:rtl;"
                                       onfocus="this.style.borderColor='#818cf8'" onblur="this.style.borderColor='#e2e8f0'" /></div>

                            @if (!lectures.Any())
                            {
                                <div style="background:#fff;border-radius:12px;padding:60px 20px;text-align:center;box-shadow:0 1px 6px rgba(0,0,0,.07);">
                                    <i class="fas fa-chalkboard" style="font-size:3rem;color:#c7d2fe;margin-bottom:16px;display:block;"></i>
                                    <p style="color:#64748b;margin:0 0 16px;font-size:.9rem;">لا توجد محاضرات لهذه الدورة حتى الآن</p>
                                    @if (isAdmin || isTrainer)
                                    {
                                        <a asp-action="Create" asp-controller="Lectures" asp-route-courseId="@course.CourseId"
                                           style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:#4f46e5;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:.875rem;">
                                            <i class="fas fa-plus"></i> إضافة أول محاضرة
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:16px;">
                                    @foreach (var lec in lectures)
                                    {
                                        var firstVid = lec.Videos?.Where(v => !v.IsDeleted).OrderBy(v => v.DisplayOrder).FirstOrDefault();
                                        var thumb = firstVid?.ThumbnailUrl
                                                 ?? (firstVid?.YouTubeVideoId != null
                                                     ? $"https://img.youtube.com/vi/{firstVid.YouTubeVideoId}/mqdefault.jpg"
                                                     : null);
                                        // fallback: old VideoUrl field (stored as YouTube ID)
                                        if (thumb == null && !string.IsNullOrEmpty(lec.VideoUrl))
                                        {
                                            var ytId = lec.VideoUrl.Contains("v=")
                                                ? System.Web.HttpUtility.ParseQueryString(new Uri(lec.VideoUrl).Query)["v"]
                                                : lec.VideoUrl.Contains("youtu.be/")
                                                    ? lec.VideoUrl.Split('/').Last()
                                                    : lec.VideoUrl;
                                            thumb = $"https://img.youtube.com/vi/{ytId}/mqdefault.jpg";
                                        }
                                        var vidCount = lec.Videos?.Count(v => !v.IsDeleted) ?? 0;
                                        var resCount = lec.Resources?.Count(r => !r.IsDeleted) ?? 0;
                                        var hasLegacyVideo = vidCount == 0 && !string.IsNullOrEmpty(lec.VideoUrl);

                                        <div class="lec-card" data-title="@lec.Title.ToLower()" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,.07);display:flex;flex-direction:column;transition:.2s;">

                                            <!-- Thumbnail -->
                                            <div class="thumb-wrap" style="position:relative;aspect-ratio:16/9;background:#e2e8f0;overflow:hidden;flex-shrink:0;">
                                                @if (thumb != null)
                                                {
                                                    <img src="@thumb" alt="@lec.Title"
                                                         style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);">
                                                        <i class="fas fa-chalkboard-teacher" style="font-size:2.5rem;color:#6366f1;"></i>
                                                    </div>
                                                }
                                                <a asp-action="ViewLecture" asp-controller="Lectures" asp-route-id="@lec.LectureId"
                                                   class="thumb-overlay"
                                                   style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.45);opacity:0;transition:.2s;text-decoration:none;">
                                                    <span style="width:50px;height:50px;background:rgba(255,255,255,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:2px;">
                                                        <i class="fas fa-play" style="color:#4f46e5;font-size:1.1rem;"></i>
                                                    </span>
                                                </a>
                                                @if (vidCount > 0 || hasLegacyVideo)
                                                {
                                                    <span style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,.65);color:#fff;font-size:.7rem;padding:2px 8px;border-radius:4px;display:flex;align-items:center;gap:4px;">
                                                        <i class="fas fa-video"></i> @(vidCount > 0 ? vidCount.ToString() : "رابط")
                                                    </span>
                                                }
                                            </div>

                                            <!-- Body -->
                                            <div style="padding:14px;flex:1;display:flex;flex-direction:column;gap:6px;">
                                                <h3 style="font-size:.92rem;font-weight:700;color:#0f172a;margin:0;line-height:1.4;">@lec.Title</h3>
                                                @if (!string.IsNullOrEmpty(lec.Description))
                                                {
                                                    <p style="font-size:.8rem;color:#64748b;margin:0;line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">@lec.Description</p>
                                                }
                                                <div style="display:flex;align-items:center;gap:12px;font-size:.75rem;color:#94a3b8;margin-top:auto;padding-top:6px;flex-wrap:wrap;">
                                                    <span><i class="fas fa-calendar-alt"></i> @lec.LectureDate.ToString("dd/MM/yyyy")</span>
                                                    @if (resCount > 0)
                                                    {
                                                        <span><i class="fas fa-paperclip"></i> @resCount ملف</span>
                                                    }
                                                </div>
                                            </div>

                                            <!-- Actions -->
                                            @if (isAdmin || isTrainer)
                                            {
                                                <div style="padding:10px 14px;border-top:1px solid #f1f5f9;display:flex;gap:6px;flex-wrap:wrap;">
                                                    <a asp-action="ViewLecture" asp-controller="Lectures" asp-route-id="@lec.LectureId"
                                                       style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:7px 10px;background:#eff6ff;color:#2563eb;border-radius:6px;text-decoration:none;font-size:.78rem;font-weight:600;" title="عرض المحاضرة">
                                                        <i class="fas fa-eye"></i> عرض
                                                    </a>
                                                    <a asp-action="Edit" asp-controller="Lectures" asp-route-id="@lec.LectureId"
                                                       style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;background:#fefce8;color:#d97706;border-radius:6px;text-decoration:none;font-size:.8rem;" title="تعديل">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Manage" asp-controller="LectureVideos" asp-route-lectureId="@lec.LectureId"
                                                       style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;background:#f0fdf4;color:#16a34a;border-radius:6px;text-decoration:none;font-size:.8rem;" title="الفيديوهات">
                                                        <i class="fas fa-video"></i>
                                                    </a>
                                                    <a asp-action="Manage" asp-controller="LectureResources" asp-route-lectureId="@lec.LectureId"
                                                       style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;background:#faf5ff;color:#7c3aed;border-radius:6px;text-decoration:none;font-size:.8rem;" title="الموارد">
                                                        <i class="fas fa-folder-open"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-controller="Lectures" asp-route-id="@lec.LectureId"
                                                       style="display:flex;align-items:center;justify-content:center;width:34px;height:34px;background:#fef2f2;color:#dc2626;border-radius:6px;text-decoration:none;font-size:.8rem;"
                                                       title="حذف"
                                                       onclick="return confirm('هل أنت متأكد من حذف محاضرة: @lec.Title ؟')">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .thumb-wrap:hover .thumb-overlay { opacity: 1 !important; }
    .lec-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.12) !important; transform: translateY(-2px); }
    .course-item:hover { background: #f8fafc !important; }
    @@media (max-width: 900px) {
        .dashboard-main > div:last-child > div[style*="grid-template-columns:260px"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<script>
    function selectCourse(courseId) {
        document.querySelectorAll('.course-item').forEach(function(el) {
            el.style.background = '';
            el.style.borderRight = '';
            var spans = el.querySelectorAll('span');
            if (spans[0]) { spans[0].style.color = '#374151'; spans[0].style.fontWeight = '500'; }
            if (spans[1]) { spans[1].style.background = '#f1f5f9'; spans[1].style.color = '#6b7280'; }
        });
        var item = document.getElementById('ci-' + courseId);
        if (item) {
            item.style.background = '#eff6ff';
            item.style.borderRight = '3px solid #4f46e5';
            var spans = item.querySelectorAll('span');
            if (spans[0]) { spans[0].style.color = '#4338ca'; spans[0].style.fontWeight = '600'; }
            if (spans[1]) { spans[1].style.background = '#e0e7ff'; spans[1].style.color = '#4338ca'; }
        }
        document.querySelectorAll('.course-section').forEach(function(el) { el.style.display = 'none'; });
        var section = document.getElementById('cs-' + courseId);
        if (section) section.style.display = 'block';
    }

    function filterLectures(courseId, query) {
        var q = query.trim().toLowerCase();
        var section = document.getElementById('cs-' + courseId);
        if (!section) return;
        var cards = section.querySelectorAll('.lec-card');
        var visible = 0;
        cards.forEach(function(card) {
            var title = (card.getAttribute('data-title') || '');
            var show = !q || title.includes(q);
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        var countEl = document.getElementById('count-' + courseId);
        if (countEl) countEl.textContent = visible + ' محاضرة';
    }
</script>
