            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 300ms ease-in-out;
        }

        .lecture-card-image-container:hover .lecture-card-overlay {
            opacity: 1;
        }

        /* New style for single button on hover */
        .single-button-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: rgba(0, 0, 0, 0.5);
            opacity: 0;
            transition: opacity 300ms ease-in-out;
        }

        .lecture-card-image-container:hover .single-button-overlay {
            opacity: 1;
        }

        /* Buttons container below image */
        .lecture-buttons-container {
            display: flex;
            gap: 0.5rem;
            justify-content: flex-start;
            padding-top: 0.5rem;
        }

        /* New button style for creating a new lecture */
        .create-button {
            display: flex;
            min-width: 84px;
            max-width: 480px;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: 0.5rem;
            height: 2.5rem;
            padding: 0 1rem;
            font-size: 0.875rem;
            font-weight: 700;
            line-height: 1.5;
            letter-spacing: 0.015em;
            border: none;
            background-color: #0d80f2;
            color: #ffffff;
            text-decoration: none; /* Remove underline for a clean look */
        }
    </style>
</head>
<body>
    <div class="relative flex size-full min-h-screen flex-col bg-white overflow-x-hidden">
        @Html.Partial("_LandingHeader")

        <div class="flex flex-1 justify-center py-5 px-10">
            <div class="flex flex-col max-w-[960px] flex-1">
                @foreach (var course in Model)
                {
                    <div class="flex flex-wrap justify-between gap-3 p-4">
                        <p class="text-[#111418] tracking-light text-3xl font-bold leading-tight min-w-72">@course.CourseName</p>
                        <a asp-action="Create" asp-route-id="@course.CourseId" class="create-button">
                            <span class="truncate">Create New Lecture</span>
                        </a>
                    </div>

                    <div class="grid-container p-4">
                        @if (course.Lectures != null && course.Lectures.Any())
                        {
                            @foreach (var lecture in course.Lectures.OrderByDescending(l => l.LectureDate))
                            {
                                <div class="flex flex-col gap-3 pb-3">
                                    <div class="w-full bg-center bg-no-repeat aspect-video bg-cover rounded-lg overflow-hidden lecture-card-image-container"
                                         style='background-image: url("@GetYoutubeThumbnailUrl(lecture.VideoUrl)");'>

                                        <div class="single-button-overlay">
                                            <a href="@lecture.VideoUrl" target="_blank" class="flex cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-3 bg-[#0d80f2] text-white text-sm font-bold leading-normal">
                                                <span class="truncate">مشاهدة المحاضرة</span>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="flex-col">
                                        <p class="text-[#111418] text-base font-medium leading-normal">@lecture.Title</p>
                                        <p class="text-[#60758a] text-sm font-normal leading-normal">@lecture.Description</p>
                                        <p class="text-[#60758a] text-sm font-normal leading-normal">@lecture.LectureDate.ToString("MMM dd, yyyy") • @(lecture.IsDeleted ? "Deleted" : "Active")</p>
                                    </div>
                                    <div class="lecture-buttons-container">
                                        <a asp-action="Edit" asp-route-id="@lecture.LectureId" class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-3 bg-[#f0f2f5] text-[#111418] text-sm font-bold leading-normal">
                                            <span class="truncate">&#9998;</span>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@lecture.LectureId" class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-3 bg-[#f0f2f5] text-[#111418] text-sm font-bold leading-normal">
                                            <span class="truncate">&#9776;</span>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@lecture.LectureId" class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-3 bg-red-500 text-white text-sm font-bold leading-normal">
                                            <span class="truncate">&#128465;</span>
                                        </a>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-[#60758a]">No lectures available for this course.</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @Html.Partial("_LandingFooter")

</body>
</html>