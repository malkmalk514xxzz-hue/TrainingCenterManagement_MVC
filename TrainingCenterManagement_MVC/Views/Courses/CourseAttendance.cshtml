@model List<TrainingCenterManagement_MVC.ViewModels.TraineeAttendanceViewModel>

@{
    ViewData["Title"] = "Course Attendance";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col text-center">
            <h3 class="fw-bold">Attendance for Course: <span class="text-primary">@ViewBag.CourseName</span></h3>
        </div>
    </div>

    <!-- Filter Form -->
    <div class="row mb-4">
        <div class="col-md-8 offset-md-2">
            <form method="get" class="row gy-2 gx-3 align-items-center justify-content-center">
                <div class="col-auto">
                    <label class="form-label mb-0">Min Attendance %</label>
                    <input type="number" name="min" value="@Context.Request.Query["min"]" class="form-control" />
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0">Max Attendance %</label>
                    <input type="number" name="max" value="@Context.Request.Query["max"]" class="form-control" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-primary mt-4">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center">
            <thead class="table-light">
                <tr>
                    <th>Student</th>
                    <th>Attended</th>
                    <th>Total</th>
                    <th>Attendance %</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var alertClass = item.IsLowAttendance ? "text-danger fw-bold" : "text-success fw-semibold";
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.AttendedLectures</td>
                        <td>@item.TotalLectures</td>
                        <td>@item.AttendancePercentage.ToString("F2")%</td>
                        <td class="@alertClass">
                            @(item.IsLowAttendance ? "Low" : "Good")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Chart Section -->
    <div class="my-5">
        <canvas id="attendanceChart" height="100"></canvas>
    </div>

    <!-- Export Buttons -->
    <div class="d-flex justify-content-center gap-3 mb-5">
        @* <a asp-action="ExportExcel" asp-route-courseId="@ViewContext.RouteData.Values["courseId"]" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export to Excel
        </a>
        <a asp-action="ExportPdf" asp-route-courseId="@ViewContext.RouteData.Values["courseId"]" class="btn btn-danger">
            <i class="bi bi-file-earmark-pdf"></i> Export to PDF
        </a> *@
        <a asp-action="ExportExcel" asp-route-courseId="@ViewBag.CourseId" class="btn btn-success">
    <i class="bi bi-file-earmark-excel"></i> Export to Excel
</a>
<a asp-action="ExportPdf" asp-route-courseId="@ViewBag.CourseId" class="btn btn-danger">
    <i class="bi bi-file-earmark-pdf"></i> Export to PDF
</a>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(Json.Serialize(Model.Select(m => m.FullName)));
        const data = @Html.Raw(Json.Serialize(Model.Select(m => m.AttendancePercentage)));

        const ctx = document.getElementById('attendanceChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Attendance %',
                    data: data,
                    backgroundColor: data.map(p => p >= 75 ? 'rgba(75, 192, 192, 0.7)' : 'rgba(255, 99, 132, 0.7)')
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return context.parsed.y + "%";
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        title: {
                            display: true,
                            text: 'Percentage'
                        }
                    }
                }
            }
        });
    </script>
}
