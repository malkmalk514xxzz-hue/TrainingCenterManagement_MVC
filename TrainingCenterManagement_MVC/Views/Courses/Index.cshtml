                        }
                    </td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                    <td>@item.ReleaseDate.ToShortDateString()</td>
                    <td>
                        @if (item.IsDeleted)
                        {
                            <span class="badge bg-danger">Deleted</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>@item.Admin?.User?.FullName</td> <!-- عرض الاسم الكامل بدلاً من الـ ID -->
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-sm btn-primary me-1">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-sm btn-info me-1">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center" role="alert">
            No courses available at the moment.
        </div>
    }
</div>
