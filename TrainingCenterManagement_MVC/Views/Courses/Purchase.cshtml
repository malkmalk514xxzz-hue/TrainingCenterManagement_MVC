@model TrainingCenterManagement_MVC.Models.Course
@{
    ViewData["Title"] = "تسجيل في الدورة";
    decimal priceInSyp      = (decimal)(ViewBag.PriceInSYP ?? 0m);
    decimal priceInUsd      = (decimal)(ViewBag.PriceInUSD ?? 0m);
    decimal traineeTotalSyp = (decimal)(ViewBag.TraineeTotalSYP ?? 0m);
    decimal traineeUsd      = (decimal)(ViewBag.TraineeBalanceUSD ?? 0m);
    decimal traineeSyp      = (decimal)(ViewBag.TraineeBalanceSYP ?? 0m);
    bool    insufficient    = ViewBag.InsufficientBalance == true;
    decimal neededSyp       = insufficient ? (decimal)(ViewBag.NeededSYP ?? 0m) : 0m;
    bool    canAfford       = traineeTotalSyp >= priceInSyp;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<style>
    :root {
        --teal:#0d9488; --teal-l:#14b8a6; --pr:#4f46e5;
        --success:#10b981; --danger:#ef4444; --warn:#f59e0b;
        --body:#f1f5f9; --card:#fff; --t1:#0f172a; --t2:#475569; --t3:#94a3b8;
        --border:#e2e8f0; --radius:16px; --shadow:0 4px 24px rgba(0,0,0,.09);
    }
    .pur-page { background:var(--body); min-height:100vh; direction:rtl; font-family:'Segoe UI',sans-serif; padding:32px 16px 60px; }
    .pur-inner { max-width:820px; margin:0 auto; }
    .pur-back { display:inline-flex; align-items:center; gap:6px; color:var(--teal); font-size:.87rem; font-weight:600; text-decoration:none; margin-bottom:24px; }
    .pur-back:hover { text-decoration:underline; }

    /* Hero course card */
    .pur-hero { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; margin-bottom:20px; }
    .pur-thumb { position:relative; aspect-ratio:16/5; background:linear-gradient(135deg,#1e1b4b,#312e81); overflow:hidden; }
    .pur-thumb img { width:100%; height:100%; object-fit:cover; }
    .pur-thumb .no-thumb { display:flex; align-items:center; justify-content:center; height:100%; font-size:5rem; color:rgba(255,255,255,.2); }
    .pur-body { padding:24px 28px; }
    .pur-course-name { font-size:1.5rem; font-weight:800; color:var(--t1); margin:0 0 8px; }
    .pur-desc { font-size:.9rem; color:var(--t2); line-height:1.7; margin:0 0 16px; }
    .pur-meta { display:flex; gap:16px; flex-wrap:wrap; }
    .pur-meta-item { display:flex; align-items:center; gap:6px; font-size:.82rem; color:var(--t3); }
    .pur-meta-item i { color:var(--teal); }

    /* Price breakdown */
    .pur-price-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); padding:24px 28px; margin-bottom:20px; }
    .pur-section-title { font-size:.95rem; font-weight:700; color:var(--t1); margin:0 0 16px; display:flex; align-items:center; gap:8px; }
    .pur-section-title i { color:var(--teal); }
    .pur-price-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--border); }
    .pur-price-row:last-child { border-bottom:none; }
    .pur-price-label { font-size:.88rem; color:var(--t2); }
    .pur-price-val { font-size:1rem; font-weight:700; color:var(--t1); }
    .pur-price-val.syp { color:var(--pr); }
    .pur-price-val.usd { color:var(--teal); }
    .pur-price-val.balance { color:var(--success); }
    .pur-price-val.balance-low { color:var(--danger); }

    /* Pay button */
    .pur-pay-btn {
        width:100%; padding:16px; border-radius:12px; border:none; cursor:pointer;
        font-size:1rem; font-weight:800; font-family:inherit; transition:.2s;
        display:flex; align-items:center; justify-content:center; gap:10px;
    }
    .pur-pay-btn.active { background:linear-gradient(135deg,#0d9488,#4f46e5); color:#fff; }
    .pur-pay-btn.active:hover { opacity:.9; }
    .pur-pay-btn.disabled { background:#e2e8f0; color:#94a3b8; cursor:not-allowed; }

    /* Insufficient balance screen */
    .pur-insufficient {
        background:#fff5f5; border:2px solid #fca5a5; border-radius:var(--radius);
        padding:28px 32px; margin-bottom:20px; text-align:center;
    }
    .pur-insufficient-icon { font-size:3rem; color:var(--danger); margin-bottom:12px; }
    .pur-insufficient h2 { font-size:1.3rem; font-weight:800; color:var(--t1); margin:0 0 8px; }
    .pur-insufficient p  { font-size:.9rem; color:var(--t2); margin:0 0 20px; line-height:1.7; }
    .pur-needed-box {
        display:inline-block; background:#fee2e2; border:1px solid #fca5a5;
        border-radius:10px; padding:10px 24px; margin-bottom:20px;
    }
    .pur-needed-label { font-size:.75rem; color:var(--danger); margin-bottom:3px; }
    .pur-needed-val   { font-size:1.5rem; font-weight:800; color:var(--danger); }
    .pur-deposit-btn {
        display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(135deg,#0d9488,#0891b2); color:#fff;
        padding:12px 28px; border-radius:10px; font-size:.95rem; font-weight:700;
        text-decoration:none; transition:.2s;
    }
    .pur-deposit-btn:hover { opacity:.88; color:#fff; }
</style>

<div class="pur-page">
    <div class="pur-inner">

        <a asp-action="Index" class="pur-back"><i class="fas fa-arrow-right"></i> العودة لقائمة الدورات</a>

        @if (insufficient)
        {
            <!-- Insufficient Balance Screen -->
            <div class="pur-insufficient">
                <div class="pur-insufficient-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <h2>اعتذار، رصيدك غير كافٍ</h2>
                <p>
                    رصيدك الحالي لا يكفي للتسجيل في دورة <strong>@Model.CourseName</strong>.<br/>
                    تحتاج إلى إيداع مبلغ إضافي بالليرة السورية.
                </p>
                <div class="pur-needed-box">
                    <div class="pur-needed-label">المبلغ المطلوب إضافته</div>
                    <div class="pur-needed-val">@neededSyp.ToString("N0") ل.س</div>
                </div>
                <br/>
                <a asp-controller="Trainees" asp-action="Deposit" class="pur-deposit-btn">
                    <i class="fas fa-plus-circle"></i> قم بإيداع المبلغ عبر شام كاش
                </a>
            </div>
        }

        <!-- Course Info -->
        <div class="pur-hero">
            @{
                string ytId = null;
                if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    var v = Model.VideoUrl;
                    if (v.Contains("v="))
                        try { ytId = System.Web.HttpUtility.ParseQueryString(new Uri(v).Query)["v"]; } catch { }
                    else if (v.Contains("youtu.be/"))
                        ytId = v.Split('/').Last().Split('?').First();
                }
                string thumb = Model.ThumbnailUrl;
                if (string.IsNullOrEmpty(thumb) && ytId != null)
                    thumb = $"https://img.youtube.com/vi/{ytId}/mqdefault.jpg";
            }
            <div class="pur-thumb">
                @if (!string.IsNullOrEmpty(thumb))
                {
                    <img src="@thumb" alt="@Model.CourseName" />
                }
                else
                {
                    <div class="no-thumb"><i class="fas fa-graduation-cap"></i></div>
                }
            </div>
            <div class="pur-body">
                <h1 class="pur-course-name">@Model.CourseName</h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="pur-desc">@Model.Description</p>
                }
                <div class="pur-meta">
                    <span class="pur-meta-item"><i class="fas fa-layer-group"></i> الدفعة @Model.BatchNumber</span>
                    <span class="pur-meta-item"><i class="fas fa-book-open"></i> @Model.NumberOfLectures محاضرة</span>
                    @if (Model.CourseTrainers?.Any() == true)
                    {
                        <span class="pur-meta-item">
                            <i class="fas fa-chalkboard-teacher"></i>
                            @string.Join("، ", Model.CourseTrainers.Select(ct => ct.Trainer?.User?.FullName ?? ""))
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- Price & Balance -->
        <div class="pur-price-card">
            <div class="pur-section-title"><i class="fas fa-receipt"></i> تفاصيل الدفع</div>
            <div class="pur-price-row">
                <span class="pur-price-label">سعر الدورة</span>
                <span class="pur-price-val syp">@priceInSyp.ToString("N0") ل.س</span>
            </div>
            <div class="pur-price-row">
                <span class="pur-price-label">ما يعادله بالدولار</span>
                <span class="pur-price-val usd">$ @priceInUsd.ToString("N2")</span>
            </div>
            <div class="pur-price-row">
                <span class="pur-price-label">رصيدك بالدولار</span>
                <span class="pur-price-val">$ @traineeUsd.ToString("N2")</span>
            </div>
            <div class="pur-price-row">
                <span class="pur-price-label">رصيدك بالليرة السورية</span>
                <span class="pur-price-val">@traineeSyp.ToString("N0") ل.س</span>
            </div>
            <div class="pur-price-row">
                <span class="pur-price-label">محصلة رصيدك (بالليرة)</span>
                <span class="pur-price-val @(canAfford ? "balance" : "balance-low")">
                    @traineeTotalSyp.ToString("N0") ل.س
                    @if (!canAfford) { <i class="fas fa-exclamation-circle" style="font-size:.85rem;"></i> }
                </span>
            </div>
        </div>

        <!-- Pay / Insufficient action -->
        @if (!insufficient)
        {
            if (canAfford)
            {
                <form asp-action="ConfirmPurchase" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@Model.CourseId" />
                    <button type="submit" class="pur-pay-btn active">
                        <i class="fas fa-lock"></i> ادفع الآن وسجّل في الدورة
                    </button>
                </form>
            }
            else
            {
                <button class="pur-pay-btn disabled" disabled>
                    <i class="fas fa-ban"></i> رصيدك غير كافٍ للدفع
                </button>
                <div style="margin-top:16px;text-align:center;">
                    <a asp-controller="Trainees" asp-action="Deposit" class="pur-deposit-btn">
                        <i class="fas fa-plus-circle"></i> قم بإيداع المبلغ عبر شام كاش
                    </a>
                </div>
            }
        }

    </div>
</div>
