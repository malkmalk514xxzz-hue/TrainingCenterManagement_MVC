@model TrainingCenterManagement_MVC.Models.Course

@{
    var courseDesc = string.IsNullOrWhiteSpace(Model.Description)
        ? $"تفاصيل كورس {Model.CourseName} — سجّل الآن وانضم لأفضل البرامج التدريبية المهنية."
        : Model.Description.Length > 160 ? Model.Description[..157] + "..." : Model.Description;

    ViewData["Title"]       = $"{Model.CourseName} | مركز التدريب";
    ViewData["Description"] = courseDesc;
    ViewData["Keywords"]    = $"{Model.CourseName}, كورس تدريبي, دورة مهنية, تسجيل في كورس, شهادة تدريب, مركز تدريب, {Model.CourseName} عبر الإنترنت";
    ViewData["OgImage"]     = string.IsNullOrEmpty(Model.ThumbnailUrl) ? null : Model.ThumbnailUrl;
    ViewData["JsonLdType"]  = "Course";
    ViewData["JsonLdName"]  = Model.CourseName;
    ViewData["JsonLdPrice"] = Model.Price.ToString("F2");
    ViewData["JsonLdDate"]  = Model.ReleaseDate != default ? Model.ReleaseDate.ToString("yyyy-MM-dd") : null;
}

<style>
    :root {
        --color-primary: #f2c00d;
        --color-background-light: #f5f4f0;
        --color-text-dark: #181611;
        --color-text-muted: #8a8160;
        --color-border: #e6e4db;
        --font-family-sans: Inter, "Noto Sans", sans-serif;
    }

    body {
        font-family: var(--font-family-sans);
        background-color: #fff;
        color: var(--color-text-dark);
        margin: 0;
    }

    .layout-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        width: 100%;
    }

    .main-content {
        flex: 1;
        display: flex;
        justify-content: center;
        padding: 20px 0;
        padding-left: 10rem;
        padding-right: 10rem;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        max-width: 960px;
        flex: 1;
    }

    .header-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 1rem;
    }

    .header-title {
        color: var(--color-text-dark);
        font-size: 32px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.015em;
        min-width: 18rem;
    }

    .info-section {
        padding: 1rem;
    }

    .card-container {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: flex-start;
        border-radius: 0.5rem;
    }

        .card-container > .image {
            width: 100%;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            aspect-ratio: 16 / 9;
            border-radius: 0.5rem;
        }

        .card-container > .content {
            display: flex;
            width: 100%;
            min-width: 18rem;
            flex-grow: 1;
            flex-direction: column;
            align-items: stretch;
            justify-content: center;
            gap: 0.25rem;
            padding: 1rem 0;
        }

        .card-container .title {
            color: var(--color-text-dark);
            font-size: 18px;
            font-weight: 700;
            line-height: 1.25;
            letter-spacing: -0.015em;
        }

        .card-container .description {
            color: var(--color-text-muted);
            font-size: 16px;
            font-weight: 400;
            line-height: 1.5;
        }

    .details-grid {
        padding: 1rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        border-top: 1px solid var(--color-border);
        padding: 1rem 0;
    }

        .detail-item:nth-child(odd) {
            padding-right: 0.5rem;
        }

        .detail-item:nth-child(even) {
            padding-left: 0.5rem;
        }

    .detail-label {
        color: var(--color-text-muted);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.5;
    }

    .detail-value {
        color: var(--color-text-dark);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.5;
    }

    .section-title {
        color: var(--color-text-dark);
        font-size: 22px;
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -0.015em;
        padding: 1.25rem 1rem 0.75rem 1rem;
    }

    .profile-card {
        padding: 1rem;
    }

    .profile-item {
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        gap: 1rem;
        border-radius: 0.5rem;
    }

        .profile-item .details {
            display: flex;
            flex-grow: 2;
            flex-basis: 0;
            flex-direction: column;
            gap: 1rem;
        }

            .profile-item .details .name {
                font-size: 16px;
                font-weight: 700;
                line-height: 1.25;
                color: var(--color-text-dark);
            }

            .profile-item .details .specialty {
                font-size: 14px;
                font-weight: 400;
                line-height: 1.5;
                color: var(--color-text-muted);
            }

        .profile-item .image {
            flex-grow: 1;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            aspect-ratio: 16 / 9;
            border-radius: 0.5rem;
        }

    .empty-state {
        display: flex;
        flex-direction: column;
        padding: 1rem;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        border: 2px dashed var(--color-border);
        border-radius: 0.5rem;
        padding: 3.5rem 1.5rem;
    }

    .empty-state-text {
        display: flex;
        max-width: 480px;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
    }

        .empty-state-text .title {
            color: var(--color-text-dark);
            font-size: 18px;
            font-weight: 700;
            line-height: 1.25;
            letter-spacing: -0.015em;
        }

        .empty-state-text .description {
            color: var(--color-text-dark);
            font-size: 14px;
            font-weight: 400;
            line-height: 1.5;
        }

    .button-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
    }

    .button-container {
        padding: 0.75rem 1rem;
    }

    .button {
        display: flex;
        min-width: 84px;
        max-width: 480px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 0.5rem;
        height: 40px;
        padding: 0 1rem;
        background-color: var(--color-background-light);
        color: var(--color-text-dark);
        font-size: 14px;
        font-weight: 700;
        line-height: 1.5;
        letter-spacing: 0.015em;
        border: none;
        white-space: nowrap;
        text-decoration: none;
    }

    .button-secondary {
        background-color: transparent;
        border: 1px solid var(--color-background-light);
    }

    .button-primary {
        background-color: var(--color-primary);
    }

    .profile-button {
        display: flex;
        min-width: 84px;
        max-width: 480px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 0.5rem;
        height: 32px;
        padding: 0 1rem;
        background-color: var(--color-background-light);
        color: var(--color-text-dark);
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        border: none;
        width: fit-content;
        text-decoration: none;
    }

    .badge {
        display: inline-block;
        padding: 0.25em 0.4em;
        font-size: 75%;
        font-weight: 700;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
        vertical-align: baseline;
        border-radius: 0.25rem;
        color: #fff;
    }

    .bg-success {
        background-color: #28a745;
    }

    .bg-danger {
        background-color: #dc3545;
    }
</style>
<div class="layout-container">
@Html.Partial("_LandingHeader")
    <div class="main-content">
