@model TrainingCenterManagement_MVC.Models.Course
@{
    var ratings   = Model.Ratings?.ToList() ?? new List<TrainingCenterManagement_MVC.Models.CourseRating>();
    var avgStars  = ratings.Any() ? ratings.Average(r => r.Stars) : 0.0;
    var myRating  = ViewBag.MyRating as TrainingCenterManagement_MVC.Models.CourseRating;
    bool isEnrolled = ViewBag.IsEnrolled == true;

    var trainersCount  = Model.CourseTrainers?.Count ?? 0;
    var traineesCount  = Model.CourseTrainees?.Count ?? 0;
    var lecturesCount  = Model.NumberOfLectures;

    var courseDesc = string.IsNullOrWhiteSpace(Model.Description)
        ? $"تفاصيل كورس {Model.CourseName} — سجّل الآن وانضم لأفضل البرامج التدريبية المهنية."
        : Model.Description.Length > 160 ? Model.Description[..157] + "..." : Model.Description;

    ViewData["Title"]       = $"{Model.CourseName} | مركز التدريب";
    ViewData["Description"] = courseDesc;

    // Extract YouTube video ID for course promo
    string? promoYtId = null;
    if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        var v = Model.VideoUrl;
        if (v.Contains("v="))
            try { promoYtId = System.Web.HttpUtility.ParseQueryString(new Uri(v).Query)["v"]; } catch { }
        else if (v.Contains("youtu.be/"))
            promoYtId = v.Split('/').Last().Split('?').First();
        else if (v.Contains("/embed/"))
            promoYtId = v.Split("/embed/").Last().Split('?').First();
        else if (!v.Contains(".") && v.Length < 20)
            promoYtId = v;
    }

    string statusColor = Model.IsDeleted ? "#ef4444" : "#10b981";
    string statusText  = Model.IsDeleted ? "محذوف" : "نشط";
    string statusBg    = Model.IsDeleted ? "#fee2e2" : "#d1fae5";
}

<link rel="stylesheet" href="~/css/TrainerDashboard.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --pr:#4f46e5; --pr-l:#6366f1; --pr-pale:#eef2ff;
        --gold:#f59e0b; --gold-pale:#fffbeb;
        --success:#10b981; --success-pale:#d1fae5;
        --danger:#ef4444; --danger-pale:#fee2e2;
        --warn:#f97316; --warn-pale:#fff7ed;
        --body:#f1f5f9; --card:#fff;
        --t1:#0f172a; --t2:#475569; --t3:#94a3b8;
        --border:#e2e8f0;
        --radius:14px; --radius-sm:8px;
        --shadow:0 4px 20px rgba(0,0,0,.08);
    }

    /* ── Page Shell ── */
    .cd-page { padding: 0; background: var(--body); min-height: 100vh; font-family: 'Segoe UI', Tahoma, sans-serif; direction: rtl; }

    /* ── Hero ── */
    .cd-hero {
        position: relative; overflow: hidden;
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
        padding: 0;
    }
    .cd-hero-bg {
        position: absolute; inset: 0;
        background-size: cover; background-position: center;
        opacity: .18; filter: blur(2px);
    }
    .cd-hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to left, rgba(30,27,75,.95) 0%, rgba(49,46,129,.7) 60%, rgba(67,56,202,.4) 100%);
    }
    .cd-hero-inner {
        position: relative; z-index: 2;
        display: flex; align-items: center; gap: 32px;
        padding: 40px 48px; max-width: 1200px; margin: 0 auto;
    }
    .cd-hero-thumb {
        flex-shrink: 0; width: 280px; height: 175px;
        border-radius: 12px; overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,.4);
        background: #1e1b4b;
        display: flex; align-items: center; justify-content: center;
    }
    .cd-hero-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
    .cd-hero-thumb .no-thumb {
        font-size: 4rem; color: rgba(255,255,255,.3);
    }
    .cd-hero-info { flex: 1; color: #fff; }
    .cd-hero-badges { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; }
    .cd-hero-badge {
        padding: 3px 10px; border-radius: 20px; font-size: .72rem; font-weight: 700;
        backdrop-filter: blur(6px);
    }
    .cd-hero-badge.active   { background: rgba(16,185,129,.25); border:1px solid rgba(16,185,129,.5); color:#6ee7b7; }
    .cd-hero-badge.deleted  { background: rgba(239,68,68,.25);  border:1px solid rgba(239,68,68,.5);  color:#fca5a5; }
    .cd-hero-badge.featured { background: rgba(245,158,11,.25); border:1px solid rgba(245,158,11,.5); color:#fcd34d; }
    .cd-hero-badge.batch    { background: rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2); color:#c7d2fe; }
    .cd-hero-title { font-size: 2rem; font-weight: 800; line-height: 1.2; margin: 0 0 10px; letter-spacing: -.02em; }
    .cd-hero-desc  { font-size: .9rem; color: rgba(255,255,255,.75); line-height: 1.65; margin: 0 0 20px; max-width: 560px; }
    .cd-hero-stats { display:flex; gap:24px; flex-wrap:wrap; }
    .cd-hero-stat  { display:flex; align-items:center; gap:7px; font-size:.84rem; color:rgba(255,255,255,.85); }
    .cd-hero-stat i { font-size:.9rem; color:var(--gold); }
    .cd-hero-actions { display:flex; gap:10px; flex-wrap:wrap; margin-top:20px; }
    .cd-ha {
        display:inline-flex; align-items:center; gap:6px;
        padding:9px 18px; border-radius:8px; font-size:.84rem; font-weight:600;
        text-decoration:none; cursor:pointer; border:none; transition:all .2s;
    }
    .cd-ha-primary { background: var(--pr); color:#fff; }
    .cd-ha-primary:hover { background: var(--pr-l); color:#fff; }
    .cd-ha-outline { background: rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.3); }
    .cd-ha-outline:hover { background: rgba(255,255,255,.2); color:#fff; }
    .cd-ha-gold { background: var(--gold); color:#1e1b4b; }
    .cd-ha-gold:hover { background:#d97706; color:#1e1b4b; }
    .cd-ha-danger { background: rgba(239,68,68,.2); color:#fca5a5; border:1px solid rgba(239,68,68,.4); }
    .cd-ha-danger:hover { background:#ef4444; color:#fff; }

    /* ── Breadcrumb ── */
    .cd-bc {
        background: var(--card); border-bottom: 1px solid var(--border);
        padding: 10px 48px; display:flex; align-items:center; gap:7px;
        font-size:.8rem; color:var(--t3);
    }
    .cd-bc a { color:var(--t2); text-decoration:none; }
    .cd-bc a:hover { color:var(--pr); }
    .cd-bc i { font-size:.6rem; }

    /* ── Stats Row ── */
    .cd-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; padding:24px 48px 0; }
    @@media(max-width:900px){ .cd-stats{ grid-template-columns:repeat(2,1fr); } }
    @@media(max-width:500px){ .cd-stats{ grid-template-columns:1fr; padding:16px; } }
    .cd-stat-card {
        background:var(--card); border-radius:var(--radius); border:1px solid var(--border);
        padding:18px 20px; display:flex; align-items:center; gap:14px;
        box-shadow:var(--shadow);
    }
    .cd-stat-icon {
        width:44px; height:44px; border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.1rem; flex-shrink:0;
    }
    .cd-stat-val { font-size:1.5rem; font-weight:800; color:var(--t1); line-height:1; }
    .cd-stat-lbl { font-size:.75rem; color:var(--t3); margin-top:2px; }

    /* ── Body Layout ── */
    .cd-body { padding: 24px 48px 48px; max-width: 1200px; margin: 0 auto; }
    @@media(max-width:700px){ .cd-body{ padding:16px; } }

    /* ── Tabs ── */
    .cd-tabs { display:flex; gap:0; background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; margin-bottom:24px; }
    .cd-tab {
        flex:1; padding:13px 10px; border:none; background:transparent;
        font-size:.84rem; font-weight:600; color:var(--t2); cursor:pointer;
        font-family:inherit; transition:all .2s; position:relative;
        display:flex; align-items:center; justify-content:center; gap:6px;
        border-left:1px solid var(--border);
    }
    .cd-tab:last-child { border-left:none; }
    .cd-tab.active { background:var(--pr-pale); color:var(--pr); }
    .cd-tab.active::after { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; background:var(--pr); border-radius:3px 3px 0 0; }
    .cd-tab-badge { background:var(--pr); color:#fff; font-size:.65rem; border-radius:10px; padding:1px 6px; min-width:18px; text-align:center; }
    .cd-tab.active .cd-tab-badge { background:var(--pr-l); }

    /* ── Panels ── */
    .cd-panel { display:none; }
    .cd-panel.active { display:block; }

    /* ── Section Card ── */
    .cd-card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); margin-bottom:20px; overflow:hidden; }
    .cd-ch { padding:14px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; background:linear-gradient(135deg,var(--pr-pale),#fff); }
    .cd-ch-left { display:flex; align-items:center; gap:9px; }
    .cd-ch-left i { font-size:.9rem; color:var(--pr); }
    .cd-ch-left h3 { font-size:.9rem; font-weight:700; color:var(--t1); margin:0; }
    .cd-cb { padding:20px; }

    /* ── Info Grid ── */
    .cd-info-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
    @@media(max-width:680px){ .cd-info-grid{ grid-template-columns:repeat(2,1fr); } }
    .cd-info-item { padding:14px 16px; border-bottom:1px solid var(--border); border-left:1px solid var(--border); }
    .cd-info-item:nth-child(3n+1) { border-right: 1px solid var(--border); }
    .cd-info-lbl { font-size:.72rem; color:var(--t3); font-weight:600; text-transform:uppercase; letter-spacing:.05em; margin-bottom:4px; }
    .cd-info-val { font-size:.88rem; color:var(--t1); font-weight:600; }

    /* ── Video Promo ── */
    .cd-promo { border-radius:10px; overflow:hidden; aspect-ratio:16/9; background:#000; }
    .cd-promo iframe { width:100%; height:100%; border:none; display:block; }
    .cd-promo-placeholder {
        aspect-ratio:16/9; border-radius:10px; background:linear-gradient(135deg,#1e1b4b,#312e81);
        display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; color:rgba(255,255,255,.6);
    }
    .cd-promo-placeholder i { font-size:3rem; }
    .cd-promo-placeholder p { font-size:.85rem; margin:0; }

    /* ── People Cards ── */
    .cd-people { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; }
    .cd-person-card {
        background:var(--body); border:1px solid var(--border); border-radius:10px;
        padding:16px; display:flex; align-items:center; gap:14px;
        transition:box-shadow .2s, border-color .2s;
    }
    .cd-person-card:hover { box-shadow:0 4px 12px rgba(79,70,229,.12); border-color:#c7d2fe; }
    .cd-avatar {
        width:46px; height:46px; border-radius:50%; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
        font-size:.95rem; font-weight:700; color:#fff;
    }
    .cd-person-name { font-size:.88rem; font-weight:700; color:var(--t1); }
    .cd-person-sub  { font-size:.76rem; color:var(--t2); margin-top:2px; }
    .cd-person-badge { font-size:.67rem; font-weight:600; padding:2px 8px; border-radius:10px; margin-top:5px; display:inline-block; }

    /* ── Empty State ── */
    .cd-empty { text-align:center; padding:40px 20px; color:var(--t3); }
    .cd-empty i { font-size:2.5rem; margin-bottom:12px; display:block; }
    .cd-empty p { font-size:.86rem; margin:0; }

    /* ── Tools Grid ── */
    .cd-tools { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:14px; }
    .cd-tool {
        display:flex; flex-direction:column; align-items:center; justify-content:center;
        gap:10px; padding:20px 16px; border-radius:10px; border:1.5px solid var(--border);
        background:var(--card); text-decoration:none; color:var(--t1);
        font-size:.82rem; font-weight:600; text-align:center;
        transition:all .2s; cursor:pointer;
    }
    .cd-tool:hover { border-color: var(--tool-color,var(--pr)); background: var(--tool-bg,var(--pr-pale)); color: var(--tool-color,var(--pr)); }
    .cd-tool-icon {
        width:44px; height:44px; border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.1rem; background:var(--tool-bg,var(--pr-pale)); color:var(--tool-color,var(--pr));
        transition:all .2s;
    }
    .cd-tool:hover .cd-tool-icon { background:var(--tool-color,var(--pr)); color:#fff; }

    /* ── Admin Actions Bar ── */
    .cd-admin-bar {
        background:var(--pr-pale); border:1px solid #c7d2fe; border-radius:var(--radius);
        padding:14px 20px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;
        margin-bottom:20px;
    }
    .cd-admin-bar-label { font-size:.78rem; font-weight:700; color:var(--pr); flex-shrink:0; display:flex; align-items:center; gap:5px; }
    .cd-ab-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:7px 14px; border-radius:7px; font-size:.8rem; font-weight:600;
        text-decoration:none; cursor:pointer; border:none; font-family:inherit;
        transition:all .2s;
    }
    .cd-ab-btn-primary { background:var(--pr); color:#fff; }
    .cd-ab-btn-primary:hover { background:var(--pr-l); color:#fff; }
    .cd-ab-btn-outline { background:#fff; color:var(--t2); border:1px solid var(--border); }
    .cd-ab-btn-outline:hover { border-color:var(--pr); color:var(--pr); }
    .cd-ab-btn-danger { background:#fff; color:var(--danger); border:1px solid #fca5a5; }
    .cd-ab-btn-danger:hover { background:var(--danger); color:#fff; }

    /* ── Ratings ── */
    .cd-rating-summary { display:flex; align-items:center; gap:24px; padding:16px 20px; border-bottom:1px solid var(--border); }
    .cd-big-score { font-size:3rem; font-weight:800; color:var(--t1); line-height:1; }
    .cd-stars-row { display:flex; gap:3px; font-size:1.2rem; }
    .cd-star-full { color:var(--gold); }
    .cd-star-empty { color:#e2e8f0; }
    .cd-rating-count { font-size:.78rem; color:var(--t3); margin-top:4px; }
    .cd-rating-bars { flex:1; display:flex; flex-direction:column; gap:5px; }
    .cd-rbar { display:flex; align-items:center; gap:8px; font-size:.73rem; color:var(--t2); }
    .cd-rbar-track { flex:1; height:6px; background:#e2e8f0; border-radius:3px; overflow:hidden; }
    .cd-rbar-fill  { height:100%; background:var(--gold); border-radius:3px; transition:width .6s ease; }
    .cd-review-item { padding:14px 20px; border-bottom:1px solid var(--border); }
    .cd-review-item:last-child { border-bottom:none; }
    .cd-review-head { display:flex; align-items:center; gap:10px; margin-bottom:6px; }
    .cd-review-avatar { width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.8rem; font-weight:700; color:#fff; flex-shrink:0; }
    .cd-review-name { font-size:.85rem; font-weight:700; color:var(--t1); }
    .cd-review-date { font-size:.72rem; color:var(--t3); margin-right:auto; }
    .cd-review-text { font-size:.83rem; color:var(--t2); line-height:1.6; margin:0; }

    /* ── Rate Form ── */
    .cd-rate-form { padding:20px; border-top:1px solid var(--border); background:linear-gradient(135deg,var(--pr-pale),#fff); }
    .cd-rate-title { font-size:.9rem; font-weight:700; color:var(--t1); margin-bottom:12px; display:flex; align-items:center; gap:7px; }
    .cd-stars-selector { display:flex; gap:6px; font-size:2rem; cursor:pointer; direction:ltr; margin-bottom:12px; }
    .cd-stars-selector span { transition:transform .1s; }
    .cd-stars-selector span:hover { transform:scale(1.15); }
    .cd-rate-ta { width:100%; padding:10px 12px; border:1.5px solid var(--border); border-radius:8px; font-size:.84rem; font-family:inherit; resize:vertical; min-height:80px; box-sizing:border-box; transition:border-color .2s; }
    .cd-rate-ta:focus { outline:none; border-color:var(--pr); box-shadow:0 0 0 3px rgba(79,70,229,.1); }

    /* ── Notify Banner ── */
    .cd-notify { margin:16px 0; padding:10px 16px; border-radius:8px; font-size:.84rem; display:flex; align-items:center; gap:8px; }
    .cd-notify.ok { background:var(--success-pale); color:#065f46; border:1px solid #6ee7b7; }
    .cd-notify.err { background:var(--danger-pale); color:#991b1b; border:1px solid #fca5a5; }
    .cd-enrolled-banner {
        background:linear-gradient(135deg,#ecfdf5,#d1fae5); border:1px solid #6ee7b7;
        border-radius:var(--radius); padding:16px 20px; margin-bottom:20px;
        display:flex; align-items:center; gap:12px;
    }
    .cd-enrolled-icon { width:40px; height:40px; background:var(--success); border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1rem; flex-shrink:0; }

    /* ── Responsive ── */
    @@media(max-width:900px) {
        .cd-hero-inner { flex-direction:column; padding:28px 20px; }
        .cd-hero-thumb { width:100%; height:200px; }
        .cd-bc, .cd-body { padding-right:16px; padding-left:16px; }
        .cd-stats { padding:16px; }
    }
    @@media(max-width:600px) {
        .cd-hero-title { font-size:1.45rem; }
        .cd-tabs { flex-wrap:wrap; }
        .cd-tab { flex-basis:50%; border-bottom:1px solid var(--border); }
    }
</style>

<div class="cd-page" dir="rtl" lang="ar">
    @Html.Partial("_LandingHeader")

    <!-- ── Hero ── -->
    <div class="cd-hero">
        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <div class="cd-hero-bg" style="background-image:url('@Model.ThumbnailUrl');"></div>
        }
        <div class="cd-hero-overlay"></div>
        <div class="cd-hero-inner">

            <!-- Thumbnail -->
            <div class="cd-hero-thumb">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <img src="@Model.ThumbnailUrl" alt="@Model.CourseName" />
                }
                else if (promoYtId != null)
                {
                    <img src="https://img.youtube.com/vi/@promoYtId/mqdefault.jpg" alt="@Model.CourseName" />
                }
                else
                {
                    <div class="no-thumb"><i class="fas fa-graduation-cap"></i></div>
                }
            </div>

            <!-- Info -->
            <div class="cd-hero-info">
                <div class="cd-hero-badges">
                    <span class="cd-hero-badge @(Model.IsDeleted ? "deleted" : "active")">
                        <i class="fas fa-circle" style="font-size:.5rem;vertical-align:middle;"></i>
                        @statusText
                    </span>
                    <span class="cd-hero-badge batch">
                        <i class="fas fa-layer-group" style="font-size:.7rem;"></i>
                        الدفعة @Model.BatchNumber
                    </span>
                    @if (Model.IsFeatured)
                    {
                        <span class="cd-hero-badge featured">
                            <i class="fas fa-star" style="font-size:.65rem;"></i> مميز
                        </span>
                    }
                </div>

                <h1 class="cd-hero-title">@Model.CourseName</h1>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="cd-hero-desc">@(Model.Description.Length > 200 ? Model.Description[..197] + "..." : Model.Description)</p>
                }

                <div class="cd-hero-stats">
                    <div class="cd-hero-stat">
                        <i class="fas fa-book-open"></i>
                        <span>@lecturesCount محاضرة</span>
                    </div>
                    <div class="cd-hero-stat">
                        <i class="fas fa-users"></i>
                        <span>@traineesCount متدرب</span>
                    </div>
                    @if (ratings.Any())
                    {
                        <div class="cd-hero-stat">
                            <i class="fas fa-star"></i>
                            <span>@avgStars.ToString("F1") / 5 (@ratings.Count تقييم)</span>
                        </div>
                    }
                    <div class="cd-hero-stat">
                        <i class="fas fa-tag"></i>
                        <span>@Model.Price.ToString("N0") ر.س</span>
                    </div>
                </div>

                <div class="cd-hero-actions">
                    @if (User.IsInRole("Trainee") && isEnrolled)
                    {
                        <a href="@Url.Action("ViewLectures","Trainees", new { courseId = Model.CourseId })" class="cd-ha cd-ha-primary">
                            <i class="fas fa-play-circle"></i> ابدأ التعلم
                        </a>
                        <a href="@Url.Action("CourseProgress","Progress", new { courseId = Model.CourseId })" class="cd-ha cd-ha-outline">
                            <i class="fas fa-chart-line"></i> تقدمي
                        </a>
                    }
                    else if (User.IsInRole("Trainee") && !isEnrolled)
                    {
                        <span class="cd-ha cd-ha-outline" style="cursor:default; opacity:.7;">
                            <i class="fas fa-lock"></i> غير مسجل
                        </span>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="@Url.Action("Edit","Courses", new { id = Model.CourseId })" class="cd-ha cd-ha-primary">
                            <i class="fas fa-edit"></i> تعديل
                        </a>
                        <a href="@Url.Action("AssignTrainer","Courses", new { id = Model.CourseId })" class="cd-ha cd-ha-outline">
                            <i class="fas fa-user-plus"></i> إضافة مدرب
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.VideoUrl))
                    {
                        <button type="button" class="cd-ha cd-ha-gold" onclick="showPromo()">
                            <i class="fas fa-play"></i> مشاهدة المقدمة
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Breadcrumb ── -->
    <nav class="cd-bc">
        <a href="/">الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="@Url.Action("Index","Courses")">الكورسات</a>
        <i class="fas fa-chevron-left"></i>
        <span style="color:var(--t1);font-weight:600;">@Model.CourseName</span>
    </nav>

    <!-- ── Stats Row ── -->
    <div class="cd-stats">
        <div class="cd-stat-card">
            <div class="cd-stat-icon" style="background:#eef2ff;color:#4f46e5;">
                <i class="fas fa-book-open"></i>
            </div>
            <div>
                <div class="cd-stat-val">@lecturesCount</div>
                <div class="cd-stat-lbl">إجمالي المحاضرات</div>
            </div>
        </div>
        <div class="cd-stat-card">
            <div class="cd-stat-icon" style="background:#d1fae5;color:#059669;">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <div class="cd-stat-val">@traineesCount</div>
                <div class="cd-stat-lbl">المتدربون المسجلون</div>
            </div>
        </div>
        <div class="cd-stat-card">
            <div class="cd-stat-icon" style="background:#fffbeb;color:#d97706;">
                <i class="fas fa-star"></i>
            </div>
            <div>
                <div class="cd-stat-val">@(ratings.Any() ? avgStars.ToString("F1") : "—")</div>
                <div class="cd-stat-lbl">متوسط التقييم</div>
            </div>
        </div>
        <div class="cd-stat-card">
            <div class="cd-stat-icon" style="background:#fff7ed;color:#ea580c;">
                <i class="fas fa-chalkboard-teacher"></i>
            </div>
            <div>
                <div class="cd-stat-val">@trainersCount</div>
                <div class="cd-stat-lbl">المدربون</div>
            </div>
        </div>
    </div>

    <!-- ── Body ── -->
    <div class="cd-body">

        <!-- Enrolled Banner -->
        @if (User.IsInRole("Trainee") && isEnrolled)
        {
            <div class="cd-enrolled-banner">
                <div class="cd-enrolled-icon"><i class="fas fa-check"></i></div>
                <div>
                    <div style="font-size:.88rem;font-weight:700;color:#065f46;">أنت مسجل في هذا الكورس</div>
                    <div style="font-size:.78rem;color:#047857;margin-top:2px;">يمكنك الوصول إلى جميع المحاضرات والمواد التدريبية</div>
                </div>
                <a href="@Url.Action("ViewLectures","Trainees", new { courseId = Model.CourseId })"
                   style="margin-right:auto;display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;background:var(--success);color:#fff;text-decoration:none;font-size:.82rem;font-weight:600;">
                    <i class="fas fa-arrow-left"></i> الذهاب للمحاضرات
                </a>
            </div>
        }

        <!-- Admin Bar -->
        @if (User.IsInRole("Admin"))
        {
            <div class="cd-admin-bar">
                <span class="cd-admin-bar-label"><i class="fas fa-shield-alt"></i> إجراءات الإدارة</span>
                <a href="@Url.Action("Edit","Courses", new { id = Model.CourseId })" class="cd-ab-btn cd-ab-btn-primary">
                    <i class="fas fa-edit"></i> تعديل الكورس
                </a>
                <a href="@Url.Action("AssignTrainer","Courses", new { id = Model.CourseId })" class="cd-ab-btn cd-ab-btn-outline">
                    <i class="fas fa-user-tie"></i> إضافة مدرب
                </a>
                <a href="@Url.Action("AssignTrainees","Courses", new { id = Model.CourseId })" class="cd-ab-btn cd-ab-btn-outline">
                    <i class="fas fa-user-graduate"></i> إضافة متدرب
                </a>
                <a href="@Url.Action("Index","Lectures")" class="cd-ab-btn cd-ab-btn-outline">
                    <i class="fas fa-book"></i> إدارة المحاضرات
                </a>
                <a href="@Url.Action("Index","Courses")" class="cd-ab-btn cd-ab-btn-outline" style="margin-right:auto;">
                    <i class="fas fa-arrow-right"></i> قائمة الكورسات
                </a>
            </div>
        }

        <!-- Notifications -->
        @if (TempData["RatingSuccess"] != null)
        {
            <div class="cd-notify ok"><i class="fas fa-check-circle"></i> @TempData["RatingSuccess"]</div>
        }
        @if (TempData["RatingError"] != null)
        {
            <div class="cd-notify err"><i class="fas fa-exclamation-circle"></i> @TempData["RatingError"]</div>
        }

        <!-- ── Tabs ── -->
        <div class="cd-tabs" role="tablist">
            <button class="cd-tab active" onclick="switchTab(this,'tab-info')">
                <i class="fas fa-info-circle"></i> معلومات
            </button>
            <button class="cd-tab" onclick="switchTab(this,'tab-trainers')">
                <i class="fas fa-chalkboard-teacher"></i> المدربون
                @if (trainersCount > 0) { <span class="cd-tab-badge">@trainersCount</span> }
            </button>
            @if (User.IsInRole("Admin") || User.IsInRole("Trainer"))
            {
                <button class="cd-tab" onclick="switchTab(this,'tab-trainees')">
                    <i class="fas fa-user-graduate"></i> المتدربون
                    @if (traineesCount > 0) { <span class="cd-tab-badge">@traineesCount</span> }
                </button>
            }
            <button class="cd-tab" onclick="switchTab(this,'tab-ratings')">
                <i class="fas fa-star"></i> التقييمات
                @if (ratings.Any()) { <span class="cd-tab-badge">@ratings.Count</span> }
            </button>
            <button class="cd-tab" onclick="switchTab(this,'tab-tools')">
                <i class="fas fa-tools"></i> الأدوات
            </button>
        </div>

        <!-- ══ Tab: Info ══ -->
        <div id="tab-info" class="cd-panel active">
            <div class="cd-card">
                <div class="cd-ch">
                    <div class="cd-ch-left"><i class="fas fa-info-circle"></i><h3>تفاصيل الكورس</h3></div>
                </div>
                <div class="cd-info-grid">
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">اسم الكورس</div>
                        <div class="cd-info-val">@Model.CourseName</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">رقم الدفعة</div>
                        <div class="cd-info-val">@Model.BatchNumber</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">عدد المحاضرات</div>
                        <div class="cd-info-val">@Model.NumberOfLectures محاضرة</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">السعر</div>
                        <div class="cd-info-val" style="color:var(--pr);font-size:1rem;">@Model.Price.ToString("N2") ر.س</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">تاريخ الإصدار</div>
                        <div class="cd-info-val">@Model.ReleaseDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">تاريخ الإنشاء</div>
                        <div class="cd-info-val">@Model.CreatedDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">الحالة</div>
                        <div class="cd-info-val">
                            <span style="padding:3px 10px;border-radius:12px;font-size:.78rem;font-weight:700;background:@statusBg;color:@statusColor;">
                                @statusText
                            </span>
                        </div>
                    </div>
                    <div class="cd-info-item">
                        <div class="cd-info-lbl">المشرف</div>
                        <div class="cd-info-val">@(Model.Admin?.User?.FullName ?? "—")</div>
                    </div>
                    @if (Model.IsFeatured)
                    {
                        <div class="cd-info-item">
                            <div class="cd-info-lbl">النوع</div>
                            <div class="cd-info-val">
                                <span style="padding:3px 10px;border-radius:12px;font-size:.78rem;font-weight:700;background:var(--gold-pale);color:#92400e;">
                                    <i class="fas fa-star"></i> كورس مميز
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="cd-card">
                    <div class="cd-ch">
                        <div class="cd-ch-left"><i class="fas fa-align-right"></i><h3>وصف الكورس</h3></div>
                    </div>
                    <div class="cd-cb">
                        <p style="font-size:.88rem;color:var(--t2);line-height:1.8;margin:0;">@Model.Description</p>
                    </div>
                </div>
            }

            @if (promoYtId != null)
            {
                <div class="cd-card">
                    <div class="cd-ch">
                        <div class="cd-ch-left"><i class="fas fa-play-circle" style="color:#ef4444;"></i><h3>فيديو تعريفي بالكورس</h3></div>
                    </div>
                    <div class="cd-cb">
                        <div class="cd-promo">
                            <iframe src="https://www.youtube.com/embed/@promoYtId"
                                    allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
                                    allowfullscreen></iframe>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══ Tab: Trainers ══ -->
        <div id="tab-trainers" class="cd-panel">
            <div class="cd-card">
                <div class="cd-ch">
                    <div class="cd-ch-left"><i class="fas fa-chalkboard-teacher"></i><h3>المدربون (@trainersCount)</h3></div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="@Url.Action("AssignTrainer","Courses", new { id = Model.CourseId })"
                           style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:7px;background:var(--pr);color:#fff;text-decoration:none;font-size:.78rem;font-weight:600;">
                            <i class="fas fa-plus"></i> إضافة مدرب
                        </a>
                    }
                </div>
                <div class="cd-cb">
                    @if (Model.CourseTrainers != null && Model.CourseTrainers.Any())
                    {
                        <div class="cd-people">
                            @{
                                string[] trainerColors = { "#4f46e5","#7c3aed","#0891b2","#059669","#d97706","#dc2626" };
                                int tci = 0;
                            }
                            @foreach (var ct in Model.CourseTrainers)
                            {
                                var col = trainerColors[tci++ % trainerColors.Length];
                                var initials = string.Join("", ct.Trainer.User.FullName.Split(' ').Take(2).Select(x => x.FirstOrDefault()));
                                <div class="cd-person-card">
                                    <div class="cd-avatar" style="background:@col;">@initials</div>
                                    <div>
                                        <div class="cd-person-name">@ct.Trainer.User.FullName</div>
                                        <div class="cd-person-sub">@(ct.Trainer.Specialty ?? "مدرب معتمد")</div>
                                        <span class="cd-person-badge" style="background:#eef2ff;color:var(--pr);">
                                            <i class="fas fa-chalkboard-teacher" style="font-size:.65rem;"></i> مدرب
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="cd-empty">
                            <i class="fas fa-chalkboard-teacher"></i>
                            <p>لم يتم تعيين مدربين لهذا الكورس بعد</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ══ Tab: Trainees ══ -->
        @if (User.IsInRole("Admin") || User.IsInRole("Trainer"))
        {
            <div id="tab-trainees" class="cd-panel">
                <div class="cd-card">
                    <div class="cd-ch">
                        <div class="cd-ch-left"><i class="fas fa-user-graduate"></i><h3>المتدربون (@traineesCount)</h3></div>
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("AssignTrainees","Courses", new { id = Model.CourseId })"
                               style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:7px;background:var(--pr);color:#fff;text-decoration:none;font-size:.78rem;font-weight:600;">
                                <i class="fas fa-plus"></i> إضافة متدرب
                            </a>
                        }
                    </div>
                    <div class="cd-cb">
                        @if (Model.CourseTrainees != null && Model.CourseTrainees.Any())
                        {
                            <!-- Search -->
                            <div style="margin-bottom:14px;position:relative;">
                                <i class="fas fa-search" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:.82rem;"></i>
                                <input type="text" id="trainee-search" placeholder="ابحث عن متدرب..."
                                       oninput="filterTrainees(this.value)"
                                       style="width:100%;padding:8px 36px 8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:.84rem;font-family:inherit;box-sizing:border-box;" />
                            </div>
                            <div class="cd-people" id="trainees-list">
                                @{
                                    string[] traineeColors = { "#7c3aed","#0891b2","#059669","#d97706","#4f46e5","#dc2626" };
                                    int tnci = 0;
                                }
                                @foreach (var ct in Model.CourseTrainees)
                                {
                                    var col = traineeColors[tnci++ % traineeColors.Length];
                                    var initials = string.Join("", ct.Trainee.User.FullName.Split(' ').Take(2).Select(x => x.FirstOrDefault()));
                                    <div class="cd-person-card" data-name="@ct.Trainee.User.FullName.ToLower()">
                                        <div class="cd-avatar" style="background:@col;">@initials</div>
                                        <div>
                                            <div class="cd-person-name">@ct.Trainee.User.FullName</div>
                                            <div class="cd-person-sub">@ct.Trainee.User.Email</div>
                                            <span class="cd-person-badge" style="background:var(--success-pale);color:#065f46;">
                                                <i class="fas fa-check" style="font-size:.65rem;"></i> مسجل
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="cd-empty">
                                <i class="fas fa-user-graduate"></i>
                                <p>لا يوجد متدربون مسجلون في هذا الكورس بعد</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ══ Tab: Ratings ══ -->
        <div id="tab-ratings" class="cd-panel">
            <div class="cd-card">
                <div class="cd-ch">
                    <div class="cd-ch-left"><i class="fas fa-star" style="color:var(--gold);"></i><h3>تقييمات الطلاب</h3></div>
                </div>

                @if (ratings.Any())
                {
                    <div class="cd-rating-summary">
                        <div style="text-align:center;flex-shrink:0;">
                            <div class="cd-big-score">@avgStars.ToString("F1")</div>
                            <div class="cd-stars-row" style="justify-content:center;margin:4px 0;">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span class="@(s <= Math.Round(avgStars) ? "cd-star-full" : "cd-star-empty")">★</span>
                                }
                            </div>
                            <div class="cd-rating-count">@ratings.Count تقييم</div>
                        </div>
                        <div class="cd-rating-bars">
                            @for (int s = 5; s >= 1; s--)
                            {
                                var cnt = ratings.Count(r => r.Stars == s);
                                var pct = ratings.Any() ? (cnt * 100.0 / ratings.Count) : 0;
                                <div class="cd-rbar">
                                    <span style="width:14px;text-align:left;">@s</span>
                                    <span style="color:var(--gold);font-size:.75rem;">★</span>
                                    <div class="cd-rbar-track">
                                        <div class="cd-rbar-fill" style="width:@pct.ToString("F0")%;"></div>
                                    </div>
                                    <span style="width:24px;text-align:center;">@cnt</span>
                                </div>
                            }
                        </div>
                    </div>

                    @foreach (var rating in ratings.OrderByDescending(r => r.CreatedAt).Take(10))
                    {
                        var rInitials = string.Join("", (rating.Trainee?.User?.FullName ?? "م").Split(' ').Take(2).Select(x => x.FirstOrDefault()));
                        string[] rColors = { "#4f46e5","#7c3aed","#0891b2","#059669","#d97706" };
                        var rCol = rColors[Math.Abs((rating.Trainee?.TraineeId ?? Guid.Empty).GetHashCode()) % rColors.Length];
                        <div class="cd-review-item">
                            <div class="cd-review-head">
                                <div class="cd-review-avatar" style="background:@rCol;">@rInitials</div>
                                <div>
                                    <div class="cd-review-name">@(rating.Trainee?.User?.FullName ?? "متدرب")</div>
                                    <div class="cd-stars-row" style="font-size:.85rem;">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <span class="@(s <= rating.Stars ? "cd-star-full" : "cd-star-empty")">★</span>
                                        }
                                    </div>
                                </div>
                                <span class="cd-review-date">@rating.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(rating.Comment))
                            {
                                <p class="cd-review-text">@rating.Comment</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="cd-empty">
                        <i class="fas fa-star"></i>
                        <p>لا توجد تقييمات لهذا الكورس بعد</p>
                    </div>
                }

                @if (User.IsInRole("Trainee") && isEnrolled)
                {
                    <div class="cd-rate-form">
                        <div class="cd-rate-title">
                            <i class="fas fa-pen-to-square" style="color:var(--pr);"></i>
                            @(myRating != null ? "عدّل تقييمك" : "أضف تقييمك")
                        </div>
                        <form asp-controller="CourseRatings" asp-action="Rate" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="courseId" value="@Model.CourseId" />
                            <div class="cd-stars-selector" id="starSelector">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span class="star-opt" data-val="@s"
                                          style="color:@(myRating != null && s <= myRating.Stars ? "#f59e0b" : "#e2e8f0");">★</span>
                                }
                            </div>
                            <input type="hidden" name="stars" id="starsInput" value="@(myRating?.Stars ?? 0)" required />
                            <textarea name="comment" class="cd-rate-ta" rows="3" maxlength="1000"
                                      placeholder="شاركنا رأيك في هذا الكورس (اختياري)...">@myRating?.Comment</textarea>
                            <div style="display:flex;gap:10px;margin-top:10px;">
                                <button type="submit" class="cd-ab-btn cd-ab-btn-primary" style="gap:6px;">
                                    <i class="fas fa-paper-plane"></i>
                                    @(myRating != null ? "تحديث التقييم" : "إرسال التقييم")
                                </button>
                                @if (myRating != null)
                                {
                                    <form asp-controller="CourseRatings" asp-action="Delete" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                                        <button type="submit" class="cd-ab-btn cd-ab-btn-danger"
                                                onclick="return confirm('هل تريد حذف تقييمك؟')">
                                            <i class="fas fa-trash-alt"></i> حذف التقييم
                                        </button>
                                    </form>
                                }
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- ══ Tab: Tools ══ -->
        <div id="tab-tools" class="cd-panel">
            <div class="cd-card">
                <div class="cd-ch">
                    <div class="cd-ch-left"><i class="fas fa-tools"></i><h3>الأدوات والتقارير</h3></div>
                </div>
                <div class="cd-cb">
                    <div class="cd-tools">
                        <a href="@Url.Action("ViewLectures","Trainees", new { courseId = Model.CourseId })"
                           class="cd-tool" style="--tool-color:#4f46e5;--tool-bg:#eef2ff;">
                            <div class="cd-tool-icon"><i class="fas fa-book-open"></i></div>
                            <span>المحاضرات</span>
                        </a>
                        <a href="@Url.Action("CourseAttendance","Courses", new { courseId = Model.CourseId })"
                           class="cd-tool" style="--tool-color:#0891b2;--tool-bg:#ecfeff;">
                            <div class="cd-tool-icon"><i class="fas fa-clipboard-check"></i></div>
                            <span>إحصائيات الحضور</span>
                        </a>
                        <a href="@Url.Action("TrackAttendance","Trainees", new { courseId = Model.CourseId })"
                           class="cd-tool" style="--tool-color:#059669;--tool-bg:#ecfdf5;">
                            <div class="cd-tool-icon"><i class="fas fa-chart-bar"></i></div>
                            <span>تتبع الحضور</span>
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Trainer"))
                        {
                            <a href="@Url.Action("ViewCoursePayments","Payments", new { courseId = Model.CourseId })"
                               class="cd-tool" style="--tool-color:#d97706;--tool-bg:#fffbeb;">
                                <div class="cd-tool-icon"><i class="fas fa-money-bill-wave"></i></div>
                                <span>مدفوعات الكورس</span>
                            </a>
                            <a href="@Url.Action("ExportPaymentsPdf","Payments", new { courseId = Model.CourseId })"
                               class="cd-tool" style="--tool-color:#dc2626;--tool-bg:#fff1f2;">
                                <div class="cd-tool-icon"><i class="fas fa-file-pdf"></i></div>
                                <span>تصدير PDF</span>
                            </a>
                        }
                        @if (User.IsInRole("Trainee") && isEnrolled)
                        {
                            <a href="@Url.Action("ViewPayments","Trainees", new { courseId = Model.CourseId })"
                               class="cd-tool" style="--tool-color:#7c3aed;--tool-bg:#f5f3ff;">
                                <div class="cd-tool-icon"><i class="fas fa-credit-card"></i></div>
                                <span>مدفوعاتي</span>
                            </a>
                            <a href="@Url.Action("CourseProgress","Progress", new { courseId = Model.CourseId })"
                               class="cd-tool" style="--tool-color:#059669;--tool-bg:#ecfdf5;">
                                <div class="cd-tool-icon"><i class="fas fa-chart-line"></i></div>
                                <span>تقدمي في الكورس</span>
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("Index","Lectures")"
                               class="cd-tool" style="--tool-color:#4f46e5;--tool-bg:#eef2ff;">
                                <div class="cd-tool-icon"><i class="fas fa-plus-circle"></i></div>
                                <span>إدارة المحاضرات</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /cd-body -->
</div><!-- /cd-page -->

<!-- ── Promo Video Modal ── -->
@if (!string.IsNullOrEmpty(Model.VideoUrl))
{
    <div id="promo-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.85);align-items:center;justify-content:center;" onclick="hidePromo(event)">
        <div style="width:min(900px,90vw);border-radius:14px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.6);" onclick="event.stopPropagation()">
            <div style="background:#0f172a;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;">
                <span style="color:#fff;font-size:.88rem;font-weight:600;">@Model.CourseName — فيديو تعريفي</span>
                <button onclick="hidePromo()" style="background:none;border:none;color:#94a3b8;font-size:1.2rem;cursor:pointer;"><i class="fas fa-times"></i></button>
            </div>
            <div id="promo-frame-wrap" style="aspect-ratio:16/9;background:#000;"></div>
        </div>
    </div>
}

<script>
    /* ── Tabs ── */
    function switchTab(btn, panelId) {
        document.querySelectorAll('.cd-tab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.cd-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(panelId)?.classList.add('active');
    }

    /* ── Star Rating ── */
    (function () {
        var stars = document.querySelectorAll('.star-opt');
        var input = document.getElementById('starsInput');
        if (!stars.length) return;
        function paint(n) {
            stars.forEach(s => s.style.color = +s.dataset.val <= n ? '#f59e0b' : '#e2e8f0');
        }
        stars.forEach(s => {
            s.addEventListener('mouseover', () => paint(+s.dataset.val));
            s.addEventListener('mouseout',  () => paint(+(input?.value || 0)));
            s.addEventListener('click',     () => { if(input) input.value = s.dataset.val; paint(+s.dataset.val); });
        });
    })();

    /* ── Trainee Search ── */
    function filterTrainees(q) {
        q = q.trim().toLowerCase();
        document.querySelectorAll('#trainees-list .cd-person-card').forEach(card => {
            card.style.display = card.dataset.name?.includes(q) ? '' : 'none';
        });
    }

    /* ── Promo Modal ── */
    var promoYtId = '@promoYtId';
    function showPromo() {
        var wrap = document.getElementById('promo-frame-wrap');
        if (wrap && promoYtId) {
            wrap.innerHTML = '<iframe src="https://www.youtube.com/embed/' + promoYtId + '?autoplay=1" allow="autoplay;accelerometer;clipboard-write;encrypted-media;picture-in-picture" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>';
        }
        var m = document.getElementById('promo-modal');
        if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
    }
    function hidePromo(e) {
        var m = document.getElementById('promo-modal');
        if (m) { m.style.display = 'none'; document.body.style.overflow = ''; }
        var wrap = document.getElementById('promo-frame-wrap');
        if (wrap) wrap.innerHTML = '';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePromo(); });
</script>
