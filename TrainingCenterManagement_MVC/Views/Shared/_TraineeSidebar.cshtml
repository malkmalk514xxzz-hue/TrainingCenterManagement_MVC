@using System.Globalization
@using TrainingCenterManagement_MVC.Resources
@using Microsoft.AspNetCore.Identity
@using TrainingCenterManagement_MVC.Models
@inject UserManager<ApplicationUser> UserManager
@{
    string currentPage = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
    Guid traineeId = ViewData["TraineeId"] != null ? Guid.Parse(ViewData["TraineeId"].ToString()) : Guid.Empty;
    var user = await UserManager.GetUserAsync(User);
    var profilePic = !string.IsNullOrEmpty(user?.ProfilePictureUrl) 
        ? user.ProfilePictureUrl 
        : "https://placehold.co/100/e2e8f0/60758a?text=User";
}

<style>
    html[dir="rtl"] .sidebar-nav ul li a i {
        margin-left: 8px;
    }

    html[dir="ltr"] .sidebar-nav ul li a i {
        margin-right: 8px;
    }

    .language-switcher {
        margin-top: 15px;
        position: relative;
        text-align: center;
    }

    .language-btn {
        background: none;
        border: 1px solid #ccc;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        width: 100%;
        text-align: left;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
        color: #333;
    }

    .language-dropdown {
        display: none;
        position: absolute;
        bottom: 100%;
        left: 0;
        width: 100%;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        z-index: 10;
        padding: 0;
        list-style: none;
    }

        .language-dropdown li a {
            display: block;
            padding: 8px 12px;
            color: #333;
            text-decoration: none;
        }

            .language-dropdown li a:hover {
                background-color: #f5f5f5;
            }
</style>

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <a href="/">
                <span class="logo-text">@SharedResource.TrainingCenter_</span>
            </a>
        </div>
        <button class="sidebar-toggle" aria-label="Toggle Sidebar">
            <i class="fas fa-bars"></i>
        </button>
    </div>
    <nav class="sidebar-nav">
        <ul>
            <li>
                <a asp-action="Index" asp-controller="Home">
                    <i class="fas fa-globe"></i><span>الصفحة الرئيسية</span>
                </a>
            </li>
            <li class="@(currentPage == "traineedashboard" ? "active" : "")">
                <a asp-action="TraineeDashboard" asp-controller="Dashboard">
                    <i class="fas fa-home"></i>
                    <span>@SharedResource.Dashboard</span>
                </a>
            </li>
            <li class="@(currentPage == "mycourses" ? "active" : "")">
                <a asp-controller="Trainees" asp-action="MyCourses">
                    <i class="fas fa-book"></i>
                    <span>@SharedResource.Courses</span>
                </a>
            </li>
            <li class="@(currentPage == "mycertificates" ? "active" : "")">
                <a asp-controller="Trainees" asp-action="MyCertificates">
                    <i class="fas fa-certificate"></i>
                    <span>@SharedResource.Certificates</span>
                </a>
            </li>
            <li class="@(currentPage == "trackattendance" ? "active" : "")">
                <a asp-controller="Trainees" asp-action="TrackAttendance">
                    <i class="fas fa-calendar-check"></i>
                    <span>@SharedResource.Attendance</span>
                </a>
            </li>
            <li class="@(currentPage == "index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")">
                <a asp-controller="Profile" asp-action="Index">
                    <i class="fas fa-user"></i>
                    <span>@SharedResource.Profile</span>
                </a>
            </li>
            <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Exams" && currentPage == "myexams" || ViewContext.RouteData.Values["controller"]?.ToString() == "ExamAttempt" ? "active" : "")">
                <a asp-controller="Exams" asp-action="MyExams">
                    <i class="fas fa-graduation-cap"></i>
                    <span>امتحاناتي</span>
                </a>
            </li>
            <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "PaymentRequests" ? "active" : "")">
                <a asp-controller="PaymentRequests" asp-action="MyRequests">
                    <i class="fas fa-credit-card"></i>
                    <span>مدفوعاتي</span>
                </a>
            </li>

            <li class="@(currentPage == "customersupportchat" ? "active" : "")">
                <a asp-controller="Chat" asp-action="Index">
                    <i class="fas fa-comments"></i>
                    <span>@SharedResource.Chat</span>
                </a>
            </li>
            <li>
                <a href="javascript:void(0)" onclick="aiW.toggle()" class="ai-sidebar-link">
                    <i class="fas fa-robot" style="color:#a78bfa"></i>
                    <span>المساعد الذكي</span>
                    <span class="ai-sidebar-badge">AI</span>
                </a>
            </li>
            <li class="@(currentPage == "index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Notifications" ? "active" : "")">
                <a asp-action="Index" asp-controller="Notifications" style="position:relative;">
                    <i class="fas fa-bell"></i>
                    <span class="sn-badge" data-hidden="true" aria-label="إشعارات غير مقروءة">0</span>
                    <span>الإشعارات</span>
                </a>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <img src="@profilePic" alt="User Avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
            </div>
            <div class="user-details">
                <span class="user-name">@(user?.FullName ?? SharedResource.AdminUser)</span>
                <span class="user-email">@(user?.Email ?? SharedResource.AdminEmail)</span>
            </div>
            <a asp-controller="Profile" asp-action="Index" class="user-settings" aria-label="User Settings" style="color: inherit; text-decoration: none;">
                <i class="fas fa-cog"></i>
            </a>
        </div>
        <div class="language-switcher">
            <button class="language-btn" id="languageToggle" aria-label="Toggle Language">
                @(CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "العربية" : "English")
                <i class="fas fa-chevron-down"></i>
            </button>
            <ul class="language-dropdown" id="languageList">
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="en" asp-route-returnUrl="@Context.Request.Path">English</a>
                </li>
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="ar" asp-route-returnUrl="@Context.Request.Path">العربية</a>
                </li>
            </ul>
        </div>
    </div>
</aside>
@await Html.PartialAsync("_NotificationsScript")
