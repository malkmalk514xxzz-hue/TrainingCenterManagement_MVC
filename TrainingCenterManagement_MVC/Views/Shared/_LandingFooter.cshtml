@using TrainingCenterManagement_MVC.Resources

<style>
    /* CSS Variables for colors, fonts, etc. */
    :root {
        --color-primary: #f2c00d;
        --color-background: #f5f5f5; /* Light gray for the footer */
        --color-text-dark: #181611;
        --color-text-muted: #8a8160;
        --font-family-sans: Inter, "Noto Sans", sans-serif;
    }

    /* Basic Page Styles */
    /* body {
        font-family: var(--font-family-sans);
        background-color: var(--color-background);
        color: var(--color-text-dark);
        margin: 0;
        direction: @(System.Threading.Thread.CurrentThread.CurrentUICulture.TextInfo.IsRightToLeft ? "rtl" : "ltr");
    } */

    .layout-container-footer {
        display: flex;
        flex-direction: column;
        min-height: 60vh;
        width: 100%;
        overflow-x: hidden;
        background-color: #f5f5f5;
    }

    .main-content-footer {
        flex: 1;
        display: flex;
        justify-content: center;
        padding: 20px 0;
        padding-left: 10rem;
        padding-right: 10rem;
    }

    .content-wrapper-footer {
        display: flex;
        flex-direction: column;
        max-width: 960px;
        flex: 1;
    }

    .hero-section-footer {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 1.5rem;
        padding: 2.5rem 1rem;
        text-align: center;
    }

    @@media (min-width: 480px) {
        .hero-section-footer {
            gap: 2rem;
            padding: 5rem 2.5rem;
        }
    }

    .hero-text-container-footer {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
    }

    .hero-title-footer {
        color: var(--color-text-dark);
        font-size: 28px; /* Reduced font size */
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -0.015em;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
    }

    @@media (min-width: 480px) {
        .hero-title-footer {
            font-size: 32px; /* Reduced font size */
            font-weight: 900;
            line-height: 1.25;
            letter-spacing: -0.033em;
        }
    }

    .hero-description-footer {
        color: var(--color-text-dark);
        font-size: 15px; /* Reduced font size */
        font-weight: 400;
        line-height: 1.5;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-container-footer {
        display: flex;
        flex-grow: 1;
        justify-content: center;
    }

    .cta-button-footer {
        display: flex;
        min-width: 84px;
        max-width: 480px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 0.5rem;
        height: 40px;
        padding: 0 1rem;
        background-color: var(--color-primary);
        color: var(--color-text-dark);
        font-size: 14px;
        font-weight: 700;
        line-height: 1.5;
        letter-spacing: 0.015em;
        border: none;
        white-space: nowrap;
        text-decoration: none;
    }

    @@media (min-width: 480px) {
        .cta-button-footer {
            height: 48px;
            padding: 0 1.25rem;
            font-size: 16px;
        }
    }

    .footer-section-footer {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 2.5rem 1.25rem;
        text-align: center;
        background-color: #f5f5f5; /* Light gray for the footer */
    }

    .footer-links-container-footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
    }

    @@media (min-width: 480px) {
        .footer-links-container-footer {
            flex-direction: row;
            justify-content: space-around;
        }
    }

    .footer-link-footer {
        color: var(--color-text-muted);
        font-size: 15px; /* Reduced font size */
        font-weight: 400;
        line-height: 1.5;
        min-width: 10rem;
        text-decoration: none;
    }

    .footer-text-footer {
        color: var(--color-text-muted);
        font-size: 15px; /* Reduced font size */
        font-weight: 400;
        line-height: 1.5;
    }
</style>

<div class="layout-container-footer">
    <div class="main-content-footer">
        <div class="content-wrapper-footer">
            <div class="hero-section-footer">
                <div class="hero-text-container-footer">
                    <h1 class="hero-title-footer">TrainingCenter</h1>
                    <p class="hero-description-footer">@SharedResource.TrainingCenterDescription</p>
                </div>
            </div>
            <footer class="footer-section-footer">
                <div class="footer-links-container-footer">
                    <a asp-controller="Chat" asp-action="CustomerSupportChat" class="footer-link-footer">@SharedResource.contact</a>
                    <a href="terms.html" class="footer-link-footer">@SharedResource.terms</a>
                    <a href="privacy.html" class="footer-link-footer">@SharedResource.privacy</a>
                    <a href="cookies.html" class="footer-link-footer">@SharedResource.cookies</a>
                </div>
                <p class="footer-text-footer">
                    &copy; <span id="current-year">2025</span> TrainingCenter. @SharedResource.allRightsReserved
                </p>
            </footer>
        </div>
    </div>
</div>

<script>
    document.getElementById('current-year').textContent = new Date().getFullYear();
</script>