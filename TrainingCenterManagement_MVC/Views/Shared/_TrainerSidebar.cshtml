@using System.Globalization
@using TrainingCenterManagement_MVC.Resources
@using Microsoft.AspNetCore.Identity
@using TrainingCenterManagement_MVC.Models
@inject UserManager<ApplicationUser> UserManager
@{
    string currentPage = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
    var user = await UserManager.GetUserAsync(User);
    var profilePic = !string.IsNullOrEmpty(user?.ProfilePictureUrl) 
        ? user.ProfilePictureUrl 
        : "https://placehold.co/100/e2e8f0/60758a?text=User";
}

<style>
    html[dir="rtl"] .sidebar-nav ul li a i {
        margin-left: 8px;
    }

    html[dir="ltr"] .sidebar-nav ul li a i {
        margin-right: 8px;
    }

    .language-switcher {
        margin-top: 15px;
        position: relative;
        text-align: center;
    }

    .language-btn {
        background: none;
        border: 1px solid #ccc;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        width: 100%;
        text-align: left;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
        color: #333;
    }

    .language-dropdown {
        display: none;
        position: absolute;
        bottom: 100%;
        left: 0;
        width: 100%;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        z-index: 10;
        padding: 0;
        list-style: none;
    }

        .language-dropdown li a {
            display: block;
            padding: 8px 12px;
            color: #333;
            text-decoration: none;
        }

            .language-dropdown li a:hover {
                background-color: #f5f5f5;
            }
</style>

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <a href="/">
                <span class="logo-text">Trainig Center</span>
            </a>
        </div>
        <button class="sidebar-toggle" aria-label="Toggle Sidebar">
            <i class="fas fa-bars"></i>
        </button>
    </div>
    <nav class="sidebar-nav">
        <ul>
          
            <li class="@(currentPage == "lectures" ? "active" : "")">
                <a asp-action="Index" asp-controller="Lectures">
                    <i class="fas fa-chalkboard-teacher"></i>
                    <span>@SharedResource.Lectures</span>
                </a>
            </li>
            <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Exams" || ViewContext.RouteData.Values["controller"]?.ToString() == "ExamAttempt" ? "active" : "")">
                <a asp-action="Index" asp-controller="Exams">
                    <i class="fas fa-file-alt"></i>
                    <span>الامتحانات</span>
                </a>
            </li>
            <li class="@(currentPage == "questionbank" ? "active" : "")">
                <a asp-action="QuestionBank" asp-controller="Exams">
                    <i class="fas fa-database"></i>
                    <span>بنك الأسئلة</span>
                </a>
            </li>
          
            <li class="@(currentPage == "presences" ? "active" : "")">
                <a asp-action="Index" asp-controller="Presences">
                    <i class="fas fa-check-circle"></i>
                    <span>@SharedResource.Attendance</span>
                </a>
            </li>
            <li class="@(currentPage == "certificates" ? "active" : "")">
                <a asp-action="Index" asp-controller="Certificates">
                    <i class="fas fa-certificate"></i>
                    <span>@SharedResource.IssueCertificate</span>
                </a>
            </li>
            <li class="@(currentPage == "chat" ? "active" : "")">
                <a asp-action="Index" asp-controller="Chat">
                    <i class="fas fa-comments"></i>
                    <span>@SharedResource.Chat</span>
                </a>
            </li>
            <li class="@(currentPage == "index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Notifications" ? "active" : "")">
                <a asp-action="Index" asp-controller="Notifications" style="position:relative;">
                    <i class="fas fa-bell"></i>
                    <span class="sn-badge" data-hidden="true" aria-label="إشعارات غير مقروءة">0</span>
                    <span>الإشعارات</span>
                </a>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <img src="@profilePic" alt="User Avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
            </div>
            <div class="user-details">
                <span class="user-name">@(user?.FullName ?? SharedResource.AdminUser)</span>
                <span class="user-email">@(user?.Email ?? SharedResource.AdminEmail)</span>
            </div>
            <a asp-controller="Profile" asp-action="Index" class="user-settings" aria-label="User settings" style="color: inherit; text-decoration: none;">
                <i class="fas fa-cog"></i>
            </a>
        </div>
        <div class="language-switcher">
            <button class="language-btn" id="languageToggle">
                @(CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "العربية" : "English")
                <i class="fas fa-chevron-down"></i>
            </button>
            <ul class="language-dropdown" id="languageList">
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="en">English</a>
                </li>
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="ar">العربية</a>
                </li>
            </ul>
        </div>
    </div>
</aside>
@await Html.PartialAsync("_NotificationsScript")

<script>
    const sidebarToggle = document.querySelector('.sidebar-toggle');
    const dashboardWrapper = document.querySelector('.dashboard-wrapper');

    sidebarToggle.addEventListener('click', () => {
      dashboardWrapper.classList.toggle('sidebar-collapsed');
    });

    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        tabButtons.forEach(btn => btn.classList.remove('active'));
        tabContents.forEach(content => content.classList.remove('active'));

        button.classList.add('active');
        const tabId = button.getAttribute('data-tab');
        document.getElementById(tabId).classList.add('active');
      });
    });
</script>

<script>
    const langBtn = document.getElementById('languageToggle');
    const langList = document.getElementById('languageList');

    langBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        langList.style.display = langList.style.display === 'block' ? 'none' : 'block';
    });

    document.addEventListener('click', function () {
        langList.style.display = 'none';
    });
</script>
