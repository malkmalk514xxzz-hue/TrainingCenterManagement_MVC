          { icon:'fas fa-credit-card',   color:'#10b981', bg:'#d1fae5', title:'مدفوعاتي',          url:'/Payments',           desc:'سجل مدفوعاتك',                          kw:['دفع','فاتورة','مبلغ'] },
          { icon:'fas fa-bell',          color:'#f59e0b', bg:'#fef3c7', title:'الإشعارات',          url:'/Notifications',      desc:'تنبيهاتك ورسائلك',                     kw:['إشعار','تنبيه'] },
          { icon:'fas fa-comments',      color:'#0ea5e9', bg:'#e0f2fe', title:'المحادثات',          url:'/Chat',               desc:'تواصل مع المدربين والزملاء',            kw:['شات','محادثة','رسالة'] },
          { icon:'fas fa-user-circle',   color:'#64748b', bg:'#f1f5f9', title:'ملفي الشخصي',        url:'/Profile',            desc:'بياناتك وإعداداتك',                     kw:['بروفايل','حساب','إعداد'] },
        ]
      }
    ]
  };

  const pages = ALL_PAGES[ROLE] || ALL_PAGES.Trainee;

  /* ── Open / Close ──────────────────────────────────── */
  function toggle() { _open ? close() : open(); }

  function open() {
    _open = true;
    const p = document.getElementById('ng-panel');
    p.classList.remove('ng-closing');
    p.classList.add('ng-open');
    p.setAttribute('aria-hidden','false');
    _render('');
    setTimeout(() => document.getElementById('ng-search')?.focus(), 280);
  }

  function close() {
    _open = false;
    const p = document.getElementById('ng-panel');
    p.classList.add('ng-closing');
    p.setAttribute('aria-hidden','true');
    setTimeout(() => p.classList.remove('ng-open','ng-closing'), 200);
  }

  /* ── Search ────────────────────────────────────────── */
  function search(val) {
    document.getElementById('ng-clear').style.display = val ? 'flex' : 'none';
    _render(val.trim());
  }

  function clearSearch() {
    const inp = document.getElementById('ng-search');
    inp.value = '';
    inp.focus();
    document.getElementById('ng-clear').style.display = 'none';
    _render('');
  }

  /* ── Render ────────────────────────────────────────── */
  function _render(q) {
    const container = document.getElementById('ng-results');
    const ql = q.toLowerCase();
    let html = '';
    let totalMatches = 0;

    pages.forEach(section => {
      const matched = section.pages.filter(p =>
        !ql ||
        p.title.includes(q) ||
        p.desc.includes(q)  ||
        (p.kw && p.kw.some(k => ql.includes(k) || k.includes(ql)))
      );
      if (!matched.length) return;
      totalMatches += matched.length;

      if (!ql) {
        html += `<div class="ng-section-title">${section.section}</div>`;
      }

      matched.forEach(p => {
        const current = window.location.pathname.startsWith(p.url) ? ' ng-active' : '';
        html += `
          <a href="${p.url}" class="ng-item${current}">
            <div class="ng-icon" style="background:${p.bg};color:${p.color}">
              <i class="${p.icon}"></i>
            </div>
            <div class="ng-item-info">
              <div class="ng-item-title">${_highlight(p.title, q)}</div>
              <div class="ng-item-desc">${p.desc}</div>
            </div>
            <i class="fas fa-chevron-left ng-item-arrow"></i>
          </a>`;
      });
    });

    if (totalMatches === 0) {
      html = `<div class="ng-empty">
                <i class="fas fa-search"></i>
                <p>لا توجد نتائج لـ "<strong>${q}</strong>"<br>جرّب كلمة أخرى</p>
              </div>`;
    }

    container.innerHTML = html;
  }

  function _highlight(text, q) {
    if (!q) return text;
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
    return text.replace(re, '<mark style="background:#bfdbfe;border-radius:3px;padding:0 2px">$1</mark>');
  }

  /* ── Init ──────────────────────────────────────────── */
  document.getElementById('ng-fab').addEventListener('click', toggle);

  // Close on outside click
  document.addEventListener('click', e => {
    if (!_open) return;
    const root = document.getElementById('ng-root');
    if (!root.contains(e.target)) close();
  });

  return { toggle, open, close, search, clearSearch };
})();
</script>
