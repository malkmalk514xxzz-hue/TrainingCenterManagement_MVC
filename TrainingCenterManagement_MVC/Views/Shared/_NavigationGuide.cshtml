@* Navigation Guide Widget — role-aware site navigator *@
@{
    var role = User.IsInRole("Admin")        ? "Admin"
             : User.IsInRole("Trainer")      ? "Trainer"
             : User.IsInRole("Receptionist") ? "Receptionist"
             : "Trainee";
}

<div id="ng-root">

  <button id="ng-fab" title="دليل التصفح" aria-label="دليل التصفح">
    <span class="ng-fab-glow"></span>
    <span class="ng-fab-inner">
      <i class="fas fa-compass"></i>
      <span>دليل الموقع</span>
    </span>
  </button>

  <div id="ng-panel" aria-hidden="true">
    <div class="ng-header">
      <div class="ng-header-icon"><i class="fas fa-compass"></i></div>
      <div class="ng-header-info">
        <div class="ng-title">دليل التصفح</div>
        <div class="ng-sub">ابحث عن أي صفحة بسرعة</div>
      </div>
      <button class="ng-close" onclick="ngW.close()" title="إغلاق">
        <i class="fas fa-xmark"></i>
      </button>
    </div>

    <div class="ng-search-row">
      <div class="ng-search-box">
        <i class="fas fa-search ng-search-icon"></i>
        <input type="text" id="ng-search" class="ng-search-inp"
               placeholder="ابحث عن صفحة… (مثال: دفع، دورات، حضور)"
               oninput="ngW.search(this.value)" autocomplete="off">
        <button class="ng-search-clear" id="ng-clear" onclick="ngW.clearSearch()" style="display:none">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>

    <div id="ng-body" class="ng-body">
      <div id="ng-results"></div>
    </div>

    <div class="ng-footer">
      <i class="fas fa-lightbulb" style="color:#f59e0b;margin-left:5px"></i>
      اضغط على أي صفحة للانتقال إليها مباشرةً
    </div>
  </div>

</div>

<style>
#ng-root {
  --c1: #0ea5e9;
  --c2: #0284c7;
  --head-bg: linear-gradient(135deg,#0c4a6e,#075985);
  font-family: 'Segoe UI', system-ui, sans-serif;
  direction: rtl;
}

/* ── FAB ──────────────────────────────────────────────── */
#ng-fab {
  position: fixed;
  bottom: 90px;   /* stacked above #ai-fab (bottom:28px) — keeps right column tidy */
  right: 28px;
  left: auto;
  z-index: 9996;
  border: none;
  cursor: pointer;
  padding: 0;
  background: transparent;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1);
}
#ng-fab:hover  { transform: translateY(-3px); }
#ng-fab:active { transform: scale(.96); }

.ng-fab-glow {
  position: absolute; inset: -4px; border-radius: 30px;
  background: linear-gradient(135deg,var(--c1),var(--c2));
  opacity: .28; filter: blur(9px);
  animation: ngGlow 3s ease-in-out infinite; pointer-events: none;
}
@@keyframes ngGlow {
  0%,100% { opacity:.25; transform:scale(1); }
  50%      { opacity:.45; transform:scale(1.08); }
}

.ng-fab-inner {
  position: relative; display: flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg,var(--c1),var(--c2));
  color: #fff; padding: 10px 18px 10px 12px; border-radius: 28px;
  font-size: .85rem; font-weight: 700;
  box-shadow: 0 5px 20px rgba(14,165,233,.42);
  pointer-events: none;
}
.ng-fab-inner i { font-size: .95rem; }

/* ── PANEL ────────────────────────────────────────────── */
#ng-panel {
  position: fixed;
  bottom: 148px;  /* opens upward from #ng-fab at bottom:90px */
  right: 28px;
  left: auto;
  z-index: 9997;
  width: 380px;
  max-height: calc(100vh - 180px);
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 24px 70px rgba(0,0,0,.2), 0 0 0 1px rgba(0,0,0,.06);
  display: none;
  flex-direction: column;
  overflow: hidden;
  transform-origin: bottom right;
}
#ng-panel.ng-open    { display: flex; animation: ngIn  .3s cubic-bezier(.34,1.56,.64,1) both; }
#ng-panel.ng-closing { animation: ngOut .2s ease forwards; }

@@keyframes ngIn  { from { opacity:0; transform:translateY(16px) scale(.93); } to { opacity:1; transform:none; } }
@@keyframes ngOut { to   { opacity:0; transform:translateY(12px) scale(.96); } }

/* ── HEADER ───────────────────────────────────────────── */
.ng-header {
  background: var(--head-bg);
  padding: 14px 16px;
  display: flex; align-items: center; gap: 10px;
  flex-shrink: 0;
}
.ng-header-icon {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; color: #fff; flex-shrink: 0;
}
.ng-header-info { flex: 1; }
.ng-title { font-weight: 700; font-size: .92rem; color: #fff; }
.ng-sub   { font-size: .7rem;  color: rgba(255,255,255,.65); margin-top: 1px; }
.ng-close {
  width: 30px; height: 30px; border-radius: 8px; border: none; cursor: pointer;
  background: rgba(255,255,255,.12); color: rgba(255,255,255,.8);
  display: flex; align-items: center; justify-content: center;
  transition: background .15s;
}
.ng-close:hover { background: rgba(255,255,255,.22); color: #fff; }

/* ── SEARCH ───────────────────────────────────────────── */
.ng-search-row { padding: 12px 14px 8px; flex-shrink: 0; }
.ng-search-box {
  background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 12px;
  display: flex; align-items: center; padding: 0 12px; gap: 8px;
  transition: border-color .18s;
}
.ng-search-box:focus-within { border-color: var(--c1); background: #fff; }
.ng-search-icon { color: #94a3b8; font-size: .8rem; flex-shrink: 0; }
.ng-search-inp {
  flex: 1; border: none; background: transparent; outline: none;
  font-size: .84rem; color: #0f172a; padding: 9px 0; direction: rtl;
  font-family: inherit;
}
.ng-search-inp::placeholder { color: #94a3b8; }
.ng-search-clear {
  background: none; border: none; cursor: pointer;
  color: #94a3b8; font-size: .8rem; padding: 4px; flex-shrink: 0;
  transition: color .15s;
}
.ng-search-clear:hover { color: #475569; }

/* ── BODY ─────────────────────────────────────────────── */
.ng-body {
  flex: 1; overflow-y: auto; padding: 4px 10px 10px;
}
.ng-body::-webkit-scrollbar { width: 4px; }
.ng-body::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

/* ── SECTION ──────────────────────────────────────────── */
.ng-section { margin-bottom: 4px; }
.ng-section-title {
  font-size: .68rem; font-weight: 800; color: #94a3b8;
  padding: 8px 6px 4px; letter-spacing: .06em; text-transform: uppercase;
}

/* ── PAGE ITEM ────────────────────────────────────────── */
.ng-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 10px; border-radius: 12px; cursor: pointer;
  text-decoration: none; color: inherit;
  transition: background .15s, transform .12s;
  margin-bottom: 3px;
}
.ng-item:hover { background: #f0f9ff; transform: translateX(-2px); text-decoration: none; color: inherit; }
.ng-item.ng-active { background: #e0f2fe; }
.ng-icon {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: .85rem;
}
.ng-item-info { flex: 1; min-width: 0; }
.ng-item-title { font-size: .84rem; font-weight: 600; color: #0f172a; }
.ng-item-desc  { font-size: .7rem;  color: #64748b; margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ng-item-arrow { color: #cbd5e1; font-size: .7rem; flex-shrink: 0; }
.ng-item:hover .ng-item-arrow { color: var(--c1); }

/* ── EMPTY STATE ──────────────────────────────────────── */
.ng-empty {
  text-align: center; padding: 28px 16px; color: #94a3b8;
}
.ng-empty i { font-size: 2rem; display: block; margin-bottom: 8px; opacity: .4; }
.ng-empty p { font-size: .82rem; }

/* ── FOOTER ───────────────────────────────────────────── */
.ng-footer {
  padding: 8px 14px; background: #f8fafc;
  border-top: 1px solid #f1f5f9;
  font-size: .72rem; color: #94a3b8; flex-shrink: 0;
  display: flex; align-items: center;
}

/* ── MOBILE ───────────────────────────────────────────── */
@@media (max-width: 640px) {
  #ng-fab { bottom: 20px !important; right: 16px !important; left: auto !important; }
  #ng-panel {
    bottom: 0 !important; left: 0 !important; right: 0 !important;
    width: 100% !important; max-height: 88dvh !important;
    border-radius: 20px 20px 0 0 !important;
    transform-origin: bottom center !important;
  }
}
</style>

