@using System.Globalization
@using TrainingCenterManagement_MVC.Resources
@inject Microsoft.AspNetCore.Mvc.Rendering.IHtmlHelper HtmlHelper
@{
    string currentPage = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
}

<style>
    html[dir="rtl"] .sidebar-nav ul li a i {
        margin-left: 8px;
    }

    html[dir="ltr"] .sidebar-nav ul li a i {
        margin-right: 8px;
    }

    .language-switcher {
        margin-top: 15px;
        position: relative;
        text-align: center;
    }

    .language-btn {
        background: none;
        border: 1px solid #ccc;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        width: 100%;
        text-align: left;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
        color: #333;
    }

    .language-dropdown {
        display: none;
        position: absolute;
        bottom: 100%;
        left: 0;
        width: 100%;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        z-index: 10;
        padding: 0;
        list-style: none;
    }

        .language-dropdown li a {
            display: block;
            padding: 8px 12px;
            color: #333;
            text-decoration: none;
        }

            .language-dropdown li a:hover {
                background-color: #f5f5f5;
            }
</style>

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <a href="/">
                <span class="logo-text">TrainingCenter</span>
            </a>
        </div>
        <button class="sidebar-toggle" aria-label="Toggle Sidebar">
            <i class="fas fa-bars"></i>
        </button>
    </div>
    <nav class="sidebar-nav">
        <ul>
            <li class="@(currentPage == "receptionistdashboard" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="dashboard-stats">
                    <i class="fas fa-home"></i>
                    <span>@SharedResource.Dashboard</span>
                </a>
            </li>
            <li class="@(currentPage == "register" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="register">
                    <i class="fas fa-user-plus"></i>
                    <span>@SharedResource.RegisterNewCustomer</span>
                </a>
            </li>
            <li class="@(currentPage == "registertraineetocourse" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="register-course">
                    <i class="fas fa-user-check"></i>
                    <span>@SharedResource.RegisterCourse</span>
                </a>
            </li>
            <li class="@(currentPage == "unregistertraineefromcourse" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="register-course">
                    <i class="fas fa-user-times"></i>
                    <span>@SharedResource.UnregisterCourse</span>
                </a>
            </li>
            <li class="@(currentPage == "create" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="add-payment">
                    <i class="fas fa-money-bill"></i>
                    <span>@SharedResource.AddPayment</span>
                </a>
            </li>
            <li class="@(currentPage == "paymentreports" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="add-payment">
                    <i class="fas fa-file-invoice-dollar"></i>
                    <span>@SharedResource.PaymentReports</span>
                </a>
            </li>
            <li class="@(currentPage == "paymentreportpdf" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="add-payment">
                    <i class="fas fa-file-pdf"></i>
                    <span>@SharedResource.ExportPaymentReport</span>
                </a>
            </li>
            <li class="@(currentPage == "attendancereports" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="attendance-reports">
                    <i class="fas fa-clipboard-check"></i>
                    <span>@SharedResource.AttendanceReports</span>
                </a>
            </li>
            <li class="@(currentPage == "attendancereportpdf" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="attendance-reports">
                    <i class="fas fa-file-pdf"></i>
                    <span>@SharedResource.ExportAttendanceReport</span>
                </a>
            </li>
            <li class="@(currentPage == "coursedetails" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="course-details">
                    <i class="fas fa-info-circle"></i>
                    <span>@SharedResource.CourseDetails</span>
                </a>
            </li>
            <li class="@(currentPage == "contacttrainees" ? "active" : "")">
                <a href="#" class="tab-btn" data-tab="contact-trainees">
                    <i class="fas fa-envelope"></i>
                    <span>@SharedResource.ContactTrainees</span>
                </a>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <img src="https://placehold.co/100" alt="Receptionist">
            </div>
           
            <button class="user-settings" aria-label="User settings">
                <i class="fas fa-cog"></i>
            </button>
        </div>
        <div class="language-switcher">
            <button class="language-btn" id="languageToggle">
                @(CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "العربية" : "English")
                <i class="fas fa-chevron-down"></i>
            </button>
            <ul class="language-dropdown" id="languageList">
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="en">English</a>
                </li>
                <li>
                    <a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="ar">العربية</a>
                </li>
            </ul>
        </div>
    </div>
</aside>

<script>
    const sidebarToggle = document.querySelector('.sidebar-toggle');
    const dashboardWrapper = document.querySelector('.dashboard-wrapper');

    sidebarToggle.addEventListener('click', () => {
        dashboardWrapper.classList.toggle('sidebar-collapsed');
    });

    const langBtn = document.getElementById('languageToggle');
    const langList = document.getElementById('languageList');

    langBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        langList.style.display = langList.style.display === 'block' ? 'none' : 'block';
    });

    document.addEventListener('click', function () {
        langList.style.display = 'none';
    });
</script>