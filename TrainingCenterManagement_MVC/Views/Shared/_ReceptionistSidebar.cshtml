@using System.Globalization
@using TrainingCenterManagement_MVC.Resources
@using Microsoft.AspNetCore.Identity
@using TrainingCenterManagement_MVC.Models
@inject UserManager<ApplicationUser> UserManager
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() ?? "";
    var user   = await UserManager.GetUserAsync(User);
    var profilePic = !string.IsNullOrEmpty(user?.ProfilePictureUrl)
        ? user.ProfilePictureUrl
        : "https://placehold.co/100/e2e8f0/1e293b?text=R";

    bool IsActive(string controller, string act = "") =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
        (string.IsNullOrEmpty(act) || action == act.ToLower());
}

<style>
    html[dir="rtl"] .sidebar-nav ul li a i { margin-left: 8px; }
    html[dir="ltr"]  .sidebar-nav ul li a i { margin-right: 8px; }
    .language-switcher { margin-top: 15px; position: relative; text-align: center; }
    .language-btn {
        background: none; border: 1px solid #ccc; padding: 6px 12px; border-radius: 6px;
        cursor: pointer; width: 100%; text-align: left; display: flex;
        justify-content: space-between; align-items: center; font-size: 14px; color: #333;
    }
    .language-dropdown {
        display: none; position: absolute; bottom: 100%; left: 0; width: 100%;
        background: #fff; border: 1px solid #ddd; border-radius: 6px;
        box-shadow: 0 4px 10px rgba(0,0,0,.05); z-index: 10; padding: 0; list-style: none;
    }
    .language-dropdown li a { display: block; padding: 8px 12px; color: #333; text-decoration: none; }
    .language-dropdown li a:hover { background: #f5f5f5; }
</style>

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <a href="/"><span class="logo-text">Training Center</span></a>
        </div>
        <button class="sidebar-toggle" aria-label="Toggle Sidebar">
            <i class="fas fa-bars"></i>
        </button>
    </div>
    <nav class="sidebar-nav">
        <ul>
            <li>
                <a asp-action="Index" asp-controller="Home">
                    <i class="fas fa-globe"></i><span>الصفحة الرئيسية</span>
                </a>
            </li>
            <li class="@(IsActive("Dashboard", "ReceptionistDashboard") ? "active" : "")">
                <a asp-action="ReceptionistDashboard" asp-controller="Dashboard">
                    <i class="fas fa-home"></i><span>لوحة التحكم</span>
                </a>
            </li>
            <li class="@(IsActive("Account", "Register") ? "active" : "")">
                <a asp-action="Register" asp-controller="Account">
                    <i class="fas fa-user-plus"></i><span>تسجيل طالب جديد</span>
                </a>
            </li>
            <li class="@(IsActive("Receptionists", "RegisterTraineeToCourse") ? "active" : "")">
                <a asp-action="RegisterTraineeToCourse" asp-controller="Receptionists">
                    <i class="fas fa-user-check"></i><span>تسجيل في دورة</span>
                </a>
            </li>
            <li class="@(IsActive("Receptionists", "UnregisterTraineeFromCourse") ? "active" : "")">
                <a asp-action="UnregisterTraineeFromCourse" asp-controller="Receptionists">
                    <i class="fas fa-user-times"></i><span>إلغاء تسجيل</span>
                </a>
            </li>
            <li class="@(IsActive("Payments") ? "active" : "")">
                <a asp-action="Create" asp-controller="Payments">
                    <i class="fas fa-money-bill-wave"></i><span>إضافة دفعة مالية</span>
                </a>
            </li>
            <li class="@(IsActive("Receptionists", "PaymentReports") ? "active" : "")">
                <a asp-action="PaymentReports" asp-controller="Receptionists">
                    <i class="fas fa-file-invoice-dollar"></i><span>تقارير المدفوعات</span>
                </a>
            </li>
            <li class="@(IsActive("Receptionists", "AttendanceReports") ? "active" : "")">
                <a asp-action="AttendanceReports" asp-controller="Receptionists">
                    <i class="fas fa-clipboard-check"></i><span>تقارير الحضور</span>
                </a>
            </li>
            <li class="@(IsActive("Receptionists", "ContactTrainees") ? "active" : "")">
                <a asp-action="ContactTrainees" asp-controller="Receptionists">
                    <i class="fas fa-envelope"></i><span>التواصل مع الطلاب</span>
                </a>
            </li>
            <li>
                <a href="javascript:void(0)" onclick="aiW.toggle()" class="ai-sidebar-link">
                    <i class="fas fa-robot" style="color:#a78bfa"></i>
                    <span>المساعد الذكي</span>
                    <span class="ai-sidebar-badge">AI</span>
                </a>
            </li>
            <li class="@(IsActive("Notifications") ? "active" : "")">
                <a asp-action="Index" asp-controller="Notifications" style="position:relative;">
                    <i class="fas fa-bell"></i>
                    <span class="sn-badge" data-hidden="true" aria-label="إشعارات غير مقروءة">0</span>
                    <span>الإشعارات</span>
                </a>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <img src="@profilePic" alt="Receptionist" style="width:40px;height:40px;border-radius:50%;object-fit:cover;">
            </div>
            <div class="user-details">
                <span class="user-name">@(user?.FullName ?? "موظف استقبال")</span>
                <span class="user-email">@(user?.Email ?? "")</span>
            </div>
            <a asp-controller="Profile" asp-action="Index" class="user-settings" style="color:inherit;text-decoration:none;">
                <i class="fas fa-cog"></i>
            </a>
        </div>
        <div class="language-switcher">
            <button class="language-btn" id="languageToggle">
                @(CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "العربية" : "English")
                <i class="fas fa-chevron-down"></i>
            </button>
            <ul class="language-dropdown" id="languageList">
                <li><a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="en">English</a></li>
                <li><a asp-controller="Language" asp-action="ChangeLanguage" asp-route-lang="ar">العربية</a></li>
            </ul>
        </div>
    </div>
</aside>

@await Html.PartialAsync("_NotificationsScript")

<script>
    document.querySelector('.sidebar-toggle')?.addEventListener('click', () =>
        document.querySelector('.dashboard-wrapper, .rc-wrapper')?.classList.toggle('sidebar-collapsed'));

    const langBtn  = document.getElementById('languageToggle');
    const langList = document.getElementById('languageList');
    langBtn?.addEventListener('click', e => {
        e.stopPropagation();
        langList.style.display = langList.style.display === 'block' ? 'none' : 'block';
    });
    document.addEventListener('click', () => { if (langList) langList.style.display = 'none'; });
</script>
