<!DOCTYPE html>
@using System.Globalization
@using Microsoft.AspNetCore.Http.Extensions

<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      dir="@(CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")"
      x-data="{ mobileMenuOpen: false }"
      x-init="AOS.init()"
      class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    @using System.Text.Json
    @{
        var title = (ViewData["Title"] ?? ViewBag.Title ?? "Training Center Management").ToString();
        var description = (ViewData["Description"] ?? "مركز تدريبي يقدم دورات مهنية وبرامج تعليمية").ToString();
        var keywords = (ViewData["Keywords"] ?? "training,courses,education,training center").ToString();
        var canonical = (ViewData["Canonical"] ?? Context.Request.GetDisplayUrl()).ToString();
        var robots = (ViewData["Robots"] ?? "index, follow").ToString();
        var siteName = "Training Center Management";
        var ogImage = (ViewData["OgImage"] ?? Url.Content("~/images/og-default.jpg")).ToString();
        var baseUrl = Context.Request.Scheme + "://" + Context.Request.Host;
        var isCoursePage = ViewData["JsonLdType"]?.ToString() == "Course";
    }

    <title>@title</title>
    <meta name="description" content="@description" />
    <meta name="keywords" content="@keywords" />
    <meta name="robots" content="@robots" />
    <link rel="canonical" href="@canonical" />

    <!-- OpenGraph -->
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    <meta property="og:type" content="@(isCoursePage ? "article" : "website")" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:site_name" content="@siteName" />
    <meta property="og:image" content="@ogImage" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@title" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImage" />

    <!-- JSON-LD -->
    @if (isCoursePage)
    {
        var courseName = ViewData["JsonLdName"]?.ToString() ?? title;
        var courseDesc = description;
        var courseImage = ogImage;
        var coursePrice = ViewData["JsonLdPrice"]?.ToString();
        var courseDate = ViewData["JsonLdDate"]?.ToString();
        var courseId = ViewData["JsonLdId"]?.ToString() ?? canonical;
        var courseLd = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Course",
            ["name"] = courseName,
            ["description"] = courseDesc,
            ["url"] = canonical,
            ["image"] = courseImage,
            ["provider"] = new Dictionary<string, object>
            {
                ["@type"] = "Organization",
                ["name"] = siteName,
                ["url"] = baseUrl
            }
        };
        if (!string.IsNullOrEmpty(coursePrice))
            courseLd["offers"] = new Dictionary<string, object>
            {
                ["@type"] = "Offer",
                ["price"] = coursePrice,
                ["priceCurrency"] = "USD",
                ["availability"] = "https://schema.org/InStock"
            };
        if (!string.IsNullOrEmpty(courseDate))
            courseLd["startDate"] = courseDate;
        <script type="application/ld+json">@Html.Raw(JsonSerializer.Serialize(courseLd))</script>
    }
    else
    {
        var orgLd = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Organization",
            ["name"] = siteName,
            ["url"] = baseUrl,
            ["logo"] = baseUrl + Url.Content("~/images/logo.png")
        };
        <script type="application/ld+json">@Html.Raw(JsonSerializer.Serialize(orgLd))</script>
    }

    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   @* STYLE CSS *@
    <!-- Google fonts -->
    <link id="u-page-google-font" rel="stylesheet" href="https://fonts.googleapis.com/css2?display=swap&amp;family=Roboto:ital,wght@0,100..900;1,100..900&amp;family=Open+Sans:ital,wght@0,300..800;1,300..800&amp;family=Montserrat:ital,wght@0,100..900;1,100..900">
    <link href="//fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet">
    <!-- Template CSS Style link -->
    <link rel="stylesheet" href="~/css/style-starter.css" asp-append-version="true">
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <!-- Syncfusion -->
    <link href="https://cdn.syncfusion.com/ej2/material.css" rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">



    <link rel="stylesheet" href="~/css/nicepage.css" media="screen">
    <link rel="stylesheet" href="~/css/Page-2.css" media="screen">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="../../../css/styles.css" type="text/css" rel="stylesheet" id="style-default">
    <link href="../../../css/styles.css" type="text/css" rel="stylesheet">
    <link href="../../../css/styles-menu.css" type="text/css" rel="stylesheet">
    <link href="~/css/chat.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div id="systemNotificationStack" class="system-notification-stack" aria-live="polite" aria-atomic="true"></div>
    @* "Admin", "Trainer", "Trainee", "Receptionist"
    @if (User.IsInRole("Admin") )
    {
        <p>@await Html.PartialAsync("_AdminSidebar")</p>
    }
    @if (User.IsInRole("Trainer"))
    {
        <p>@await Html.PartialAsync("_TrainerSidebar")</p>
    }
    @if (User.IsInRole("Trainee"))
    {
        <p>@await Html.PartialAsync("_TraineeSidebar")</p>
    }
    @if (User.IsInRole("Receptionist"))
    {
        <p>@await Html.PartialAsync("_ReceptionistSidebar")</p>
    } *@
    @* @Html.Partial("_LandingHeader") *@
    <div>
        @RenderBody()

    </div>


    <div class="main" id="top">
    </div>

    @*  JS  *@
   
    <script>
        (function() {
          var culture = '@CultureInfo.CurrentUICulture.Name';
          var isRTL = culture.toLowerCase().startsWith('ar');

          var htmlEl            = document.documentElement;

          if (isRTL) {
            htmlEl.setAttribute('dir', 'rtl');
          } else {
            htmlEl.setAttribute('dir', 'ltr');
          }

          var btn = document.getElementById('dropdownMenuButton');
          if (btn) {
            btn.textContent = isRTL ? 'العربية' : 'English';
          }
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    @* <script src="https://unpkg.com/alpinejs" defer></script> *@
    <script href="../../../assets/js/menu.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        const themeToggle = document.querySelector('.theme-toggle');
        const prefersDarkScheme = window.matchMedia('(prefers-color-scheme: dark)');

        const currentTheme = localStorage.getItem('theme') || (prefersDarkScheme.matches ? 'dark' : 'light');

        if (currentTheme === 'dark') {
          document.body.classList.add('dark-theme');
        }

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
              document.body.classList.toggle('dark-theme');
              const theme = document.body.classList.contains('dark-theme') ? 'dark' : 'light';
              localStorage.setItem('theme', theme);
            });
        }
    </script>
 
    @await Html.PartialAsync("_NotificationsScript")
    @RenderSection("Scripts", required: false)
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Html.PartialAsync("_AIChat")
    }
</body>
</html>




