<!DOCTYPE html>
@using System.Globalization
@using Microsoft.AspNetCore.Http.Extensions

<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      dir="@(CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")"
      x-data="{ mobileMenuOpen: false }"
      x-init="AOS.init()"
      class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    @{
        var title = (ViewData["Title"] ?? ViewBag.Title ?? "Training Center Management").ToString();
        var description = (ViewData["Description"] ?? "مركز تدريبي يقدم دورات مهنية وبرامج تعليمية").ToString();
        var keywords = (ViewData["Keywords"] ?? "training,courses,education,training center").ToString();
        var canonical = (ViewData["Canonical"] ?? Context.Request.GetDisplayUrl()).ToString();
        var siteName = "Training Center Management";
        var ogImage = (ViewData["OgImage"] ?? Url.Content("~/images/og-default.jpg")).ToString();
    }

    <title>@title</title>
    <meta name="description" content="@description" />
    <meta name="keywords" content="@keywords" />
    <link rel="canonical" href="@canonical" />

    <!-- OpenGraph -->
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:site_name" content="@siteName" />
    <meta property="og:image" content="@ogImage" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@title" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImage" />

    <!-- JSON-LD Organization -->
    @using System.Text.Json
    @{
        var ld = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Organization",
            ["name"] = siteName,
            ["url"] = canonical,
            ["logo"] = Url.Content("~/images/logo.png")
        };
        var jsonLd = JsonSerializer.Serialize(ld);
    }
    <script type="application/ld+json">@Html.Raw(jsonLd)</script>

    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   @* STYLE CSS *@
    <!-- Google fonts -->
    <link id="u-page-google-font" rel="stylesheet" href="https://fonts.googleapis.com/css2?display=swap&amp;family=Roboto:ital,wght@0,100..900;1,100..900&amp;family=Open+Sans:ital,wght@0,300..800;1,300..800&amp;family=Montserrat:ital,wght@0,100..900;1,100..900">
    <link href="//fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet">
    <!-- Template CSS Style link -->
    <link rel="stylesheet" href="~/css/style-starter.css" asp-append-version="true">
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <!-- Syncfusion -->
    <link href="https://cdn.syncfusion.com/ej2/material.css" rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">



    <link rel="stylesheet" href="~/css/nicepage.css" media="screen">
    <link rel="stylesheet" href="~/css/Page-2.css" media="screen">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="../../../css/styles.css" type="text/css" rel="stylesheet" id="style-default">
    <link href="../../../css/styles.css" type="text/css" rel="stylesheet">
    <link href="../../../css/styles-menu.css" type="text/css" rel="stylesheet">
    <link href="~/css/chat.css" rel="stylesheet" />
    <style>
        .system-notification-stack {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 5000;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            width: min(360px, calc(100vw - 2rem));
            pointer-events: none;
        }
        html[dir="rtl"] .system-notification-stack {
            right: auto;
            left: 1rem;
        }
        .system-notification-toast {
            pointer-events: auto;
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 0.75rem;
            align-items: start;
            padding: 0.95rem 1rem;
            border-radius: 16px;
            background: rgba(24, 22, 17, 0.96);
            color: #fff;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.22);
            border: 1px solid rgba(255,255,255,0.08);
            transform: translateY(-14px);
            opacity: 0;
            transition: transform 0.25s ease, opacity 0.25s ease;
        }
        .system-notification-toast.show {
            transform: translateY(0);
            opacity: 1;
        }
        .system-notification-icon {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f2c00d, #ffdc67);
            color: #181611;
            font-size: 1rem;
            margin-top: 0.1rem;
        }
        .system-notification-title {
            font-size: 0.96rem;
            font-weight: 700;
            line-height: 1.3;
            margin: 0 0 0.15rem;
        }
        .system-notification-message {
            font-size: 0.88rem;
            line-height: 1.5;
            margin: 0;
            color: rgba(255,255,255,0.88);
        }
        .system-notification-close {
            border: 0;
            background: transparent;
            color: rgba(255,255,255,0.78);
            cursor: pointer;
            padding: 0;
            width: 1.6rem;
            height: 1.6rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
        }
        .system-notification-close:hover {
            color: #fff;
            background: rgba(255,255,255,0.08);
        }
    </style>
</head>
<body>
    <div id="systemNotificationStack" class="system-notification-stack" aria-live="polite" aria-atomic="true"></div>
    @* "Admin", "Trainer", "Trainee", "Receptionist"
    @if (User.IsInRole("Admin") )
    {
        <p>@await Html.PartialAsync("_AdminSidebar")</p>
    }
    @if (User.IsInRole("Trainer"))
    {
        <p>@await Html.PartialAsync("_TrainerSidebar")</p>
    }
    @if (User.IsInRole("Trainee"))
    {
        <p>@await Html.PartialAsync("_TraineeSidebar")</p>
    }
    @if (User.IsInRole("Receptionist"))
    {
        <p>@await Html.PartialAsync("_ReceptionistSidebar")</p>
    } *@
    @* @Html.Partial("_LandingHeader") *@
    <div>
        @RenderBody()

    </div>


    <div class="main" id="top">
    </div>

    @*  JS  *@
   
    <script>
        (function() {
          var culture = '@CultureInfo.CurrentUICulture.Name';
          var isRTL = culture.toLowerCase().startsWith('ar');

          var htmlEl            = document.documentElement;

          if (isRTL) {
            htmlEl.setAttribute('dir', 'rtl');
          } else {
            htmlEl.setAttribute('dir', 'ltr');
          }

          var btn = document.getElementById('dropdownMenuButton');
          if (btn) {
            btn.textContent = isRTL ? 'العربية' : 'English';
          }
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    @* <script src="https://unpkg.com/alpinejs" defer></script> *@
    <script href="../../../assets/js/menu.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        const themeToggle = document.querySelector('.theme-toggle');
        const prefersDarkScheme = window.matchMedia('(prefers-color-scheme: dark)');

        const currentTheme = localStorage.getItem('theme') || (prefersDarkScheme.matches ? 'dark' : 'light');

        if (currentTheme === 'dark') {
          document.body.classList.add('dark-theme');
        }

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
              document.body.classList.toggle('dark-theme');
              const theme = document.body.classList.contains('dark-theme') ? 'dark' : 'light';
              localStorage.setItem('theme', theme);
            });
        }
    </script>
 
    <script>
        (function () {
            const stack = document.getElementById('systemNotificationStack');
            const isAuthenticated = '@User.Identity?.IsAuthenticated'.toLowerCase() === 'true';
            const duplicateWindowMs = 2500;
            const seenNotifications = new Map();

            function cleanupSeenNotifications() {
                const now = Date.now();
                for (const [key, value] of seenNotifications.entries()) {
                    if (now - value > duplicateWindowMs) {
                        seenNotifications.delete(key);
                    }
                }
            }

            function showTopNotification(title, message) {
                if (!stack || !title || !message) {
                    return;
                }

                cleanupSeenNotifications();

                const key = `${title}::${message}`;
                const now = Date.now();
                if (seenNotifications.has(key) && now - seenNotifications.get(key) < duplicateWindowMs) {
                    return;
                }
                seenNotifications.set(key, now);

                const toast = document.createElement('div');
                toast.className = 'system-notification-toast';
                toast.innerHTML = `
                    <div class="system-notification-icon"><i class="fas fa-bell"></i></div>
                    <div>
                        <p class="system-notification-title"></p>
                        <p class="system-notification-message"></p>
                    </div>
                    <button type="button" class="system-notification-close" aria-label="Close notification">
                        <i class="fas fa-times"></i>
                    </button>`;

                toast.querySelector('.system-notification-title').textContent = title;
                toast.querySelector('.system-notification-message').textContent = message;

                const closeButton = toast.querySelector('.system-notification-close');
                let removed = false;

                function removeToast() {
                    if (removed) {
                        return;
                    }
                    removed = true;
                    toast.classList.remove('show');
                    window.setTimeout(() => toast.remove(), 250);
                }

                closeButton.addEventListener('click', removeToast);
                stack.appendChild(toast);
                requestAnimationFrame(() => toast.classList.add('show'));
                window.setTimeout(removeToast, 5000);
            }

            window.showTopSystemNotification = showTopNotification;

            if (!isAuthenticated || typeof signalR === 'undefined') {
                return;
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/ChatHub')
                .withAutomaticReconnect()
                .build();

            connection.on('ReceiveSystemNotification', function (title, message) {
                showTopNotification(title, message);
            });

            connection.start().catch(function (err) {
                console.error('System notification hub connection failed:', err);
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>




