@model List<TrainingCenterManagement_MVC.Models.PaymentRequest>
@{
    ViewData["Title"] = "مدفوعاتي";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<style>
    .mr-page { padding: 28px 32px; background: #f8fafc; min-height: 100vh; direction: rtl; font-family: 'Segoe UI', Tahoma, sans-serif; }
    .mr-card  { background: #fff; border-radius: 14px; box-shadow: 0 2px 16px rgba(0,0,0,.07); border: 1px solid #e2e8f0; padding: 24px; margin-bottom: 20px; }
    .mr-stat  { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .mr-stat-box { flex: 1; min-width: 130px; background: #fff; border-radius: 12px; padding: 18px 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); border: 1px solid #e2e8f0; text-align: center; }
    .mr-stat-box .val { font-size: 1.6rem; font-weight: 800; }
    .mr-stat-box .lbl { font-size: .75rem; color: #64748b; margin-top: 4px; }
    .mr-badge { border-radius: 20px; padding: 4px 12px; font-size: .75rem; font-weight: 700; display: inline-block; }
    .badge-pending  { background: #fef9c3; color: #854d0e; }
    .badge-approved { background: #d1fae5; color: #065f46; }
    .badge-rejected { background: #fee2e2; color: #b91c1c; }
    .mr-row { border-bottom: 1px solid #f1f5f9; padding: 14px 0; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .mr-row:last-child { border-bottom: none; }
    .mr-method-badge { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: .95rem; flex-shrink: 0; }
</style>

<div class="mr-page">

    @if (TempData["PaymentRequestSuccess"] != null)
    {
        <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:10px;padding:12px 18px;margin-bottom:20px;color:#065f46;font-weight:600;">
            <i class="fas fa-check-circle"></i> @TempData["PaymentRequestSuccess"]
        </div>
    }

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
        <h2 style="font-size:1.2rem;font-weight:700;color:#0f172a;margin:0;">
            <i class="fas fa-credit-card" style="color:#7c3aed;margin-left:8px;"></i> طلبات الدفع الإلكتروني
        </h2>
        <div style="display:flex;gap:10px;">
            <a asp-controller="Trainees" asp-action="Deposit"
               style="padding:8px 16px;border-radius:9px;background:#7c3aed;color:#fff;text-decoration:none;font-size:.84rem;font-weight:600;">
                <i class="fas fa-mobile-alt" style="margin-left:5px;"></i> إيداع عبر شام كاش
            </a>
        </div>
    </div>

    <!-- Stats -->
    @{
        var pending  = Model.Count(r => r.Status == TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Pending);
        var approved = Model.Count(r => r.Status == TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Approved);
        var rejected = Model.Count(r => r.Status == TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Rejected);
    }
    <div class="mr-stat">
        <div class="mr-stat-box">
            <div class="val" style="color:#0f172a;">@Model.Count</div>
            <div class="lbl">إجمالي الطلبات</div>
        </div>
        <div class="mr-stat-box">
            <div class="val" style="color:#854d0e;">@pending</div>
            <div class="lbl">قيد المراجعة</div>
        </div>
        <div class="mr-stat-box">
            <div class="val" style="color:#065f46;">@approved</div>
            <div class="lbl">تمت الموافقة</div>
        </div>
        <div class="mr-stat-box">
            <div class="val" style="color:#b91c1c;">@rejected</div>
            <div class="lbl">مرفوض</div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="mr-card" style="text-align:center;padding:50px 20px;color:#94a3b8;">
            <i class="fas fa-inbox" style="font-size:3rem;margin-bottom:14px;display:block;"></i>
            <p style="font-size:1rem;margin:0 0 16px;">لا توجد طلبات دفع بعد</p>
            <a href="@Url.Action("MyCourses","Trainees")"
               style="padding:9px 20px;border-radius:9px;background:#7c3aed;color:#fff;text-decoration:none;font-size:.88rem;font-weight:600;">
                <i class="fas fa-book" style="margin-left:5px;"></i> اذهب إلى كورساتي
            </a>
        </div>
    }
    else
    {
        <div class="mr-card">
            @foreach (var r in Model)
            {
                var isSham = r.Method == TrainingCenterManagement_MVC.Models.OnlinePaymentMethod.ShamCash;
                var sym    = r.Currency == TrainingCenterManagement_MVC.Models.PaymentCurrency.USD ? "$"
                           : r.Currency == TrainingCenterManagement_MVC.Models.PaymentCurrency.EUR ? "€" : "ل.س";
                var (badgeCls, statusLabel) = r.Status switch {
                    TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Approved => ("badge-approved", "تمت الموافقة ✓"),
                    TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Rejected => ("badge-rejected", "مرفوض"),
                    _ => ("badge-pending", "قيد المراجعة ...")
                };
                <div class="mr-row">
                    <div class="mr-method-badge" style="background:@(isSham ? "#f5f3ff" : "#fffbeb");color:@(isSham ? "#7c3aed" : "#92400e");">
                        <i class="@(isSham ? "fas fa-mobile-alt" : "fab fa-bitcoin")"></i>
                    </div>
                    <div style="flex:1;min-width:150px;">
                        <div style="font-weight:600;color:#0f172a;font-size:.9rem;">@r.Course?.CourseName</div>
                        <div style="font-size:.75rem;color:#64748b;margin-top:2px;">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm") — @(isSham ? "شام كاش" : "Binance")</div>
                        @if (!string.IsNullOrEmpty(r.RejectionReason))
                        {
                            <div style="font-size:.75rem;color:#b91c1c;margin-top:3px;"><i class="fas fa-info-circle"></i> @r.RejectionReason</div>
                        }
                    </div>
                    <div style="font-weight:700;color:#059669;font-size:.95rem;">@r.Amount.ToString("N0") @sym</div>
                    <span class="mr-badge @badgeCls">@statusLabel</span>
                    @if (!string.IsNullOrEmpty(r.ReceiptFilePath))
                    {
                        <a href="@r.ReceiptFilePath" target="_blank"
                           style="padding:4px 10px;border-radius:7px;background:#f1f5f9;color:#64748b;text-decoration:none;font-size:.75rem;">
                            <i class="fas fa-file-alt"></i> الإيصال
                        </a>
                    }
                </div>
            }
        </div>
    }

    <!-- How it works box -->
    <div style="background:#f0f4ff;border:1.5px solid #c7d2fe;border-radius:12px;padding:18px 20px;direction:rtl;">
        <div style="font-weight:700;color:#3730a3;margin-bottom:10px;font-size:.9rem;"><i class="fas fa-question-circle" style="margin-left:5px;"></i> كيف يعمل الإيداع عبر شام كاش؟</div>
        <div style="font-size:.82rem;color:#374151;display:flex;flex-direction:column;gap:7px;">
            <div><span style="background:#4f46e5;color:#fff;border-radius:50%;width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;margin-left:6px;">1</span>اضغط "إيداع عبر شام كاش" وانتقل لصفحة الإيداع</div>
            <div><span style="background:#4f46e5;color:#fff;border-radius:50%;width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;margin-left:6px;">2</span>حوّل المبلغ وضع رمز التحويل الخاص بك في خانة الملاحظات</div>
            <div><span style="background:#10b981;color:#fff;border-radius:50%;width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;margin-left:6px;">✓</span>يُضاف الرصيد لحسابك تلقائياً فور التحقق من التحويل</div>
        </div>
    </div>
</div>
