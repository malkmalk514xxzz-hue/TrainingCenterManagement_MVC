@model List<TrainingCenterManagement_MVC.Models.PaymentRequest>
@{
    ViewData["Title"] = "إدارة طلبات الدفع";
    var statusFilter = (string)(ViewBag.StatusFilter ?? "all");
    var pendingCount = (int)(ViewBag.PendingCount ?? 0);
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="dashboard-wrapper" style="display:flex;direction:rtl;min-height:100vh">
@await Html.PartialAsync("_AdminSidebar")
<main style="flex:1;padding:28px 32px;background:#f8fafc;overflow-x:hidden">

@if (TempData["Success"] != null)
{
    <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:10px;padding:12px 18px;margin-bottom:20px;color:#065f46;font-weight:600;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:10px;padding:12px 18px;margin-bottom:20px;color:#b91c1c;font-weight:600;">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
    </div>
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
    <h2 style="font-size:1.3rem;font-weight:700;color:#0f172a;margin:0;">
        <i class="fas fa-file-invoice-dollar" style="color:#4f46e5;margin-left:8px;"></i>
        طلبات الدفع الإلكتروني
        @if (pendingCount > 0)
        {
            <span style="background:#ef4444;color:#fff;border-radius:20px;padding:2px 10px;font-size:.75rem;font-weight:700;margin-right:8px;">@pendingCount جديد</span>
        }
    </h2>

    <!-- Filter tabs -->
    <div style="display:flex;gap:8px;">
        @foreach (var f in new[] { ("all","الكل","#64748b"), ("pending","قيد المراجعة","#f59e0b"), ("approved","موافق","#10b981"), ("rejected","مرفوض","#ef4444") })
        {
            <a href="@Url.Action("Manage","PaymentRequests", new { status = f.Item1 })"
               style="padding:6px 14px;border-radius:8px;font-size:.8rem;font-weight:600;text-decoration:none;
                      background:@(statusFilter == f.Item1 ? f.Item3 : "#fff");
                      color:@(statusFilter == f.Item1 ? "#fff" : f.Item3);
                      border:1.5px solid @f.Item3;">
                @f.Item2
            </a>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div style="text-align:center;padding:60px 20px;color:#94a3b8;">
        <i class="fas fa-inbox" style="font-size:3rem;margin-bottom:14px;display:block;"></i>
        <p style="font-size:1rem;">لا توجد طلبات دفع</p>
    </div>
}
else
{
    <div style="background:#fff;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.07);border:1px solid #e2e8f0;overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:.85rem;">
            <thead>
                <tr style="background:#f8fafc;border-bottom:1.5px solid #e2e8f0;">
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">#</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">الطالب</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">الكورس</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">المبلغ</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">طريقة الدفع</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">التاريخ</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">الحالة</th>
                    <th style="padding:12px 16px;text-align:right;color:#64748b;font-weight:600;">إجراء</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var r in Model)
                {
                    var (statusBg, statusColor, statusText) = r.Status switch {
                        TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Approved => ("#d1fae5","#065f46","موافق ✓"),
                        TrainingCenterManagement_MVC.Models.PaymentRequestStatus.Rejected => ("#fee2e2","#b91c1c","مرفوض ✗"),
                        _ => ("#fef9c3","#854d0e","قيد المراجعة")
                    };
                    var methodIcon = r.Method == TrainingCenterManagement_MVC.Models.OnlinePaymentMethod.Binance
                        ? "<i class='fab fa-bitcoin'></i> Binance"
                        : "<i class='fas fa-mobile-alt'></i> شام كاش";
                    <tr style="border-bottom:1px solid #f1f5f9;">
                        <td style="padding:12px 16px;color:#94a3b8;">@idx</td>
                        <td style="padding:12px 16px;">
                            <div style="font-weight:600;color:#0f172a;">@r.Trainee?.User?.FullName</div>
                            <div style="font-size:.75rem;color:#64748b;">@r.Trainee?.User?.Email</div>
                        </td>
                        <td style="padding:12px 16px;color:#374151;font-weight:500;">@r.Course?.CourseName</td>
                        <td style="padding:12px 16px;font-weight:700;color:#059669;">@r.Amount.ToString("N0") @(r.Currency == TrainingCenterManagement_MVC.Models.PaymentCurrency.USD ? "$" : r.Currency == TrainingCenterManagement_MVC.Models.PaymentCurrency.EUR ? "€" : "ل.س")</td>
                        <td style="padding:12px 16px;color:#374151;">@Html.Raw(methodIcon)</td>
                        <td style="padding:12px 16px;color:#64748b;font-size:.8rem;">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="padding:12px 16px;">
                            <span style="background:@statusBg;color:@statusColor;border-radius:20px;padding:3px 10px;font-size:.75rem;font-weight:700;">@statusText</span>
                        </td>
                        <td style="padding:12px 16px;">
                            <a href="@Url.Action("Review","PaymentRequests", new { id = r.RequestId })"
                               style="padding:5px 12px;border-radius:7px;background:#eef2ff;color:#4f46e5;text-decoration:none;font-size:.78rem;font-weight:600;">
                                <i class="fas fa-search"></i> مراجعة
                            </a>
                        </td>
                    </tr>
                    idx++;
                }
            </tbody>
        </table>
    </div>
}

</main>
</div>
