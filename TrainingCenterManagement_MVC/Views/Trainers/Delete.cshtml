@model TrainingCenterManagement_MVC.Models.Trainer

@{
    ViewData["Title"] = "حذف المدرب";
    var avatarChar = Model.User?.FullName?.Length > 0 ? Model.User.FullName[0].ToString() : "M";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --danger:        #dc2626;
        --danger-light:  #ef4444;
        --danger-pale:   #fff1f2;
        --danger-border: #fca5a5;
        --success:       #10b981;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:     0 8px 32px rgba(0,0,0,.14);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .tr-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
        display: flex; flex-direction: column; align-items: center;
    }

    /* ── Breadcrumb ── */
    .tr-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3);
        margin-bottom: 32px; align-self: flex-start;
    }
    .tr-breadcrumb a { color: var(--primary); text-decoration: none; }
    .tr-breadcrumb a:hover { text-decoration: underline; }

    /* ── Warning Banner ── */
    .tr-warn-banner {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 50%, #b91c1c 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex; align-items: center; gap: 18px;
        flex-wrap: wrap;
        position: relative; overflow: hidden;
        box-shadow: 0 8px 28px rgba(185,28,28,.25);
        width: 100%; max-width: 680px;
    }
    .tr-warn-banner::before {
        content: '';
        position: absolute; top: -60px; left: -40px;
        width: 200px; height: 200px;
        background: rgba(255,255,255,.05); border-radius: 50%;
    }
    .tr-warn-icon {
        width: 64px; height: 64px; border-radius: 50%;
        background: rgba(255,255,255,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; color: #fff; flex-shrink: 0;
        position: relative; z-index: 1;
        animation: pulse-warn 2s ease-in-out infinite;
    }
    @@keyframes pulse-warn {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,.3); }
        50%       { box-shadow: 0 0 0 10px rgba(255,255,255,.0); }
    }
    .tr-warn-text { flex: 1; color: #fff; position: relative; z-index: 1; }
    .tr-warn-text h2 { font-size: 1.35rem; font-weight: 800; margin: 0 0 5px; }
    .tr-warn-text p  { font-size: .9rem; opacity: .88; margin: 0; line-height: 1.5; }

    /* ── Trainer Info Card ── */
    .tr-info-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border);
        overflow: hidden;
        width: 100%; max-width: 680px;
        margin-bottom: 20px;
    }
    .tr-info-card-head {
        background: linear-gradient(to left, #fafbff, var(--card-bg));
        border-bottom: 1px solid var(--border);
        padding: 18px 24px;
        display: flex; align-items: center; gap: 14px;
    }
    .tr-avatar {
        width: 58px; height: 58px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; font-weight: 800; color: #fff;
        flex-shrink: 0; border: 3px solid var(--primary-pale);
    }
    .tr-avatar img {
        width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
    }
    .tr-info-card-name {
        font-size: 1.05rem; font-weight: 700; color: var(--text-1); margin-bottom: 3px;
    }
    .tr-info-card-role {
        font-size: .8rem; color: var(--text-3);
        display: flex; align-items: center; gap: 5px;
    }
    .tr-info-card-body { padding: 0; }

    .tr-detail-row {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 24px;
        border-bottom: 1px solid var(--border);
    }
    .tr-detail-row:last-child { border-bottom: none; }
    .tr-detail-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem; flex-shrink: 0;
    }
    .tr-detail-label {
        font-size: .75rem; font-weight: 600; color: var(--text-3);
        text-transform: uppercase; letter-spacing: .04em;
        margin-bottom: 2px;
    }
    .tr-detail-value {
        font-size: .95rem; font-weight: 600; color: var(--text-1);
    }
    .tr-detail-link {
        font-size: .88rem; color: var(--primary);
        text-decoration: none; font-weight: 600;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .tr-detail-link:hover { text-decoration: underline; }

    /* ── Consequence notice ── */
    .tr-consequence {
        background: var(--danger-pale);
        border: 1px solid var(--danger-border);
        border-radius: var(--radius-sm);
        padding: 14px 18px;
        font-size: .875rem; color: #991b1b;
        width: 100%; max-width: 680px;
        margin-bottom: 20px;
    }
    .tr-consequence-title {
        font-weight: 700; margin-bottom: 8px;
        display: flex; align-items: center; gap: 7px;
    }
    .tr-consequence ul {
        margin: 0; padding-right: 18px;
    }
    .tr-consequence li { margin-bottom: 4px; line-height: 1.5; }

    /* ── Action buttons ── */
    .tr-action-row {
        display: flex; align-items: center; gap: 12px;
        flex-wrap: wrap; justify-content: flex-end;
        width: 100%; max-width: 680px;
    }
    .tr-btn-confirm {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 26px; border-radius: var(--radius-sm);
        background: var(--danger); color: #fff;
        border: none; font-size: .92rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        transition: var(--tr), transform .1s;
        box-shadow: 0 4px 14px rgba(220,38,38,.28);
    }
    .tr-btn-confirm:hover {
        background: #b91c1c;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(220,38,38,.35);
    }
    .tr-btn-cancel {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tr-btn-cancel:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="tr-page">

    <!-- Breadcrumb -->
    <nav class="tr-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Trainers">المدربون</a>
        <i class="fas fa-chevron-left"></i>
        <a asp-action="Details" asp-route-id="@Model.TrainerId">تفاصيل المدرب</a>
        <i class="fas fa-chevron-left"></i>
        <span style="color:var(--danger)">حذف</span>
    </nav>

    <!-- Warning Banner -->
    <div class="tr-warn-banner">
        <div class="tr-warn-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="tr-warn-text">
            <h2>تأكيد حذف المدرب</h2>
            <p>هذا الإجراء نهائي ولا يمكن التراجع عنه. يرجى مراجعة البيانات قبل المتابعة.</p>
        </div>
    </div>

    <!-- Trainer Info Card -->
    <div class="tr-info-card">
        <div class="tr-info-card-head">
            <div class="tr-avatar">
                @if (!string.IsNullOrEmpty(Model.User?.ProfilePictureUrl))
                {
                    <img src="@Model.User.ProfilePictureUrl" alt="@Model.User.FullName"
                         onerror="this.style.display='none';this.parentElement.innerHTML='@avatarChar';" />
                }
                else
                {
                    @avatarChar
                }
            </div>
            <div>
                <div class="tr-info-card-name">@Model.User?.FullName</div>
                <div class="tr-info-card-role">
                    <i class="fas fa-chalkboard-teacher"></i> مدرب معتمد
                </div>
            </div>
        </div>

        <div class="tr-info-card-body">
            <div class="tr-detail-row">
                <div class="tr-detail-icon"><i class="fas fa-star"></i></div>
                <div>
                    <div class="tr-detail-label">التخصص</div>
                    <div class="tr-detail-value">
                        @(string.IsNullOrEmpty(Model.Specialty) ? "—" : Model.Specialty)
                    </div>
                </div>
            </div>

            <div class="tr-detail-row">
                <div class="tr-detail-icon"><i class="fas fa-hourglass-half"></i></div>
                <div>
                    <div class="tr-detail-label">سنوات الخبرة</div>
                    <div class="tr-detail-value">@Model.YearsOfExperience سنة</div>
                </div>
            </div>

            <div class="tr-detail-row">
                <div class="tr-detail-icon"><i class="fas fa-link"></i></div>
                <div>
                    <div class="tr-detail-label">الرابط المهني</div>
                    <div class="tr-detail-value">
                        @if (!string.IsNullOrEmpty(Model.BusinessLink))
                        {
                            <a href="@Model.BusinessLink" target="_blank" class="tr-detail-link">
                                <i class="fas fa-external-link-alt" style="font-size:.75rem;"></i>
                                @Model.BusinessLink
                            </a>
                        }
                        else { <span style="color:var(--text-3)">—</span> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Consequences -->
    <div class="tr-consequence">
        <div class="tr-consequence-title">
            <i class="fas fa-exclamation-circle"></i>
            ماذا سيحدث عند الحذف؟
        </div>
        <ul>
            <li>سيتم حذف ملف المدرب بشكل نهائي من النظام</li>
            <li>ستُفقد جميع البيانات المرتبطة بهذا المدرب</li>
            <li>لا يمكن استعادة هذه البيانات بعد الحذف</li>
        </ul>
    </div>

    <!-- Actions -->
    <div class="tr-action-row">
        <a asp-action="Index" class="tr-btn-cancel">
            <i class="fas fa-arrow-right"></i> إلغاء، العودة للقائمة
        </a>
        <form asp-action="Delete" style="margin:0;">
            <input type="hidden" asp-for="TrainerId" />
            <button type="submit" class="tr-btn-confirm">
                <i class="fas fa-trash-alt"></i> نعم، احذف المدرب
            </button>
        </form>
    </div>

</div>
