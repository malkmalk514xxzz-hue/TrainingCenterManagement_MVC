@model TrainingCenterManagement_MVC.Models.Trainer

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Trainer</h1>

<h3>Are you sure you want to delete this?</h3>

<div class="card p-4 mb-3">
    <h4>Trainer Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.User)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.User.FullName)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Specialty)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Specialty)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.YearsOfExperience)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.YearsOfExperience)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BusinessLink)</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.BusinessLink))
            {
                <a href="@Model.BusinessLink" target="_blank">@Model.BusinessLink</a>
            }
            else
            {
                <span>—</span>
            }
        </dd>
    </dl>
</div>

<form asp-action="Delete" class="mb-3">
    <input type="hidden" asp-for="TrainerId" />
    <button type="submit" class="btn btn-danger me-2">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
