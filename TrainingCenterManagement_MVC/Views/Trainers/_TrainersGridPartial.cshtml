@model IEnumerable<TrainingCenterManagement_MVC.Models.Trainer>
@using TrainingCenterManagement_MVC.Models

@{
    int  currentPage = ViewBag.CurrentPage ?? 1;
    int  totalPages  = ViewBag.TotalPages  ?? 1;
    int  filterCount = ViewBag.FilterCount ?? 0;
    int  pageSize    = ViewBag.PageSize    ?? 10;
    var  list        = Model.ToList();

    string AvatarUrl(Trainer t) {
        if (!string.IsNullOrEmpty(t.User?.ProfilePictureUrl)) return t.User.ProfilePictureUrl;
        var name = Uri.EscapeDataString(t.User?.FullName ?? "T");
        var bg   = (t.User?.Gender == Gender.Female) ? "ec4899" : "1d4ed8";
        return $"https://ui-avatars.com/api/?name={name}&background={bg}&color=ffffff&bold=true&size=128&rounded=true";
    }
}

@if (!list.Any())
{
    <div class="tr-empty">
        <i class="fas fa-chalkboard-teacher"></i>
        <h3>لا يوجد مدربون مطابقون</h3>
        <p>جرّب تغيير كلمة البحث أو الفلتر</p>
    </div>
}
else
{
    <!-- Results bar — بارزة -->
    <div class="tr-results-bar">
        <span class="tr-results-text">
            عرض
            <strong class="tr-results-hl">@(((currentPage - 1) * pageSize) + 1)</strong>
            —
            <strong class="tr-results-hl">@(Math.Min(currentPage * pageSize, filterCount))</strong>
            من
            <strong class="tr-results-hl">@filterCount</strong>
            مدرب
        </span>
    </div>

    <!-- Grid -->
    <div class="tr-grid" id="tr-grid">
        @foreach (var item in list)
        {
            var av       = AvatarUrl(item);
            var isFemale = item.User?.Gender == Gender.Female;

            <div class="tr-card"
                 data-name="@(item.User?.FullName?.ToLower())"
                 data-specialty="@(item.Specialty?.ToLower())"
                 data-gender="@(isFemale ? "female" : "male")">

                <span class="tr-role-badge"><i class="fas fa-chalkboard-teacher"></i> مدرب</span>

                <div class="tr-avatar-wrap">
                    <img src="@av" class="tr-avatar" alt="@item.User?.FullName"
                         onerror="this.src='https://ui-avatars.com/api/?name=T&background=94a3b8&color=fff&rounded=true'" />
                    <span class="tr-gender-dot @(isFemale ? "tr-gf" : "tr-gm")">
                        <i class="fas @(isFemale ? "fa-venus" : "fa-mars")"></i>
                    </span>
                </div>

                @if (item.User != null)
                {
                    <div class="tr-name">@item.User.FullName</div>
                    <div class="tr-email">@item.User.Email</div>
                }
                else
                {
                    <div class="tr-name" style="color:var(--text-3);">لا يوجد مستخدم</div>
                }

                @if (!string.IsNullOrEmpty(item.Specialty))
                {
                    <span class="tr-specialty">@item.Specialty</span>
                }

                <div class="tr-exp">
                    <i class="fas fa-briefcase" style="color:var(--text-3);margin-left:4px;font-size:.68rem"></i>
                    @item.YearsOfExperience سنوات خبرة
                </div>

                <div class="tr-actions">
                    <a asp-action="Details" asp-route-id="@item.TrainerId" class="tr-btn tr-btn-info">
                        <i class="fas fa-eye"></i> تفاصيل
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.TrainerId" class="tr-btn tr-btn-edit">
                        <i class="fas fa-pen"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.TrainerId" class="tr-btn tr-btn-del">
                        <i class="fas fa-trash-alt"></i>
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="tr-pag-wrap">
            <div class="tr-pag-info">
                صفحة <strong>@currentPage</strong> من <strong>@totalPages</strong>
            </div>
            <ul class="tr-pag">

                <li class="@(currentPage <= 1 ? "disabled" : "")">
                    <a href="#" class="tr-pag-link" data-page="@(currentPage - 1)" title="السابق">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>

                @{
                    int startP = Math.Max(1, currentPage - 3);
                    int endP   = Math.Min(totalPages, startP + 6);
                    if (endP - startP < 6) startP = Math.Max(1, endP - 6);
                }
                @if (startP > 1)
                {
                    <li><a href="#" class="tr-pag-link" data-page="1">1</a></li>
                    if (startP > 2) { <li class="ellipsis"><span>…</span></li> }
                }
                @for (int pi = startP; pi <= endP; pi++)
                {
                    <li class="@(pi == currentPage ? "active" : "")">
                        <a href="#" class="tr-pag-link" data-page="@pi">@pi</a>
                    </li>
                }
                @if (endP < totalPages)
                {
                    if (endP < totalPages - 1) { <li class="ellipsis"><span>…</span></li> }
                    <li><a href="#" class="tr-pag-link" data-page="@totalPages">@totalPages</a></li>
                }

                <li class="@(currentPage >= totalPages ? "disabled" : "")">
                    <a href="#" class="tr-pag-link" data-page="@(currentPage + 1)" title="التالي">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>

            </ul>
        </div>
    }
}
