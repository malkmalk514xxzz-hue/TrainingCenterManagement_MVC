@model TrainingCenterManagement_MVC.Models.Trainer

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Trainer</h1>

<h4>Trainer Details</h4>
<hr />

<div class="row">
    <div class="col-md-6 col-lg-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="TrainerId" />

            <div class="mb-3">
                <label asp-for="UserId" class="form-label"></label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Specialty" class="form-label"></label>
                <input asp-for="Specialty" class="form-control" />
                <span asp-validation-for="Specialty" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="YearsOfExperience" class="form-label"></label>
                <input asp-for="YearsOfExperience" type="number" min="0" class="form-control" />
                <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BusinessLink" class="form-label"></label>
                <input asp-for="BusinessLink" type="url" class="form-control" placeholder="https://example.com" />
                <span asp-validation-for="BusinessLink" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
