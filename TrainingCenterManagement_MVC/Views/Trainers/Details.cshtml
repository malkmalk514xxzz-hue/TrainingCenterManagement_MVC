@model TrainingCenterManagement_MVC.Models.Trainer

@{
    ViewData["Title"] = "تفاصيل المدرب";
    var avatarChar = Model.User?.FullName?.Length > 0 ? Model.User.FullName[0].ToString() : "M";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --success:       #10b981;
        --warning:       #f59e0b;
        --danger:        #ef4444;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:     0 8px 32px rgba(0,0,0,.14);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .tr-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
    }

    /* ── Breadcrumb ── */
    .tr-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3); margin-bottom: 22px;
    }
    .tr-breadcrumb a { color: var(--primary); text-decoration: none; }
    .tr-breadcrumb a:hover { text-decoration: underline; }
    .tr-breadcrumb i { font-size: .65rem; }

    /* ── Hero Banner ── */
    .tr-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #1d4ed8 100%);
        border-radius: var(--radius);
        padding: 32px 36px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .tr-hero::before {
        content: '';
        position: absolute; top: -70px; left: -50px;
        width: 260px; height: 260px;
        background: rgba(255,255,255,.05); border-radius: 50%;
    }
    .tr-hero::after {
        content: '';
        position: absolute; bottom: -90px; right: -40px;
        width: 300px; height: 300px;
        background: rgba(255,255,255,.04); border-radius: 50%;
    }
    .tr-hero-avatar-wrap {
        position: relative; z-index: 1; flex-shrink: 0;
    }
    .tr-hero-avatar {
        width: 96px; height: 96px; border-radius: 50%;
        border: 4px solid rgba(255,255,255,.55);
        object-fit: cover;
        box-shadow: 0 4px 16px rgba(0,0,0,.25);
        display: block;
    }
    .tr-hero-avatar-fallback {
        width: 96px; height: 96px; border-radius: 50%;
        border: 4px solid rgba(255,255,255,.55);
        background: rgba(255,255,255,.18);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.2rem; font-weight: 800; color: #fff;
        flex-shrink: 0; position: relative; z-index: 1;
    }
    .tr-hero-status {
        position: absolute; bottom: 4px; left: 4px;
        width: 18px; height: 18px; border-radius: 50%;
        background: #10b981; border: 3px solid #1d4ed8;
    }
    .tr-hero-info { flex: 1; color: #fff; position: relative; z-index: 1; }
    .tr-hero-info h2 {
        font-size: 1.8rem; font-weight: 800;
        margin: 0 0 5px; letter-spacing: -.3px;
    }
    .tr-hero-info .tr-role {
        font-size: .9rem; opacity: .85; margin: 0 0 14px;
        display: flex; align-items: center; gap: 6px;
    }
    .tr-hero-badges { display: flex; gap: 10px; flex-wrap: wrap; }
    .tr-hero-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(6px);
        border-radius: 30px;
        padding: 5px 14px; font-size: .8rem; color: #fff; font-weight: 500;
    }
    .tr-hero-actions {
        display: flex; gap: 10px; flex-wrap: wrap;
        position: relative; z-index: 1;
    }
    .tr-hero-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 20px; border-radius: var(--radius-sm);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; border: none; cursor: pointer;
        transition: var(--tr); white-space: nowrap;
    }
    .tr-hero-btn-white { background: #fff; color: var(--primary); }
    .tr-hero-btn-white:hover { background: #eff6ff; color: var(--primary-dark); }
    .tr-hero-btn-glass {
        background: rgba(255,255,255,.15); color: #fff;
        border: 1.5px solid rgba(255,255,255,.35);
        backdrop-filter: blur(4px);
    }
    .tr-hero-btn-glass:hover { background: rgba(255,255,255,.25); color: #fff; }
    .tr-hero-btn-red {
        background: #fee2e2; color: #b91c1c;
        border: 1.5px solid rgba(255,255,255,.25);
    }
    .tr-hero-btn-red:hover { background: #fecaca; }

    /* ── Grid layout ── */
    .tr-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    @@media (max-width: 860px) { .tr-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .tr-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 26px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        transition: var(--tr);
    }
    .tr-card:hover { box-shadow: var(--shadow-md); }
    .tr-card-title {
        font-size: .95rem; font-weight: 700; color: var(--text-1);
        margin: 0 0 20px;
        display: flex; align-items: center; gap: 9px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
    }
    .tr-card-title i {
        width: 34px; height: 34px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }

    /* ── Info rows ── */
    .tr-info-row {
        display: flex; align-items: flex-start;
        gap: 14px; padding: 13px 0;
        border-bottom: 1px solid var(--border);
    }
    .tr-info-row:last-child { border-bottom: none; padding-bottom: 0; }
    .tr-info-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem; flex-shrink: 0; margin-top: 1px;
    }
    .tr-info-body { flex: 1; }
    .tr-info-label {
        font-size: .75rem; font-weight: 600; color: var(--text-3);
        text-transform: uppercase; letter-spacing: .04em;
        margin-bottom: 3px;
    }
    .tr-info-value {
        font-size: .95rem; font-weight: 600; color: var(--text-1);
    }
    .tr-info-link {
        font-size: .88rem; color: var(--primary);
        word-break: break-all; text-decoration: none;
        display: inline-flex; align-items: center; gap: 5px;
        font-weight: 600;
    }
    .tr-info-link:hover { text-decoration: underline; }

    /* ── Quick actions card ── */
    .tr-actions-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }
    .tr-action-btn {
        display: flex; flex-direction: column;
        align-items: center; gap: 9px;
        padding: 18px 12px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg);
        text-decoration: none; color: var(--text-1);
        font-size: .82rem; font-weight: 600;
        transition: var(--tr); text-align: center;
        cursor: pointer;
    }
    .tr-action-btn:hover {
        border-color: var(--primary); color: var(--primary);
        transform: translateY(-2px); box-shadow: var(--shadow-sm);
    }
    .tr-action-icon {
        width: 44px; height: 44px; border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
    }

    /* ── Experience badge ── */
    .tr-exp-badge {
        display: inline-flex; align-items: center; gap: 8px;
        background: linear-gradient(135deg, var(--primary-pale), #dbeafe);
        border: 1.5px solid #bfdbfe;
        border-radius: 30px; padding: 8px 18px;
        font-size: .95rem; font-weight: 700; color: var(--primary);
    }

    /* ── Back button ── */
    .tr-back-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tr-back-btn:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="tr-page">

    <!-- Breadcrumb -->
    <nav class="tr-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Trainers">المدربون</a>
        <i class="fas fa-chevron-left"></i>
        <span>تفاصيل المدرب</span>
    </nav>

    <!-- Hero Banner -->
    <div class="tr-hero">
        <div class="tr-hero-avatar-wrap">
            @if (!string.IsNullOrEmpty(Model.User?.ProfilePictureUrl))
            {
                <img src="@Model.User.ProfilePictureUrl"
                     alt="@Model.User.FullName"
                     class="tr-hero-avatar"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                <div class="tr-hero-avatar-fallback" style="display:none;">@avatarChar</div>
            }
            else
            {
                <div class="tr-hero-avatar-fallback">@avatarChar</div>
            }
            <div class="tr-hero-status"></div>
        </div>

        <div class="tr-hero-info">
            <h2>@Model.User?.FullName</h2>
            <p class="tr-role"><i class="fas fa-chalkboard-teacher"></i> مدرب معتمد</p>
            <div class="tr-hero-badges">
                @if (!string.IsNullOrEmpty(Model.Specialty))
                {
                    <span class="tr-hero-badge"><i class="fas fa-star"></i> @Model.Specialty</span>
                }
                <span class="tr-hero-badge"><i class="fas fa-calendar-check"></i> @Model.YearsOfExperience سنوات خبرة</span>
                <span class="tr-hero-badge" style="background:rgba(16,185,129,.3);">
                    <i class="fas fa-circle" style="font-size:.45rem;"></i> نشط
                </span>
            </div>
        </div>

        <div class="tr-hero-actions">
            <a asp-action="Edit" asp-route-id="@Model.TrainerId" class="tr-hero-btn tr-hero-btn-white">
                <i class="fas fa-pen"></i> تعديل
            </a>
            <a asp-action="MyCourses" class="tr-hero-btn tr-hero-btn-glass">
                <i class="fas fa-graduation-cap"></i> الدورات
            </a>
            <a asp-action="Delete" asp-route-id="@Model.TrainerId" class="tr-hero-btn tr-hero-btn-red">
                <i class="fas fa-trash-alt"></i> حذف
            </a>
        </div>
    </div>

    <!-- Info Grid -->
    <div class="tr-grid">

        <!-- Personal Info -->
        <div class="tr-card">
            <div class="tr-card-title">
                <i class="fas fa-id-card"></i>
                المعلومات الشخصية
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-user"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">الاسم الكامل</div>
                    <div class="tr-info-value">@Html.DisplayFor(m => m.User.FullName)</div>
                </div>
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-envelope"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">البريد الإلكتروني</div>
                    <div class="tr-info-value">
                        @if (!string.IsNullOrEmpty(Model.User?.Email))
                        {
                            <a href="mailto:@Model.User.Email" class="tr-info-link">
                                <i class="fas fa-envelope" style="font-size:.75rem;"></i>
                                @Model.User.Email
                            </a>
                        }
                        else { <span style="color:var(--text-3)">—</span> }
                    </div>
                </div>
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-phone"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">رقم الهاتف</div>
                    <div class="tr-info-value">
                        @(string.IsNullOrEmpty(Model.User?.PhoneNumber) ? "—" : Model.User.PhoneNumber)
                    </div>
                </div>
            </div>
        </div>

        <!-- Professional Info -->
        <div class="tr-card">
            <div class="tr-card-title">
                <i class="fas fa-briefcase"></i>
                المعلومات المهنية
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-star"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">التخصص</div>
                    <div class="tr-info-value">
                        @(string.IsNullOrEmpty(Model.Specialty) ? "—" : Model.Specialty)
                    </div>
                </div>
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-hourglass-half"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">سنوات الخبرة</div>
                    <div class="tr-info-value">
                        <span class="tr-exp-badge">
                            <i class="fas fa-award"></i>
                            @Model.YearsOfExperience سنة
                        </span>
                    </div>
                </div>
            </div>

            <div class="tr-info-row">
                <div class="tr-info-icon"><i class="fas fa-link"></i></div>
                <div class="tr-info-body">
                    <div class="tr-info-label">الرابط المهني</div>
                    <div class="tr-info-value">
                        @if (!string.IsNullOrEmpty(Model.BusinessLink))
                        {
                            <a href="@Model.BusinessLink" target="_blank" class="tr-info-link">
                                <i class="fas fa-external-link-alt" style="font-size:.75rem;"></i>
                                @Model.BusinessLink
                            </a>
                        }
                        else { <span style="color:var(--text-3)">—</span> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="tr-card" style="margin-bottom:24px;">
        <div class="tr-card-title">
            <i class="fas fa-bolt"></i>
            الإجراءات السريعة
        </div>
        <div class="tr-actions-grid">
            <a asp-action="MyCourses" class="tr-action-btn">
                <div class="tr-action-icon" style="background:#eff6ff;color:#1d4ed8;">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                دوراتي
            </a>
            <a asp-action="MyCoursesAttendance" class="tr-action-btn">
                <div class="tr-action-icon" style="background:#d1fae5;color:#059669;">
                    <i class="fas fa-clipboard-check"></i>
                </div>
                سجل الحضور
            </a>
            <a asp-action="Edit" asp-route-id="@Model.TrainerId" class="tr-action-btn">
                <div class="tr-action-icon" style="background:#fef3c7;color:#d97706;">
                    <i class="fas fa-pen"></i>
                </div>
                تعديل البيانات
            </a>
            <a asp-action="Index" class="tr-action-btn">
                <div class="tr-action-icon" style="background:#f1f5f9;color:#64748b;">
                    <i class="fas fa-list"></i>
                </div>
                قائمة المدربين
            </a>
        </div>
    </div>

    <!-- Back -->
    <a asp-action="Index" class="tr-back-btn">
        <i class="fas fa-arrow-right"></i> العودة للقائمة
    </a>

</div>
