@model TrainingCenterManagement_MVC.Models.Trainer

@{
    ViewData["Title"] = "إضافة مدرب جديد";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --success:       #10b981;
        --danger:        #ef4444;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:     0 8px 32px rgba(0,0,0,.14);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .tr-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
    }

    /* ── Breadcrumb ── */
    .tr-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3); margin-bottom: 22px;
    }
    .tr-breadcrumb a { color: var(--primary); text-decoration: none; }
    .tr-breadcrumb a:hover { text-decoration: underline; }
    .tr-breadcrumb i { font-size: .65rem; }

    /* ── Page header ── */
    .tr-page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        margin-bottom: 28px;
    }
    .tr-page-header-left { display: flex; align-items: center; gap: 16px; }
    .tr-page-icon {
        width: 52px; height: 52px; border-radius: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #fff;
        box-shadow: 0 4px 14px rgba(29,78,216,.30);
    }
    .tr-page-header h1 {
        font-size: 1.5rem; font-weight: 800;
        color: var(--text-1); margin: 0 0 3px;
    }
    .tr-page-header p {
        font-size: .85rem; color: var(--text-2); margin: 0;
    }
    .tr-back-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tr-back-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── Layout ── */
    .tr-create-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 22px;
        align-items: start;
    }
    @@media (max-width: 900px) {
        .tr-create-layout { grid-template-columns: 1fr; }
    }

    /* ── Card ── */
    .tr-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        overflow: hidden;
        transition: var(--tr);
    }
    .tr-card:hover { box-shadow: var(--shadow-md); }
    .tr-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 10px;
        background: linear-gradient(to left, #fafbff, var(--card-bg));
    }
    .tr-card-head-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }
    .tr-card-head h3 {
        font-size: .97rem; font-weight: 700; color: var(--text-1); margin: 0;
    }
    .tr-card-head p {
        font-size: .78rem; color: var(--text-3); margin: 2px 0 0;
    }
    .tr-card-body { padding: 24px; }

    /* ── Aside preview ── */
    .tr-preview-aside {
        display: flex; flex-direction: column; align-items: center;
        padding: 32px 20px; text-align: center;
        background: linear-gradient(160deg, var(--primary-pale) 0%, #fff 60%);
    }
    .tr-preview-avatar {
        width: 88px; height: 88px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; color: #fff;
        border: 4px solid #fff;
        box-shadow: 0 6px 18px rgba(29,78,216,.22);
        margin-bottom: 14px;
    }
    .tr-preview-label {
        font-size: 1rem; font-weight: 700; color: var(--text-1); margin-bottom: 4px;
    }
    .tr-preview-sub {
        font-size: .8rem; color: var(--text-3);
        display: flex; align-items: center; justify-content: center;
        gap: 5px; margin-bottom: 18px;
    }

    /* Steps indicator */
    .tr-steps { width: 100%; margin-top: 6px; }
    .tr-step {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid var(--border);
        font-size: .82rem; color: var(--text-3);
    }
    .tr-step:last-child { border-bottom: none; }
    .tr-step.done { color: var(--success); }
    .tr-step-dot {
        width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
        background: var(--border);
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; color: var(--text-3); font-weight: 700;
    }
    .tr-step.done .tr-step-dot {
        background: var(--success); color: #fff;
    }
    .tr-step.active .tr-step-dot {
        background: var(--primary); color: #fff;
    }
    .tr-step.active { color: var(--primary); font-weight: 600; }

    .tr-tip {
        margin-top: 20px;
        background: #fffbeb; border: 1px solid #fde68a;
        border-radius: var(--radius-sm); padding: 12px 14px;
        font-size: .78rem; color: #78350f; text-align: right;
        display: flex; align-items: flex-start; gap: 8px; width: 100%;
    }
    .tr-tip i { color: #d97706; flex-shrink: 0; margin-top: 1px; }

    /* ── Form fields ── */
    .tr-form-group { margin-bottom: 20px; }
    .tr-label {
        display: flex; align-items: center; gap: 7px;
        font-size: .85rem; font-weight: 600; color: var(--text-1);
        margin-bottom: 8px;
    }
    .tr-label i {
        width: 26px; height: 26px; border-radius: 7px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; flex-shrink: 0;
    }
    .tr-label .tr-required {
        color: var(--danger); font-size: .85rem; margin-right: 2px;
    }
    .tr-input, .tr-select {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: .9rem; font-family: inherit;
        color: var(--text-1); background: #fafcff;
        transition: border-color var(--tr), box-shadow var(--tr);
        outline: none;
    }
    .tr-input:focus, .tr-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(29,78,216,.10);
        background: #fff;
    }
    .tr-input::placeholder { color: var(--text-3); }
    .tr-field-error {
        font-size: .78rem; color: var(--danger);
        margin-top: 5px; display: none;
        align-items: center; gap: 4px;
    }
    .tr-field-error:not(:empty) { display: flex; }

    /* Validation summary */
    .tr-validation-box {
        background: #fff0f0; border: 1px solid #fca5a5;
        border-radius: var(--radius-sm); padding: 14px 18px;
        margin-bottom: 20px; font-size: .87rem; color: #b91c1c;
        display: none; align-items: flex-start; gap: 10px;
    }
    .tr-validation-box:not(:empty) { display: flex; }
    .tr-validation-box i { margin-top: 1px; flex-shrink: 0; }

    /* ── Divider ── */
    .tr-section-divider {
        display: flex; align-items: center; gap: 10px;
        margin: 20px 0 18px; color: var(--text-3); font-size: .78rem;
    }
    .tr-section-divider::before,
    .tr-section-divider::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }

    /* ── Submit row ── */
    .tr-submit-row {
        display: flex; align-items: center;
        justify-content: flex-end; gap: 12px;
        padding-top: 6px; flex-wrap: wrap;
    }
    .tr-btn-save {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 28px; border-radius: var(--radius-sm);
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff; border: none; font-size: .92rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        transition: var(--tr), transform .1s;
        box-shadow: 0 4px 14px rgba(29,78,216,.28);
    }
    .tr-btn-save:hover {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(29,78,216,.35);
    }
    .tr-btn-save:active { transform: translateY(0); }
    .tr-btn-cancel {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tr-btn-cancel:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="tr-page">

    <!-- Breadcrumb -->
    <nav class="tr-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Trainers">المدربون</a>
        <i class="fas fa-chevron-left"></i>
        <span>إضافة مدرب جديد</span>
    </nav>

    <!-- Page Header -->
    <div class="tr-page-header">
        <div class="tr-page-header-left">
            <div class="tr-page-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <div>
                <h1>إضافة مدرب جديد</h1>
                <p>أدخل بيانات المدرب لإضافته إلى المنصة</p>
            </div>
        </div>
        <a asp-action="Index" class="tr-back-btn">
            <i class="fas fa-arrow-right"></i> العودة للقائمة
        </a>
    </div>

    <!-- Layout -->
    <div class="tr-create-layout">

        <!-- Aside: Preview + Steps -->
        <div class="tr-card">
            <div class="tr-preview-aside">
                <div class="tr-preview-avatar">
                    <i class="fas fa-chalkboard-teacher"></i>
                </div>
                <div class="tr-preview-label">مدرب جديد</div>
                <div class="tr-preview-sub">
                    <i class="fas fa-plus-circle" style="color:var(--primary);"></i>
                    سيُضاف للمنصة
                </div>

                <!-- Steps -->
                <div class="tr-steps">
                    <div class="tr-step active">
                        <div class="tr-step-dot">1</div>
                        اختيار المستخدم
                    </div>
                    <div class="tr-step active">
                        <div class="tr-step-dot">2</div>
                        تحديد التخصص
                    </div>
                    <div class="tr-step active">
                        <div class="tr-step-dot">3</div>
                        سنوات الخبرة
                    </div>
                    <div class="tr-step active">
                        <div class="tr-step-dot">4</div>
                        الرابط المهني
                    </div>
                </div>

                <div class="tr-tip">
                    <i class="fas fa-lightbulb"></i>
                    <span>تأكد من اختيار المستخدم الصحيح قبل الحفظ. لا يمكن تعديل المستخدم المرتبط لاحقاً بسهولة.</span>
                </div>
            </div>
        </div>

        <!-- Form Card -->
        <div class="tr-card">
            <div class="tr-card-head">
                <div class="tr-card-head-icon"><i class="fas fa-user-plus"></i></div>
                <div>
                    <h3>بيانات المدرب</h3>
                    <p>الحقول المميزة بـ * مطلوبة</p>
                </div>
            </div>
            <div class="tr-card-body">

                <form asp-action="Create">

                    <!-- Validation summary -->
                    <div asp-validation-summary="ModelOnly" class="tr-validation-box">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>

                    <!-- User -->
                    <div class="tr-form-group">
                        <label asp-for="UserId" class="tr-label">
                            <i class="fas fa-user"></i>
                            المستخدم <span class="tr-required">*</span>
                        </label>
                        <select asp-for="UserId" class="tr-select" asp-items="ViewBag.UserId">
                            <option value="">— اختر المستخدم —</option>
                        </select>
                        <span asp-validation-for="UserId" class="tr-field-error"></span>
                    </div>

                    <div class="tr-section-divider">المعلومات المهنية</div>

                    <!-- Specialty -->
                    <div class="tr-form-group">
                        <label asp-for="Specialty" class="tr-label">
                            <i class="fas fa-star"></i>
                            التخصص
                        </label>
                        <input asp-for="Specialty" class="tr-input"
                               placeholder="مثال: تطوير الويب، الذكاء الاصطناعي..." />
                        <span asp-validation-for="Specialty" class="tr-field-error"></span>
                    </div>

                    <!-- Years of Experience -->
                    <div class="tr-form-group">
                        <label asp-for="YearsOfExperience" class="tr-label">
                            <i class="fas fa-hourglass-half"></i>
                            سنوات الخبرة
                        </label>
                        <input asp-for="YearsOfExperience" type="number" min="0"
                               class="tr-input" placeholder="0" />
                        <span asp-validation-for="YearsOfExperience" class="tr-field-error"></span>
                    </div>

                    <!-- Business Link -->
                    <div class="tr-form-group">
                        <label asp-for="BusinessLink" class="tr-label">
                            <i class="fas fa-link"></i>
                            الرابط المهني
                        </label>
                        <input asp-for="BusinessLink" type="url" class="tr-input"
                               placeholder="https://linkedin.com/in/..." dir="ltr" />
                        <span asp-validation-for="BusinessLink" class="tr-field-error"></span>
                    </div>

                    <!-- ShamCash Account Code -->
                    <div class="tr-form-group">
                        <label asp-for="ShamCashAccountCode" class="tr-label">
                            <i class="fas fa-wallet"></i>
                            كود حساب الشام كاش <span class="tr-required">*</span>
                        </label>
                        <input asp-for="ShamCashAccountCode" class="tr-input"
                               maxlength="32"
                               placeholder="1906b1ad48773bc8785b9b2004d3ccc6" dir="ltr" />
                        <span asp-validation-for="ShamCashAccountCode" class="tr-field-error"></span>
                    </div>

                    <!-- Actions -->
                    <div class="tr-submit-row">
                        <a asp-action="Index" class="tr-btn-cancel">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                        <button type="submit" class="tr-btn-save">
                            <i class="fas fa-plus-circle"></i> إضافة المدرب
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
