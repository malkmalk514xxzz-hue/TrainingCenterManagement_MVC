@model TrainingCenterManagement_MVC.Models.Payment

@{
    ViewData["Title"] = "تفاصيل الدفعة";
    var traineeChar = Model.Trainee?.User?.FullName?.Length > 0
        ? Model.Trainee.User.FullName[0].ToString() : "م";
    var isPaid    = !Model.IsDeleted;
    var statusLbl = isPaid ? "مدفوعة" : "ملغاة";
    var statusCls = isPaid ? "py-status-paid" : "py-status-cancelled";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --success:       #10b981;
        --warning:       #f59e0b;
        --danger:        #ef4444;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:     0 8px 32px rgba(0,0,0,.14);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .py-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
    }

    /* ── Breadcrumb ── */
    .py-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3); margin-bottom: 22px;
    }
    .py-breadcrumb a { color: var(--primary); text-decoration: none; }
    .py-breadcrumb a:hover { text-decoration: underline; }
    .py-breadcrumb i { font-size: .65rem; }

    /* ── Page header ── */
    .py-page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        margin-bottom: 28px;
    }
    .py-page-header-left { display: flex; align-items: center; gap: 16px; }
    .py-page-icon {
        width: 52px; height: 52px; border-radius: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #fff;
        box-shadow: 0 4px 14px rgba(29,78,216,.30);
    }
    .py-page-header h1 { font-size: 1.5rem; font-weight: 800; color: var(--text-1); margin: 0 0 3px; }
    .py-page-header p  { font-size: .85rem; color: var(--text-2); margin: 0; }
    .py-back-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .py-back-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── Hero amount banner ── */
    .py-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #1d4ed8 100%);
        border-radius: var(--radius);
        padding: 30px 36px;
        margin-bottom: 24px;
        display: flex; align-items: center; gap: 28px; flex-wrap: wrap;
        position: relative; overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    .py-hero::before {
        content: ''; position: absolute; top: -70px; left: -50px;
        width: 250px; height: 250px;
        background: rgba(255,255,255,.05); border-radius: 50%;
    }
    .py-hero-amount-wrap { position: relative; z-index: 1; }
    .py-hero-amount-label {
        font-size: .82rem; color: rgba(255,255,255,.7);
        font-weight: 500; margin-bottom: 4px; letter-spacing: .04em;
        text-transform: uppercase;
    }
    .py-hero-amount {
        font-size: 2.6rem; font-weight: 900; color: #fff;
        letter-spacing: -1px; line-height: 1;
    }
    .py-hero-amount span { font-size: 1.1rem; font-weight: 600; opacity: .8; margin-right: 6px; }
    .py-hero-meta { flex: 1; position: relative; z-index: 1; color: #fff; }
    .py-hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
    .py-hero-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(255,255,255,.15); backdrop-filter: blur(6px);
        border-radius: 30px; padding: 5px 14px;
        font-size: .8rem; color: #fff; font-weight: 500;
    }
    .py-hero-id {
        font-size: .78rem; color: rgba(255,255,255,.55);
        font-family: monospace; letter-spacing: .05em;
    }
    .py-hero-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }
    .py-hero-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 20px; border-radius: var(--radius-sm);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; border: none; cursor: pointer;
        transition: var(--tr); white-space: nowrap;
    }
    .py-hero-btn-white { background: #fff; color: var(--primary); }
    .py-hero-btn-white:hover { background: #eff6ff; color: var(--primary-dark); }
    .py-hero-btn-red {
        background: #fee2e2; color: #b91c1c;
        border: 1.5px solid rgba(255,255,255,.2);
    }
    .py-hero-btn-red:hover { background: #fecaca; }

    /* ── Grid ── */
    .py-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px; margin-bottom: 20px;
    }
    @@media (max-width: 860px) { .py-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .py-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 26px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        transition: var(--tr);
    }
    .py-card:hover { box-shadow: var(--shadow-md); }
    .py-card-title {
        font-size: .95rem; font-weight: 700; color: var(--text-1);
        margin: 0 0 20px;
        display: flex; align-items: center; gap: 9px;
        padding-bottom: 14px; border-bottom: 1px solid var(--border);
    }
    .py-card-title i {
        width: 34px; height: 34px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }

    /* ── Info rows ── */
    .py-info-row {
        display: flex; align-items: flex-start; gap: 14px;
        padding: 13px 0; border-bottom: 1px solid var(--border);
    }
    .py-info-row:last-child { border-bottom: none; padding-bottom: 0; }
    .py-info-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem; flex-shrink: 0; margin-top: 1px;
    }
    .py-info-label {
        font-size: .75rem; font-weight: 600; color: var(--text-3);
        text-transform: uppercase; letter-spacing: .04em; margin-bottom: 3px;
    }
    .py-info-value { font-size: .95rem; font-weight: 600; color: var(--text-1); }

    /* ── Trainee avatar ── */
    .py-trainee-cell { display: flex; align-items: center; gap: 11px; }
    .py-trainee-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff; font-size: .95rem; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .py-trainee-name { font-size: .95rem; font-weight: 600; color: var(--text-1); }
    .py-trainee-email { font-size: .78rem; color: var(--text-3); }

    /* ── Status chips ── */
    .py-status-paid {
        display: inline-flex; align-items: center; gap: 6px;
        background: #d1fae5; color: #065f46;
        border-radius: 20px; padding: 4px 12px;
        font-size: .82rem; font-weight: 700;
    }
    .py-status-cancelled {
        display: inline-flex; align-items: center; gap: 6px;
        background: #fee2e2; color: #991b1b;
        border-radius: 20px; padding: 4px 12px;
        font-size: .82rem; font-weight: 700;
    }
    .py-status-dot {
        width: 7px; height: 7px; border-radius: 50%;
    }
    .py-status-paid      .py-status-dot { background: #10b981; }
    .py-status-cancelled .py-status-dot { background: #ef4444; }
</style>

<div class="py-page">

    <!-- Breadcrumb -->
    <nav class="py-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Payments">المدفوعات</a>
        <i class="fas fa-chevron-left"></i>
        <span>تفاصيل الدفعة</span>
    </nav>

    <!-- Page Header -->
    <div class="py-page-header">
        <div class="py-page-header-left">
            <div class="py-page-icon"><i class="fas fa-receipt"></i></div>
            <div>
                <h1>تفاصيل الدفعة</h1>
                <p>عرض كامل بيانات الدفعة المالية</p>
            </div>
        </div>
        <a asp-action="Index" class="py-back-btn">
            <i class="fas fa-arrow-right"></i> العودة للقائمة
        </a>
    </div>

    <!-- Hero Amount Banner -->
    <div class="py-hero">
        <div class="py-hero-amount-wrap">
            <div class="py-hero-amount-label">المبلغ الإجمالي</div>
            <div class="py-hero-amount">
                <span>ل.س</span>@Model.TotalAmount.ToString("N0")
            </div>
        </div>

        <div class="py-hero-meta">
            <div class="py-hero-badges">
                <span class="py-hero-badge">
                    <i class="fas fa-calendar-alt"></i>
                    @Model.CreatedDate.ToString("yyyy-MM-dd")
                </span>
                <span class="py-hero-badge">
                    <i class="fas fa-user-graduate"></i>
                    @(Model.Trainee?.User?.FullName ?? "—")
                </span>
                <span class="py-hero-badge">
                    <i class="fas fa-book-open"></i>
                    @(Model.Course?.CourseName ?? "—")
                </span>
            </div>
            <div class="py-hero-id">
                رقم الدفعة: @Model.PaymentId
            </div>
        </div>

        <div class="py-hero-actions">
            <a asp-action="Delete" asp-route-id="@Model.PaymentId" class="py-hero-btn py-hero-btn-red">
                <i class="fas fa-trash-alt"></i> حذف
            </a>
            <a asp-action="Index" class="py-hero-btn py-hero-btn-white">
                <i class="fas fa-list"></i> القائمة
            </a>
        </div>
    </div>

    <!-- Info Grid -->
    <div class="py-grid">

        <!-- Payment Info -->
        <div class="py-card">
            <div class="py-card-title">
                <i class="fas fa-money-bill-wave"></i>
                بيانات الدفعة
            </div>

            <div class="py-info-row">
                <div class="py-info-icon"><i class="fas fa-coins"></i></div>
                <div>
                    <div class="py-info-label">المبلغ الإجمالي</div>
                    <div class="py-info-value" style="color:var(--success);font-size:1.15rem;">
                        @Model.TotalAmount.ToString("N0") ل.س
                    </div>
                </div>
            </div>

            <div class="py-info-row">
                <div class="py-info-icon"><i class="fas fa-calendar-alt"></i></div>
                <div>
                    <div class="py-info-label">تاريخ الإنشاء</div>
                    <div class="py-info-value">@Model.CreatedDate.ToString("yyyy-MM-dd")</div>
                </div>
            </div>

            <div class="py-info-row">
                <div class="py-info-icon"><i class="fas fa-info-circle"></i></div>
                <div>
                    <div class="py-info-label">الحالة</div>
                    <div class="py-info-value">
                        <span class="@statusCls">
                            <span class="py-status-dot"></span>
                            @statusLbl
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Info -->
        <div class="py-card">
            <div class="py-card-title">
                <i class="fas fa-link"></i>
                البيانات المرتبطة
            </div>

            <div class="py-info-row">
                <div class="py-info-icon"><i class="fas fa-user-graduate"></i></div>
                <div>
                    <div class="py-info-label">المتدرب</div>
                    <div class="py-info-value">
                        <div class="py-trainee-cell">
                            <div class="py-trainee-avatar">@traineeChar</div>
                            <div>
                                <div class="py-trainee-name">
                                    @(Model.Trainee?.User?.FullName ?? "—")
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Trainee?.User?.Email))
                                {
                                    <div class="py-trainee-email">@Model.Trainee.User.Email</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="py-info-row">
                <div class="py-info-icon"><i class="fas fa-book-open"></i></div>
                <div>
                    <div class="py-info-label">الدورة</div>
                    <div class="py-info-value">@(Model.Course?.CourseName ?? "—")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Back -->
    <a asp-action="Index" class="py-back-btn">
        <i class="fas fa-arrow-right"></i> العودة للقائمة
    </a>

</div>
