@model IEnumerable<TrainingCenterManagement_MVC.Models.Course>

<h3 class="mb-4">الدورات المسجّل بها</h3>

<table class="table table-bordered table-hover">
    <thead class="table-primary text-center">
        <tr>
            <th>الدورة</th>
            <th>المدرب</th>
            <th style="width: 120px;">تفاصيل</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr class="text-center">
                <td>@course.CourseName</td>
                <td>@course.Admin?.User?.FullName ?? "غير محدد"</td>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.CourseId"
                       class="btn btn-info btn-sm" title="عرض تفاصيل الدورة">
                        تفاصيل
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
