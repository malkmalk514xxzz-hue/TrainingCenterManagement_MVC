@model IEnumerable<TrainingCenterManagement_MVC.Models.Course>

<h3 class="mb-4">Enrolled Courses</h3>

<table class="table table-bordered table-hover">
    <thead class="table-primary text-center">
        <tr>
            <th>Course</th>
            <th>Trainer</th>
            <th style="width: 120px;">Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr class="text-center">
                <td>@course.CourseName</td>
                <td>@course.Admin?.User?.FullName ?? "Not Assigned"</td>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.CourseId"
                       class="btn btn-info btn-sm" title="View course details">
                        Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
