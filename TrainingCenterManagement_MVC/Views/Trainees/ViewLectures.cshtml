@model IEnumerable<TrainingCenterManagement_MVC.Models.Lecture>
@{
    ViewData["Title"] = "Lectures";
    var course = ViewBag.Course as TrainingCenterManagement_MVC.Models.Course;
}

<h2 class="mb-4">Lectures for @course?.CourseName</h2>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Description</th>
            <th>Video</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var lecture in Model)
        {
            <tr>
                <td>@lecture.Title</td>
                <td>@lecture.LectureDate.ToString("dd MMM yyyy")</td>
                <td>@lecture.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(lecture.VideoUrl))
                    {
                        <a href="@lecture.VideoUrl" class="btn btn-sm btn-primary" target="_blank" rel="noopener noreferrer">
                            ▶️ Watch
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No video</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
