<body>
    <div class="relative flex size-full min-h-screen flex-col bg-white overflow-x-hidden">
        @Html.Partial("_LandingHeader")

        <div class="flex flex-1 justify-center py-5 px-10">
            <div class="flex flex-col max-w-[960px] flex-1">
                <h2 class="text-[#111418] tracking-light text-3xl font-bold leading-tight min-w-72 mb-8">Lectures for @course?.CourseName</h2>
                <div class="grid-container">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var lecture in Model.OrderByDescending(l => l.LectureDate))
                        {
                            <div class="lecture-card">
                                <div class="w-full bg-center bg-no-repeat aspect-video bg-cover rounded-t-lg overflow-hidden lecture-card-image-container"
                                     style='background-image: url("@GetYoutubeThumbnailUrl(lecture.VideoUrl)");'>

                                    <div class="single-button-overlay">
                                        <a href="@lecture.VideoUrl" target="_blank" class="flex cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-3 bg-[#0d80f2] text-white text-sm font-bold leading-normal">
                                            <span class="truncate">مشاهدة المحاضرة</span>
                                        </a>
                                    </div>
                                </div>
                                <div class="lecture-info">
                                    <div class="flex-col">
                                        <p class="text-[#111418] text-base font-medium leading-normal">@lecture.Title</p>
                                        <p class="text-[#60758a] text-sm font-normal leading-normal">@lecture.Description</p>
                                        <p class="text-[#60758a] text-sm font-normal leading-normal">@lecture.LectureDate.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-[#60758a]">No lectures available for this course.</div>
                    }
                </div>
            </div>
        </div>
    </div>
