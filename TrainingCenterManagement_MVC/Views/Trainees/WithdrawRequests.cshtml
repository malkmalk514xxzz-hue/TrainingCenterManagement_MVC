@model IEnumerable<TrainingCenterManagement_MVC.Models.WithdrawRequest>
@using TrainingCenterManagement_MVC.Models
@{
    ViewData["Title"] = "طلبات استرداد الأموال";
    var pending   = Model.Where(r => r.Status == WithdrawStatus.PendingReview).ToList();
    var partial   = Model.Where(r => r.Status == WithdrawStatus.PartiallyApproved).ToList();
    var approved  = Model.Where(r => r.Status == WithdrawStatus.FullyApproved).ToList();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<style>
    :root {
        --warn:#f59e0b; --success:#10b981; --danger:#ef4444; --partial:#6366f1;
        --teal:#0d9488;
        --body:#f1f5f9; --card:#fff; --t1:#0f172a; --t2:#475569; --t3:#94a3b8;
        --border:#e2e8f0; --radius:14px; --shadow:0 4px 20px rgba(0,0,0,.08);
    }
    .wr-page { background:var(--body); min-height:100vh; direction:rtl; font-family:'Segoe UI',sans-serif; padding:28px 20px 60px; }
    .wr-inner { max-width:1000px; margin:0 auto; }
    .wr-header { display:flex; align-items:center; margin-bottom:24px; }
    .wr-header h1 { font-size:1.4rem; font-weight:800; color:var(--t1); margin:0; display:flex; align-items:center; gap:10px; }
    .wr-header h1 i { color:var(--warn); }

    .wr-tabs { display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap; }
    .wr-tab { padding:7px 18px; border-radius:20px; border:1.5px solid var(--border); background:var(--card); font-size:.82rem; font-weight:600; color:var(--t2); cursor:pointer; font-family:inherit; transition:.2s; }
    .wr-tab.active { background:var(--warn); color:#fff; border-color:var(--warn); }
    .wr-tab-content { display:none; }
    .wr-tab-content.active { display:block; }

    .wr-table-wrap { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; }
    .wr-table { width:100%; border-collapse:collapse; font-size:.86rem; }
    .wr-table th { background:#f8fafc; padding:12px 16px; text-align:right; font-weight:700; color:var(--t2); border-bottom:1px solid var(--border); }
    .wr-table td { padding:12px 16px; border-bottom:1px solid var(--border); color:var(--t1); vertical-align:middle; }
    .wr-table tr:last-child td { border-bottom:none; }
    .wr-table tr:hover td { background:#fafafa; }

    .wr-badge { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:10px; font-size:.74rem; font-weight:700; }
    .wr-badge.pending  { background:#fef3c7; color:#92400e; border:1px solid #fcd34d; }
    .wr-badge.partial  { background:#ede9fe; color:#5b21b6; border:1px solid #c4b5fd; }
    .wr-badge.done     { background:#d1fae5; color:#065f46; border:1px solid #6ee7b7; }

    .wr-btn { display:inline-flex; align-items:center; gap:5px; padding:6px 14px; border-radius:7px; font-size:.78rem; font-weight:600; text-decoration:none; color:#fff; background:var(--teal); transition:.2s; }
    .wr-btn:hover { opacity:.85; color:#fff; }

    .wr-empty { text-align:center; padding:48px 20px; color:var(--t3); }
    .wr-empty i { font-size:2.5rem; display:block; margin-bottom:10px; }

    .wr-summary { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:20px; }
    .wr-stat { flex:1; min-width:140px; background:var(--card); border-radius:12px; padding:16px; border:1px solid var(--border); text-align:center; box-shadow:var(--shadow); }
    .wr-stat-val { font-size:1.6rem; font-weight:800; }
    .wr-stat-label { font-size:.75rem; color:var(--t2); }
</style>

<div class="wr-page">
    <div class="wr-inner">

        <div class="wr-header">
            <h1><i class="fas fa-hand-holding-usd"></i> طلبات استرداد الأموال</h1>
        </div>

        <!-- Summary -->
        <div class="wr-summary">
            <div class="wr-stat">
                <div class="wr-stat-val" style="color:var(--warn);">@pending.Count</div>
                <div class="wr-stat-label">قيد المراجعة</div>
            </div>
            <div class="wr-stat">
                <div class="wr-stat-val" style="color:var(--partial);">@partial.Count</div>
                <div class="wr-stat-label">تم جزئياً</div>
            </div>
            <div class="wr-stat">
                <div class="wr-stat-val" style="color:var(--success);">@approved.Count</div>
                <div class="wr-stat-label">تم كلياً</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="wr-tabs">
            <button class="wr-tab active" onclick="showTab('pending',this)">
                <i class="fas fa-clock"></i> قيد المراجعة (@pending.Count)
            </button>
            <button class="wr-tab" onclick="showTab('partial',this)">
                <i class="fas fa-hourglass-half"></i> تم جزئياً (@partial.Count)
            </button>
            <button class="wr-tab" onclick="showTab('approved',this)">
                <i class="fas fa-check-circle"></i> تم كلياً (@approved.Count)
            </button>
        </div>

        <!-- قيد المراجعة -->
        <div id="tab-pending" class="wr-tab-content active">
            @if (!pending.Any())
            {
                <div class="wr-empty"><i class="fas fa-inbox"></i><div>لا توجد طلبات قيد المراجعة</div></div>
            }
            else
            {
                <div class="wr-table-wrap">
                    <table class="wr-table">
                        <thead>
                            <tr><th>المتدرب</th><th>USD</th><th>SYP</th><th>المدفوع USD</th><th>المدفوع SYP</th><th>الحالة</th><th>التاريخ</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var r in pending)
                            {
                                <tr>
                                    <td><strong>@(r.Trainee?.User?.FullName ?? "—")</strong></td>
                                    <td>@(r.AmountUSD > 0 ? $"${r.AmountUSD:N2}" : "—")</td>
                                    <td>@(r.AmountSYP > 0 ? $"{r.AmountSYP:N0} ل.س" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountUSD > 0 ? $"${r.PaidAmountUSD:N2}" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountSYP > 0 ? $"{r.PaidAmountSYP:N0} ل.س" : "—")</td>
                                    <td><span class="wr-badge pending"><i class="fas fa-clock"></i> قيد المراجعة</span></td>
                                    <td style="font-size:.76rem;color:var(--t3);">@r.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                    <td><a asp-action="WithdrawRequestDetail" asp-route-id="@r.Id" class="wr-btn"><i class="fas fa-eye"></i> عرض</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- تم جزئياً -->
        <div id="tab-partial" class="wr-tab-content">
            @if (!partial.Any())
            {
                <div class="wr-empty"><i class="fas fa-inbox"></i><div>لا توجد طلبات منجزة جزئياً</div></div>
            }
            else
            {
                <div class="wr-table-wrap">
                    <table class="wr-table">
                        <thead>
                            <tr><th>المتدرب</th><th>USD</th><th>SYP</th><th>المدفوع USD</th><th>المدفوع SYP</th><th>الحالة</th><th>التاريخ</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var r in partial)
                            {
                                <tr>
                                    <td><strong>@(r.Trainee?.User?.FullName ?? "—")</strong></td>
                                    <td>@(r.AmountUSD > 0 ? $"${r.AmountUSD:N2}" : "—")</td>
                                    <td>@(r.AmountSYP > 0 ? $"{r.AmountSYP:N0} ل.س" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountUSD > 0 ? $"${r.PaidAmountUSD:N2}" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountSYP > 0 ? $"{r.PaidAmountSYP:N0} ل.س" : "—")</td>
                                    <td><span class="wr-badge partial"><i class="fas fa-hourglass-half"></i> تم جزئياً</span></td>
                                    <td style="font-size:.76rem;color:var(--t3);">@r.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                    <td><a asp-action="WithdrawRequestDetail" asp-route-id="@r.Id" class="wr-btn"><i class="fas fa-eye"></i> عرض</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- تم كلياً -->
        <div id="tab-approved" class="wr-tab-content">
            @if (!approved.Any())
            {
                <div class="wr-empty"><i class="fas fa-inbox"></i><div>لا توجد طلبات منجزة بالكامل</div></div>
            }
            else
            {
                <div class="wr-table-wrap">
                    <table class="wr-table">
                        <thead>
                            <tr><th>المتدرب</th><th>USD</th><th>SYP</th><th>المدفوع USD</th><th>المدفوع SYP</th><th>الحالة</th><th>التاريخ</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var r in approved)
                            {
                                <tr>
                                    <td><strong>@(r.Trainee?.User?.FullName ?? "—")</strong></td>
                                    <td>@(r.AmountUSD > 0 ? $"${r.AmountUSD:N2}" : "—")</td>
                                    <td>@(r.AmountSYP > 0 ? $"{r.AmountSYP:N0} ل.س" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountUSD > 0 ? $"${r.PaidAmountUSD:N2}" : "—")</td>
                                    <td style="color:var(--success);">@(r.PaidAmountSYP > 0 ? $"{r.PaidAmountSYP:N0} ل.س" : "—")</td>
                                    <td><span class="wr-badge done"><i class="fas fa-check-circle"></i> تم كلياً</span></td>
                                    <td style="font-size:.76rem;color:var(--t3);">@r.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                    <td><a asp-action="WithdrawRequestDetail" asp-route-id="@r.Id" class="wr-btn"><i class="fas fa-eye"></i> عرض</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

<script>
    function showTab(name, btn) {
        document.querySelectorAll('.wr-tab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.wr-tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + name).classList.add('active');
    }
</script>
