@model IEnumerable<TrainingCenterManagement_MVC.Models.Trainee>
@using TrainingCenterManagement_MVC.Models
@{
    ViewData["Title"] = "إدارة المتدربين";
    var list = Model.ToList();

    string AvatarUrl(ApplicationUser u) {
        if (!string.IsNullOrEmpty(u?.ProfilePictureUrl)) return u.ProfilePictureUrl;
        var name = Uri.EscapeDataString(u?.FullName ?? "U");
        var bg   = (u?.Gender == Gender.Female) ? "ec4899" : "4f46e5";
        return $"https://ui-avatars.com/api/?name={name}&background={bg}&color=ffffff&bold=true&size=128&rounded=true";
    }
}

<style>
    :root {
        --pr:#4f46e5;--pr-l:#6366f1;--pr-pale:#eef2ff;
        --success:#10b981;--danger:#ef4444;--gold:#f59e0b;
        --body:#f1f5f9;--card:#fff;--t1:#0f172a;--t2:#475569;--t3:#94a3b8;
        --border:#e2e8f0;--shadow:0 4px 20px rgba(0,0,0,.07);--radius:14px;
    }
    .tn-page { background:var(--body); padding:28px 32px; direction:rtl; font-family:'Segoe UI',sans-serif; }

    /* Header */
    .tn-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
    .tn-header h1 { font-size:1.5rem; font-weight:800; color:var(--t1); margin:0; display:flex; align-items:center; gap:10px; }
    .tn-header h1 .icon { width:40px;height:40px;border-radius:10px;background:var(--pr-pale);color:var(--pr);display:flex;align-items:center;justify-content:center;font-size:1rem; }
    .tn-add-btn { display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:9px;background:var(--pr);color:#fff;text-decoration:none;font-size:.84rem;font-weight:700;transition:all .2s; }
    .tn-add-btn:hover { background:var(--pr-l);color:#fff; }

    /* Stats */
    .tn-stats { display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px; }
    @@media(max-width:600px){ .tn-stats{ grid-template-columns:1fr 1fr; } }
    .tn-stat { background:var(--card);border-radius:12px;border:1px solid var(--border);padding:18px 20px;box-shadow:var(--shadow);display:flex;align-items:center;gap:14px; }
    .tn-stat-icon { width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0; }
    .tn-stat-val { font-size:1.5rem;font-weight:800;color:var(--t1);line-height:1; }
    .tn-stat-lbl { font-size:.74rem;color:var(--t3);margin-top:2px; }

    /* Toolbar */
    .tn-toolbar { background:var(--card);border-radius:12px;border:1px solid var(--border);padding:14px 18px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:20px; }
    .tn-search { flex:1;min-width:180px;position:relative; }
    .tn-search i { position:absolute;right:11px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:.8rem; }
    .tn-search input { width:100%;padding:8px 34px 8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:.84rem;font-family:inherit;box-sizing:border-box; }
    .tn-search input:focus { outline:none;border-color:var(--pr);box-shadow:0 0 0 3px rgba(79,70,229,.1); }
    .tn-filter { display:flex;gap:6px; }
    .tn-fb { padding:6px 12px;border-radius:20px;border:1.5px solid var(--border);background:#fff;font-size:.75rem;font-weight:600;color:var(--t2);cursor:pointer;font-family:inherit;transition:all .2s; }
    .tn-fb.active,.tn-fb:hover { background:var(--pr);color:#fff;border-color:var(--pr); }
    .tn-count { font-size:.78rem;color:var(--t3);margin-right:auto; }

    /* Grid */
    .tn-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px; }

    /* Card */
    .tn-card { background:var(--card);border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow);padding:20px;display:flex;flex-direction:column;align-items:center;text-align:center;transition:all .2s;position:relative; }
    .tn-card:hover { transform:translateY(-3px);box-shadow:0 8px 24px rgba(79,70,229,.12);border-color:#c7d2fe; }
    .tn-avatar-wrap { position:relative;margin-bottom:12px; }
    .tn-avatar { width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--border);transition:border-color .2s; }
    .tn-card:hover .tn-avatar { border-color:#c7d2fe; }
    .tn-gender-dot { position:absolute;bottom:2px;left:2px;width:16px;height:16px;border-radius:50%;border:2px solid #fff;display:flex;align-items:center;justify-content:center;font-size:.55rem;color:#fff; }
    .tn-gender-m { background:#4f46e5; }
    .tn-gender-f { background:#ec4899; }
    .tn-name { font-size:.92rem;font-weight:700;color:var(--t1);margin:0 0 3px; }
    .tn-email { font-size:.71rem;color:var(--t3);margin:0 0 6px;word-break:break-all; }
    .tn-courses-badge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:12px;background:var(--pr-pale);color:var(--pr);font-size:.72rem;font-weight:600;margin-bottom:12px; }
    .tn-actions { display:flex;gap:7px;width:100%; }
    .tn-btn { flex:1;padding:7px 10px;border-radius:7px;font-size:.75rem;font-weight:600;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:5px;transition:all .2s;border:none;cursor:pointer;font-family:inherit; }
    .tn-btn-info { background:var(--pr-pale);color:var(--pr); }
    .tn-btn-info:hover { background:var(--pr);color:#fff; }
    .tn-btn-del { background:#fee2e2;color:var(--danger); }
    .tn-btn-del:hover { background:var(--danger);color:#fff; }

    /* Empty */
    .tn-empty { text-align:center;padding:60px 20px;color:var(--t3); }
    .tn-empty i { font-size:2.5rem;margin-bottom:12px;display:block; }
</style>

<div class="dashboard-wrapper">
    @await Html.PartialAsync("_AdminSidebar")
    <main class="dashboard-main tn-page">

        <!-- Header -->
        <div class="tn-header">
            <h1>
                <span class="icon"><i class="fas fa-user-graduate"></i></span>
                إدارة المتدربين
            </h1>
            <a asp-action="Create" class="tn-add-btn">
                <i class="fas fa-user-plus"></i> إضافة متدرب
            </a>
        </div>

        <!-- Stats -->
        @{
            var maleCount   = list.Count(t => t.User?.Gender == Gender.Male);
            var femaleCount = list.Count(t => t.User?.Gender == Gender.Female);
            var enrolled    = list.Count(t => t.CourseTrainees?.Any() == true);
        }
        <div class="tn-stats">
            <div class="tn-stat">
                <div class="tn-stat-icon" style="background:#eef2ff;color:#4f46e5;"><i class="fas fa-users"></i></div>
                <div><div class="tn-stat-val">@list.Count</div><div class="tn-stat-lbl">إجمالي المتدربين</div></div>
            </div>
            <div class="tn-stat">
                <div class="tn-stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="fas fa-mars"></i></div>
                <div><div class="tn-stat-val">@maleCount</div><div class="tn-stat-lbl">ذكر</div></div>
            </div>
            <div class="tn-stat">
                <div class="tn-stat-icon" style="background:#fce7f3;color:#db2777;"><i class="fas fa-venus"></i></div>
                <div><div class="tn-stat-val">@femaleCount</div><div class="tn-stat-lbl">أنثى</div></div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="tn-toolbar">
            <div class="tn-search">
                <i class="fas fa-search"></i>
                <input type="text" id="tn-search-input" placeholder="ابحث بالاسم أو الإيميل..." oninput="tnFilter()" />
            </div>
            <div class="tn-filter">
                <button class="tn-fb active" onclick="tnSetFilter('all',this)">الكل</button>
                <button class="tn-fb" onclick="tnSetFilter('male',this)">ذكر</button>
                <button class="tn-fb" onclick="tnSetFilter('female',this)">أنثى</button>
            </div>
            <span class="tn-count" id="tn-count">@list.Count متدرب</span>
        </div>

        <!-- Grid -->
        @if (list.Any())
        {
            <div class="tn-grid" id="tn-grid">
                @foreach (var item in list)
                {
                    var av = AvatarUrl(item.User);
                    var isFemale = item.User?.Gender == Gender.Female;
                    var courses = item.CourseTrainees?.Count ?? 0;
                    <div class="tn-card"
                         data-name="@(item.User?.FullName?.ToLower())"
                         data-email="@(item.User?.Email?.ToLower())"
                         data-gender="@(isFemale ? "female" : "male")">
                        <div class="tn-avatar-wrap">
                            <img src="@av" class="tn-avatar" alt="@item.User?.FullName"
                                 onerror="this.src='https://ui-avatars.com/api/?name=U&background=94a3b8&color=fff&rounded=true'" />
                            <span class="tn-gender-dot @(isFemale ? "tn-gender-f" : "tn-gender-m")">
                                <i class="fas @(isFemale ? "fa-venus" : "fa-mars")"></i>
                            </span>
                        </div>
                        <div class="tn-name">@item.User?.FullName</div>
                        <div class="tn-email">@item.User?.Email</div>
                        @if (courses > 0)
                        {
                            <span class="tn-courses-badge">
                                <i class="fas fa-book-open"></i> @courses كورس
                            </span>
                        }
                        <div class="tn-actions">
                            <a asp-action="Details" asp-route-id="@item.TraineeId" class="tn-btn tn-btn-info">
                                <i class="fas fa-eye"></i> تفاصيل
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.TraineeId" class="tn-btn tn-btn-del">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="tn-empty">
                <i class="fas fa-user-graduate"></i>
                <p>لا يوجد متدربون مسجلون بعد</p>
            </div>
        }

    </main>
</div>

<script>
    var tnCurrentFilter = 'all';
    function tnSetFilter(f, btn) {
        tnCurrentFilter = f;
        document.querySelectorAll('.tn-fb').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tnApply();
    }
    function tnFilter() { tnApply(); }
    function tnApply() {
        var q = (document.getElementById('tn-search-input').value || '').trim().toLowerCase();
        var cards = document.querySelectorAll('#tn-grid .tn-card');
        var count = 0;
        cards.forEach(function(c) {
            var matchQ = !q || (c.dataset.name || '').includes(q) || (c.dataset.email || '').includes(q);
            var matchF = tnCurrentFilter === 'all' || c.dataset.gender === tnCurrentFilter;
            c.style.display = (matchQ && matchF) ? '' : 'none';
            if (matchQ && matchF) count++;
        });
        document.getElementById('tn-count').textContent = count + ' متدرب';
    }
</script>
