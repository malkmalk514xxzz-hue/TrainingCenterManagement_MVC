@model IEnumerable<TrainingCenterManagement_MVC.Models.Trainee>

@{
    ViewData["Title"] = "Trainees List";
}

<style>
    :root {
        --color-background: #fff;
        --color-header-border: #f0f2f4;
        --color-text-dark: #111418;
        --color-text-muted: #617589;
        --font-family-sans: Inter, "Noto Sans", sans-serif;
    }

    body {
        font-family: var(--font-family-sans);
        background-color: var(--color-background);
        margin: 0;
        direction: rtl;
    }

    .layout-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        width: 100%;
        overflow-x: hidden;
    }

    .header-style {
        display: flex;
        align-items: center;
        justify-content: space-between;
        white-space: nowrap;
        border-bottom: 1px solid var(--color-header-border);
        padding: 0.75rem 2.5rem;
    }

    .header-logo-section {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: var(--color-text-dark);
    }

    .header-logo-svg {
        width: 1rem;
        height: 1rem;
    }

    .header-title {
        color: var(--color-text-dark);
        font-size: 1.125rem;
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -0.015em;
    }

    .header-links-section {
        display: flex;
        flex: 1;
        justify-content: flex-end;
        gap: 2rem;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 2.25rem;
    }

    .nav-link {
        color: var(--color-text-dark);
        font-size: 0.875rem;
        font-weight: 500;
        line-height: 1.5;
        text-decoration: none;
    }

    .profile-picture {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
    }

    .main-content {
        flex: 1;
        display: flex;

        justify-content: center;
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
        padding-left: 6rem;
        padding-right: 6rem;
    }

    .content-container {
        display: flex;
        flex-direction: column;
        max-width:960px;
        flex: 1;
    }

    .header-controls {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 1rem;
    }

    .page-title {
        color: var(--color-text-dark);
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.25;
        min-width: 18rem;
    }

    .create-button {
        display: flex;
        min-width: 84px;
        max-width: 480px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 0.5rem;
        height: 2rem;
        padding: 0 1rem;
        background-color: var(--color-header-border);
        color: var(--color-text-dark);
        font-size: 0.875rem;
        font-weight: 500;
        line-height: 1.5;
        border: none;
        text-decoration: none;
        transition: background-color 0.2s;
    }

        .create-button:hover {
            background-color: #e2e6e9;
        }

    .grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        padding: 1rem;
    }

    .trainee-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem;
        background-color: #ffffff;
        border-radius: 0.5rem;
        border: 0px solid #e0e0e0;
        text-align: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .trainee-image {
        width: 96px;
        height: 96px;
        object-fit: cover;
        border-radius: 50%;
        margin-bottom: 1rem;
        border: 2px solid #ccc;
    }

    .trainee-name {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--color-text-dark);
        margin-bottom: 0.25rem;
    }

    .trainee-email {
        font-size: 0.75rem; /* Smaller font size for email */
        color: var(--color-text-muted);
        line-height: 1.4;
        margin-bottom: 1rem;
        word-wrap: break-word; /* Allows long email to wrap */
        white-space: normal;
    }

    .card-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

        .card-actions a {
            padding: 0.5rem 1rem;
            border-radius: 0.25rem;
            font-size: 0.875rem;
            text-decoration: none;
            font-weight: 500;
        }

    .details-btn {
        background-color: #fff;
        color: #1a73e8;
        border-color: #1a73e8;
        border-width: 1px;
        border-radius: 10px;
        border-style: solid;
    }

    .delete-btn {
        background-color: #fff;
        color: #d9534f;
        border-color: #d9534f;
        border-width: 1px;
        border-radius: 10px;
        border-style: solid;
    }

    .details-btn:hover {
        background-color: #1a73e8;
        color: #fff;
    }

    .delete-btn:hover {
        background-color: #d9534f;
        color: #fff;
    }

    .no-data-message {
        text-align: center;
        color: var(--color-text-muted);
        padding: 2rem;
        grid-column: 1 / -1;
    }
</style>

<div class="layout-container" style="background-color:white">
    @Html.Partial("_LandingHeader")
    <div class="main-content">
        <div class="content-container">
            <div class="header-controls">
                <p class="page-title">Trainees</p>
                <a asp-action="Create" class="create-button">
                    <span class="truncate">Create New Trainee</span>
                </a>
            </div>
            <div class="grid-container">
                @if (!Model.Any())
                {
                    <div class="no-data-message">
                        No trainees found.
                    </div>
                }
                else
                {
                    var random = new Random();
                    foreach (var item in Model)
                    {
                        var randomImageNumber = random.Next(1, 7);
                        var imagePath = Url.Content($"~/images/profile/{randomImageNumber}.png");

                        <div class="trainee-card">
                            <img src="@imagePath" class="trainee-image" alt="Trainee Profile Picture" />
                            <p class="trainee-name">@item.User.FullName</p>
                            @* @if (item.User != null)
                            {
                                <p class="trainee-email">@item.User.Email</p>
                            } *@
                            <div class="card-actions">
                                <a asp-action="Details" asp-route-id="@item.TraineeId" class="details-btn">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.TraineeId" class="delete-btn">Delete</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    @Html.Partial("_LandingFooter")
</div>