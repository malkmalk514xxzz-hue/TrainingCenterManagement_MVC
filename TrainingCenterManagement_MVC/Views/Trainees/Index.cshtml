@model IEnumerable<TrainingCenterManagement_MVC.Models.Trainee>

@{
    ViewData["Title"] = "Trainees List";
}

<h1 class="mb-4">Trainees</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>

<table class="table table-striped table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.User)</th>
            <th>@Html.DisplayNameFor(model => model.User.BirthDate)</th>
            <th style="width: 150px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.User.FullName</td>
                    <td>@item.User.BirthDate.ToShortDateString()</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.TraineeId" class="btn btn-sm btn-primary me-1">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.TraineeId" class="btn btn-sm btn-info me-1">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.TraineeId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">No trainees found.</td>
            </tr>
        }
    </tbody>
</table>
