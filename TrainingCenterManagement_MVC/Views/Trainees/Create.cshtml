@using TrainingCenterManagement_MVC.ViewModels
@model TraineeCreateViewModel

@{
    ViewData["Title"] = "إضافة متدرب جديد";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --success:       #10b981;
        --danger:        #ef4444;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .tn-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
    }

    /* ── Breadcrumb ── */
    .tn-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3); margin-bottom: 22px;
    }
    .tn-breadcrumb a { color: var(--primary); text-decoration: none; }
    .tn-breadcrumb a:hover { text-decoration: underline; }
    .tn-breadcrumb i { font-size: .65rem; }

    /* ── Page header ── */
    .tn-page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        margin-bottom: 28px;
    }
    .tn-page-header-left { display: flex; align-items: center; gap: 16px; }
    .tn-page-icon {
        width: 52px; height: 52px; border-radius: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #fff;
        box-shadow: 0 4px 14px rgba(29,78,216,.30);
    }
    .tn-page-header h1 {
        font-size: 1.5rem; font-weight: 800;
        color: var(--text-1); margin: 0 0 3px;
    }
    .tn-page-header p { font-size: .85rem; color: var(--text-2); margin: 0; }

    .tn-back-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tn-back-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── Layout ── */
    .tn-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 22px;
        align-items: start;
    }
    @@media (max-width: 860px) { .tn-layout { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .tn-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        overflow: hidden;
        transition: var(--tr);
    }
    .tn-card:hover { box-shadow: var(--shadow-md); }

    .tn-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 10px;
        background: linear-gradient(to left, #fafbff, var(--card-bg));
    }
    .tn-card-head-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }
    .tn-card-head h3 { font-size: .97rem; font-weight: 700; color: var(--text-1); margin: 0; }
    .tn-card-head p  { font-size: .78rem; color: var(--text-3); margin: 2px 0 0; }
    .tn-card-body { padding: 24px; }

    /* ── Aside ── */
    .tn-aside {
        display: flex; flex-direction: column; align-items: center;
        padding: 30px 20px; text-align: center;
        background: linear-gradient(160deg, var(--primary-pale) 0%, #fff 60%);
    }
    .tn-aside-avatar {
        width: 86px; height: 86px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.9rem; color: #fff;
        border: 4px solid #fff;
        box-shadow: 0 6px 18px rgba(29,78,216,.22);
        margin-bottom: 14px;
    }
    .tn-aside-label { font-size: 1rem; font-weight: 700; color: var(--text-1); margin-bottom: 4px; }
    .tn-aside-sub {
        font-size: .8rem; color: var(--text-3);
        display: flex; align-items: center; gap: 5px; margin-bottom: 20px;
    }

    .tn-steps { width: 100%; }
    .tn-step {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 0; border-bottom: 1px solid var(--border);
        font-size: .82rem; color: var(--primary); font-weight: 600;
    }
    .tn-step:last-child { border-bottom: none; }
    .tn-step-dot {
        width: 26px; height: 26px; border-radius: 50%;
        background: var(--primary); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 700; flex-shrink: 0;
    }

    .tn-tip {
        margin-top: 20px; width: 100%;
        background: #fffbeb; border: 1px solid #fde68a;
        border-radius: var(--radius-sm); padding: 12px 14px;
        font-size: .78rem; color: #78350f; text-align: right;
        display: flex; align-items: flex-start; gap: 8px;
    }
    .tn-tip i { color: #d97706; flex-shrink: 0; margin-top: 1px; }

    /* ── Form ── */
    .tn-form-group { margin-bottom: 20px; }
    .tn-label {
        display: flex; align-items: center; gap: 7px;
        font-size: .85rem; font-weight: 600; color: var(--text-1);
        margin-bottom: 8px;
    }
    .tn-label i {
        width: 26px; height: 26px; border-radius: 7px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; flex-shrink: 0;
    }
    .tn-required { color: var(--danger); margin-right: 2px; }
    .tn-input {
        width: 100%; padding: 11px 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: .9rem; font-family: inherit;
        color: var(--text-1); background: #fafcff;
        transition: border-color var(--tr), box-shadow var(--tr);
        outline: none;
    }
    .tn-input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(29,78,216,.10);
        background: #fff;
    }
    .tn-input::placeholder { color: var(--text-3); }
    .tn-field-error {
        font-size: .78rem; color: var(--danger);
        margin-top: 5px; display: none; align-items: center; gap: 4px;
    }
    .tn-field-error:not(:empty) { display: flex; }

    /* Validation summary */
    .tn-val-box {
        background: #fff0f0; border: 1px solid #fca5a5;
        border-radius: var(--radius-sm); padding: 14px 18px;
        margin-bottom: 20px; font-size: .87rem; color: #b91c1c;
        display: none; align-items: flex-start; gap: 10px;
    }
    .tn-val-box:not(:empty) { display: flex; }
    .tn-val-box i { margin-top: 1px; flex-shrink: 0; }

    /* ── Submit row ── */
    .tn-submit-row {
        display: flex; align-items: center;
        justify-content: flex-end; gap: 12px;
        padding-top: 6px; flex-wrap: wrap;
    }
    .tn-btn-save {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 28px; border-radius: var(--radius-sm);
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff; border: none; font-size: .92rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        transition: var(--tr), transform .1s;
        box-shadow: 0 4px 14px rgba(29,78,216,.28);
    }
    .tn-btn-save:hover {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(29,78,216,.35);
    }
    .tn-btn-save:active { transform: translateY(0); }
    .tn-btn-cancel {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tn-btn-cancel:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="tn-page">

    <!-- Breadcrumb -->
    <nav class="tn-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Trainees">المتدربون</a>
        <i class="fas fa-chevron-left"></i>
        <span>إضافة متدرب جديد</span>
    </nav>

    <!-- Page Header -->
    <div class="tn-page-header">
        <div class="tn-page-header-left">
            <div class="tn-page-icon">
                <i class="fas fa-user-graduate"></i>
            </div>
            <div>
                <h1>إضافة متدرب جديد</h1>
                <p>أدخل بيانات المتدرب لإضافته إلى المنصة</p>
            </div>
        </div>
        <a asp-action="Index" class="tn-back-btn">
            <i class="fas fa-arrow-right"></i> العودة للقائمة
        </a>
    </div>

    <!-- Layout -->
    <div class="tn-layout">

        <!-- Aside -->
        <div class="tn-card">
            <div class="tn-aside">
                <div class="tn-aside-avatar">
                    <i class="fas fa-user-graduate"></i>
                </div>
                <div class="tn-aside-label">متدرب جديد</div>
                <div class="tn-aside-sub">
                    <i class="fas fa-plus-circle" style="color:var(--primary);"></i>
                    سيُضاف للمنصة
                </div>
                <div class="tn-steps">
                    <div class="tn-step">
                        <div class="tn-step-dot">1</div>
                        الاسم الكامل
                    </div>
                    <div class="tn-step">
                        <div class="tn-step-dot">2</div>
                        البريد الإلكتروني
                    </div>
                </div>
                <div class="tn-tip">
                    <i class="fas fa-lightbulb"></i>
                    <span>البريد الإلكتروني سيُستخدم لتسجيل الدخول. تأكد من صحته قبل الإضافة.</span>
                </div>
            </div>
        </div>

        <!-- Form Card -->
        <div class="tn-card">
            <div class="tn-card-head">
                <div class="tn-card-head-icon"><i class="fas fa-user-plus"></i></div>
                <div>
                    <h3>بيانات المتدرب</h3>
                    <p>الحقول المميزة بـ * مطلوبة</p>
                </div>
            </div>
            <div class="tn-card-body">

                <form asp-action="Create" method="post" novalidate>

                    <div asp-validation-summary="ModelOnly" class="tn-val-box">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>

                    <!-- Full Name -->
                    <div class="tn-form-group">
                        <label asp-for="FullName" class="tn-label">
                            <i class="fas fa-user"></i>
                            الاسم الكامل <span class="tn-required">*</span>
                        </label>
                        <input asp-for="FullName" class="tn-input"
                               placeholder="أدخل الاسم الكامل" />
                        <span asp-validation-for="FullName" class="tn-field-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="tn-form-group">
                        <label asp-for="Email" class="tn-label">
                            <i class="fas fa-envelope"></i>
                            البريد الإلكتروني <span class="tn-required">*</span>
                        </label>
                        <input asp-for="Email" class="tn-input"
                               placeholder="example@domain.com" dir="ltr" />
                        <span asp-validation-for="Email" class="tn-field-error"></span>
                    </div>

                    <!-- Actions -->
                    <div class="tn-submit-row">
                        <a asp-action="Index" class="tn-btn-cancel">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                        <button type="submit" class="tn-btn-save">
                            <i class="fas fa-plus-circle"></i> إضافة المتدرب
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
