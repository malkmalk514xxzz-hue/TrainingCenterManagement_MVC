@model TrainingCenterManagement_MVC.Models.Trainee
@{
    ViewData["Title"]       = $"ملف المتدرب — {Model.User.FullName}";
    ViewData["Description"] = $"ملف المتدرب {Model.User.FullName}: الدورات المسجلة، الشهادات، ونسبة الحضور.";
    ViewData["Robots"]      = "noindex, nofollow";

    var initials       = string.Concat(Model.User.FullName.Split(' ').Take(2).Select(w => w.FirstOrDefault().ToString())).ToUpper();
    var genderAr       = Model.User.Gender == TrainingCenterManagement_MVC.Models.Gender.Female ? "أنثى" : "ذكر";
    var genderIcon     = Model.User.Gender == TrainingCenterManagement_MVC.Models.Gender.Female ? "♀" : "♂";
    var genderBadgeCls = Model.User.Gender == TrainingCenterManagement_MVC.Models.Gender.Female ? "badge-female" : "badge-male";
    var attendanceRate = (double)ViewBag.AttendanceRate;
    var bestScore      = (double?)ViewBag.BestExamScore;
    var enrolledCount  = Model.CourseTrainees?.Count ?? 0;
    var certCount      = Model.Certificates?.Count ?? 0;
    var attendColor    = attendanceRate >= 75 ? "#22c55e" : attendanceRate >= 50 ? "#f59e0b" : "#ef4444";
}

<style>
    .profile-hero {
        background: linear-gradient(135deg, #1a2c5b 0%, #2a4494 60%, #1a2c5b 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        color: #fff;
    }
    .profile-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(45deg, transparent, transparent 30px, rgba(201,162,39,.06) 30px, rgba(201,162,39,.06) 31px);
        pointer-events: none;
    }
    .profile-hero::after {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 220px; height: 220px;
        border-radius: 50%;
        background: rgba(201,162,39,.12);
        pointer-events: none;
    }
    .profile-avatar {
        width: 110px; height: 110px;
        border-radius: 50%;
        border: 4px solid #c9a227;
        background: linear-gradient(135deg, #c9a227, #e8c542);
        display: flex; align-items: center; justify-content: center;
        font-size: 38px; font-weight: 800;
        color: #1a2c5b;
        flex-shrink: 0;
        box-shadow: 0 0 0 6px rgba(201,162,39,.25);
        position: relative; z-index: 1;
        overflow: hidden;
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .profile-name { font-size: 2rem; font-weight: 800; letter-spacing: 1px; margin-bottom: 8px; position: relative; z-index: 1; }
    .profile-email { font-size: .95rem; opacity: .8; position: relative; z-index: 1; }
    .profile-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; position: relative; z-index: 1; }
    .badge-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 50px;
        font-size: .78rem; font-weight: 700; letter-spacing: .5px;
    }
    .badge-trainee { background: rgba(201,162,39,.25); border: 1.5px solid #c9a227; color: #c9a227; }
    .badge-male    { background: rgba(59,130,246,.2);  border: 1.5px solid #60a5fa; color: #bfdbfe; }
    .badge-female  { background: rgba(236,72,153,.2);  border: 1.5px solid #f9a8d4; color: #fbcfe8; }

    /* Stats Row */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 28px; }
    @@media (max-width: 900px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 500px) { .stats-row { grid-template-columns: 1fr 1fr; } }
    .stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px 18px;
        text-align: center;
        box-shadow: 0 2px 16px rgba(26,44,91,.08);
        border: 1px solid #e8eaf6;
        transition: transform .2s;
    }
    .stat-card:hover { transform: translateY(-3px); }
    .stat-icon { font-size: 2rem; margin-bottom: 8px; }
    .stat-value { font-size: 2rem; font-weight: 800; color: #1a2c5b; line-height: 1; }
    .stat-label { font-size: .78rem; color: #888; font-weight: 600; margin-top: 5px; text-transform: uppercase; letter-spacing: .5px; }

    /* Cards */
    .info-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(26,44,91,.07);
        border: 1px solid #e8eaf6;
        overflow: hidden;
        margin-bottom: 22px;
    }
    .info-card-header {
        background: linear-gradient(90deg, #1a2c5b, #2a4494);
        color: #fff;
        padding: 14px 22px;
        font-weight: 700;
        font-size: 1rem;
        display: flex; align-items: center; gap: 10px;
    }
    .info-card-header .card-icon { font-size: 1.2rem; }
    .info-card-body { padding: 20px 22px; }

    /* Info rows */
    .info-row { display: flex; align-items: center; gap: 14px; padding: 10px 0; border-bottom: 1px solid #f1f3f9; }
    .info-row:last-child { border-bottom: none; }
    .info-row-icon { width: 36px; height: 36px; border-radius: 10px; background: #eef0fa; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
    .info-row-label { font-size: .78rem; color: #888; font-weight: 600; }
    .info-row-value { font-size: .95rem; color: #1a2c5b; font-weight: 600; }

    /* Course/cert items */
    .course-item {
        display: flex; align-items: center; gap: 14px;
        padding: 10px 0; border-bottom: 1px solid #f1f3f9;
    }
    .course-item:last-child { border-bottom: none; }
    .course-bullet { width: 10px; height: 10px; border-radius: 50%; background: #c9a227; flex-shrink: 0; }
    .course-name { font-size: .93rem; font-weight: 600; color: #1a2c5b; }
    .cert-badge-gold {
        display: inline-flex; align-items: center; gap: 5px;
        background: linear-gradient(135deg, #c9a227, #e8c542);
        color: #1a2c5b; font-size: .75rem; font-weight: 700;
        padding: 3px 10px; border-radius: 50px;
    }

    /* Progress bar */
    .attend-bar-wrap { background: #e8eaf6; border-radius: 50px; height: 10px; width: 100%; margin-top: 6px; overflow: hidden; }
    .attend-bar-fill { height: 100%; border-radius: 50px; transition: width .6s ease; }

    /* Action buttons */
    .action-btn-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
    .action-btn {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 18px; border-radius: 14px;
        border: 2px solid #e8eaf6; background: #fff;
        text-decoration: none; color: #1a2c5b;
        font-weight: 700; font-size: .9rem;
        transition: all .2s; box-shadow: 0 2px 10px rgba(0,0,0,.05);
    }
    .action-btn:hover { border-color: #c9a227; background: #fffef8; color: #1a2c5b; box-shadow: 0 4px 18px rgba(201,162,39,.2); transform: translateY(-2px); }
    .action-btn-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .ab-blue   { background: #eef2ff; }
    .ab-green  { background: #f0fdf4; }
    .ab-red    { background: #fef2f2; }
    .ab-amber  { background: #fffbeb; }
    .ab-indigo { background: #eef2ff; }
    .empty-msg { color: #bbb; font-size: .88rem; text-align: center; padding: 16px 0; }
</style>

@* ── Profile Hero ─────────────────────────────────────── *@
<div class="profile-hero">
    <div class="d-flex align-items-center gap-4 flex-wrap">
        <div class="profile-avatar">
            @if (!string.IsNullOrEmpty(Model.User.ProfilePictureUrl))
            {
                <img src="@Model.User.ProfilePictureUrl" alt="@Model.User.FullName" />
            }
            else
            {
                @initials
            }
        </div>
        <div>
            <div class="profile-name">@Model.User.FullName</div>
            <div class="profile-email">✉ @Model.User.Email</div>
            <div class="profile-badges">
                <span class="badge-pill badge-trainee">🎓 متدرب</span>
                <span class="badge-pill @genderBadgeCls">@genderIcon @genderAr</span>
            </div>
        </div>
    </div>
</div>

@* ── Stats Row ─────────────────────────────────────────── *@
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon">📚</div>
        <div class="stat-value">@enrolledCount</div>
        <div class="stat-label">الدورات المسجلة</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-value">@certCount</div>
        <div class="stat-label">الشهادات المكتسبة</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📅</div>
        <div class="stat-value" style="color:@attendColor;">@attendanceRate%</div>
        <div class="stat-label">نسبة الحضور</div>
        <div class="attend-bar-wrap mt-2">
            <div class="attend-bar-fill" style="width:@attendanceRate%; background:@attendColor;"></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📝</div>
        @if (bestScore.HasValue)
        {
            <div class="stat-value">@bestScore.Value.ToString("F1")</div>
        }
        else
        {
            <div class="stat-value" style="font-size:1.2rem; color:#bbb;">—</div>
        }
        <div class="stat-label">أفضل درجة امتحان</div>
    </div>
</div>

@* ── Two-column layout ─────────────────────────────────── *@
<div class="row g-4">

    @* Left column: Personal Info + Enrolled Courses *@
    <div class="col-lg-6">

        @* Personal Info *@
        <div class="info-card">
            <div class="info-card-header">
                <span class="card-icon">👤</span> المعلومات الشخصية
            </div>
            <div class="info-card-body">
                <div class="info-row">
                    <div class="info-row-icon">✉</div>
                    <div>
                        <div class="info-row-label">البريد الإلكتروني</div>
                        <div class="info-row-value">@Model.User.Email</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-row-icon">🎂</div>
                    <div>
                        <div class="info-row-label">تاريخ الميلاد</div>
                        <div class="info-row-value">@Model.User.BirthDate.ToString("dd MMMM yyyy")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-row-icon">@genderIcon</div>
                    <div>
                        <div class="info-row-label">الجنس</div>
                        <div class="info-row-value">@genderAr</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.User.PhoneNumber))
                {
                    <div class="info-row">
                        <div class="info-row-icon">📞</div>
                        <div>
                            <div class="info-row-label">رقم الهاتف</div>
                            <div class="info-row-value">@Model.User.PhoneNumber</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Enrolled Courses *@
        <div class="info-card">
            <div class="info-card-header">
                <span class="card-icon">📚</span> الدورات المسجلة
            </div>
            <div class="info-card-body">
                @if (Model.CourseTrainees != null && Model.CourseTrainees.Any())
                {
                    foreach (var ct in Model.CourseTrainees)
                    {
                        <div class="course-item">
                            <div class="course-bullet"></div>
                            <div>
                                <div class="course-name">@ct.Course?.CourseName</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-msg">لا توجد دورات مسجلة بعد</div>
                }
            </div>
        </div>
    </div>

    @* Right column: Certificates *@
    <div class="col-lg-6">
        <div class="info-card">
            <div class="info-card-header">
                <span class="card-icon">🏆</span> الشهادات المكتسبة
            </div>
            <div class="info-card-body">
                @if (Model.Certificates != null && Model.Certificates.Any())
                {
                    foreach (var cert in Model.Certificates)
                    {
                        <div class="course-item">
                            <div style="font-size:1.4rem; flex-shrink:0;">🎓</div>
                            <div class="flex-grow-1">
                                <div class="course-name">@cert.Course?.CourseName</div>
                                <div class="mt-1">
                                    <span class="cert-badge-gold">⭐ @cert.Average.ToString("F1") / 100</span>
                                </div>
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("Trainee"))
                            {
                                <a asp-controller="Certificates" asp-action="CertificatePdf"
                                   asp-route-id="@cert.CertificateId"
                                   class="btn btn-sm btn-outline-secondary" title="تحميل PDF" target="_blank">
                                    ⬇ PDF
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="empty-msg">لا توجد شهادات بعد</div>
                }
            </div>
        </div>

        @* Exam summary *@
        @if (Model.ExamAttempts != null && Model.ExamAttempts.Any())
        {
            <div class="info-card">
                <div class="info-card-header">
                    <span class="card-icon">📝</span> سجل الامتحانات
                </div>
                <div class="info-card-body">
                    @foreach (var attempt in Model.ExamAttempts.OrderByDescending(a => a.StartedAt).Take(5))
                    {
                        var scoreColor = (attempt.ScorePercentage ?? 0) >= 60 ? "#22c55e" : "#ef4444";
                        <div class="course-item">
                            <div style="font-size:1.2rem;">📄</div>
                            <div class="flex-grow-1">
                                <div class="course-name">محاولة امتحان</div>
                                <div style="font-size:.8rem; color:#888;">@attempt.StartedAt.ToString("dd/MM/yyyy")</div>
                            </div>
                            @if (attempt.ScorePercentage.HasValue)
                            {
                                <span style="font-weight:800; color:@scoreColor; font-size:1rem;">@attempt.ScorePercentage.Value.ToString("F1")%</span>
                            }
                            else
                            {
                                <span style="color:#bbb; font-size:.9rem;">قيد المراجعة</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* ── Quick Actions ─────────────────────────────────────── *@
<div class="info-card mt-2">
    <div class="info-card-header">
        <span class="card-icon">⚡</span> الإجراءات السريعة
    </div>
    <div class="info-card-body">
        <div class="action-btn-grid">
            <a asp-action="MyCertificates" class="action-btn">
                <div class="action-btn-icon ab-amber">🏆</div>
                <div>شهاداتي</div>
            </a>
            <a asp-action="MyCourses" class="action-btn">
                <div class="action-btn-icon ab-green">📚</div>
                <div>دوراتي</div>
            </a>
            <a asp-controller="Exams" asp-action="MyExams" class="action-btn">
                <div class="action-btn-icon ab-red">📝</div>
                <div>امتحاناتي</div>
            </a>
            <a asp-action="Profile" class="action-btn">
                <div class="action-btn-icon ab-blue">👤</div>
                <div>ملفي الشخصي</div>
            </a>
            <a asp-action="TrackAttendance" class="action-btn">
                <div class="action-btn-icon ab-indigo">📅</div>
                <div>متابعة الحضور</div>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Index" class="action-btn">
                    <div class="action-btn-icon" style="background:#f1f5f9;">⬅</div>
                    <div>العودة للقائمة</div>
                </a>
            }
        </div>
    </div>
</div>
