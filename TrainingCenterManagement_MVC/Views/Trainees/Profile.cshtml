@model TrainingCenterManagement_MVC.Models.Trainee

@{
    ViewData["Title"] = "Profile";
}

<h2 class="mb-4">Profile</h2>

<div class="card shadow-sm mt-3 text-center" style="max-width: 600px; margin: auto;">
    <div class="card-body">
        <!-- Profile Picture -->
        <img src="~/images/profile-student.jpg" alt="Profile Picture"
             class="rounded-circle mb-3" style="width:120px; height:120px; object-fit:cover; border:3px solid #ddd;" />

        <h5 class="card-title mb-4">Trainee Information</h5>
        <dl class="row text-start">
            <dt class="col-sm-4 fw-bold">Username</dt>
            <dd class="col-sm-8">@Model.User?.UserName</dd>

            <dt class="col-sm-4 fw-bold">Email</dt>
            <dd class="col-sm-8">@Model.User?.Email</dd>

            <dt class="col-sm-4 fw-bold">Date of Birth</dt>
            <dd class="col-sm-8">@Model.User.BirthDate.ToShortDateString()</dd>
        </dl>
    </div>
</div>
