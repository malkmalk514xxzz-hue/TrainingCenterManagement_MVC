@model TrainingCenterManagement_MVC.Models.Trainee

@{
    ViewData["Title"] = "حذف المتدرب";
    var avatarChar = Model.User?.FullName?.Length > 0 ? Model.User.FullName[0].ToString() : "م";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --danger:        #dc2626;
        --danger-pale:   #fff1f2;
        --danger-border: #fca5a5;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:     0 8px 32px rgba(0,0,0,.14);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .tn-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
        display: flex; flex-direction: column; align-items: center;
    }

    /* ── Breadcrumb ── */
    .tn-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3);
        margin-bottom: 30px; align-self: flex-start;
    }
    .tn-breadcrumb a { color: var(--primary); text-decoration: none; }
    .tn-breadcrumb a:hover { text-decoration: underline; }
    .tn-breadcrumb i { font-size: .65rem; }

    /* ── Warning Banner ── */
    .tn-warn-banner {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 50%, #b91c1c 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 22px;
        display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
        position: relative; overflow: hidden;
        box-shadow: 0 8px 28px rgba(185,28,28,.25);
        width: 100%; max-width: 660px;
    }
    .tn-warn-banner::before {
        content: '';
        position: absolute; top: -60px; left: -40px;
        width: 200px; height: 200px;
        background: rgba(255,255,255,.05); border-radius: 50%;
    }
    .tn-warn-icon {
        width: 62px; height: 62px; border-radius: 50%;
        background: rgba(255,255,255,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.7rem; color: #fff; flex-shrink: 0;
        position: relative; z-index: 1;
        animation: tn-pulse 2s ease-in-out infinite;
    }
    @@keyframes tn-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,.3); }
        50%       { box-shadow: 0 0 0 10px rgba(255,255,255,.0); }
    }
    .tn-warn-text { flex: 1; color: #fff; position: relative; z-index: 1; }
    .tn-warn-text h2 { font-size: 1.35rem; font-weight: 800; margin: 0 0 5px; }
    .tn-warn-text p  { font-size: .9rem; opacity: .88; margin: 0; line-height: 1.5; }

    /* ── Info Card ── */
    .tn-info-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border);
        overflow: hidden;
        width: 100%; max-width: 660px;
        margin-bottom: 18px;
    }
    .tn-info-card-head {
        background: linear-gradient(to left, #fafbff, var(--card-bg));
        border-bottom: 1px solid var(--border);
        padding: 18px 24px;
        display: flex; align-items: center; gap: 14px;
    }
    .tn-avatar {
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem; font-weight: 800; color: #fff;
        flex-shrink: 0; border: 3px solid var(--primary-pale);
    }
    .tn-info-card-name {
        font-size: 1.05rem; font-weight: 700; color: var(--text-1); margin-bottom: 3px;
    }
    .tn-info-card-role {
        font-size: .8rem; color: var(--text-3);
        display: flex; align-items: center; gap: 5px;
    }

    .tn-detail-row {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 24px;
        border-bottom: 1px solid var(--border);
    }
    .tn-detail-row:last-child { border-bottom: none; }
    .tn-detail-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem; flex-shrink: 0;
    }
    .tn-detail-label {
        font-size: .75rem; font-weight: 600; color: var(--text-3);
        text-transform: uppercase; letter-spacing: .04em; margin-bottom: 2px;
    }
    .tn-detail-value { font-size: .95rem; font-weight: 600; color: var(--text-1); }

    /* ── Consequence ── */
    .tn-consequence {
        background: var(--danger-pale);
        border: 1px solid var(--danger-border);
        border-radius: var(--radius-sm);
        padding: 14px 18px;
        font-size: .875rem; color: #991b1b;
        width: 100%; max-width: 660px;
        margin-bottom: 20px;
    }
    .tn-consequence-title {
        font-weight: 700; margin-bottom: 8px;
        display: flex; align-items: center; gap: 7px;
    }
    .tn-consequence ul { margin: 0; padding-right: 18px; }
    .tn-consequence li { margin-bottom: 4px; line-height: 1.5; }

    /* ── Action buttons ── */
    .tn-action-row {
        display: flex; align-items: center; gap: 12px;
        flex-wrap: wrap; justify-content: flex-end;
        width: 100%; max-width: 660px;
    }
    .tn-btn-confirm {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 26px; border-radius: var(--radius-sm);
        background: var(--danger); color: #fff;
        border: none; font-size: .92rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        transition: var(--tr), transform .1s;
        box-shadow: 0 4px 14px rgba(220,38,38,.28);
    }
    .tn-btn-confirm:hover {
        background: #b91c1c; transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(220,38,38,.35);
    }
    .tn-btn-cancel {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .tn-btn-cancel:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="tn-page">

    <!-- Breadcrumb -->
    <nav class="tn-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Trainees">المتدربون</a>
        <i class="fas fa-chevron-left"></i>
        <span style="color:#dc2626;">حذف</span>
    </nav>

    <!-- Warning Banner -->
    <div class="tn-warn-banner">
        <div class="tn-warn-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="tn-warn-text">
            <h2>تأكيد حذف المتدرب</h2>
            <p>هذا الإجراء نهائي ولا يمكن التراجع عنه. يرجى مراجعة البيانات قبل المتابعة.</p>
        </div>
    </div>

    <!-- Info Card -->
    <div class="tn-info-card">
        <div class="tn-info-card-head">
            <div class="tn-avatar">@avatarChar</div>
            <div>
                <div class="tn-info-card-name">@Html.DisplayFor(m => m.User.FullName)</div>
                <div class="tn-info-card-role">
                    <i class="fas fa-user-graduate"></i> متدرب
                </div>
            </div>
        </div>

        <div class="tn-detail-row">
            <div class="tn-detail-icon"><i class="fas fa-user"></i></div>
            <div>
                <div class="tn-detail-label">الاسم الكامل</div>
                <div class="tn-detail-value">@Html.DisplayFor(m => m.User.FullName)</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.User?.Email))
        {
            <div class="tn-detail-row">
                <div class="tn-detail-icon"><i class="fas fa-envelope"></i></div>
                <div>
                    <div class="tn-detail-label">البريد الإلكتروني</div>
                    <div class="tn-detail-value">@Model.User.Email</div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.User?.PhoneNumber))
        {
            <div class="tn-detail-row">
                <div class="tn-detail-icon"><i class="fas fa-phone"></i></div>
                <div>
                    <div class="tn-detail-label">رقم الهاتف</div>
                    <div class="tn-detail-value">@Model.User.PhoneNumber</div>
                </div>
            </div>
        }
    </div>

    <!-- Consequences -->
    <div class="tn-consequence">
        <div class="tn-consequence-title">
            <i class="fas fa-exclamation-circle"></i>
            ماذا سيحدث عند الحذف؟
        </div>
        <ul>
            <li>سيتم حذف ملف المتدرب بشكل نهائي من النظام</li>
            <li>ستُفقد جميع سجلات الحضور والدورات المرتبطة</li>
            <li>لا يمكن استعادة هذه البيانات بعد الحذف</li>
        </ul>
    </div>

    <!-- Actions -->
    <div class="tn-action-row">
        <a asp-action="Index" class="tn-btn-cancel">
            <i class="fas fa-arrow-right"></i> إلغاء، العودة للقائمة
        </a>
        <form asp-action="Delete" method="post" style="margin:0;">
            <input type="hidden" asp-for="TraineeId" />
            <button type="submit" class="tn-btn-confirm">
                <i class="fas fa-trash-alt"></i> نعم، احذف المتدرب
            </button>
        </form>
    </div>

</div>
