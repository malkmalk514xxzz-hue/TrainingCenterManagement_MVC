@model TrainingCenterManagement_MVC.Models.Trainee

@{
    ViewData["Title"] = "Delete";
}

<h1 class="mb-4">Delete Trainee</h1>

<h3>Are you sure you want to delete this?</h3>

<div class="card p-4 mb-4" style="max-width: 600px;">
    <h4 class="mb-3">Trainee Details</h4>
    <dl class="row">
        <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(m => m.User)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.User.Id)</dd>

      @*   <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(m => m.BirthDate)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.BirthDate)</dd> *@
    </dl>

    <form asp-action="Delete" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا المتدرب؟');">
        <input type="hidden" asp-for="TraineeId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
    </form>
</div>
