@model IEnumerable<TrainingCenterManagement_MVC.Models.Certificate>

<h2>My Certificates</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">You have no certificates yet.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Course</th>
                <th>Trainer</th>
                <th>Average</th>
                <th>Issued</th>
                <th>Actions</th> <!-- عمود جديد -->
            </tr>
        </thead>
        <tbody>
            @foreach (var cert in Model)
            {
                <tr>
                    <td>@cert.Course.CourseName</td>
                    <td>@cert.Trainer?.User?.FullName</td>
                    <td>@cert.Average</td>
                    <td>✔️</td>
                    <td>
                        <a asp-action="GenerateCertificatePdf" asp-route-certificateId="@cert.CertificateId" class="btn btn-danger btn-sm">
                            Download PDF
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
