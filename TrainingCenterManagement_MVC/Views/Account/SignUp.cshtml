@model TrainingCenterManagement_MVC.ViewModels.SignUpViewModel
@{
    ViewData["Title"] = "إنشاء حساب جديد | مركز التدريب";
    ViewData["Description"] = "سجّل حسابك في مركز التدريب وابدأ رحلتك التعليمية اليوم.";
    Layout = "_LayoutAccount";
}

<style>
.signup-wrap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #07111f 0%, #0b1830 60%, #07111f 100%);
    padding: 40px 16px;
}
.signup-card {
    width: 100%;
    max-width: 520px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(148,163,184,.15);
    border-radius: 20px;
    padding: 44px 40px;
    backdrop-filter: blur(10px);
    box-shadow: 0 24px 60px rgba(0,0,0,.5);
}
@@media (max-width: 560px) { .signup-card { padding: 30px 20px; } }

.signup-logo {
    text-align: center;
    margin-bottom: 28px;
}
.signup-logo-icon {
    width: 64px; height: 64px;
    border-radius: 18px;
    background: linear-gradient(135deg, #c9a227, #e8c542);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 28px; margin-bottom: 14px;
    box-shadow: 0 8px 24px rgba(201,162,39,.35);
}
.signup-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 4px;
}
.signup-sub {
    font-size: .88rem;
    color: #94a3b8;
}

/* Form fields */
.form-label-up { font-size: .82rem; font-weight: 600; color: #94a3b8; margin-bottom: 6px; }
.form-ctrl {
    width: 100%;
    background: rgba(255,255,255,.06);
    border: 1.5px solid rgba(148,163,184,.2);
    border-radius: 10px;
    padding: 11px 14px;
    color: #f1f5f9;
    font-size: .93rem;
    transition: border-color .2s, box-shadow .2s;
    outline: none;
}
.form-ctrl:focus {
    border-color: #c9a227;
    box-shadow: 0 0 0 3px rgba(201,162,39,.15);
}
.form-ctrl::placeholder { color: #64748b; }
.form-ctrl option { background: #0f1f38; color: #f1f5f9; }

/* Gender toggle */
.gender-group { display: flex; gap: 10px; }
.gender-btn {
    flex: 1; padding: 10px;
    border: 1.5px solid rgba(148,163,184,.2);
    border-radius: 10px;
    background: rgba(255,255,255,.04);
    color: #94a3b8;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    transition: all .2s;
}
.gender-btn.active {
    border-color: #c9a227;
    background: rgba(201,162,39,.12);
    color: #e8c542;
}

/* Submit */
.btn-signup {
    width: 100%;
    padding: 13px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(135deg, #c9a227, #e8c542);
    color: #1a2c5b;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
    margin-top: 6px;
}
.btn-signup:hover { opacity: .92; transform: translateY(-1px); }

.signup-login-link {
    text-align: center;
    margin-top: 18px;
    font-size: .85rem;
    color: #64748b;
}
.signup-login-link a { color: #c9a227; font-weight: 600; text-decoration: none; }
.signup-login-link a:hover { text-decoration: underline; }

.field-error { color: #f87171; font-size: .78rem; margin-top: 4px; }
.alert-danger-dark {
    background: rgba(239,68,68,.12);
    border: 1px solid rgba(239,68,68,.3);
    border-radius: 10px;
    color: #fca5a5;
    padding: 12px 16px;
    font-size: .85rem;
    margin-bottom: 18px;
}
</style>

<div class="signup-wrap">
    <div class="signup-card" dir="rtl">

        <div class="signup-logo">
            <div class="signup-logo-icon">🎓</div>
            <div class="signup-title">إنشاء حساب جديد</div>
            <div class="signup-sub">انضم إلى مركز التدريب وابدأ رحلتك التعليمية</div>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
        {
            <div class="alert-danger-dark">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>⚠ @error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="SignUp" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <div class="form-label-up">الاسم الكامل *</div>
                <input asp-for="FullName" class="form-ctrl" placeholder="أدخل اسمك الكامل" />
                <div class="field-error"><span asp-validation-for="FullName"></span></div>
            </div>

            <div class="mb-3">
                <div class="form-label-up">البريد الإلكتروني *</div>
                <input asp-for="Email" class="form-ctrl" placeholder="example@email.com" type="email" />
                <div class="field-error"><span asp-validation-for="Email"></span></div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <div class="form-label-up">رقم الهاتف</div>
                    <input asp-for="PhoneNumber" class="form-ctrl" placeholder="+966..." />
                    <div class="field-error"><span asp-validation-for="PhoneNumber"></span></div>
                </div>
                <div class="col-6">
                    <div class="form-label-up">تاريخ الميلاد *</div>
                    <input asp-for="BirthDate" class="form-ctrl" type="date" />
                    <div class="field-error"><span asp-validation-for="BirthDate"></span></div>
                </div>
            </div>

            <div class="mb-3">
                <div class="form-label-up">الجنس</div>
                <input type="hidden" asp-for="Gender" id="genderInput" />
                <div class="gender-group">
                    <div class="gender-btn @(Model?.Gender == TrainingCenterManagement_MVC.Models.Gender.Male ? "active" : "")"
                         onclick="setGender(1, this)">♂ ذكر</div>
                    <div class="gender-btn @(Model?.Gender == TrainingCenterManagement_MVC.Models.Gender.Female ? "active" : "")"
                         onclick="setGender(2, this)">♀ أنثى</div>
                </div>
            </div>

            <div class="mb-3">
                <div class="form-label-up">كلمة المرور *</div>
                <input asp-for="Password" class="form-ctrl" type="password" placeholder="6 أحرف على الأقل" />
                <div class="field-error"><span asp-validation-for="Password"></span></div>
            </div>

            <div class="mb-4">
                <div class="form-label-up">تأكيد كلمة المرور *</div>
                <input asp-for="ConfirmPassword" class="form-ctrl" type="password" placeholder="أعد كتابة كلمة المرور" />
                <div class="field-error"><span asp-validation-for="ConfirmPassword"></span></div>
            </div>

            <button type="submit" class="btn-signup">إنشاء الحساب</button>
        </form>

        <div class="signup-login-link">
            لديك حساب بالفعل؟ <a asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setGender(val, el) {
            document.getElementById('genderInput').value = val;
            document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
