@model TrainingCenterManagement_MVC.Models.Certificate

@{
    ViewData["Title"] = "إنشاء شهادة";
}

<div class="container-xl mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h2 class="text-center text-dark fw-bold mb-0">
                        <i class="bi bi-patch-check-fill text-success me-2"></i>
                        إنشاء شهادة جديدة
                    </h2>
                    <p class="text-center text-muted small mt-1 mb-3">
                        سيتم توليد رابط التحقق تلقائياً بعد الحفظ
                    </p>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" class="row g-4">
                        <div asp-validation-summary="ModelOnly" class="col-12 alert alert-danger d-none" id="validationSummary"></div>

                        <!-- ═══ STEP 1 – Trainee ═══ -->
                        <div class="col-12">
                            <label asp-for="TraineeId" class="form-label fw-semibold">
                                <i class="bi bi-person-badge me-1 text-primary"></i> الطالب (المتدرب)
                            </label>
                            <select asp-for="TraineeId" id="TraineeId"
                                    class="form-select form-select-lg select2"
                                    asp-items="ViewBag.TraineeId">
                                <option value="">-- اختر الطالب أولاً --</option>
                            </select>
                            <span asp-validation-for="TraineeId" class="text-danger small"></span>
                        </div>

                        <!-- ═══ STEP 2 – Course (loaded after trainee) ═══ -->
                        <div class="col-md-6">
                            <label asp-for="CourseId" class="form-label fw-semibold">
                                <i class="bi bi-book me-1 text-info"></i> الدورة
                            </label>
                            <select asp-for="CourseId" id="CourseId" class="form-select form-select-lg select2" disabled>
                                <option value="">-- اختر الطالب أولاً --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <!-- ═══ STEP 3 – Trainer (loaded after course) ═══ -->
                        <div class="col-md-6">
                            <label asp-for="TrainerId" class="form-label fw-semibold">
                                <i class="bi bi-person-workspace me-1 text-warning"></i> المدرب
                            </label>
                            <select asp-for="TrainerId" id="TrainerId" class="form-select form-select-lg select2" disabled>
                                <option value="">-- اختر الدورة أولاً --</option>
                            </select>
                            <span asp-validation-for="TrainerId" class="text-danger small"></span>
                        </div>

                        <!-- ═══ STEP 4 – Exam (loaded after course) ═══ -->
                        <div class="col-md-6">
                            <label asp-for="ExamId" class="form-label fw-semibold">
                                <i class="bi bi-clipboard2-check me-1 text-danger"></i> الاختبار
                            </label>
                            <select asp-for="ExamId" id="ExamId" class="form-select form-select-lg select2" disabled>
                                <option value="">-- اختر الدورة أولاً --</option>
                            </select>
                            <span asp-validation-for="ExamId" class="text-danger small"></span>
                        </div>

                        <!-- ═══ STEP 5 – Average (auto-filled after exam) ═══ -->
                        <div class="col-md-6">
                            <label asp-for="Average" class="form-label fw-semibold">
                                <i class="bi bi-bar-chart-fill me-1 text-success"></i> المعدل (%)
                            </label>
                            <div class="input-group">
                                <input asp-for="Average" id="Average" type="number" step="0.1" min="0" max="100"
                                       class="form-control form-control-lg" placeholder="يملأ تلقائياً من نتيجة الاختبار" />
                                <span class="input-group-text">%</span>
                            </div>
                            <div id="avgInfo" class="form-text text-success d-none">
                                <i class="bi bi-check-circle me-1"></i>
                                <span id="avgInfoText"></span>
                            </div>
                            <span asp-validation-for="Average" class="text-danger small"></span>
                        </div>

                        <!-- ═══ IsDeleted ═══ -->
                        <div class="col-12">
                            <div class="form-check form-switch ps-0">
                                <label class="form-check-label fw-semibold d-flex align-items-center gap-2">
                                    <input class="form-check-input ms-0" asp-for="IsDeleted" role="switch" />
                                    <span>تحديد كمحذوف</span>
                                </label>
                            </div>
                        </div>

                        <!-- ═══ Actions ═══ -->
                        <div class="col-12 d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-light border text-dark btn-lg">
                                <i class="bi bi-arrow-right-circle me-1"></i> رجوع
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm">
                                <i class="bi bi-save2-fill me-1"></i> حفظ الشهادة
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
    $(function () {
        // ── helpers ────────────────────────────────────────────
        function initSelect2(sel, placeholder) {
            $(sel).select2({ placeholder: placeholder, allowClear: true, width: '100%' });
        }
        function fillSelect(sel, items, placeholderText) {
            var $s = $(sel);
            $s.empty().append('<option value="">' + placeholderText + '</option>');
            $.each(items, function (_, item) {
                $s.append($('<option>', { value: item.value, text: item.text }));
            });
            $s.prop('disabled', items.length === 0).trigger('change');
        }

        initSelect2('#TraineeId', '-- اختر الطالب --');
        initSelect2('#CourseId',  '-- اختر الدورة --');
        initSelect2('#TrainerId', '-- اختر المدرب --');
        initSelect2('#ExamId',    '-- اختر الاختبار --');

        // ── Trainee → Courses ───────────────────────────────────
        $('#TraineeId').on('change', function () {
            var traineeId = $(this).val();
            $('#CourseId, #TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
            $('#Average').val('');
            $('#avgInfo').addClass('d-none');

            if (!traineeId) return;

            $.getJSON('/Certificates/GetCoursesByTrainee', { traineeId: traineeId }, function (data) {
                fillSelect('#CourseId', data, data.length ? '-- اختر الدورة --' : 'لا توجد دورات مسجلة');
            });
        });

        // ── Course → Trainers + Exams ───────────────────────────
        $('#CourseId').on('change', function () {
            var courseId  = $(this).val();
            var traineeId = $('#TraineeId').val();
            $('#TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
            $('#Average').val('');
            $('#avgInfo').addClass('d-none');

            if (!courseId) return;

            $.getJSON('/Certificates/GetTrainersByCourse', { courseId: courseId }, function (data) {
                fillSelect('#TrainerId', data, data.length ? '-- اختر المدرب --' : 'لا يوجد مدربون');
            });

            $.getJSON('/Certificates/GetExamsByCourse', { courseId: courseId }, function (data) {
                fillSelect('#ExamId', data, data.length ? '-- اختر الاختبار --' : 'لا توجد اختبارات');
            });
        });

        // ── Exam → Auto-fill Average ────────────────────────────
        $('#ExamId').on('change', function () {
            var examId    = $(this).val();
            var traineeId = $('#TraineeId').val();
            $('#avgInfo').addClass('d-none');

            if (!examId || !traineeId) return;

            $.getJSON('/Certificates/GetAttemptScore', { examId: examId, traineeId: traineeId }, function (data) {
                if (data.score !== null && data.score !== undefined) {
                    $('#Average').val(data.score);
                    $('#avgInfoText').text('تم جلب النتيجة من محاولة الاختبار: ' + data.score + '%');
                    $('#avgInfo').removeClass('d-none');
                } else {
                    $('#avgInfoText').text('');
                    $('#avgInfo').addClass('d-none');
                }
            });
        });

        // ── Validation summary visibility ────────────────────────
        var summary = document.getElementById('validationSummary');
        if (summary && summary.innerText.trim().length > 0) {
            summary.classList.remove('d-none');
        }
    });
    </script>
}
