@model TrainingCenterManagement_MVC.Models.Certificate

@{
    ViewData["Title"] = "📝Create Certificate";
}

<div class="container-xl mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0">
                    <h2 class="text-center text-dark fw-bold mb-0">
                        <i class="bi bi-patch-check-fill text-success me-2"></i>
                        Create New Certificate
                    </h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" class="row g-4">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

                        <div class="col-md-6">
                            <label asp-for="Average" class="form-label fw-semibold">Average (%)</label>
                            <input asp-for="Average" class="form-control form-control-lg" placeholder="Ex: 85.5" />
                            <span asp-validation-for="Average" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Url" class="form-label fw-semibold">Certificate URL</label>
                            <input asp-for="Url" class="form-control form-control-lg" placeholder="https://..." />
                            <span asp-validation-for="Url" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch ps-0">
                                <label class="form-check-label fw-semibold d-flex align-items-center gap-2">
                                    <input class="form-check-input ms-0" asp-for="IsDeleted" role="switch" />
                                    <span>Mark as Deleted</span>
                                </label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TraineeId" class="form-label fw-semibold">Trainee</label>
                            <select asp-for="TraineeId" class="form-select form-select-lg select2" asp-items="ViewBag.TraineeId">
                                <option disabled selected>Select a trainee...</option>
                            </select>
                            <span asp-validation-for="TraineeId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TrainerId" class="form-label fw-semibold">Trainer</label>
                            <select asp-for="TrainerId" class="form-select form-select-lg select2" asp-items="ViewBag.TrainerId">
                                <option disabled selected>Select a trainer...</option>
                            </select>
                            <span asp-validation-for="TrainerId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CourseId" class="form-label fw-semibold">Course</label>
                            <select asp-for="CourseId" class="form-select form-select-lg select2" asp-items="ViewBag.CourseId">
                                <option disabled selected>Select a course...</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ExamId" class="form-label fw-semibold">Exam</label>
                            <select asp-for="ExamId" class="form-select form-select-lg select2" asp-items="ViewBag.ExamId">
                                <option disabled selected>Select an exam...</option>
                            </select>
                            <span asp-validation-for="ExamId" class="text-danger small"></span>
                        </div>

                        <div class="col-12 d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-light border text-dark btn-lg">
                                <i class="bi bi-arrow-left-circle me-1"></i> Back
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm">
                                <i class="bi bi-save2-fill me-1"></i> Save Certificate
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <!-- Select2 CSS & JS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "Select an option",
                allowClear: true
            });

            const summary = document.getElementById('validationSummary');
            if (summary && summary.innerText.trim().length > 0) {
                summary.classList.remove('d-none');
            }
        });
    </script>
}
