@model TrainingCenterManagement_MVC.Models.Certificate
@{
    ViewData["Title"] = "إنشاء شهادة جديدة";
}

<style>
    .cf-page { background:#f0f9ff; padding:28px 32px; direction:rtl; font-family:'Segoe UI','Tajawal',sans-serif; min-height:100vh; }
    .cf-banner { background:linear-gradient(135deg,#0d2347 0%,#1d4ed8 55%,#3b82f6 100%); border-radius:16px; padding:26px 32px; color:#fff; margin-bottom:24px; display:flex; align-items:center; gap:18px; }
    .cf-banner-icon { width:56px; height:56px; border-radius:14px; background:rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; font-size:1.5rem; flex-shrink:0; }
    .cf-banner h1 { margin:0; font-size:1.4rem; font-weight:800; }
    .cf-banner p { margin:4px 0 0; opacity:.8; font-size:.88rem; }

    .cf-card { background:#fff; border-radius:14px; box-shadow:0 4px 24px rgba(0,0,0,.07); border:1px solid #e2e8f0; overflow:hidden; }
    .cf-card-head { padding:14px 24px; background:linear-gradient(135deg,#f8fafc,#eff6ff); border-bottom:1px solid #e2e8f0; display:flex; align-items:center; gap:10px; }
    .cf-card-head h3 { margin:0; font-size:.93rem; font-weight:700; color:#0f172a; }
    .cf-card-body { padding:28px 32px; }

    .cf-steps { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .cf-step-full { grid-column:1 / -1; }
    .cf-field { display:flex; flex-direction:column; gap:6px; }
    .cf-label { font-size:.84rem; font-weight:700; color:#374151; display:flex; align-items:center; gap:7px; }
    .cf-label .step-badge { width:22px; height:22px; border-radius:50%; background:linear-gradient(135deg,#1d4ed8,#3b82f6); color:#fff; font-size:.7rem; font-weight:800; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
    .cf-label i { color:#1d4ed8; }
    .cf-select, .cf-input { width:100%; padding:11px 14px; border:1.5px solid #e2e8f0; border-radius:9px; font-size:.88rem; font-family:inherit; background:#fff; color:#0f172a; box-sizing:border-box; transition:border-color .18s,box-shadow .18s; }
    .cf-select:focus, .cf-input:focus { outline:none; border-color:#1d4ed8; box-shadow:0 0 0 3px rgba(29,78,216,.1); }
    .cf-select:disabled { background:#f1f5f9; color:#94a3b8; cursor:not-allowed; }
    .cf-input-group { display:flex; gap:0; }
    .cf-input-group .cf-input { border-radius:9px 0 0 9px; flex:1; }
    .cf-input-suffix { padding:11px 14px; background:#f1f5f9; border:1.5px solid #e2e8f0; border-right:none; border-radius:0 9px 9px 0; font-size:.88rem; font-weight:700; color:#64748b; }
    .cf-err { font-size:.76rem; color:#dc2626; }
    .cf-hint { font-size:.76rem; color:#10b981; display:none; }
    .cf-hint.show { display:block; }

    .cf-switch-row { display:flex; align-items:center; gap:10px; padding:14px 16px; background:#fef2f2; border:1.5px solid #fecaca; border-radius:9px; }
    .cf-switch-row label { font-size:.86rem; font-weight:600; color:#991b1b; cursor:pointer; }
    .cf-switch-row input[type=checkbox] { width:18px; height:18px; cursor:pointer; }

    .cf-divider { border:none; border-top:1.5px dashed #e2e8f0; margin:24px 0; }

    .cf-actions { display:flex; justify-content:space-between; align-items:center; padding:20px 32px; background:#f8fafc; border-top:1px solid #e2e8f0; }
    .btn-cf { display:inline-flex; align-items:center; gap:7px; padding:10px 22px; border-radius:9px; font-size:.86rem; font-weight:700; text-decoration:none; border:none; cursor:pointer; transition:all .18s; }
    .btn-cf-back { background:#fff; color:#475569; border:1.5px solid #e2e8f0 !important; }
    .btn-cf-back:hover { background:#f1f5f9; color:#0f172a; }
    .btn-cf-save { background:linear-gradient(135deg,#1d4ed8,#3b82f6); color:#fff; }
    .btn-cf-save:hover { opacity:.88; color:#fff; }

    /* Select2 RTL overrides */
    .select2-container { width:100% !important; }
    .select2-container--default .select2-selection--single { border:1.5px solid #e2e8f0; border-radius:9px; height:42px; padding:0 12px; display:flex; align-items:center; font-size:.88rem; }
    .select2-container--default .select2-selection--single:focus { border-color:#1d4ed8; }
    .select2-container--default.select2-container--focus .select2-selection--single { border-color:#1d4ed8; box-shadow:0 0 0 3px rgba(29,78,216,.1); }
    .select2-container--default .select2-selection--single .select2-selection__rendered { line-height:normal; padding:0; color:#0f172a; }
    .select2-container--default .select2-selection--single .select2-selection__arrow { top:50%; transform:translateY(-50%); }
    .select2-dropdown { border:1.5px solid #e2e8f0; border-radius:9px; box-shadow:0 8px 24px rgba(0,0,0,.12); }
    .select2-container--default .select2-results__option--highlighted { background:#1d4ed8; }
    @@media(max-width:640px) { .cf-steps { grid-template-columns:1fr; } .cf-step-full { grid-column:1; } }
</style>

<div class="dashboard-wrapper" style="display:flex;direction:rtl;min-height:100vh">
@await Html.PartialAsync("_AdminSidebar")
<main style="flex:1;order:2;overflow-x:hidden">
<div class="cf-page">

    <!-- Banner -->
    <div class="cf-banner">
        <div class="cf-banner-icon"><i class="fas fa-plus-circle"></i></div>
        <div>
            <h1>إنشاء شهادة جديدة</h1>
            <p>اختر الطالب والدورة والاختبار — يتم توليد رابط التوثيق تلقائياً</p>
        </div>
    </div>

    <div class="cf-card">
        <div class="cf-card-head">
            <i class="fas fa-certificate" style="color:#d4a015;"></i>
            <h3>بيانات الشهادة</h3>
        </div>

        <form asp-action="Create">
            <div id="validationSummary" asp-validation-summary="ModelOnly"
                 style="display:none;margin:20px 32px 0;padding:12px 16px;background:#fef2f2;border:1.5px solid #fecaca;border-radius:9px;color:#991b1b;font-size:.84rem;"></div>

            <div class="cf-card-body">
                <div class="cf-steps">

                    <!-- Step 1: Trainee (full width) -->
                    <div class="cf-step-full cf-field">
                        <label class="cf-label" for="TraineeId">
                            <span class="step-badge">1</span>
                            <i class="fas fa-user-graduate"></i> الطالب (المتدرب)
                        </label>
                        <select asp-for="TraineeId" id="TraineeId"
                                class="cf-select select2"
                                asp-items="ViewBag.TraineeId">
                            <option value="">-- اختر الطالب أولاً --</option>
                        </select>
                        <span asp-validation-for="TraineeId" class="cf-err"></span>
                    </div>

                    <!-- Step 2: Course -->
                    <div class="cf-field">
                        <label class="cf-label" for="CourseId">
                            <span class="step-badge">2</span>
                            <i class="fas fa-book-open"></i> الدورة
                        </label>
                        <select asp-for="CourseId" id="CourseId" class="cf-select select2" disabled>
                            <option value="">-- اختر الطالب أولاً --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="cf-err"></span>
                    </div>

                    <!-- Step 3: Trainer -->
                    <div class="cf-field">
                        <label class="cf-label" for="TrainerId">
                            <span class="step-badge">3</span>
                            <i class="fas fa-chalkboard-teacher"></i> المدرب
                        </label>
                        <select asp-for="TrainerId" id="TrainerId" class="cf-select select2" disabled>
                            <option value="">-- اختر الدورة أولاً --</option>
                        </select>
                        <span asp-validation-for="TrainerId" class="cf-err"></span>
                    </div>

                    <!-- Step 4: Exam -->
                    <div class="cf-field">
                        <label class="cf-label" for="ExamId">
                            <span class="step-badge">4</span>
                            <i class="fas fa-clipboard-check"></i> الاختبار
                        </label>
                        <select asp-for="ExamId" id="ExamId" class="cf-select select2" disabled>
                            <option value="">-- اختر الدورة أولاً --</option>
                        </select>
                        <span asp-validation-for="ExamId" class="cf-err"></span>
                    </div>

                    <!-- Step 5: Average -->
                    <div class="cf-field">
                        <label class="cf-label" for="Average">
                            <span class="step-badge">5</span>
                            <i class="fas fa-chart-bar"></i> المعدل (%)
                        </label>
                        <div class="cf-input-group">
                            <input asp-for="Average" id="Average" type="number" step="0.1" min="0" max="100"
                                   class="cf-input" placeholder="يُملأ تلقائياً من نتيجة الاختبار" />
                            <span class="cf-input-suffix">%</span>
                        </div>
                        <span id="avgInfo" class="cf-hint">
                            <i class="fas fa-check-circle"></i>
                            <span id="avgInfoText"></span>
                        </span>
                        <span asp-validation-for="Average" class="cf-err"></span>
                    </div>

                </div>

                <hr class="cf-divider" />

                <!-- IsDeleted switch -->
                <div class="cf-switch-row">
                    <input class="form-check-input" asp-for="IsDeleted" type="checkbox" id="IsDeleted" />
                    <label for="IsDeleted">
                        <i class="fas fa-trash-alt" style="margin-left:4px;"></i>
                        تحديد كمحذوف (لن تظهر للطالب)
                    </label>
                </div>
            </div>

            <div class="cf-actions">
                <a asp-action="Index" class="btn-cf btn-cf-back"><i class="fas fa-arrow-right"></i> رجوع</a>
                <button type="submit" class="btn-cf btn-cf-save">
                    <i class="fas fa-save"></i> حفظ الشهادة
                </button>
            </div>
        </form>
    </div>

</div>
</main>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
    $(function () {
        function initSelect2(sel, placeholder) {
            $(sel).select2({ placeholder: placeholder, allowClear: true, width: '100%' });
        }
        function fillSelect(sel, items, placeholderText) {
            var $s = $(sel);
            $s.empty().append('<option value="">' + placeholderText + '</option>');
            $.each(items, function (_, item) {
                $s.append($('<option>', { value: item.value, text: item.text }));
            });
            $s.prop('disabled', items.length === 0).trigger('change');
        }

        initSelect2('#TraineeId', '-- اختر الطالب --');
        initSelect2('#CourseId',  '-- اختر الدورة --');
        initSelect2('#TrainerId', '-- اختر المدرب --');
        initSelect2('#ExamId',    '-- اختر الاختبار --');

        $('#TraineeId').on('change', function () {
            var traineeId = $(this).val();
            $('#CourseId, #TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
            $('#Average').val('');
            $('#avgInfo').removeClass('show');

            if (!traineeId) return;

            $.getJSON('/Certificates/GetCoursesByTrainee', { traineeId: traineeId }, function (data) {
                fillSelect('#CourseId', data, data.length ? '-- اختر الدورة --' : 'لا توجد دورات مسجلة');
            });
        });

        $('#CourseId').on('change', function () {
            var courseId  = $(this).val();
            var traineeId = $('#TraineeId').val();
            $('#TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
            $('#Average').val('');
            $('#avgInfo').removeClass('show');

            if (!courseId) return;

            $.getJSON('/Certificates/GetTrainersByCourse', { courseId: courseId }, function (data) {
                fillSelect('#TrainerId', data, data.length ? '-- اختر المدرب --' : 'لا يوجد مدربون');
            });

            $.getJSON('/Certificates/GetExamsByCourse', { courseId: courseId }, function (data) {
                fillSelect('#ExamId', data, data.length ? '-- اختر الاختبار --' : 'لا توجد اختبارات');
            });
        });

        $('#ExamId').on('change', function () {
            var examId    = $(this).val();
            var traineeId = $('#TraineeId').val();
            $('#avgInfo').removeClass('show');

            if (!examId || !traineeId) return;

            $.getJSON('/Certificates/GetAttemptScore', { examId: examId, traineeId: traineeId }, function (data) {
                if (data.score !== null && data.score !== undefined) {
                    $('#Average').val(data.score);
                    $('#avgInfoText').text('تم جلب النتيجة تلقائياً: ' + data.score + '%');
                    $('#avgInfo').addClass('show');
                }
            });
        });

        var summary = document.getElementById('validationSummary');
        if (summary && summary.innerText.trim().length > 0) {
            summary.style.display = 'block';
        }
    });
    </script>
}
