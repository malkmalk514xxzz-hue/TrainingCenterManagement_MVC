@model IEnumerable<TrainingCenterManagement_MVC.Models.Certificate>

@{
    ViewData["Title"] = "Certificates";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Certificates List</h2>
        <a class="btn btn-success" asp-action="Create">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>

    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Average)</th>
                    <th>@Html.DisplayNameFor(model => model.Url)</th>
                    <th>@Html.DisplayNameFor(model => model.IsDeleted)</th>
                    <th>@Html.DisplayNameFor(model => model.Trainee)</th>
                    <th>@Html.DisplayNameFor(model => model.Trainer)</th>
                    <th>@Html.DisplayNameFor(model => model.Course)</th>
                    <th>@Html.DisplayNameFor(model => model.Exam)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Average)</td>
                        <td>
                            <a href="@item.Url" target="_blank">@item.Url</a>
                        </td>
                        <td>
                            @if (item.IsDeleted)
                            {
                                <span class="badge bg-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td>@item.Trainee?.UserId</td>
                        <td>@item.Trainer?.Specialty</td>
                        <td>@item.Course?.CourseName</td>
                        <td>@item.Exam?.ExamName</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.CertificateId" class="btn btn-sm btn-info me-1">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.CertificateId" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.CertificateId" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
