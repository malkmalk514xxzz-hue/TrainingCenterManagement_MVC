@model IEnumerable<TrainingCenterManagement_MVC.Models.Certificate>
@{
    ViewData["Title"] = "إدارة الشهادات";
    var list = Model.ToList();
    var activeCount  = list.Count(c => !c.IsDeleted);
    var deletedCount = list.Count(c => c.IsDeleted);
}

<style>
    :root {
        --pr:#4f46e5;--pr-l:#6366f1;--pr-pale:#eef2ff;
        --gold:#f59e0b;--gold-pale:#fffbeb;
        --success:#10b981;--danger:#ef4444;
        --body:#f1f5f9;--card:#fff;--t1:#0f172a;--t2:#475569;--t3:#94a3b8;
        --border:#e2e8f0;--shadow:0 4px 20px rgba(0,0,0,.07);--radius:14px;
    }
    .ct-page { background:var(--body);padding:28px 32px;direction:rtl;font-family:'Segoe UI',sans-serif; }

    .ct-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px; }
    .ct-header h1 { font-size:1.5rem;font-weight:800;color:var(--t1);margin:0;display:flex;align-items:center;gap:10px; }
    .ct-header h1 .icon { width:40px;height:40px;border-radius:10px;background:var(--gold-pale);color:var(--gold);display:flex;align-items:center;justify-content:center;font-size:1rem; }
    .ct-add-btn { display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:9px;background:var(--pr);color:#fff;text-decoration:none;font-size:.84rem;font-weight:700;transition:all .2s; }
    .ct-add-btn:hover { background:var(--pr-l);color:#fff; }

    .ct-stats { display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px; }
    @@media(max-width:700px){ .ct-stats{ grid-template-columns:repeat(2,1fr); } }
    .ct-stat { background:var(--card);border-radius:12px;border:1px solid var(--border);padding:18px 20px;box-shadow:var(--shadow);display:flex;align-items:center;gap:12px; }
    .ct-stat-icon { width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0; }
    .ct-stat-val { font-size:1.4rem;font-weight:800;color:var(--t1); }
    .ct-stat-lbl { font-size:.73rem;color:var(--t3);margin-top:2px; }

    .ct-toolbar { background:var(--card);border-radius:12px;border:1px solid var(--border);padding:14px 18px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:20px; }
    .ct-search { flex:1;min-width:180px;position:relative; }
    .ct-search i { position:absolute;right:11px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:.8rem; }
    .ct-search input { width:100%;padding:8px 34px 8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:.84rem;font-family:inherit;box-sizing:border-box; }
    .ct-search input:focus { outline:none;border-color:var(--pr);box-shadow:0 0 0 3px rgba(79,70,229,.1); }
    .ct-fb { padding:6px 14px;border-radius:20px;border:1.5px solid var(--border);background:#fff;font-size:.75rem;font-weight:600;color:var(--t2);cursor:pointer;font-family:inherit;transition:all .2s; }
    .ct-fb.active,.ct-fb:hover { background:var(--pr);color:#fff;border-color:var(--pr); }
    .ct-count { font-size:.78rem;color:var(--t3);margin-right:auto; }

    /* Table */
    .ct-table-wrap { background:var(--card);border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden; }
    .ct-table { width:100%;border-collapse:collapse;font-size:.84rem; }
    .ct-table thead th { padding:11px 16px;background:linear-gradient(135deg,var(--gold-pale),#fff);color:var(--t2);font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid var(--border);text-align:right; }
    .ct-table tbody td { padding:13px 16px;border-bottom:1px solid #f8f9fb;vertical-align:middle; }
    .ct-table tbody tr:last-child td { border-bottom:none; }
    .ct-table tbody tr:hover td { background:#fafafe; }

    /* Cert icon */
    .ct-cert-icon { width:38px;height:38px;border-radius:8px;background:linear-gradient(135deg,var(--gold),#f97316);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.9rem;flex-shrink:0; }
    .ct-trainee-cell { display:flex;align-items:center;gap:10px; }
    .ct-avatar { width:32px;height:32px;border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0; }
    .ct-name { font-weight:600;color:var(--t1); }
    .ct-sub  { font-size:.72rem;color:var(--t3); }

    .ct-badge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:12px;font-size:.72rem;font-weight:700; }
    .ct-badge-active  { background:var(--pr-pale);color:var(--pr); }
    .ct-badge-deleted { background:#fee2e2;color:var(--danger); }
    .ct-badge-gold    { background:var(--gold-pale);color:#92400e; }

    .ct-score { font-size:1rem;font-weight:800;color:var(--t1); }
    .ct-score small { font-size:.7rem;color:var(--t3);font-weight:400; }

    .ct-act-btn { display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:6px;font-size:.74rem;font-weight:600;text-decoration:none;transition:all .2s;border:1px solid var(--border); }
    .ct-act-view { background:var(--pr-pale);color:var(--pr);border-color:#c7d2fe; }
    .ct-act-view:hover { background:var(--pr);color:#fff; }
    .ct-act-edit { background:#fffbeb;color:#92400e;border-color:#fde68a; }
    .ct-act-edit:hover { background:var(--gold);color:#fff;border-color:var(--gold); }
    .ct-act-del  { background:#fee2e2;color:var(--danger);border-color:#fca5a5; }
    .ct-act-del:hover  { background:var(--danger);color:#fff; }
    .ct-act-pdf  { background:#f0fdf4;color:#065f46;border-color:#86efac; }
    .ct-act-pdf:hover  { background:var(--success);color:#fff; }

    .ct-empty { text-align:center;padding:60px 20px;color:var(--t3); }
    .ct-empty i { font-size:2.5rem;margin-bottom:12px;display:block; }
</style>

<div class="dashboard-wrapper">
    @await Html.PartialAsync("_AdminSidebar")
    <main class="dashboard-main ct-page">

        <!-- Header -->
        <div class="ct-header">
            <h1>
                <span class="icon"><i class="fas fa-certificate"></i></span>
                إدارة الشهادات
            </h1>
            <a asp-action="Create" class="ct-add-btn">
                <i class="fas fa-plus-circle"></i> إصدار شهادة
            </a>
        </div>

        <!-- Stats -->
        <div class="ct-stats">
            <div class="ct-stat">
                <div class="ct-stat-icon" style="background:var(--gold-pale);color:var(--gold);"><i class="fas fa-certificate"></i></div>
                <div><div class="ct-stat-val">@list.Count</div><div class="ct-stat-lbl">إجمالي الشهادات</div></div>
            </div>
            <div class="ct-stat">
                <div class="ct-stat-icon" style="background:#d1fae5;color:#059669;"><i class="fas fa-check-circle"></i></div>
                <div><div class="ct-stat-val">@activeCount</div><div class="ct-stat-lbl">شهادة نشطة</div></div>
            </div>
            <div class="ct-stat">
                <div class="ct-stat-icon" style="background:#fee2e2;color:var(--danger);"><i class="fas fa-times-circle"></i></div>
                <div><div class="ct-stat-val">@deletedCount</div><div class="ct-stat-lbl">محذوفة</div></div>
            </div>
            <div class="ct-stat">
                <div class="ct-stat-icon" style="background:var(--pr-pale);color:var(--pr);"><i class="fas fa-user-graduate"></i></div>
                <div><div class="ct-stat-val">@list.Select(c => c.TraineeId).Distinct().Count()</div><div class="ct-stat-lbl">متدرب حاصل</div></div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="ct-toolbar">
            <div class="ct-search">
                <i class="fas fa-search"></i>
                <input type="text" id="ct-q" placeholder="ابحث بالاسم أو الكورس..." oninput="ctFilter()" />
            </div>
            <button class="ct-fb active" onclick="ctSetFilter('all',this)">الكل</button>
            <button class="ct-fb" onclick="ctSetFilter('active',this)">نشط</button>
            <button class="ct-fb" onclick="ctSetFilter('deleted',this)">محذوف</button>
            <span class="ct-count" id="ct-count">@list.Count شهادة</span>
        </div>

        <!-- Table -->
        @if (list.Any())
        {
            <div class="ct-table-wrap">
                <table class="ct-table">
                    <thead>
                        <tr>
                            <th>الشهادة</th>
                            <th>المتدرب</th>
                            <th>الكورس</th>
                            <th>المدرب</th>
                            <th>الامتحان</th>
                            <th>الدرجة</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="ct-tbody">
                        @foreach (var item in list)
                        {
                            var traineeInitials = string.Join("", (item.Trainee?.User?.FullName ?? "?").Split(' ').Take(2).Select(x => x.FirstOrDefault().ToString()));
                            string[] colors = { "#4f46e5","#7c3aed","#0891b2","#059669","#d97706" };
                            var col = colors[Math.Abs((item.TraineeId).GetHashCode()) % colors.Length];
                            var avatarBg = Uri.EscapeDataString(item.Trainee?.User?.FullName ?? "U");
                            <tr data-status="@(item.IsDeleted ? "deleted" : "active")"
                                data-trainee="@(item.Trainee?.User?.FullName?.ToLower())"
                                data-course="@(item.Course?.CourseName?.ToLower())">
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div class="ct-cert-icon"><i class="fas fa-award"></i></div>
                                        <div>
                                            <div class="ct-name" style="font-size:.8rem;">
                                                @(string.IsNullOrEmpty(item.Url) ? "شهادة" : "مُصدرة")
                                            </div>
                                            <div class="ct-sub">@item.CertificateId.ToString()[..8]...</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="ct-trainee-cell">
                                        <img src="https://ui-avatars.com/api/?name=@avatarBg&background=@(col.Replace("#",""))&color=fff&size=64&rounded=true"
                                             class="ct-avatar" alt="@item.Trainee?.User?.FullName"
                                             onerror="this.style.display='none'" />
                                        <div>
                                            <div class="ct-name">@(item.Trainee?.User?.FullName ?? "—")</div>
                                            <div class="ct-sub">@(item.Trainee?.User?.Email)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="ct-badge ct-badge-gold">
                                        <i class="fas fa-book-open" style="font-size:.6rem;"></i>
                                        @(item.Course?.CourseName ?? "—")
                                    </span>
                                </td>
                                <td style="color:var(--t2);font-size:.82rem;">@(item.Trainer?.User?.FullName ?? item.Trainer?.Specialty ?? "—")</td>
                                <td style="color:var(--t2);font-size:.82rem;">@(item.Exam?.ExamName ?? "—")</td>
                                <td>
                                    @if (item.Average > 0)
                                    {
                                        <span class="ct-score">@item.Average.ToString("F1")<small>/100</small></span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--t3);">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="ct-badge @(item.IsDeleted ? "ct-badge-deleted" : "ct-badge-active")">
                                        @(item.IsDeleted ? "محذوف" : "نشط")
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:5px;flex-wrap:wrap;">
                                        <a asp-action="Details" asp-route-id="@item.CertificateId" class="ct-act-btn ct-act-view">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.CertificateId" class="ct-act-btn ct-act-edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a asp-action="CertificatePdf" asp-route-id="@item.CertificateId" target="_blank" class="ct-act-btn ct-act-pdf">
                                            <i class="fas fa-file-pdf"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.CertificateId" class="ct-act-btn ct-act-del">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ct-empty">
                <i class="fas fa-certificate"></i>
                <p>لا توجد شهادات مسجلة بعد</p>
            </div>
        }

    </main>
</div>

<script>
    var ctFilter_ = 'all';
    function ctSetFilter(f, btn) {
        ctFilter_ = f;
        document.querySelectorAll('.ct-fb').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        ctApply();
    }
    function ctFilter() { ctApply(); }
    function ctApply() {
        var q = (document.getElementById('ct-q').value || '').trim().toLowerCase();
        var rows = document.querySelectorAll('#ct-tbody tr');
        var count = 0;
        rows.forEach(function(r) {
            var mQ = !q || (r.dataset.trainee||'').includes(q) || (r.dataset.course||'').includes(q);
            var mF = ctFilter_ === 'all' || r.dataset.status === ctFilter_;
            r.style.display = (mQ && mF) ? '' : 'none';
            if (mQ && mF) count++;
        });
        document.getElementById('ct-count').textContent = count + ' شهادة';
    }
</script>
