@model TrainingCenterManagement_MVC.Models.Certificate

@{
    ViewData["Title"] = "Edit Certificate";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4><i class="bi bi-pencil-square"></i> Edit Certificate</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="CertificateId" />

                <div class="mb-3">
                    <label asp-for="Average" class="form-label"></label>
                    <input asp-for="Average" class="form-control" />
                    <span asp-validation-for="Average" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Url" class="form-label"></label>
                    <input asp-for="Url" class="form-control" />
                    <span asp-validation-for="Url" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="IsDeleted" />
                    <label class="form-check-label" asp-for="IsDeleted"></label>
                </div>

                <div class="mb-3">
                    <label asp-for="TraineeId" class="form-label"></label>
                    <select asp-for="TraineeId" class="form-select select2" asp-items="ViewBag.TraineeId">
                        <option disabled selected>Select a trainee...</option>
                    </select>
                    <span asp-validation-for="TraineeId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TrainerId" class="form-label"></label>
                    <select asp-for="TrainerId" class="form-select select2" asp-items="ViewBag.TrainerId">
                        <option disabled selected>Select a trainer...</option>
                    </select>
                    <span asp-validation-for="TrainerId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label"></label>
                    <select asp-for="CourseId" class="form-select select2" asp-items="ViewBag.CourseId">
                        <option disabled selected>Select a course...</option>
                    </select>
                    <span asp-validation-for="CourseId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ExamId" class="form-label"></label>
                    <select asp-for="ExamId" class="form-select select2" asp-items="ViewBag.ExamId">
                        <option disabled selected>Select an exam...</option>
                    </select>
                    <span asp-validation-for="ExamId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Save</button>
                <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left"></i> Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <!-- Select2 CSS & JS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "Select an option",
                allowClear: true
            });
        });
    </script>
}
