@model TrainingCenterManagement_MVC.Models.Certificate
@{
    ViewData["Title"] = "تعديل الشهادة";
}

<style>
    .ce-page { background:#f0f9ff; padding:28px 32px; direction:rtl; font-family:'Segoe UI','Tajawal',sans-serif; min-height:100vh; }
    .ce-banner { background:linear-gradient(135deg,#1e1b4b 0%,#4f46e5 55%,#818cf8 100%); border-radius:16px; padding:26px 32px; color:#fff; margin-bottom:24px; display:flex; align-items:center; gap:18px; }
    .ce-banner-icon { width:56px; height:56px; border-radius:14px; background:rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; font-size:1.5rem; flex-shrink:0; }
    .ce-banner h1 { margin:0; font-size:1.4rem; font-weight:800; }
    .ce-banner p { margin:4px 0 0; opacity:.8; font-size:.88rem; }

    .ce-card { background:#fff; border-radius:14px; box-shadow:0 4px 24px rgba(0,0,0,.07); border:1px solid #e2e8f0; overflow:hidden; }
    .ce-card-head { padding:14px 24px; background:linear-gradient(135deg,#f8fafc,#f5f3ff); border-bottom:1px solid #e2e8f0; display:flex; align-items:center; gap:10px; }
    .ce-card-head h3 { margin:0; font-size:.93rem; font-weight:700; color:#0f172a; }
    .ce-card-body { padding:28px 32px; }

    .ce-url-banner { background:#eff6ff; border:1.5px solid #bfdbfe; border-radius:10px; padding:12px 16px; display:flex; align-items:center; gap:10px; margin-bottom:24px; }
    .ce-url-banner a { color:#1d4ed8; font-size:.8rem; word-break:break-all; font-weight:600; }

    .ce-steps { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .ce-step-full { grid-column:1 / -1; }
    .ce-field { display:flex; flex-direction:column; gap:6px; }
    .ce-label { font-size:.84rem; font-weight:700; color:#374151; display:flex; align-items:center; gap:7px; }
    .ce-label i { color:#4f46e5; }
    .ce-select, .ce-input { width:100%; padding:11px 14px; border:1.5px solid #e2e8f0; border-radius:9px; font-size:.88rem; font-family:inherit; background:#fff; color:#0f172a; box-sizing:border-box; transition:border-color .18s,box-shadow .18s; }
    .ce-select:focus, .ce-input:focus { outline:none; border-color:#4f46e5; box-shadow:0 0 0 3px rgba(79,70,229,.1); }
    .ce-select:disabled { background:#f1f5f9; color:#94a3b8; cursor:not-allowed; }
    .ce-input-group { display:flex; }
    .ce-input-group .ce-input { border-radius:9px 0 0 9px; flex:1; }
    .ce-input-suffix { padding:11px 14px; background:#f1f5f9; border:1.5px solid #e2e8f0; border-right:none; border-radius:0 9px 9px 0; font-size:.88rem; font-weight:700; color:#64748b; }
    .ce-err { font-size:.76rem; color:#dc2626; }
    .ce-hint { font-size:.76rem; color:#10b981; display:none; }
    .ce-hint.show { display:block; }

    .ce-switch-row { display:flex; align-items:center; gap:10px; padding:14px 16px; background:#fef2f2; border:1.5px solid #fecaca; border-radius:9px; }
    .ce-switch-row label { font-size:.86rem; font-weight:600; color:#991b1b; cursor:pointer; }

    .ce-divider { border:none; border-top:1.5px dashed #e2e8f0; margin:24px 0; }

    .ce-actions { display:flex; justify-content:space-between; align-items:center; padding:20px 32px; background:#f8fafc; border-top:1px solid #e2e8f0; }
    .btn-ce { display:inline-flex; align-items:center; gap:7px; padding:10px 22px; border-radius:9px; font-size:.86rem; font-weight:700; text-decoration:none; border:none; cursor:pointer; transition:all .18s; }
    .btn-ce-back { background:#fff; color:#475569; border:1.5px solid #e2e8f0 !important; }
    .btn-ce-back:hover { background:#f1f5f9; color:#0f172a; }
    .btn-ce-save { background:linear-gradient(135deg,#4f46e5,#818cf8); color:#fff; }
    .btn-ce-save:hover { opacity:.88; color:#fff; }

    .select2-container { width:100% !important; }
    .select2-container--default .select2-selection--single { border:1.5px solid #e2e8f0; border-radius:9px; height:42px; padding:0 12px; display:flex; align-items:center; font-size:.88rem; }
    .select2-container--default.select2-container--focus .select2-selection--single { border-color:#4f46e5; box-shadow:0 0 0 3px rgba(79,70,229,.1); }
    .select2-container--default .select2-selection--single .select2-selection__rendered { line-height:normal; padding:0; color:#0f172a; }
    .select2-container--default .select2-selection--single .select2-selection__arrow { top:50%; transform:translateY(-50%); }
    .select2-dropdown { border:1.5px solid #e2e8f0; border-radius:9px; box-shadow:0 8px 24px rgba(0,0,0,.12); }
    .select2-container--default .select2-results__option--highlighted { background:#4f46e5; }
    @@media(max-width:640px) { .ce-steps { grid-template-columns:1fr; } .ce-step-full { grid-column:1; } }
</style>

<div class="dashboard-wrapper" style="display:flex;direction:rtl;min-height:100vh">
@await Html.PartialAsync("_AdminSidebar")
<main style="flex:1;order:2;overflow-x:hidden">
<div class="ce-page">

    <!-- Banner -->
    <div class="ce-banner">
        <div class="ce-banner-icon"><i class="fas fa-pencil-alt"></i></div>
        <div>
            <h1>تعديل الشهادة</h1>
            <p>رابط التوثيق محفوظ تلقائياً ولن يتغير عند الحفظ</p>
        </div>
    </div>

    <div class="ce-card">
        <div class="ce-card-head">
            <i class="fas fa-certificate" style="color:#4f46e5;"></i>
            <h3>تعديل بيانات الشهادة</h3>
        </div>

        <form asp-action="Edit">
            <input type="hidden" asp-for="CertificateId" />

            <div class="ce-card-body">

                @if (!string.IsNullOrEmpty(Model.Url))
                {
                    <div class="ce-url-banner">
                        <i class="fas fa-link" style="color:#1d4ed8;flex-shrink:0;"></i>
                        <div style="flex:1">
                            <div style="font-size:.7rem;color:#64748b;font-weight:600;margin-bottom:2px;">رابط التوثيق الحالي</div>
                            <a href="@Model.Url" target="_blank">@Model.Url</a>
                        </div>
                    </div>
                }

                <div class="ce-steps">

                    <!-- Trainee (full width) -->
                    <div class="ce-step-full ce-field">
                        <label class="ce-label" for="TraineeId">
                            <i class="fas fa-user-graduate"></i> الطالب (المتدرب)
                        </label>
                        <select asp-for="TraineeId" id="TraineeId"
                                class="ce-select select2"
                                asp-items="ViewBag.TraineeId"
                                data-current-course="@Model.CourseId"
                                data-current-trainer="@Model.TrainerId"
                                data-current-exam="@Model.ExamId">
                            <option value="">-- اختر الطالب --</option>
                        </select>
                        <span asp-validation-for="TraineeId" class="ce-err"></span>
                    </div>

                    <!-- Course -->
                    <div class="ce-field">
                        <label class="ce-label" for="CourseId">
                            <i class="fas fa-book-open"></i> الدورة
                        </label>
                        <select asp-for="CourseId" id="CourseId"
                                class="ce-select select2"
                                asp-items="ViewBag.CourseId">
                            <option value="">-- اختر الدورة --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="ce-err"></span>
                    </div>

                    <!-- Trainer -->
                    <div class="ce-field">
                        <label class="ce-label" for="TrainerId">
                            <i class="fas fa-chalkboard-teacher"></i> المدرب
                        </label>
                        <select asp-for="TrainerId" id="TrainerId"
                                class="ce-select select2"
                                asp-items="ViewBag.TrainerId">
                            <option value="">-- اختر المدرب --</option>
                        </select>
                        <span asp-validation-for="TrainerId" class="ce-err"></span>
                    </div>

                    <!-- Exam -->
                    <div class="ce-field">
                        <label class="ce-label" for="ExamId">
                            <i class="fas fa-clipboard-check"></i> الاختبار
                        </label>
                        <select asp-for="ExamId" id="ExamId"
                                class="ce-select select2"
                                asp-items="ViewBag.ExamId">
                            <option value="">-- اختر الاختبار --</option>
                        </select>
                        <span asp-validation-for="ExamId" class="ce-err"></span>
                    </div>

                    <!-- Average -->
                    <div class="ce-field">
                        <label class="ce-label" for="Average">
                            <i class="fas fa-chart-bar"></i> المعدل (%)
                        </label>
                        <div class="ce-input-group">
                            <input asp-for="Average" id="Average" type="number" step="0.1" min="0" max="100"
                                   class="ce-input" />
                            <span class="ce-input-suffix">%</span>
                        </div>
                        <span id="avgInfo" class="ce-hint">
                            <i class="fas fa-check-circle"></i>
                            <span id="avgInfoText"></span>
                        </span>
                        <span asp-validation-for="Average" class="ce-err"></span>
                    </div>

                </div>

                <hr class="ce-divider" />

                <div class="ce-switch-row">
                    <input asp-for="IsDeleted" type="checkbox" id="IsDeleted" />
                    <label for="IsDeleted">
                        <i class="fas fa-trash-alt" style="margin-left:4px;"></i>
                        تحديد كمحذوف (لن تظهر للطالب)
                    </label>
                </div>
            </div>

            <div class="ce-actions">
                <a asp-action="Index" class="btn-ce btn-ce-back"><i class="fas fa-arrow-right"></i> رجوع</a>
                <button type="submit" class="btn-ce btn-ce-save">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </div>
        </form>
    </div>

</div>
</main>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
    $(function () {
        var currentCourse  = '@Model.CourseId';
        var currentTrainer = '@Model.TrainerId';
        var currentExam    = '@Model.ExamId';

        function initSelect2(sel, placeholder) {
            $(sel).select2({ placeholder: placeholder, allowClear: true, width: '100%' });
        }
        function fillSelect(sel, items, placeholderText, selectVal) {
            var $s = $(sel);
            $s.empty().append('<option value="">' + placeholderText + '</option>');
            $.each(items, function (_, item) {
                $s.append($('<option>', { value: item.value, text: item.text }));
            });
            if (selectVal) $s.val(selectVal);
            $s.prop('disabled', items.length === 0).trigger('change');
        }

        initSelect2('#TraineeId', '-- اختر الطالب --');
        initSelect2('#CourseId',  '-- اختر الدورة --');
        initSelect2('#TrainerId', '-- اختر المدرب --');
        initSelect2('#ExamId',    '-- اختر الاختبار --');

        $('#TraineeId').on('change', function () {
            var traineeId = $(this).val();
            if (!traineeId) {
                $('#CourseId, #TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
                return;
            }
            $.getJSON('/Certificates/GetCoursesByTrainee', { traineeId: traineeId }, function (data) {
                fillSelect('#CourseId', data,
                    data.length ? '-- اختر الدورة --' : 'لا توجد دورات مسجلة',
                    currentCourse);
            });
        });

        $('#CourseId').on('change', function () {
            var courseId = $(this).val();
            if (!courseId) {
                $('#TrainerId, #ExamId').val('').prop('disabled', true).trigger('change');
                return;
            }
            $.getJSON('/Certificates/GetTrainersByCourse', { courseId: courseId }, function (data) {
                fillSelect('#TrainerId', data,
                    data.length ? '-- اختر المدرب --' : 'لا يوجد مدربون',
                    currentTrainer);
            });
            $.getJSON('/Certificates/GetExamsByCourse', { courseId: courseId }, function (data) {
                fillSelect('#ExamId', data,
                    data.length ? '-- اختر الاختبار --' : 'لا توجد اختبارات',
                    currentExam);
            });
        });

        $('#ExamId').on('change', function () {
            var examId    = $(this).val();
            var traineeId = $('#TraineeId').val();
            if (!examId || !traineeId) { $('#avgInfo').removeClass('show'); return; }

            $.getJSON('/Certificates/GetAttemptScore', { examId: examId, traineeId: traineeId }, function (data) {
                if (data.score !== null && data.score !== undefined) {
                    $('#Average').val(data.score);
                    $('#avgInfoText').text('تم جلب النتيجة تلقائياً: ' + data.score + '%');
                    $('#avgInfo').addClass('show');
                } else {
                    $('#avgInfo').removeClass('show');
                }
            });
        });

        var initTraineeId = $('#TraineeId').val();
        if (initTraineeId) {
            setTimeout(function () {
                $('#CourseId').trigger('change');
            }, 300);
        }
    });
    </script>
}
