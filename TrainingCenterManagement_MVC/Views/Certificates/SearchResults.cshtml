@model IEnumerable<TrainingCenterManagement_MVC.Models.Certificate>
@{
    ViewData["Title"] = "Certificate Search";
}

<h2>Search for Certificates</h2>

<form method="get" asp-action="Search" class="form-inline mb-3">
    <input type="text" name="traineeName" class="form-control mr-2" placeholder="Trainee Name" />
    <input type="text" name="courseName" class="form-control mr-2" placeholder="Course Name" />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (!Model.Any())
{
    <p>No certificates found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Trainee</th>
                <th>Course</th>
                <th>Average</th>
                <th>Trainer</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cert in Model)
            {
                <tr>
                    <td>@cert.Trainee.User.FullName</td>
                    <td>@cert.Course.CourseName</td>
                    <td>@cert.Average %</td>
                    <td>@cert.Trainer?.User?.FullName</td>
                </tr>
            }
        </tbody>
    </table>
}
