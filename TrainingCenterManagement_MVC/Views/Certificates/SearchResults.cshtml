@model IEnumerable<TrainingCenterManagement_MVC.Models.Certificate>

@{
    ViewData["Title"] = "Certificate Search";
}

<div class="container mt-4">
    <h2 class="mb-4">Search for Certificates</h2>

    <form method="get" asp-action="Search" class="row g-3 mb-4">
        <div class="col-md-5">
            <input type="text" name="traineeName" class="form-control" placeholder="Trainee Name" />
        </div>
        <div class="col-md-5">
            <input type="text" name="courseName" class="form-control" placeholder="Course Name" />
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Search
            </button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-exclamation-circle"></i> No certificates found.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm border rounded">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Trainee</th>
                        <th>Course</th>
                        <th>Average</th>
                        <th>Trainer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cert in Model)
                    {
                        <tr>
                            <td>@cert.Trainee?.User?.FullName</td>
                            <td>@cert.Course?.CourseName</td>
                            <td>@cert.Average %</td>
                            <td>@cert.Trainer?.User?.FullName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
