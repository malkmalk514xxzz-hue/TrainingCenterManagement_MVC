@model TrainingCenterManagement_MVC.Models.Certificate

@{
    ViewData["Title"] = "Delete Certificate";
}

<div class="container-xl mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-danger text-white text-center rounded-top">
                    <h2 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion</h2>
                </div>

                <div class="card-body px-5 py-4">
                    <p class="lead text-center text-muted mb-4">
                        Are you sure you want to permanently delete the following certificate?
                    </p>

                    <dl class="row mb-4">
                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Average</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Average)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">URL</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Url)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Is Deleted</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.IsDeleted)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Trainee ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Trainee.UserId)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Trainer Specialty</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Trainer.Specialty)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Course Name</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Course.CourseName)</dd>

                        <dt class="col-sm-3 text-end fw-semibold text-secondary">Exam Name</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Exam.ExamName)</dd>
                    </dl>

                    <form asp-action="Delete" class="d-flex justify-content-between align-items-center">
                        <input type="hidden" asp-for="CertificateId" />
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left-circle"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm px-4">
                            <i class="bi bi-trash-fill me-1"></i> Delete Certificate
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
