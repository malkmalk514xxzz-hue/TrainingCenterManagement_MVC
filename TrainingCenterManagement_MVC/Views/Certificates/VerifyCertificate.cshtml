@model TrainingCenterManagement_MVC.Models.Certificate
@{
    ViewData["Title"] = "Verify Certificate";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-gradient bg-success text-white text-center">
                    <h4 class="mb-0">Certificate Verification</h4>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-primary">@Model.Trainee.User.FullName</h3>
                        <p class="lead">has successfully completed the course</p>
                        <h5 class="text-dark">@Model.Course.CourseName</h5>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Issued By:</strong> @Model.Trainer?.User?.FullName</p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <p><strong>Average Score:</strong> @Model.Average%</p>
                        </div>
                    </div>

                    <div class="text-center text-muted">
                        <small><strong>Certificate ID:</strong> @Model.CertificateId</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
