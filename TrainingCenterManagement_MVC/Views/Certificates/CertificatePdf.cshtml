@model TrainingCenterManagement_MVC.Models.Certificate

@{
    Layout = null; // حتى لا يظهر Layout عادي، فقط شهادة
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Certificate</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            padding: 50px;
            background: #fdfdfd;
        }

        .certificate {
            border: 10px solid #2c3e50;
            padding: 50px;
            background: #fff;
            box-shadow: 0 0 20px rgba(0,0,0,0.3);
        }

        h1 {
            font-size: 48px;
            margin-bottom: 10px;
            color: #2c3e50;
        }

        h2 {
            margin-top: 10px;
            font-size: 28px;
            font-weight: normal;
        }

        .details {
            margin: 40px 0;
            font-size: 22px;
        }

        .footer {
            margin-top: 60px;
            font-size: 16px;
        }

        .highlight {
            font-weight: bold;
            color: #34495e;
        }
    </style>
</head>
<body>
    <div class="certificate">
        <h1>Certificate of Completion</h1>
        <h2>This certifies that</h2>

        <div class="details">
            <p class="highlight" style="font-size: 26px;">
                @Model.Trainee?.User?.FullName
            </p>
            <p>Email: <span class="highlight">@Model.Trainee?.User?.Email</span></p>

            <p>has successfully completed the course:</p>
            <p class="highlight">@Model.Course?.CourseName</p>

            <p>
                with an average score of
                <span class="highlight">@Model.Average.ToString("F2")%</span>
            </p>
        </div>

        <div class="footer">
            <p>Issued by Training Center</p>
            <p>Trainer: @Model.Trainer?.User?.FullName</p>
            <p>Date: @DateTime.Now.ToString("MMMM dd, yyyy")</p>
        </div>
    </div>
</body>
</html>
