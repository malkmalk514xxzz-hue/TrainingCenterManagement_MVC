@using QRCoder
@model TrainingCenterManagement_MVC.Models.Certificate
@{
    Layout = null;
    var baseUrl    = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var certUrl    = $"{baseUrl}/Certificates/Verify/{Model.CertificateId}";
    var issueDate  = DateTime.Now.ToString("MMMM dd, yyyy");
    var certIdShort = Model.CertificateId.ToString().ToUpper()[..8];
    var grade = Model.Average switch {
        >= 90 => "Distinction",
        >= 80 => "Excellence",
        >= 70 => "Very Good",
        >= 60 => "Good",
        _     => "Pass"
    };

    string qrBase64 = "";
    try {
        using var gen  = new QRCodeGenerator();
        using var data = gen.CreateQrCode(certUrl, QRCodeGenerator.ECCLevel.Q);
        using var png  = new PngByteQRCode(data);
        qrBase64 = Convert.ToBase64String(png.GetGraphic(8));
    } catch { }
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Certificate — @Model.Trainee.User.FullName</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
    width: 297mm;
    height: 210mm;
    background: #fffef8;
    font-family: 'Georgia', 'Times New Roman', serif;
    color: #1a2c5b;
    overflow: hidden;
}

/* ─── Page ─── */
.page {
    width: 297mm;
    height: 210mm;
    position: relative;
    background: #fffef8;
}

/* ─── Background Pattern ─── */
.page::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        repeating-linear-gradient(
            45deg,
            transparent,
            transparent 30px,
            rgba(201,162,39,.035) 30px,
            rgba(201,162,39,.035) 31px
        );
    pointer-events: none;
}

/* ─── Borders ─── */
.border-out {
    position: absolute;
    inset: 6mm;
    border: 4px solid #1a2c5b;
}
.border-gold {
    position: absolute;
    inset: 8.5mm;
    border: 1.5px solid #c9a227;
}
.border-in {
    position: absolute;
    inset: 10.5mm;
    border: 1px solid #1a2c5b;
}

/* ─── Corner Ornaments ─── */
.corners { position: absolute; inset: 0; pointer-events: none; }
.corner {
    position: absolute;
    width: 24mm; height: 24mm;
    overflow: hidden;
}
.corner::before, .corner::after { content: ''; position: absolute; background: #c9a227; }
.corner-tl { top: 5mm; left: 5mm; }
.corner-tl::before { width: 100%; height: 3px; top: 0; }
.corner-tl::after  { width: 3px; height: 100%; left: 0; }
.corner-tr { top: 5mm; right: 5mm; transform: scaleX(-1); }
.corner-tr::before { width: 100%; height: 3px; top: 0; }
.corner-tr::after  { width: 3px; height: 100%; left: 0; }
.corner-bl { bottom: 5mm; left: 5mm; transform: scaleY(-1); }
.corner-bl::before { width: 100%; height: 3px; top: 0; }
.corner-bl::after  { width: 3px; height: 100%; left: 0; }
.corner-br { bottom: 5mm; right: 5mm; transform: scale(-1); }
.corner-br::before { width: 100%; height: 3px; top: 0; }
.corner-br::after  { width: 3px; height: 100%; left: 0; }

.corner-gem {
    position: absolute;
    width: 10px; height: 10px;
    background: #c9a227;
    transform: rotate(45deg);
}
.corner-tl .corner-gem { top: -5px; left: -5px; }
.corner-tr .corner-gem { top: -5px; left: -5px; }
.corner-bl .corner-gem { top: -5px; left: -5px; }
.corner-br .corner-gem { top: -5px; left: -5px; }

/* ─── Left Accent Bar ─── */
.accent-left {
    position: absolute;
    top: 12mm; bottom: 12mm; left: 12mm;
    width: 14mm;
    background: linear-gradient(180deg, #1a2c5b 0%, #2a4494 50%, #1a2c5b 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 6px;
}
.accent-left-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: #c9a227;
    font-size: 7px;
    letter-spacing: 2px;
    font-weight: bold;
    text-transform: uppercase;
}
.accent-star {
    color: #c9a227;
    font-size: 14px;
    line-height: 1;
}

/* ─── Content Area ─── */
.content {
    position: absolute;
    top: 12mm; bottom: 12mm;
    left: 28mm; right: 12mm;
    display: flex; flex-direction: column;
    align-items: center; justify-content: space-between;
    padding: 6mm 10mm;
}

/* ─── Header ─── */
.header { text-align: center; width: 100%; }
.institution {
    font-size: 22px;
    font-weight: bold;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #1a2c5b;
    line-height: 1.2;
}
.institution-sub {
    font-size: 9px;
    letter-spacing: 3px;
    color: #c9a227;
    text-transform: uppercase;
    margin-top: 2px;
    font-weight: bold;
}
.divider {
    display: flex; align-items: center; gap: 8px;
    margin: 5px auto; width: 80%;
}
.divider-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, #c9a227, transparent); }
.divider-gem  { width: 6px; height: 6px; background: #c9a227; transform: rotate(45deg); flex-shrink: 0; }

/* ─── Certificate Title ─── */
.cert-title {
    font-size: 30px;
    letter-spacing: 6px;
    color: #1a2c5b;
    text-transform: uppercase;
    font-weight: bold;
    line-height: 1;
    text-shadow: 1px 1px 0 rgba(201,162,39,.3);
}
.cert-sub {
    font-size: 10px;
    letter-spacing: 2px;
    color: #7a6a3a;
    margin-top: 2px;
}

/* ─── Body ─── */
.body-section { text-align: center; width: 100%; }
.presented-to {
    font-size: 10px;
    letter-spacing: 2px;
    color: #666;
    text-transform: uppercase;
    font-style: italic;
}
.recipient-name {
    font-size: 36px;
    color: #1a2c5b;
    font-style: italic;
    font-weight: bold;
    margin: 3px 0 5px;
    line-height: 1.1;
    letter-spacing: 1px;
}
.name-underline {
    width: 70%; height: 1px; margin: 0 auto 5px;
    background: linear-gradient(90deg, transparent, #c9a227, transparent);
}
.completion-text {
    font-size: 10px;
    color: #555;
    letter-spacing: 1px;
    margin-bottom: 4px;
}
.course-box {
    display: inline-block;
    border-top: 1.5px solid #c9a227;
    border-bottom: 1.5px solid #c9a227;
    padding: 4px 20px;
    margin: 4px 0;
}
.course-name {
    font-size: 17px;
    color: #1a2c5b;
    font-weight: bold;
    letter-spacing: 1px;
}
.grade-row {
    font-size: 10px;
    color: #555;
    margin-top: 4px;
    letter-spacing: 1px;
}
.grade-val {
    font-size: 13px;
    color: #c9a227;
    font-weight: bold;
}

/* ─── Footer ─── */
.footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    width: 100%;
}
.footer-col { text-align: center; min-width: 80px; }
.sig-line {
    width: 90px; height: 1px;
    background: #1a2c5b;
    margin: 0 auto 3px;
}
.sig-name  { font-size: 9px; font-weight: bold; color: #1a2c5b; letter-spacing: 1px; }
.sig-title { font-size: 7.5px; color: #888; letter-spacing: 1px; text-transform: uppercase; }

/* Seal / medallion */
.seal {
    width: 60px; height: 60px;
    border-radius: 50%;
    border: 3px double #c9a227;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: radial-gradient(circle, #fffef8 60%, #f5eec8 100%);
    margin: 0 auto 4px;
    position: relative;
}
.seal::before {
    content: '';
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    border: 1px solid #c9a227;
}
.seal-star  { font-size: 18px; color: #c9a227; line-height: 1; }
.seal-text  { font-size: 5.5px; letter-spacing: 1px; color: #1a2c5b; text-transform: uppercase; font-weight: bold; }

/* Date / ID block */
.date-block { text-align: left; }
.date-label { font-size: 7px; letter-spacing: 1px; color: #888; text-transform: uppercase; }
.date-val   { font-size: 10px; font-weight: bold; color: #1a2c5b; }
.cert-id    { font-size: 7px; color: #aaa; letter-spacing: 1px; margin-top: 3px; }

/* QR */
.qr-block { text-align: right; }
.qr-block img { width: 55px; height: 55px; }
.qr-text { font-size: 6px; color: #aaa; letter-spacing: 1px; text-align: center; }
</style>
</head>
<body>
<div class="page">

    <!-- Borders -->
    <div class="border-out"></div>
    <div class="border-gold"></div>
    <div class="border-in"></div>

    <!-- Corner ornaments -->
    <div class="corners">
        <div class="corner corner-tl"><div class="corner-gem"></div></div>
        <div class="corner corner-tr"><div class="corner-gem"></div></div>
        <div class="corner corner-bl"><div class="corner-gem"></div></div>
        <div class="corner corner-br"><div class="corner-gem"></div></div>
    </div>

    <!-- Left accent bar -->
    <div class="accent-left">
        <span class="accent-star">&#9670;</span>
        <span class="accent-left-text">Training Center Academy</span>
        <span class="accent-star">&#9670;</span>
        <span class="accent-left-text">Certificate of Completion</span>
        <span class="accent-star">&#9670;</span>
    </div>

    <!-- Main content -->
    <div class="content">

        <!-- Header -->
        <div class="header">
            <div class="institution">Training Center Academy</div>
            <div class="institution-sub">&#9670;&nbsp; Professional Development &amp; Certification &nbsp;&#9670;</div>
            <div class="divider">
                <div class="divider-line"></div>
                <div class="divider-gem"></div>
                <div class="divider-line"></div>
                <div class="divider-gem"></div>
                <div class="divider-line"></div>
            </div>
        </div>

        <!-- Title -->
        <div style="text-align:center;">
            <div class="cert-title">Certificate</div>
            <div class="cert-sub">&#9670;&nbsp; of Completion &nbsp;&#9670;</div>
        </div>

        <!-- Body -->
        <div class="body-section">
            <div class="presented-to">This is to proudly certify that</div>
            <div class="recipient-name">@Model.Trainee.User.FullName</div>
            <div class="name-underline"></div>
            <div class="completion-text">has successfully fulfilled all the requirements and completed</div>
            <div class="course-box">
                <div class="course-name">@Model.Course.CourseName</div>
            </div>
            <div class="grade-row">
                with a final score of &nbsp;<span class="grade-val">@Model.Average.ToString("F1") / 100</span>
                &nbsp;—&nbsp;
                <span class="grade-val">@grade</span>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <!-- Date + ID -->
            <div class="date-block">
                <div class="date-label">Date of Issue</div>
                <div class="date-val">@issueDate</div>
                <div class="cert-id">ID: @certIdShort</div>
            </div>

            <!-- Center: seal + signatures -->
            <div style="text-align:center; display:flex; flex-direction:column; align-items:center; gap:8px;">
                <div class="seal">
                    <div class="seal-star">&#9733;</div>
                    <div class="seal-text">Official</div>
                    <div class="seal-text">Seal</div>
                </div>
                <div style="display:flex; gap:30px; align-items:flex-end;">
                    <div class="footer-col">
                        <div class="sig-line"></div>
                        <div class="sig-name">@Model.Trainer.User.FullName</div>
                        <div class="sig-title">Course Instructor</div>
                    </div>
                    <div class="footer-col">
                        <div class="sig-line"></div>
                        <div class="sig-name">Academy Director</div>
                        <div class="sig-title">Training Center Academy</div>
                    </div>
                </div>
            </div>

            <!-- QR -->
            <div class="qr-block">
                @if (!string.IsNullOrEmpty(qrBase64))
                {
                    <img src="data:image/png;base64,@qrBase64" alt="Verify Certificate"/>
                    <div class="qr-text">Scan to verify</div>
                }
            </div>
        </div>

    </div><!-- /content -->
</div><!-- /page -->
</body>
</html>
