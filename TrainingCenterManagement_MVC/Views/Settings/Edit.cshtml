@{
    ViewData["Title"] = "إعدادات النظام";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="dashboard-wrapper" style="display:flex;direction:rtl;min-height:100vh">
@await Html.PartialAsync("_AdminSidebar")
<main style="flex:1;padding:28px 32px;background:#f8fafc;overflow-x:hidden">

<h2 style="font-size:1.3rem;font-weight:700;color:#0f172a;margin-bottom:24px;">
    <i class="fas fa-cog" style="color:#4f46e5;margin-left:8px;"></i> إعدادات النظام
</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:10px;padding:12px 18px;margin-bottom:20px;color:#065f46;font-weight:600;">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
    </div>
}

<form method="post" asp-controller="Settings" asp-action="Edit" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- ── General Settings ── -->
    <div style="background:#fff;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.07);border:1px solid #e2e8f0;padding:24px;margin-bottom:24px;">
        <h3 style="font-size:1rem;font-weight:700;color:#0f172a;margin:0 0 18px;padding-bottom:12px;border-bottom:1px solid #f1f5f9;">
            <i class="fas fa-sliders-h" style="color:#4f46e5;margin-left:8px;"></i> الإعدادات العامة
        </h3>
      
        <div style="margin-bottom:16px;">
            <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">العملة الافتراضية للعرض</label>
            @{
                var defCur = (string)(ViewBag.DefaultCurrency ?? "SYP");
            }
            <select name="DefaultCurrency" style="padding:9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.84rem;width:200px;">
                <option value="SYP" selected="@(defCur == "SYP")">ل.س — ليرة سورية</option>
                <option value="USD" selected="@(defCur == "USD")">$ — دولار أمريكي</option>
                <option value="EUR" selected="@(defCur == "EUR")">€ — يورو</option>
            </select>
        </div>
    </div>

    <!-- ── Sham Cash ── -->
    <div style="background:#fff;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.07);border:1px solid #e2e8f0;padding:24px;margin-bottom:24px;">
        <h3 style="font-size:1rem;font-weight:700;color:#0f172a;margin:0 0 6px;display:flex;align-items:center;gap:10px;">
            <span style="background:#7c3aed;color:#fff;border-radius:8px;padding:4px 10px;font-size:.82rem;">شام كاش</span>
            إعدادات الدفع عبر شام كاش
        </h3>
        <p style="font-size:.82rem;color:#64748b;margin:0 0 18px;">أدخل بيانات حسابك في شام كاش — ستُعرض للطلاب لدى الدفع وتُستخدم للتحقق من الإيصال.</p>

        <!-- Row 1: Name + Serial -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:16px;">
            <div>
                <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
                    اسم صاحب الحساب
                    <span style="font-size:.74rem;color:#7c3aed;font-weight:500;margin-right:5px;">← يجب مطابقته في حقل "اسم المستلم" بالإيصال</span>
                </label>
                <input type="text" name="ShamCashAccountName" value="@((string)ViewBag.ShamCashAccountName)"
                       placeholder="مثال: محمود رضا حكيم "
                       style="width:100%;padding:9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.84rem;box-sizing:border-box;" />
            </div>
            <div>
                <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
                    الرقم التسلسلي للحساب
                    <span style="font-size:.74rem;color:#7c3aed;font-weight:500;margin-right:5px;">← يجب مطابقته في حقل "حساب المستلم" بالإيصال</span>
                </label>
                <input type="text" name="ShamCashAccountNumber" value="@((string)ViewBag.ShamCashAccountNumber)"
                       placeholder="مثال: 6ef7b9f0107fdfraea01ad693cf1eref"
                       style="width:100%;padding:9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.84rem;font-family:monospace;box-sizing:border-box;" />
            </div>
        </div>

        <!-- Row 2: QR upload -->
        <div>
            <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
                صورة الباركود (QR)
                @if (!string.IsNullOrEmpty((string)ViewBag.ShamCashQrCodeUrl))
                { <span style="font-size:.75rem;color:#10b981;font-weight:500;margin-right:6px;"><i class="fas fa-check-circle"></i> محفوظة</span> }
            </label>
            @if (!string.IsNullOrEmpty((string)ViewBag.ShamCashQrCodeUrl))
            {
                <div style="display:flex;align-items:center;gap:14px;margin-bottom:10px;padding:10px 14px;background:#f8fafc;border-radius:9px;border:1px solid #e2e8f0;">
                    <img src="@ViewBag.ShamCashQrCodeUrl" alt="شام كاش QR"
                         style="width:70px;height:70px;object-fit:contain;border:1px solid #e2e8f0;border-radius:8px;padding:3px;background:#fff;" />
                    <div>
                        <div style="font-size:.82rem;font-weight:600;color:#0f172a;margin-bottom:2px;">الصورة الحالية</div>
                        <div style="font-size:.75rem;color:#64748b;">ارفع صورة جديدة لاستبدالها</div>
                    </div>
                </div>
            }

            <!-- Upload zone with smart extraction hint -->
            <div style="position:relative;">
                <label for="ShamCashQrFile"
                       style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1.5px dashed #c7d2fe;border-radius:8px;background:#f8fafc;cursor:pointer;transition:.15s;"
                       id="shamQrLabel">
                    <i class="fas fa-qrcode" style="font-size:1.3rem;color:#7c3aed;flex-shrink:0;"></i>
                    <div>
                        <div style="font-size:.84rem;font-weight:600;color:#374151;" id="shamQrLabelText">اضغط لاختيار صورة الباركود</div>
                        <div style="font-size:.72rem;color:#94a3b8;margin-top:1px;">سيتم استخراج الاسم والرقم التسلسلي تلقائياً</div>
                    </div>
                </label>
                <input type="file" id="ShamCashQrFile" name="ShamCashQrFile" accept="image/*"
                       style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;"
                       onchange="analyzeShamQr(this)" />
            </div>

            <!-- Analysis status -->
            <div id="shamQrStatus" style="display:none;margin-top:10px;padding:10px 14px;border-radius:8px;background:#ede9fe;border:1px solid #c4b5fd;align-items:center;gap:10px;">
                <div id="shamQrSpinner" style="width:18px;height:18px;border:2.5px solid #c4b5fd;border-top-color:#7c3aed;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0;"></div>
                <span id="shamQrStatusText" style="font-size:.83rem;color:#5b21b6;font-weight:600;">جار تحليل الصورة...</span>
            </div>
            <div id="shamQrResult" style="display:none;margin-top:10px;padding:10px 14px;border-radius:8px;background:#d1fae5;border:1px solid #6ee7b7;font-size:.82rem;color:#065f46;">
                <i class="fas fa-magic" style="margin-left:4px;"></i>
                <strong>تم الاستخراج التلقائي:</strong>
                <span id="shamQrResultText"></span>
                <span style="font-size:.75rem;color:#047857;display:block;margin-top:3px;">راجع الحقول أعلاه وعدّل إذا لزم الأمر</span>
            </div>
            <div id="shamQrError" style="display:none;margin-top:8px;font-size:.78rem;color:#b91c1c;">
                <i class="fas fa-exclamation-triangle" style="margin-left:4px;"></i>
                <span id="shamQrErrorText"></span>
            </div>
        </div>
    </div>

<style>
@@keyframes spin { to { transform: rotate(360deg); } }
</style>
<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>

<script src="~/js/shamcash-analyzer.js" asp-append-version="true"></script>

    <!-- ── Binance ── -->
    <div style="background:#fff;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.07);border:1px solid #e2e8f0;padding:24px;margin-bottom:24px;">
        <h3 style="font-size:1rem;font-weight:700;color:#0f172a;margin:0 0 6px;display:flex;align-items:center;gap:10px;">
            <span style="background:#f59e0b;color:#fff;border-radius:8px;padding:4px 10px;font-size:.82rem;">Binance</span>
            إعدادات الدفع عبر Binance
        </h3>
        <p style="font-size:.82rem;color:#64748b;margin:0 0 18px;">أدخل عنوان المحفظة وصورة الباركود الخاصة بـ Binance Pay.</p>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;align-items:start;">
            <div>
                <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">عنوان المحفظة</label>
                <input type="text" name="BinanceWalletAddress" value="@((string)ViewBag.BinanceWalletAddress)"
                       placeholder="T... أو 0x..."
                       style="width:100%;padding:9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.82rem;font-family:monospace;box-sizing:border-box;" />
            </div>
            <div>
                <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">الشبكة (Network)</label>
                <select name="BinanceNetwork" style="width:100%;padding:9px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.84rem;box-sizing:border-box;">
                    @{
                        var curNet = (string)(ViewBag.BinanceNetwork ?? "TRC20");
                    }
                    @foreach (var net in new[] { "TRC20", "BEP20", "ERC20", "BNB" })
                    {
                        <option value="@net" selected="@(curNet == net)">@net</option>
                    }
                </select>
            </div>
            <div>
                <label style="font-size:.85rem;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
                    صورة الباركود
                    @if (!string.IsNullOrEmpty((string)ViewBag.BinanceQrCodeUrl))
                    { <span style="font-size:.75rem;color:#10b981;font-weight:500;margin-right:6px;"><i class="fas fa-check-circle"></i> محفوظة</span> }
                </label>
                @if (!string.IsNullOrEmpty((string)ViewBag.BinanceQrCodeUrl))
                {
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                        <img src="@ViewBag.BinanceQrCodeUrl" alt="Binance QR"
                             style="width:64px;height:64px;object-fit:contain;border:1px solid #e2e8f0;border-radius:8px;padding:3px;background:#fff;" />
                        <span style="font-size:.75rem;color:#64748b;">الصورة الحالية — ارفع صورة جديدة للاستبدال</span>
                    </div>
                }
                <input type="file" name="BinanceQrFile" accept="image/*"
                       style="width:100%;padding:7px 10px;border:1.5px dashed #fde68a;border-radius:8px;font-size:.83rem;background:#fffbeb;box-sizing:border-box;cursor:pointer;" />
                <p style="font-size:.72rem;color:#94a3b8;margin:4px 0 0;">PNG, JPG, WEBP — يُنصح بصورة مربعة (500×500)</p>
            </div>
        </div>
    </div>

    <button type="submit"
            style="padding:10px 28px;background:#4f46e5;color:#fff;border:none;border-radius:9px;font-size:.9rem;font-weight:700;cursor:pointer;">
        <i class="fas fa-save"></i> حفظ جميع الإعدادات
    </button>
</form>

</main>
</div>


