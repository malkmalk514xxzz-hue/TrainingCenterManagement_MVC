@{
    ViewData["Title"] = "Edit Settings";
}

<h2>Edit Settings</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<form method="post" asp-controller="Settings" asp-action="Edit">
    <div class="mb-3">
        <label for="JwtKey" class="form-label">JWT Key (min 32 bytes)</label>
        <textarea class="form-control" id="JwtKey" name="JwtKey" rows="3">@((string)ViewBag.JwtKey)</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
