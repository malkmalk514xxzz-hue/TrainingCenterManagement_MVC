@using TrainingCenterManagement_MVC.Models.Enums
@model TrainingCenterManagement_MVC.DTOs.ExamAttemptDto
@{
    ViewData["Title"] = Model.ExamName;
    Layout = null; // Full-screen exam — no shared layout
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.ExamName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { background:#f0f4ff;font-family:'Segoe UI',Tahoma,sans-serif;margin:0; }

        /* ── Top Bar ── */
        .exam-topbar { position:fixed;top:0;left:0;right:0;z-index:1000;background:#fff;border-bottom:2px solid #e8ecef;padding:0 20px;height:58px;display:flex;align-items:center;justify-content:space-between;gap:12px; }
        .timer-badge { background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff;border-radius:12px;padding:6px 16px;font-size:1.05rem;font-weight:800;font-variant-numeric:tabular-nums;min-width:100px;text-align:center; }
        .timer-badge.warning  { background:linear-gradient(135deg,#f59e0b,#d97706); }
        .timer-badge.critical { background:linear-gradient(135deg,#ef4444,#dc2626);animation:blink .8s step-end infinite; }
        @@keyframes blink { 50% { opacity:.6; } }

        /* ── Layout ── */
        .exam-body    { display:flex;min-height:100vh;padding-top:58px; }
        .q-sidebar    { width:220px;flex-shrink:0;background:#fff;border-left:1.5px solid #e8ecef;padding:16px;overflow-y:auto;position:sticky;top:58px;height:calc(100vh - 58px); }
        .q-main       { flex:1;padding:24px 20px;max-width:820px;margin:0 auto; }

        /* ── Sidebar Nav ── */
        .q-nav-grid   { display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin-top:8px; }
        .q-nav-btn    { width:100%;aspect-ratio:1;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;font-size:.8rem;font-weight:600;color:#374151;display:flex;align-items:center;justify-content:center;transition:all .15s; }
        .q-nav-btn.active   { border-color:#4f46e5;background:#4f46e5;color:#fff; }
        .q-nav-btn.answered { border-color:#10b981;background:#d1fae5;color:#065f46; }
        .q-nav-btn.active.answered { background:#10b981;color:#fff; }

        /* ── Question Card ── */
        .q-card { background:#fff;border-radius:16px;border:1.5px solid #e8ecef;padding:28px;margin-bottom:16px;display:none; }
        .q-card.active { display:block; }
        .q-number { width:36px;height:36px;border-radius:50%;background:#eef2ff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;color:#4f46e5;flex-shrink:0; }
        .q-type-badge { font-size:.72rem;padding:3px 10px;border-radius:10px; }

        /* ── MC Options ── */
        .mc-option { border:2px solid #e5e7eb;border-radius:12px;padding:12px 16px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:12px;margin-bottom:8px; }
        .mc-option:hover { border-color:#4f46e5;background:#f5f3ff; }
        .mc-option.selected { border-color:#4f46e5;background:#eef2ff; }
        .mc-radio { width:20px;height:20px;border-radius:50%;border:2px solid #d1d5db;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s; }
        .mc-option.selected .mc-radio { border-color:#4f46e5;background:#4f46e5; }
        .mc-option.selected .mc-radio::after { content:'';width:8px;height:8px;border-radius:50%;background:#fff; }

        /* ── TF Options ── */
        .tf-option { border:2px solid #e5e7eb;border-radius:12px;padding:16px 20px;cursor:pointer;transition:all .15s;text-align:center;flex:1; }
        .tf-option:hover { border-color:#4f46e5; }
        .tf-option.selected-true  { border-color:#10b981;background:#d1fae5; }
        .tf-option.selected-false { border-color:#ef4444;background:#fee2e2; }

        /* ── Save indicator ── */
        .save-dot { width:8px;height:8px;border-radius:50%;background:#9ca3af;transition:background .3s; }
        .save-dot.saving  { background:#f59e0b;animation:pulse-dot .6s ease-in-out infinite; }
        .save-dot.saved   { background:#10b981; }
        .save-dot.error   { background:#ef4444; }
        @@keyframes pulse-dot { 0%,100% { opacity:1; } 50% { opacity:.4; } }

        @@media (max-width:768px) {
            .q-sidebar { display:none; }
        }
    </style>
</head>
<body>

<!-- Top Bar -->
<div class="exam-topbar">
    <div class="d-flex align-items-center gap-3">
        <div style="font-weight:700;color:#1e293b;font-size:.95rem">@Model.ExamName</div>
        <span style="font-size:.78rem;color:#6b7280">محاولة @Model.AttemptNumber</span>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2">
            <div class="save-dot" id="saveDot"></div>
            <span id="saveLabel" style="font-size:.75rem;color:#6b7280">جاهز</span>
        </div>
        <div class="timer-badge" id="timerBadge">
            <i class="fas fa-clock me-1"></i>
            <span id="timerDisplay">--:--</span>
        </div>
        <button class="btn btn-sm text-white fw-semibold" id="submitBtn"
                style="background:#10b981;border-radius:10px;padding:6px 16px"
                data-bs-toggle="modal" data-bs-target="#submitModal">
            <i class="fas fa-paper-plane me-1"></i>إرسال
        </button>
    </div>
</div>

<!-- Body -->
<div class="exam-body">

    <!-- Sidebar Navigation -->
    <aside class="q-sidebar">
        <div style="font-size:.72rem;font-weight:700;color:#6b7280;text-transform:uppercase;margin-bottom:8px">الأسئلة</div>
        <div class="q-nav-grid" id="qNavGrid">
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var q = Model.Questions[i];
                bool hasAnswer = !string.IsNullOrWhiteSpace(q.SavedAnswer);
                <button class="q-nav-btn @(i == 0 ? "active" : "") @(hasAnswer ? "answered" : "")"
                        data-idx="@i" onclick="goToQuestion(@i)">@(i + 1)</button>
            }
        </div>
        <div class="mt-3 pt-3" style="border-top:1px solid #f1f5f9">
            <div class="d-flex align-items-center gap-2 mb-1">
                <div style="width:12px;height:12px;border-radius:3px;background:#d1fae5;border:1.5px solid #10b981"></div>
                <span style="font-size:.72rem;color:#6b7280">تمت الإجابة</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div style="width:12px;height:12px;border-radius:3px;background:#fff;border:1.5px solid #e5e7eb"></div>
                <span style="font-size:.72rem;color:#6b7280">لم يُجَب بعد</span>
            </div>
        </div>
        <div class="mt-3 pt-3" style="border-top:1px solid #f1f5f9">
            <div style="font-size:.72rem;color:#6b7280">مُجاب عليها</div>
            <div class="fw-bold" style="color:#1e293b;font-size:1rem">
                <span id="answeredCount">@Model.Questions.Count(q => !string.IsNullOrWhiteSpace(q.SavedAnswer))</span>
                <span style="color:#6b7280;font-weight:400"> / @Model.Questions.Count</span>
            </div>
        </div>
    </aside>

    <!-- Questions Main Area -->
    <main class="q-main">

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];
            string typeLabel = q.QuestionType switch {
                QuestionType.MultipleChoice => "اختيار متعدد",
                QuestionType.TrueFalse      => "صح / خطأ",
                QuestionType.ShortAnswer    => "إجابة قصيرة",
                _                            => "مقالي"
            };
            string typeColor = q.QuestionType switch {
                QuestionType.MultipleChoice => "background:#dbeafe;color:#1d4ed8",
                QuestionType.TrueFalse      => "background:#dcfce7;color:#16a34a",
                QuestionType.ShortAnswer    => "background:#fef9c3;color:#a16207",
                _                            => "background:#fce7f3;color:#be185d"
            };

            <div class="q-card @(i == 0 ? "active" : "")" id="qCard_@i"
                 data-qid="@q.QuestionId" data-idx="@i">

                <!-- Header -->
                <div class="d-flex align-items-start gap-3 mb-4">
                    <div class="q-number">@(i + 1)</div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="q-type-badge" style="@typeColor">@typeLabel</span>
                            <span style="font-size:.78rem;color:#6b7280">
                                <i class="fas fa-star me-1" style="color:#f59e0b"></i>@q.Points نقطة
                            </span>
                        </div>
                        <p class="fw-semibold mb-0" style="color:#1e293b;font-size:1rem;line-height:1.6">@q.QuestionText</p>
                    </div>
                </div>

                <!-- Answer Input based on type -->
                @if (q.QuestionType == QuestionType.MultipleChoice)
                {
                    <div class="mc-options" data-qid="@q.QuestionId">
                        @for (int o = 0; o < q.Options.Count; o++)
                        {
                            bool isSaved = q.SavedAnswer == q.Options[o];
                            <div class="mc-option @(isSaved ? "selected" : "")"
                                 data-val="@q.Options[o]" onclick="selectMC(this)">
                                <div class="mc-radio">@if (isSaved){ <span></span> }</div>
                                <span style="font-size:.92rem;color:#374151">@q.Options[o]</span>
                            </div>
                        }
                    </div>
                }
                else if (q.QuestionType == QuestionType.TrueFalse)
                {
                    bool savedTrue  = q.SavedAnswer == "True";
                    bool savedFalse = q.SavedAnswer == "False";
                    <div class="d-flex gap-3 tf-group" data-qid="@q.QuestionId">
                        <div class="tf-option @(savedTrue ? "selected-true" : "")" data-val="True" onclick="selectTF(this)">
                            <i class="fas fa-check mb-2" style="font-size:1.4rem;color:#10b981;display:block"></i>
                            <div class="fw-bold" style="color:#065f46">صحيح</div>
                        </div>
                        <div class="tf-option @(savedFalse ? "selected-false" : "")" data-val="False" onclick="selectTF(this)">
                            <i class="fas fa-times mb-2" style="font-size:1.4rem;color:#ef4444;display:block"></i>
                            <div class="fw-bold" style="color:#991b1b">خاطئ</div>
                        </div>
                    </div>
                }
                else if (q.QuestionType == QuestionType.ShortAnswer)
                {
                    <input type="text" class="form-control sa-input"
                           style="border-radius:12px;border:1.5px solid #e5e7eb;padding:12px 16px;font-size:.95rem"
                           placeholder="اكتب إجابتك هنا..."
                           data-qid="@q.QuestionId"
                           value="@(q.SavedAnswer ?? "")"
                           oninput="scheduleAutoSave(this.closest('.q-card'))" />
                }
                else
                {
                    <textarea class="form-control essay-input"
                              style="border-radius:12px;border:1.5px solid #e5e7eb;padding:12px 16px;font-size:.92rem;min-height:140px;resize:vertical"
                              placeholder="اكتب إجابتك التفصيلية هنا..."
                              data-qid="@q.QuestionId"
                              oninput="scheduleAutoSave(this.closest('.q-card'))">@(q.SavedAnswer ?? "")</textarea>
                }

                <!-- Navigation -->
                <div class="d-flex justify-content-between mt-4 pt-3" style="border-top:1px solid #f1f5f9">
                    <button class="btn btn-outline-secondary" style="border-radius:10px" onclick="goToQuestion(@(i - 1))"
                            @(i == 0 ? "disabled" : "")>
                        <i class="fas fa-chevron-right me-1"></i>السابق
                    </button>
                    @if (i < Model.Questions.Count - 1)
                    {
                        <button class="btn text-white" style="background:#4f46e5;border-radius:10px"
                                onclick="goToQuestion(@(i + 1))">
                            التالي <i class="fas fa-chevron-left ms-1"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn text-white fw-semibold" style="background:#10b981;border-radius:10px"
                                data-bs-toggle="modal" data-bs-target="#submitModal">
                            <i class="fas fa-paper-plane me-1"></i>إرسال الامتحان
                        </button>
                    }
                </div>
            </div>
        }

    </main>
</div>

<!-- Submit Modal -->
<div class="modal fade" id="submitModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none">
            <div class="modal-body p-4 text-center">
                <div style="width:64px;height:64px;background:#d1fae5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                    <i class="fas fa-paper-plane" style="font-size:1.4rem;color:#10b981"></i>
                </div>
                <h5 class="fw-bold mb-2" style="color:#1e293b">إرسال الامتحان</h5>
                <p class="text-muted mb-1" style="font-size:.9rem">
                    أجبت على <span class="fw-bold" id="modalAnsweredCount">0</span> من <strong>@Model.Questions.Count</strong> سؤال.
                </p>
                <p class="text-muted mb-3" style="font-size:.85rem">لن تتمكن من التعديل بعد الإرسال.</p>
                <form id="submitForm" asp-controller="ExamAttempt" asp-action="Submit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AttemptId" value="@Model.AttemptId" />
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" class="btn btn-outline-secondary px-4" style="border-radius:10px"
                                data-bs-dismiss="modal">العودة</button>
                        <button type="submit" class="btn text-white fw-semibold px-4"
                                style="background:#10b981;border-radius:10px">
                            تأكيد الإرسال
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Tab Switch Warning -->
<div id="cheatWarning" style="display:none;position:fixed;top:70px;left:50%;transform:translateX(-50%);z-index:2000;background:#fef2f2;border:1.5px solid #ef4444;border-radius:12px;padding:12px 20px;font-size:.85rem;color:#991b1b;text-align:center">
    <i class="fas fa-eye-slash me-2"></i>تحذير: مغادرة نافذة الامتحان تُسجَّل كمخالفة!
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
const ATTEMPT_ID  = '@Model.AttemptId';
const SECONDS_LEFT = @Model.SecondsRemaining;
const SAVE_URL    = '/ExamAttempt/SaveAnswer';
const TAB_URL     = '/ExamAttempt/RecordTabSwitch';
const TOKEN       = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
let allowUnload = false;

// ── Timer ──
let secondsLeft = SECONDS_LEFT;
const timerEl   = document.getElementById('timerDisplay');
const timerBadge = document.getElementById('timerBadge');

function updateTimer() {
    if (secondsLeft <= 0) { document.getElementById('submitForm').submit(); return; }
    const m = Math.floor(secondsLeft / 60);
    const s = secondsLeft % 60;
    timerEl.textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');

    if (secondsLeft <= 300) timerBadge.classList.add('warning');
    if (secondsLeft <= 60)  { timerBadge.classList.remove('warning'); timerBadge.classList.add('critical'); }
    secondsLeft--;
}
setInterval(updateTimer, 1000);
updateTimer();

// ── Question Navigation ──
let currentIdx = 0;

function goToQuestion(idx) {
    if (idx < 0 || idx >= @Model.Questions.Count) return;
    document.querySelectorAll('.q-card').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.q-nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('qCard_' + idx).classList.add('active');
    document.querySelector('.q-nav-btn[data-idx="' + idx + '"]').classList.add('active');
    currentIdx = idx;
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Answer State ──
const answers = {};

// Pre-populate from server-saved answers
@foreach (var q in Model.Questions)
{
    if (!string.IsNullOrWhiteSpace(q.SavedAnswer))
    {
        <text>answers['@q.QuestionId'] = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(q.SavedAnswer));</text>
    }
}

function updateAnsweredCount() {
    const count = Object.keys(answers).filter(k => answers[k] && answers[k].trim()).length;
    document.getElementById('answeredCount').textContent = count;
    document.getElementById('modalAnsweredCount').textContent = count;
}
updateAnsweredCount();

function markNavAnswered(qid) {
    const card = document.querySelector('.q-card[data-qid="' + qid + '"]');
    if (!card) return;
    const idx = parseInt(card.dataset.idx);
    const btn = document.querySelector('.q-nav-btn[data-idx="' + idx + '"]');
    if (btn) btn.classList.add('answered');
    updateAnsweredCount();
}

// ── MC Select ──
function selectMC(optEl) {
    const container = optEl.closest('.mc-options');
    const qid = container.dataset.qid;
    container.querySelectorAll('.mc-option').forEach(o => o.classList.remove('selected'));
    optEl.classList.add('selected');
    const val = optEl.dataset.val;
    answers[qid] = val;
    markNavAnswered(qid);
    saveAnswer(qid, val);
}

// ── TF Select ──
function selectTF(optEl) {
    const container = optEl.closest('.tf-group');
    const qid = container.dataset.qid;
    container.querySelectorAll('.tf-option').forEach(o => {
        o.classList.remove('selected-true', 'selected-false');
    });
    const val = optEl.dataset.val;
    optEl.classList.add(val === 'True' ? 'selected-true' : 'selected-false');
    answers[qid] = val;
    markNavAnswered(qid);
    saveAnswer(qid, val);
}

// ── Auto-Save Debounce (for text inputs) ──
let saveTimers = {};

function scheduleAutoSave(cardEl) {
    const inp = cardEl.querySelector('input[data-qid], textarea[data-qid]');
    if (!inp) return;
    const qid = inp.dataset.qid;
    const val = inp.value;
    if (saveTimers[qid]) clearTimeout(saveTimers[qid]);
    saveTimers[qid] = setTimeout(() => {
        answers[qid] = val;
        if (val.trim()) markNavAnswered(qid);
        else {
            const idx = parseInt(cardEl.dataset.idx);
            const btn = document.querySelector('.q-nav-btn[data-idx="' + idx + '"]');
            if (btn) btn.classList.remove('answered');
            updateAnsweredCount();
        }
        saveAnswer(qid, val);
    }, 800);
}

// ── AJAX Save ──
function setSaveStatus(status) {
    const dot   = document.getElementById('saveDot');
    const label = document.getElementById('saveLabel');
    dot.className = 'save-dot ' + status;
    label.textContent = status === 'saving' ? 'يحفظ...' : status === 'saved' ? 'محفوظ ✓' : 'خطأ في الحفظ';
}

async function saveAnswer(qid, val) {
    setSaveStatus('saving');
    try {
        const res = await fetch(SAVE_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify({ attemptId: ATTEMPT_ID, questionId: qid, answerText: val || null })
        });
        setSaveStatus(res.ok ? 'saved' : 'error');
    } catch {
        setSaveStatus('error');
    }
}

// ── Anti-Cheat: Tab Switch ──
let tabWarnTimer;

document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
        // Record on server
        fetch(TAB_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify({ attemptId: ATTEMPT_ID })
        });
        // Show warning
        const warn = document.getElementById('cheatWarning');
        warn.style.display = 'block';
        if (tabWarnTimer) clearTimeout(tabWarnTimer);
        tabWarnTimer = setTimeout(() => { warn.style.display = 'none'; }, 4000);
    }
});

// ── Prevent accidental leave ──
window.addEventListener('beforeunload', e => {
    if (allowUnload) return;
    e.preventDefault();
    e.returnValue = '';
});

// Allow submit form to leave without warning
document.getElementById('submitForm').addEventListener('submit', () => {
    allowUnload = true;
});

// Update modal count on open
document.getElementById('submitModal').addEventListener('show.bs.modal', updateAnsweredCount);
</script>
</body>
</html>
