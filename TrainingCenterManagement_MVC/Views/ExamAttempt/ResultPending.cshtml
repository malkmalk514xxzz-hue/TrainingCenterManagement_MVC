@{
    ViewData["Title"] = "قيد المراجعة";
}
<style>
    .pending-card { border-radius:20px;border:1.5px solid #e8ecef;background:#fff;max-width:540px;margin:0 auto;text-align:center; }
    .step-item    { display:flex;align-items:flex-start;gap:12px;text-align:right; }
    .step-num     { width:28px;height:28px;border-radius:50%;background:#eef2ff;color:#4f46e5;font-weight:700;font-size:.82rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px; }
</style>

<div class="dashboard-wrapper">
    @await Html.PartialAsync("_TraineeSidebar")
    <main class="dashboard-main">
        <div class="container-fluid px-4 py-4" style="max-width:600px">

            <div class="pending-card p-4 p-md-5 mt-3">

                <!-- Animated Icon -->
                <div style="width:80px;height:80px;background:linear-gradient(135deg,#fef3c7,#fde68a);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 0 0 12px rgba(245,158,11,.1)">
                    <i class="fas fa-hourglass-half" style="font-size:2rem;color:#d97706"></i>
                </div>

                <h4 class="fw-bold mb-2" style="color:#1e293b">نتيجتك قيد المراجعة</h4>
                <p class="text-muted mb-4" style="font-size:.9rem;line-height:1.6">
                    إجاباتك وصلت بنجاح! يحتوي الامتحان على أسئلة مقالية تحتاج مراجعة يدوية من المدرب قبل إعلان نتيجتك النهائية.
                </p>

                <div style="background:#fffbeb;border-radius:12px;padding:16px 20px;border:1.5px solid #fde68a;margin-bottom:28px;text-align:right">
                    <div class="fw-semibold mb-3" style="color:#92400e;font-size:.85rem">
                        <i class="fas fa-list-check me-2"></i>ما الذي يحدث الآن؟
                    </div>
                    <div class="step-item mb-2">
                        <div class="step-num">1</div>
                        <span style="font-size:.85rem;color:#374151">تم تصحيح الأسئلة التلقائية (اختيار متعدد، صح/خطأ، إجابة قصيرة) فوراً.</span>
                    </div>
                    <div class="step-item mb-2">
                        <div class="step-num">2</div>
                        <span style="font-size:.85rem;color:#374151">المدرب يراجع إجاباتك على الأسئلة المقالية ويضع درجاتها.</span>
                    </div>
                    <div class="step-item">
                        <div class="step-num">3</div>
                        <span style="font-size:.85rem;color:#374151">بعد اكتمال المراجعة ستظهر نتيجتك كاملةً في صفحة امتحاناتي.</span>
                    </div>
                </div>

                <a asp-controller="Exams" asp-action="MyExams"
                   class="btn w-100 text-white fw-semibold" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);border-radius:12px;padding:12px">
                    <i class="fas fa-graduation-cap me-2"></i>العودة لامتحاناتي
                </a>
            </div>

        </div>
    </main>
</div>
