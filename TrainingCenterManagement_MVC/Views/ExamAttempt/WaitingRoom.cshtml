@model TrainingCenterManagement_MVC.Models.Exam
@{
    ViewData["Title"] = "قاعة الانتظار";
    var deadline = Model.StartDateTime;
}
<style>
    .waiting-card { border-radius:20px;border:1.5px solid #e8ecef;background:#fff;max-width:560px;margin:0 auto;text-align:center; }
    .countdown-box { background:linear-gradient(135deg,#f0f4ff,#e9d5ff);border-radius:14px;padding:24px; }
    .digit-block   { background:#fff;border-radius:12px;padding:10px 14px;box-shadow:0 2px 8px rgba(0,0,0,.08); }
    .digit-val     { font-size:2.2rem;font-weight:800;color:#4f46e5;line-height:1; }
    .digit-lbl     { font-size:.7rem;color:#6b7280;margin-top:4px; }
    .pulse-ring    { width:80px;height:80px;border-radius:50%;border:3px solid #4f46e5;position:absolute;animation:ring 2s ease-out infinite; }
    .exam-icon     { width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#4f46e5,#7c3aed);display:flex;align-items:center;justify-content:center;margin:0 auto;position:relative;z-index:1; }
</style>

<div class="dashboard-wrapper">
    @await Html.PartialAsync("_TraineeSidebar")
    <main class="dashboard-main">
        <div class="container-fluid px-4 py-4" style="max-width:620px">

            <div class="d-flex align-items-center gap-3 mb-4">
                <a asp-controller="Exams" asp-action="MyExams" class="btn btn-sm btn-outline-secondary" style="border-radius:10px">
                    <i class="fas fa-arrow-right"></i>
                </a>
                <h2 class="fw-bold mb-0" style="color:#1e293b">قاعة الانتظار</h2>
            </div>

            <div class="waiting-card p-4 p-md-5">
                <!-- Animated Icon -->
                <div style="position:relative;width:80px;height:80px;margin:0 auto 24px">
                    <div class="pulse-ring"></div>
                    <div class="exam-icon">
                        <i class="fas fa-graduation-cap" style="font-size:1.8rem;color:#fff"></i>
                    </div>
                </div>

                <h4 class="fw-bold mb-1" style="color:#1e293b">@Model.ExamName</h4>
                <p class="text-muted mb-4" style="font-size:.9rem">الامتحان لم يبدأ بعد — تبقّى:</p>

                <!-- Countdown -->
                <div class="countdown-box mb-4">
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <div class="digit-block">
                            <div class="digit-val" id="cd-days">--</div>
                            <div class="digit-lbl">يوم</div>
                        </div>
                        <div class="digit-block">
                            <div class="digit-val" id="cd-hours">--</div>
                            <div class="digit-lbl">ساعة</div>
                        </div>
                        <div class="digit-block">
                            <div class="digit-val" id="cd-mins">--</div>
                            <div class="digit-lbl">دقيقة</div>
                        </div>
                        <div class="digit-block">
                            <div class="digit-val" id="cd-secs">--</div>
                            <div class="digit-lbl">ثانية</div>
                        </div>
                    </div>
                </div>

                <!-- Exam Info -->
                <div class="row g-3 mb-4 text-start">
                    <div class="col-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:12px">
                            <div style="font-size:.72rem;color:#9ca3af">موعد البدء</div>
                            <div class="fw-semibold" style="color:#1e293b;font-size:.88rem">
                                @Model.StartDateTime.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:12px">
                            <div style="font-size:.72rem;color:#9ca3af">المدة</div>
                            <div class="fw-semibold" style="color:#1e293b;font-size:.88rem">@Model.DurationMinutes دقيقة</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:12px">
                            <div style="font-size:.72rem;color:#9ca3af">عدد الأسئلة</div>
                            <div class="fw-semibold" style="color:#1e293b;font-size:.88rem">@(Model.ExamQuestions?.Count ?? 0) سؤال</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:12px">
                            <div style="font-size:.72rem;color:#9ca3af">درجة النجاح</div>
                            <div class="fw-semibold" style="color:#1e293b;font-size:.88rem">@Model.PassingScore%</div>
                        </div>
                    </div>
                </div>

                <p class="text-muted" style="font-size:.82rem">
                    <i class="fas fa-info-circle me-1"></i>
                    ستُحوَّل تلقائياً لصفحة الامتحان فور انطلاقه.
                </p>
            </div>
        </div>
    </main>
</div>

<style>
@@keyframes ring { 0% { transform:scale(1);opacity:.8; } 100% { transform:scale(1.6);opacity:0; } }
</style>

<script>
const deadline = new Date("@deadline.ToString("o")");

function updateCountdown() {
    const diff = deadline - Date.now();
    if (diff <= 0) { location.href = '@Url.Action("Start", "ExamAttempt", new { examId = Model.ExamId })'; return; }
    const days  = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins  = Math.floor((diff % 3600000) / 60000);
    const secs  = Math.floor((diff % 60000) / 1000);
    document.getElementById('cd-days').textContent  = String(days).padStart(2, '0');
    document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
    document.getElementById('cd-mins').textContent  = String(mins).padStart(2, '0');
    document.getElementById('cd-secs').textContent  = String(secs).padStart(2, '0');
}
setInterval(updateCountdown, 1000);
updateCountdown();
</script>
