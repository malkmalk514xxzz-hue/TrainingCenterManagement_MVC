@model IEnumerable<TrainingCenterManagement_MVC.Models.Presence>

@{
    ViewData["Title"] = "تقارير الحضور";
    int    page       = ViewBag.CurrentPage  ?? 1;
    int    totalPages = ViewBag.TotalPages   ?? 1;
    int    totalCount = ViewBag.TotalCount   ?? 0;
    int    present    = ViewBag.TotalPresent ?? 0;
    int    absent     = ViewBag.TotalAbsent  ?? 0;
    string search     = ViewBag.Search       ?? "";
    string sortBy     = ViewBag.SortBy       ?? "date";
    string sortDir    = ViewBag.SortDir      ?? "desc";
    int    pageSize   = ViewBag.PageSize     ?? 10;
    string status     = ViewBag.Status       ?? "all";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:#1d4ed8;--primary-light:#3b82f6;--primary-pale:#eff6ff;--primary-dark:#1e3a8a;
        --success:#10b981;--warning:#f59e0b;--danger:#ef4444;
        --body-bg:#f1f5f9;--card-bg:#fff;--text-1:#0f172a;--text-2:#475569;--text-3:#94a3b8;
        --border:#e2e8f0;--shadow-sm:0 1px 3px rgba(0,0,0,.08);--shadow-md:0 4px 16px rgba(0,0,0,.10);
        --radius:16px;--radius-sm:10px;--tr:.2s ease;
    }
    * { box-sizing:border-box; }
    .ar-page { background:var(--body-bg); min-height:100vh; padding:36px 32px; direction:rtl; font-family:'Segoe UI','Cairo',sans-serif; }
    .ar-breadcrumb { display:flex; align-items:center; gap:7px; font-size:.82rem; color:var(--text-3); margin-bottom:22px; }
    .ar-breadcrumb a { color:var(--primary); text-decoration:none; }
    .ar-breadcrumb a:hover { text-decoration:underline; }
    .ar-kpi-row { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-bottom:24px; }
    @@media(max-width:700px){ .ar-kpi-row{ grid-template-columns:1fr; } }
    .ar-kpi { background:var(--card-bg); border-radius:var(--radius); padding:20px; display:flex; align-items:center; gap:16px; box-shadow:var(--shadow-sm); border:1px solid var(--border); transition:var(--tr); }
    .ar-kpi:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); }
    .ar-kpi-icon { width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
    .ar-kpi-val { font-size:1.7rem; font-weight:800; color:var(--text-1); line-height:1; margin-bottom:3px; }
    .ar-kpi-lbl { font-size:.8rem; color:var(--text-2); font-weight:500; }
    .ar-card { background:var(--card-bg); border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid var(--border); overflow:hidden; }
    .ar-toolbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding:18px 24px; border-bottom:1px solid var(--border); }
    .ar-toolbar-left { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .ar-toolbar-right { display:flex; align-items:center; gap:10px; }
    .ar-search-wrap { position:relative; width:240px; }
    .ar-search-wrap .si { position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--text-3); font-size:.9rem; pointer-events:none; }
    .ar-search-wrap input { width:100%; padding:9px 36px 9px 36px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:.9rem; font-family:inherit; outline:none; background:#fafcff; transition:border-color var(--tr),box-shadow var(--tr); }
    .ar-search-wrap input:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(29,78,216,.10); background:#fff; }
    .ar-search-clear { position:absolute; left:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-3); cursor:pointer; font-size:.8rem; display:none; padding:2px; }
    /* Status filter tabs */
    .ar-filter-tabs { display:flex; gap:6px; }
    .ar-ftab { display:inline-flex; align-items:center; gap:6px; padding:7px 14px; border-radius:20px; font-size:.82rem; font-weight:600; border:1.5px solid var(--border); background:var(--card-bg); color:var(--text-2); cursor:pointer; transition:var(--tr); text-decoration:none; }
    .ar-ftab:hover { border-color:var(--primary); color:var(--primary); }
    .ar-ftab.active-all     { background:var(--primary-pale); border-color:var(--primary); color:var(--primary); }
    .ar-ftab.active-present { background:#d1fae5; border-color:#6ee7b7; color:#065f46; }
    .ar-ftab.active-absent  { background:#fee2e2; border-color:#fca5a5; color:#991b1b; }
    .ar-psize { display:flex; align-items:center; gap:6px; font-size:.85rem; color:var(--text-2); }
    .ar-psize select { padding:7px 10px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:.85rem; outline:none; }
    .ar-pdf-btn { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-sm); background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; font-size:.85rem; font-weight:600; text-decoration:none; transition:var(--tr); }
    .ar-pdf-btn:hover { background:#fecaca; color:#991b1b; }
    #ar-container { padding:0 24px 24px; }
    .ar-loader { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px; gap:14px; color:var(--text-3); }
    .ar-spinner { width:36px; height:36px; border:3px solid var(--border); border-top-color:var(--primary); border-radius:50%; animation:ar-spin .7s linear infinite; }
    @@keyframes ar-spin { to{ transform:rotate(360deg); } }
    .ar-table { width:100%; border-collapse:separate; border-spacing:0; font-size:.9rem; }
    .ar-table thead th { padding:11px 14px; font-weight:700; font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; color:var(--text-2); border-bottom:2px solid var(--border); white-space:nowrap; }
    .ar-table thead th.sortable { cursor:pointer; }
    .ar-table thead th.sortable:hover { color:var(--primary); }
    .ar-table thead th .sort-icon { margin-right:4px; font-size:.72rem; opacity:.4; }
    .ar-table thead th .sort-icon.active { opacity:1; color:var(--primary); }
    .ar-table tbody tr:hover td { background:#f8fbff; }
    .ar-table tbody td { padding:13px 14px; border-bottom:1px solid var(--border); vertical-align:middle; color:var(--text-1); }
    .ar-table tbody tr:last-child td { border-bottom:none; }
    .ar-avatar { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--primary-light)); color:#fff; font-size:.85rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; margin-left:8px; }
    .ar-trainee-cell { display:flex; align-items:center; }
    .ar-badge-present { background:#d1fae5; color:#065f46; border-radius:20px; padding:4px 12px; font-size:.8rem; font-weight:600; display:inline-flex; align-items:center; gap:5px; }
    .ar-badge-absent  { background:#fee2e2; color:#991b1b; border-radius:20px; padding:4px 12px; font-size:.8rem; font-weight:600; display:inline-flex; align-items:center; gap:5px; }
    .ar-empty { text-align:center; padding:60px 20px; color:var(--text-3); }
    .ar-empty i { font-size:2.5rem; display:block; margin-bottom:12px; }
    .ar-pag-wrap { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding-top:18px; }
    .ar-pag-info { font-size:.82rem; color:var(--text-3); }
    .ar-pag { list-style:none; display:flex; gap:4px; margin:0; padding:0; }
    .ar-pag li a, .ar-pag li span { display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; font-size:.88rem; border:1px solid var(--border); color:var(--text-1); text-decoration:none; background:var(--card-bg); transition:var(--tr); }
    .ar-pag li a:hover { background:var(--primary); color:#fff; border-color:var(--primary); }
    .ar-pag li.active a { background:var(--primary); color:#fff; border-color:var(--primary); font-weight:700; }
    .ar-pag li.disabled a { opacity:.4; pointer-events:none; }
    .ar-pag li.ellipsis span { border:none; background:none; }
    .ar-results { padding:14px 0 8px; font-size:.85rem; color:var(--text-3); }
</style>

<div class="ar-page">

    <nav class="ar-breadcrumb">
        <a href="/Dashboard/ReceptionistDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <span>تقارير الحضور</span>
    </nav>

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;gap:16px;">
            <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;box-shadow:0 4px 14px rgba(29,78,216,.30);">
                <i class="fas fa-clipboard-check"></i>
            </div>
            <div>
                <h1 style="font-size:1.5rem;font-weight:800;color:var(--text-1);margin:0 0 3px;">تقارير الحضور</h1>
                <p style="font-size:.85rem;color:var(--text-2);margin:0;">متابعة حضور وغياب المتدربين في المحاضرات</p>
            </div>
        </div>
        <a asp-action="AttendanceReportPdf" asp-controller="Receptionists" class="ar-pdf-btn">
            <i class="fas fa-file-pdf"></i> تصدير PDF
        </a>
    </div>

    <!-- KPI Cards -->
    <div class="ar-kpi-row">
        <div class="ar-kpi">
            <div class="ar-kpi-icon" style="background:var(--primary-pale);color:var(--primary);"><i class="fas fa-list-check"></i></div>
            <div>
                <div class="ar-kpi-val">@totalCount</div>
                <div class="ar-kpi-lbl">إجمالي السجلات</div>
            </div>
        </div>
        <div class="ar-kpi">
            <div class="ar-kpi-icon" style="background:#d1fae5;color:#059669;"><i class="fas fa-user-check"></i></div>
            <div>
                <div class="ar-kpi-val">@present</div>
                <div class="ar-kpi-lbl">حاضر</div>
            </div>
        </div>
        <div class="ar-kpi">
            <div class="ar-kpi-icon" style="background:#fee2e2;color:#dc2626;"><i class="fas fa-user-times"></i></div>
            <div>
                <div class="ar-kpi-val">@absent</div>
                <div class="ar-kpi-lbl">غائب</div>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="ar-card">
        <div class="ar-toolbar">
            <div class="ar-toolbar-left">
                <!-- Search -->
                <div class="ar-search-wrap">
                    <i class="fas fa-search si"></i>
                    <input type="text" id="arSearch" placeholder="بحث بالاسم أو المحاضرة…" value="@search" autocomplete="off" />
                    <button class="ar-search-clear" id="arClear"><i class="fas fa-times"></i></button>
                </div>
                <!-- Status filter -->
                <div class="ar-filter-tabs">
                    <a href="#" class="ar-ftab @(status=="all"?"active-all":"")" data-status="all">
                        <i class="fas fa-list"></i> الكل
                    </a>
                    <a href="#" class="ar-ftab @(status=="present"?"active-present":"")" data-status="present">
                        <i class="fas fa-check"></i> حاضر
                    </a>
                    <a href="#" class="ar-ftab @(status=="absent"?"active-absent":"")" data-status="absent">
                        <i class="fas fa-times"></i> غائب
                    </a>
                </div>
            </div>
            <div class="ar-toolbar-right">
                <div class="ar-psize">
                    <span>عرض</span>
                    <select id="arPageSize">
                        @foreach (var s in new[] { 5, 10, 20, 50 })
                        {
                            if (pageSize == s)
                            {
                                <option value="@s" selected="selected">@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                    <span>لكل صفحة</span>
                </div>
            </div>
        </div>

        <div id="ar-container">
            @await Html.PartialAsync("_AttendanceReportsTablePartial", Model)
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    let arSort = '@sortBy', arDir = '@sortDir', arStatus = '@status', arTimer = null;

    function loadAttendance(page = 1) {
        const search   = $('#arSearch').val().trim();
        const pageSize = $('#arPageSize').val();
        $('#ar-container').html('<div class="ar-loader"><div class="ar-spinner"></div><span>جارٍ التحميل…</span></div>');
        $.ajax({
            url: '/Receptionists/AttendanceReports',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            data: { page, pageSize, search, sortBy: arSort, sortDir: arDir, status: arStatus },
            success: html => $('#ar-container').html(html),
            error: () => $('#ar-container').html('<div class="ar-empty"><i class="fas fa-exclamation-circle"></i><p>حدث خطأ أثناء التحميل</p></div>')
        });
    }

    $(document).on('click', '.ar-pag-link', function(e) {
        e.preventDefault();
        const p = parseInt($(this).data('page'));
        if (!isNaN(p) && p >= 1) loadAttendance(p);
    });

    $(document).on('click', '.ar-sort-col', function() {
        const s = $(this).data('sort');
        arDir = (arSort === s && arDir === 'asc') ? 'desc' : 'asc';
        arSort = s;
        loadAttendance(1);
    });

    $('.ar-ftab').on('click', function(e) {
        e.preventDefault();
        arStatus = $(this).data('status');
        $('.ar-ftab').removeClass('active-all active-present active-absent');
        const cls = arStatus === 'all' ? 'active-all' : arStatus === 'present' ? 'active-present' : 'active-absent';
        $(this).addClass(cls);
        loadAttendance(1);
    });

    $('#arSearch').on('input', function() {
        clearTimeout(arTimer);
        $(this).next('.ar-search-clear').css('display', this.value ? 'block' : 'none');
        arTimer = setTimeout(() => loadAttendance(1), 300);
    });

    $('#arClear').on('click', function() {
        $('#arSearch').val('').trigger('input');
    });

    $('#arPageSize').on('change', () => loadAttendance(1));

    if ('@search') { $('#arClear').show(); }
</script>
