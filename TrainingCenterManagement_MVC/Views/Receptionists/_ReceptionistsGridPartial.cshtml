@model IEnumerable<TrainingCenterManagement_MVC.Models.Receptionist>
@using TrainingCenterManagement_MVC.Models

@{
    int  currentPage = ViewBag.CurrentPage ?? 1;
    int  totalPages  = ViewBag.TotalPages  ?? 1;
    int  filterCount = ViewBag.FilterCount ?? 0;
    int  pageSize    = ViewBag.PageSize    ?? 10;
    var  list        = Model.ToList();

    string AvatarUrl(ApplicationUser u) {
        if (!string.IsNullOrEmpty(u?.ProfilePictureUrl)) return u.ProfilePictureUrl;
        var name = Uri.EscapeDataString(u?.FullName ?? "R");
        var bg   = (u?.Gender == Gender.Female) ? "ec4899" : "1d4ed8";
        return $"https://ui-avatars.com/api/?name={name}&background={bg}&color=ffffff&bold=true&size=128&rounded=true";
    }
}

@if (!list.Any())
{
    <div class="rc-empty">
        <i class="fas fa-headset"></i>
        <h3>لا يوجد موظفون مطابقون</h3>
        <p>جرّب تغيير كلمة البحث أو الفلتر</p>
    </div>
}
else
{
    <!-- Results bar — بارزة -->
    <div class="rc-results-bar">
        <span class="rc-results-text">
            عرض
            <strong class="rc-results-hl">@(((currentPage - 1) * pageSize) + 1)</strong>
            —
            <strong class="rc-results-hl">@(Math.Min(currentPage * pageSize, filterCount))</strong>
            من
            <strong class="rc-results-hl">@filterCount</strong>
            موظف
        </span>
    </div>

    <!-- Grid -->
    <div class="rc-grid" id="rc-grid">
        @foreach (var item in list)
        {
            var av       = AvatarUrl(item.User);
            var isFemale = item.User?.Gender == Gender.Female;

            <div class="rc-card" data-name="@(item.User?.FullName?.ToLower())">
                <span class="rc-role-badge"><i class="fas fa-headset"></i> استقبال</span>
                <div class="rc-avatar-wrap">
                    <img src="@av" class="rc-avatar" alt="@item.User?.FullName"
                         onerror="this.src='https://ui-avatars.com/api/?name=R&background=94a3b8&color=fff&rounded=true'" />
                    <span class="rc-gender-dot @(isFemale ? "rc-gf" : "rc-gm")">
                        <i class="fas @(isFemale ? "fa-venus" : "fa-mars")"></i>
                    </span>
                </div>
                @if (item.User != null)
                {
                    <div class="rc-name">@item.User.FullName</div>
                    <div class="rc-email">@item.User.Email</div>
                }
                else
                {
                    <div class="rc-name" style="color:var(--text-3);">لا يوجد مستخدم مرتبط</div>
                }
                <div class="rc-actions">
                    <a asp-action="Details" asp-route-id="@item.ReceptionistId" class="rc-btn rc-btn-info">
                        <i class="fas fa-eye"></i> تفاصيل
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.ReceptionistId" class="rc-btn rc-btn-del">
                        <i class="fas fa-trash-alt"></i>
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="rc-pag-wrap">
            <div class="rc-pag-info">
                صفحة <strong>@currentPage</strong> من <strong>@totalPages</strong>
            </div>
            <ul class="rc-pag">

                <li class="@(currentPage <= 1 ? "disabled" : "")">
                    <a href="#" class="rc-pag-link" data-page="@(currentPage - 1)" title="السابق">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>

                @{
                    int startP = Math.Max(1, currentPage - 3);
                    int endP   = Math.Min(totalPages, startP + 6);
                    if (endP - startP < 6) startP = Math.Max(1, endP - 6);
                }
                @if (startP > 1)
                {
                    <li><a href="#" class="rc-pag-link" data-page="1">1</a></li>
                    if (startP > 2) { <li class="ellipsis"><span>…</span></li> }
                }
                @for (int pi = startP; pi <= endP; pi++)
                {
                    <li class="@(pi == currentPage ? "active" : "")">
                        <a href="#" class="rc-pag-link" data-page="@pi">@pi</a>
                    </li>
                }
                @if (endP < totalPages)
                {
                    if (endP < totalPages - 1) { <li class="ellipsis"><span>…</span></li> }
                    <li><a href="#" class="rc-pag-link" data-page="@totalPages">@totalPages</a></li>
                }

                <li class="@(currentPage >= totalPages ? "disabled" : "")">
                    <a href="#" class="rc-pag-link" data-page="@(currentPage + 1)" title="التالي">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>

            </ul>
        </div>
    }
}
