@model TrainingCenterManagement_MVC.Models.Receptionist

@{
    ViewData["Title"] = "Delete Receptionist";
}

<div class="container mt-5">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white text-center">
            <h3>⚠️ Confirm Deletion</h3>
        </div>
        <div class="card-body">
            <h5 class="card-title text-center mb-4">Are you sure you want to delete this receptionist?</h5>

            <dl class="row">
                <dt class="col-sm-4">User</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.User.FullName)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ReceptionistId" />
                <div class="text-center">
                    <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
