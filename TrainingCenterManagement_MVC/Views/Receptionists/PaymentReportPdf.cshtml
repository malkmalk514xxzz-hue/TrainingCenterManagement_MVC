@model IEnumerable<TrainingCenterManagement_MVC.Models.Payment>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Payment Report</title>
    <style>
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            font-size: 14px;
            color: #333;
            margin: 20px;
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #004085;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            box-shadow: 0 0 5px rgba(0,0,0,0.1);
        }

        th, td {
            border: 1px solid #ddd;
            padding: 10px 12px;
            text-align: center;
        }

        th {
            background-color: #007bff;
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        tbody tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tfoot tr {
            background-color: #e9ecef;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <h2>Payment Report</h2>
    <table>
        <thead>
            <tr>
                <th>Course</th>
                <th>Trainee</th>
                <th>Amount Paid</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Course?.CourseName</td>
                    <td>@item.Trainee?.User?.FullName</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="2">Total</td>
                <td>
                    @{
                        var totalPaid = Model.Sum(p => p.TotalAmount);
                    }
                    @totalPaid.ToString("C")
                </td>
                <td></td>
            </tr>
        </tfoot>
    </table>
</body>
</html>
