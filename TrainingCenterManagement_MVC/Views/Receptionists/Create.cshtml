@model TrainingCenterManagement_MVC.Models.Receptionist

@{
    ViewData["Title"] = "Create Receptionist";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4 text-center">🧾 Create Receptionist</h2>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-action="Create" class="shadow p-4 border rounded bg-light">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="UserId" class="form-label">Select User</label>
                    <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId"></select>
                </div>

                <div class="form-group text-center">
                    <input type="submit" value="Create" class="btn btn-primary w-50" />
                </div>
            </form>

            <div class="mt-3 text-center">
                <a asp-action="Index" class="btn btn-link">← Back to List</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
