@using TrainingCenterManagement_MVC.ViewModels
@model ReceptionistCreateViewModel

@{
    ViewData["Title"] = "إضافة موظف استقبال جديد";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:       #1d4ed8;
        --primary-light: #3b82f6;
        --primary-pale:  #eff6ff;
        --primary-dark:  #1e3a8a;
        --danger:        #ef4444;
        --body-bg:       #f1f5f9;
        --card-bg:       #ffffff;
        --text-1:        #0f172a;
        --text-2:        #475569;
        --text-3:        #94a3b8;
        --border:        #e2e8f0;
        --shadow-sm:     0 1px 3px rgba(0,0,0,.08);
        --shadow-md:     0 4px 16px rgba(0,0,0,.10);
        --radius:        16px;
        --radius-sm:     10px;
        --tr:            .2s ease;
    }

    * { box-sizing: border-box; }

    .rc-page {
        background: var(--body-bg);
        min-height: 100vh;
        padding: 36px 32px;
        direction: rtl;
        font-family: 'Segoe UI', 'Cairo', sans-serif;
    }

    /* ── Breadcrumb ── */
    .rc-breadcrumb {
        display: flex; align-items: center; gap: 7px;
        font-size: .82rem; color: var(--text-3); margin-bottom: 22px;
    }
    .rc-breadcrumb a { color: var(--primary); text-decoration: none; }
    .rc-breadcrumb a:hover { text-decoration: underline; }
    .rc-breadcrumb i { font-size: .65rem; }

    /* ── Page header ── */
    .rc-page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
        margin-bottom: 28px;
    }
    .rc-page-header-left { display: flex; align-items: center; gap: 16px; }
    .rc-page-icon {
        width: 52px; height: 52px; border-radius: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #fff;
        box-shadow: 0 4px 14px rgba(29,78,216,.30);
    }
    .rc-page-header h1 { font-size: 1.5rem; font-weight: 800; color: var(--text-1); margin: 0 0 3px; }
    .rc-page-header p  { font-size: .85rem; color: var(--text-2); margin: 0; }
    .rc-back-btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .rc-back-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── Layout ── */
    .rc-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 22px; align-items: start;
    }
    @@media (max-width: 860px) { .rc-layout { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .rc-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        overflow: hidden; transition: var(--tr);
    }
    .rc-card:hover { box-shadow: var(--shadow-md); }

    .rc-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 10px;
        background: linear-gradient(to left, #fafbff, var(--card-bg));
    }
    .rc-card-head-icon {
        width: 36px; height: 36px; border-radius: 9px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }
    .rc-card-head h3 { font-size: .97rem; font-weight: 700; color: var(--text-1); margin: 0; }
    .rc-card-head p  { font-size: .78rem; color: var(--text-3); margin: 2px 0 0; }
    .rc-card-body { padding: 24px; }

    /* ── Aside ── */
    .rc-aside {
        display: flex; flex-direction: column; align-items: center;
        padding: 30px 20px; text-align: center;
        background: linear-gradient(160deg, var(--primary-pale) 0%, #fff 60%);
    }
    .rc-aside-avatar {
        width: 86px; height: 86px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.9rem; color: #fff;
        border: 4px solid #fff;
        box-shadow: 0 6px 18px rgba(29,78,216,.22);
        margin-bottom: 14px;
    }
    .rc-aside-label { font-size: 1rem; font-weight: 700; color: var(--text-1); margin-bottom: 4px; }
    .rc-aside-sub {
        font-size: .8rem; color: var(--text-3);
        display: flex; align-items: center; gap: 5px; margin-bottom: 20px;
    }
    .rc-steps { width: 100%; }
    .rc-step {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 0; border-bottom: 1px solid var(--border);
        font-size: .82rem; color: var(--primary); font-weight: 600;
    }
    .rc-step:last-child { border-bottom: none; }
    .rc-step-dot {
        width: 26px; height: 26px; border-radius: 50%;
        background: var(--primary); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 700; flex-shrink: 0;
    }
    .rc-tip {
        margin-top: 20px; width: 100%;
        background: #fffbeb; border: 1px solid #fde68a;
        border-radius: var(--radius-sm); padding: 12px 14px;
        font-size: .78rem; color: #78350f; text-align: right;
        display: flex; align-items: flex-start; gap: 8px;
    }
    .rc-tip i { color: #d97706; flex-shrink: 0; margin-top: 1px; }

    /* ── Form ── */
    .rc-form-group { margin-bottom: 20px; }
    .rc-label {
        display: flex; align-items: center; gap: 7px;
        font-size: .85rem; font-weight: 600; color: var(--text-1); margin-bottom: 8px;
    }
    .rc-label i {
        width: 26px; height: 26px; border-radius: 7px;
        background: var(--primary-pale); color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; flex-shrink: 0;
    }
    .rc-required { color: var(--danger); margin-right: 2px; }
    .rc-input {
        width: 100%; padding: 11px 14px;
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        font-size: .9rem; font-family: inherit; color: var(--text-1);
        background: #fafcff; transition: border-color var(--tr), box-shadow var(--tr);
        outline: none;
    }
    .rc-input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(29,78,216,.10); background: #fff;
    }
    .rc-input::placeholder { color: var(--text-3); }
    .rc-field-error {
        font-size: .78rem; color: var(--danger);
        margin-top: 5px; display: none; align-items: center; gap: 4px;
    }
    .rc-field-error:not(:empty) { display: flex; }

    .rc-val-box {
        background: #fff0f0; border: 1px solid #fca5a5;
        border-radius: var(--radius-sm); padding: 14px 18px;
        margin-bottom: 20px; font-size: .87rem; color: #b91c1c;
        display: none; align-items: flex-start; gap: 10px;
    }
    .rc-val-box:not(:empty) { display: flex; }
    .rc-val-box i { margin-top: 1px; flex-shrink: 0; }

    /* ── Submit row ── */
    .rc-submit-row {
        display: flex; align-items: center;
        justify-content: flex-end; gap: 12px;
        padding-top: 6px; flex-wrap: wrap;
    }
    .rc-btn-save {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 28px; border-radius: var(--radius-sm);
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff; border: none; font-size: .92rem; font-weight: 700;
        font-family: inherit; cursor: pointer;
        transition: var(--tr), transform .1s;
        box-shadow: 0 4px 14px rgba(29,78,216,.28);
    }
    .rc-btn-save:hover {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(29,78,216,.35);
    }
    .rc-btn-save:active { transform: translateY(0); }
    .rc-btn-cancel {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 22px; border-radius: var(--radius-sm);
        border: 1.5px solid var(--border);
        background: var(--card-bg); color: var(--text-2);
        font-size: .875rem; font-weight: 600;
        text-decoration: none; transition: var(--tr);
    }
    .rc-btn-cancel:hover { border-color: var(--primary); color: var(--primary); }
</style>

<div class="rc-page">

    <!-- Breadcrumb -->
    <nav class="rc-breadcrumb">
        <a href="/Dashboard/AdminDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <a href="/Receptionists">موظفو الاستقبال</a>
        <i class="fas fa-chevron-left"></i>
        <span>إضافة موظف جديد</span>
    </nav>

    <!-- Page Header -->
    <div class="rc-page-header">
        <div class="rc-page-header-left">
            <div class="rc-page-icon"><i class="fas fa-headset"></i></div>
            <div>
                <h1>إضافة موظف استقبال جديد</h1>
                <p>أدخل بيانات الموظف لإضافته إلى المنصة</p>
            </div>
        </div>
        <a asp-action="Index" class="rc-back-btn">
            <i class="fas fa-arrow-right"></i> العودة للقائمة
        </a>
    </div>

    <!-- Layout -->
    <div class="rc-layout">

        <!-- Aside -->
        <div class="rc-card">
            <div class="rc-aside">
                <div class="rc-aside-avatar">
                    <i class="fas fa-headset"></i>
                </div>
                <div class="rc-aside-label">موظف استقبال جديد</div>
                <div class="rc-aside-sub">
                    <i class="fas fa-plus-circle" style="color:var(--primary);"></i>
                    سيُضاف للمنصة
                </div>
                <div class="rc-steps">
                    <div class="rc-step">
                        <div class="rc-step-dot">1</div>
                        الاسم الكامل
                    </div>
                    <div class="rc-step">
                        <div class="rc-step-dot">2</div>
                        البريد الإلكتروني
                    </div>
                </div>
                <div class="rc-tip">
                    <i class="fas fa-lightbulb"></i>
                    <span>سيتم استخدام البريد الإلكتروني لتسجيل الدخول. تأكد من صحته قبل الإضافة.</span>
                </div>
            </div>
        </div>

        <!-- Form Card -->
        <div class="rc-card">
            <div class="rc-card-head">
                <div class="rc-card-head-icon"><i class="fas fa-user-plus"></i></div>
                <div>
                    <h3>بيانات موظف الاستقبال</h3>
                    <p>الحقول المميزة بـ * مطلوبة</p>
                </div>
            </div>
            <div class="rc-card-body">

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="rc-val-box">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>

                    <!-- Full Name -->
                    <div class="rc-form-group">
                        <label asp-for="FullName" class="rc-label">
                            <i class="fas fa-user"></i>
                            الاسم الكامل <span class="rc-required">*</span>
                        </label>
                        <input asp-for="FullName" class="rc-input"
                               placeholder="أدخل الاسم الكامل" />
                        <span asp-validation-for="FullName" class="rc-field-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="rc-form-group">
                        <label asp-for="Email" class="rc-label">
                            <i class="fas fa-envelope"></i>
                            البريد الإلكتروني <span class="rc-required">*</span>
                        </label>
                        <input asp-for="Email" class="rc-input"
                               placeholder="example@domain.com" dir="ltr" />
                        <span asp-validation-for="Email" class="rc-field-error"></span>
                    </div>

                    <!-- ShamCash Account Code -->
                    <div class="rc-form-group">
                        <label asp-for="ShamCashAccountCode" class="rc-label">
                            <i class="fas fa-wallet"></i>
                            كود حساب الشام كاش <span class="rc-required">*</span>
                        </label>
                        <input asp-for="ShamCashAccountCode" class="rc-input"
                               maxlength="32"
                               placeholder="1906b1ad48773bc8785b9b2004d3ccc6" dir="ltr" />
                        <span asp-validation-for="ShamCashAccountCode" class="rc-field-error"></span>
                    </div>

                    <!-- Actions -->
                    <div class="rc-submit-row">
                        <a asp-action="Index" class="rc-btn-cancel">
                            <i class="fas fa-times"></i> إلغاء
                        </a>
                        <button type="submit" class="rc-btn-save">
                            <i class="fas fa-plus-circle"></i> إضافة الموظف
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
