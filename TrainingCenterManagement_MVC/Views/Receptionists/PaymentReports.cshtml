@model IEnumerable<TrainingCenterManagement_MVC.Models.Payment>

@{
    ViewData["Title"] = "تقارير المدفوعات";
    int    page       = ViewBag.CurrentPage ?? 1;
    int    totalPages = ViewBag.TotalPages  ?? 1;
    int    totalCount = ViewBag.TotalCount  ?? 0;
    decimal totalAmt  = ViewBag.TotalAmount ?? 0m;
    string search     = ViewBag.Search      ?? "";
    string sortBy     = ViewBag.SortBy      ?? "date";
    string sortDir    = ViewBag.SortDir     ?? "desc";
    int    pageSize   = ViewBag.PageSize    ?? 10;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --primary:#1d4ed8;--primary-light:#3b82f6;--primary-pale:#eff6ff;--primary-dark:#1e3a8a;
        --success:#10b981;--warning:#f59e0b;--danger:#ef4444;
        --body-bg:#f1f5f9;--card-bg:#fff;--text-1:#0f172a;--text-2:#475569;--text-3:#94a3b8;
        --border:#e2e8f0;--shadow-sm:0 1px 3px rgba(0,0,0,.08);--shadow-md:0 4px 16px rgba(0,0,0,.10);
        --shadow-lg:0 8px 32px rgba(0,0,0,.14);--radius:16px;--radius-sm:10px;--tr:.2s ease;
    }
    * { box-sizing:border-box; }
    .rp-page { background:var(--body-bg); min-height:100vh; padding:36px 32px; direction:rtl; font-family:'Segoe UI','Cairo',sans-serif; }
    .rp-breadcrumb { display:flex; align-items:center; gap:7px; font-size:.82rem; color:var(--text-3); margin-bottom:22px; }
    .rp-breadcrumb a { color:var(--primary); text-decoration:none; }
    .rp-breadcrumb a:hover { text-decoration:underline; }
    /* KPI cards */
    .rp-kpi-row { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-bottom:24px; }
    @@media(max-width:700px){ .rp-kpi-row{ grid-template-columns:1fr; } }
    .rp-kpi { background:var(--card-bg); border-radius:var(--radius); padding:20px; display:flex; align-items:center; gap:16px; box-shadow:var(--shadow-sm); border:1px solid var(--border); transition:var(--tr); }
    .rp-kpi:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); }
    .rp-kpi-icon { width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
    .rp-kpi-val { font-size:1.7rem; font-weight:800; color:var(--text-1); line-height:1; margin-bottom:3px; }
    .rp-kpi-lbl { font-size:.8rem; color:var(--text-2); font-weight:500; }
    /* Main card */
    .rp-card { background:var(--card-bg); border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid var(--border); overflow:hidden; }
    .rp-toolbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding:18px 24px; border-bottom:1px solid var(--border); }
    .rp-toolbar-left { display:flex; align-items:center; gap:10px; }
    .rp-toolbar-right { display:flex; align-items:center; gap:10px; }
    .rp-search-wrap { position:relative; width:260px; }
    .rp-search-wrap .si { position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--text-3); font-size:.9rem; pointer-events:none; }
    .rp-search-wrap input { width:100%; padding:9px 36px 9px 36px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:.9rem; font-family:inherit; outline:none; background:#fafcff; transition:border-color var(--tr),box-shadow var(--tr); }
    .rp-search-wrap input:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(29,78,216,.10); background:#fff; }
    .rp-search-clear { position:absolute; left:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-3); cursor:pointer; font-size:.8rem; display:none; padding:2px; }
    .rp-psize { display:flex; align-items:center; gap:6px; font-size:.85rem; color:var(--text-2); }
    .rp-psize select { padding:7px 10px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:.85rem; outline:none; }
    .rp-pdf-btn { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-sm); background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; font-size:.85rem; font-weight:600; text-decoration:none; transition:var(--tr); }
    .rp-pdf-btn:hover { background:#fecaca; color:#991b1b; }
    /* Table */
    #rp-container { padding:0 24px 24px; }
    .rp-loader { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px; gap:14px; color:var(--text-3); }
    .rp-spinner { width:36px; height:36px; border:3px solid var(--border); border-top-color:var(--primary); border-radius:50%; animation:rp-spin .7s linear infinite; }
    @@keyframes rp-spin { to{ transform:rotate(360deg); } }
    .rp-table { width:100%; border-collapse:separate; border-spacing:0; font-size:.9rem; }
    .rp-table thead th { padding:11px 14px; font-weight:700; font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; color:var(--text-2); border-bottom:2px solid var(--border); white-space:nowrap; user-select:none; }
    .rp-table thead th.sortable:hover { color:var(--primary); cursor:pointer; }
    .rp-table thead th .sort-icon { margin-right:4px; font-size:.72rem; opacity:.4; }
    .rp-table thead th .sort-icon.active { opacity:1; color:var(--primary); }
    .rp-table tbody tr:hover td { background:#f8fbff; }
    .rp-table tbody td { padding:13px 14px; border-bottom:1px solid var(--border); vertical-align:middle; color:var(--text-1); }
    .rp-table tbody tr:last-child td { border-bottom:none; }
    .rp-table tfoot td { padding:12px 14px; font-weight:700; color:var(--text-1); border-top:2px solid var(--border); background:#f8fbff; }
    /* Avatar */
    .rp-avatar { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--primary-light)); color:#fff; font-size:.85rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; margin-left:8px; }
    .rp-trainee-cell { display:flex; align-items:center; }
    /* Amount badge */
    .rp-amount { background:#d1fae5; color:#065f46; border-radius:20px; padding:3px 10px; font-size:.82rem; font-weight:700; }
    /* Date */
    .rp-date { color:var(--text-3); font-size:.82rem; }
    /* Status */
    .rp-status-active { background:#d1fae5; color:#065f46; border-radius:20px; padding:3px 10px; font-size:.78rem; font-weight:600; }
    .rp-status-deleted { background:#fee2e2; color:#991b1b; border-radius:20px; padding:3px 10px; font-size:.78rem; font-weight:600; }
    /* Empty state */
    .rp-empty { text-align:center; padding:60px 20px; color:var(--text-3); }
    .rp-empty i { font-size:2.5rem; display:block; margin-bottom:12px; }
    /* Pagination */
    .rp-pag-wrap { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding-top:18px; }
    .rp-pag-info { font-size:.82rem; color:var(--text-3); }
    .rp-pag { list-style:none; display:flex; gap:4px; margin:0; padding:0; }
    .rp-pag li a, .rp-pag li span { display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; font-size:.88rem; border:1px solid var(--border); color:var(--text-1); text-decoration:none; background:var(--card-bg); transition:var(--tr); }
    .rp-pag li a:hover { background:var(--primary); color:#fff; border-color:var(--primary); }
    .rp-pag li.active a { background:var(--primary); color:#fff; border-color:var(--primary); font-weight:700; }
    .rp-pag li.disabled a { opacity:.4; pointer-events:none; }
    .rp-pag li.ellipsis span { border:none; background:none; }
    /* Results summary */
    .rp-results { padding:14px 0 8px; font-size:.85rem; color:var(--text-3); }
</style>

<div class="rp-page">

    <!-- Breadcrumb -->
    <nav class="rp-breadcrumb">
        <a href="/Dashboard/ReceptionistDashboard"><i class="fas fa-home"></i> الرئيسية</a>
        <i class="fas fa-chevron-left"></i>
        <span>تقارير المدفوعات</span>
    </nav>

    <!-- Page header -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;gap:16px;">
            <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;box-shadow:0 4px 14px rgba(29,78,216,.30);">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div>
                <h1 style="font-size:1.5rem;font-weight:800;color:var(--text-1);margin:0 0 3px;">تقارير المدفوعات</h1>
                <p style="font-size:.85rem;color:var(--text-2);margin:0;">عرض وتتبع جميع الدفعات المالية المسجلة</p>
            </div>
        </div>
        <a asp-action="PaymentReportPdf" asp-controller="Receptionists" class="rp-pdf-btn">
            <i class="fas fa-file-pdf"></i> تصدير PDF
        </a>
    </div>

    <!-- KPI Cards -->
    <div class="rp-kpi-row">
        <div class="rp-kpi">
            <div class="rp-kpi-icon" style="background:#eff6ff;color:#1d4ed8;"><i class="fas fa-receipt"></i></div>
            <div>
                <div class="rp-kpi-val">@totalCount</div>
                <div class="rp-kpi-lbl">إجمالي الدفعات</div>
            </div>
        </div>
        <div class="rp-kpi">
            <div class="rp-kpi-icon" style="background:#d1fae5;color:#059669;"><i class="fas fa-coins"></i></div>
            <div>
                <div class="rp-kpi-val">@totalAmt.ToString("N0")</div>
                <div class="rp-kpi-lbl">إجمالي الإيرادات (ل.س)</div>
            </div>
        </div>
        <div class="rp-kpi">
            <div class="rp-kpi-icon" style="background:#fef3c7;color:#d97706;"><i class="fas fa-calculator"></i></div>
            <div>
                <div class="rp-kpi-val">@(totalCount > 0 ? (totalAmt / totalCount).ToString("N0") : "0")</div>
                <div class="rp-kpi-lbl">متوسط الدفعة (ل.س)</div>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="rp-card">
        <div class="rp-toolbar">
            <div class="rp-toolbar-left">
                <div class="rp-search-wrap">
                    <i class="fas fa-search si"></i>
                    <input type="text" id="rpSearch" placeholder="بحث بالاسم أو الدورة…" value="@search" autocomplete="off" />
                    <button class="rp-search-clear" id="rpClear"><i class="fas fa-times"></i></button>
                </div>
            </div>
            <div class="rp-toolbar-right">
                <div class="rp-psize">
                    <span>عرض</span>
                    <select id="rpPageSize">
                        @foreach (var s in new[] { 5, 10, 20, 50 })
                        {
                            if (pageSize == s)
                            {
                                <option value="@s" selected="selected">@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                    <span>لكل صفحة</span>
                </div>
            </div>
        </div>

        <div id="rp-container">
            @await Html.PartialAsync("_PaymentReportsTablePartial", Model)
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    let rpSort = '@sortBy', rpDir = '@sortDir', rpTimer = null;

    function loadPayments(page = 1) {
        const search   = $('#rpSearch').val().trim();
        const pageSize = $('#rpPageSize').val();
        $('#rp-container').html('<div class="rp-loader"><div class="rp-spinner"></div><span>جارٍ التحميل…</span></div>');
        $.ajax({
            url: '/Receptionists/PaymentReports',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            data: { page, pageSize, search, sortBy: rpSort, sortDir: rpDir },
            success: html => $('#rp-container').html(html),
            error: () => $('#rp-container').html('<div class="rp-empty"><i class="fas fa-exclamation-circle"></i><p>حدث خطأ أثناء التحميل</p></div>')
        });
    }

    $(document).on('click', '.rp-pag-link', function(e) {
        e.preventDefault();
        const p = parseInt($(this).data('page'));
        if (!isNaN(p) && p >= 1) loadPayments(p);
    });

    $(document).on('click', '.rp-sort-col', function() {
        const s = $(this).data('sort');
        rpDir = (rpSort === s && rpDir === 'asc') ? 'desc' : 'asc';
        rpSort = s;
        loadPayments(1);
    });

    $('#rpSearch').on('input', function() {
        clearTimeout(rpTimer);
        $(this).next('.rp-search-clear').css('display', this.value ? 'block' : 'none');
        rpTimer = setTimeout(() => loadPayments(1), 300);
    });

    $('#rpClear').on('click', function() {
        $('#rpSearch').val('').trigger('input');
    });

    $('#rpPageSize').on('change', () => loadPayments(1));

    // init
    if ('@search') { $('#rpClear').show(); }
</script>
