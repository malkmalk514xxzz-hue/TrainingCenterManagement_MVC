@model IEnumerable<TrainingCenterManagement_MVC.Models.Trainee>

@{
    ViewData["Title"] = "Contact Trainees";
}

<div class="container mt-4">
    <h2 class="text-center text-primary mb-4">📩 Contact Trainees</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark text-center">
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Birth Date</th>
                <th>Send Message</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                int index = 1;
                foreach (var trainee in Model)
                {
                    <tr>
                        <td class="text-center">@index</td>
                        <td>@trainee.User.FullName</td>
                        <td><a href="mailto:@trainee.User.Email">@trainee.User.Email</a></td>
                        <td>@trainee.BirthDate.ToShortDateString()</td>
                        <td>
                            <form asp-action="SendMessageToTrainee" asp-controller="Receptionists" method="post" class="d-flex flex-column flex-sm-row gap-2">
                                <input type="hidden" name="email" value="@trainee.User.Email" />
                                <input type="text" name="message" class="form-control" placeholder="Type message..." required />
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="bi bi-send"></i> Send
                                </button>
                            </form>
                        </td>
                    </tr>
                    index++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">No trainees available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
