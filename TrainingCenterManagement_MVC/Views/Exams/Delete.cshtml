@model TrainingCenterManagement_MVC.Models.Exam
@{
    ViewData["Title"] = "Delete Exam";
}

<div class="container mt-5">
    <div class="card shadow-lg border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill"></i> Confirm Delete
            </h4>
        </div>
        <div class="card-body">
            <p class="text-danger fw-bold">
                Are you sure you want to delete this exam? This action cannot be undone.
            </p>

            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ExamName)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ExamName)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ExamDate)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ExamDate)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsDeleted)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.IsDeleted)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Course)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Course.CourseName)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ExamId" />

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
