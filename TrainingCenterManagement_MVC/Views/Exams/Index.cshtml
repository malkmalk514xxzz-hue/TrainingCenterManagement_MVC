@model IEnumerable<TrainingCenterManagement_MVC.Models.Exam>
@{
    ViewData["Title"] = "Exams List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">
            <i class="bi bi-journal-check"></i> Exams List
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Exam
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-primary text-center">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.ExamName)</th>
                    <th>@Html.DisplayNameFor(model => model.ExamDate)</th>
                    <th>@Html.DisplayNameFor(model => model.IsDeleted)</th>
                    <th>@Html.DisplayNameFor(model => model.Course)</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.ExamName)</td>
                            <td>@item.ExamDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.IsDeleted)
                                {
                                    <span class="badge bg-danger">Deleted</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Course.CourseName)</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.ExamId" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.ExamId" class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ExamId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No exams available.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
