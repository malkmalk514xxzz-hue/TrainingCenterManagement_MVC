@model TrainingCenterManagement_MVC.Models.LiveSession
@{
    ViewData["Title"] = Model.Title;
    Layout = null;
    var displayName = (string)ViewBag.DisplayName;
    var isModerator = (bool)ViewBag.IsModerator;
    var isHost      = (bool)(ViewBag.IsHost ?? false);
    var endTimeUtc  = Model.DurationMinutes.HasValue
        ? Model.ScheduledAt.AddMinutes(Model.DurationMinutes.Value)
        : (DateTime?)null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@Model.Title — @Model.Course.CourseName</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; background: #0f0f1a; color: #fff; font-family: 'Segoe UI', Tahoma, sans-serif; }

        /* ── Top bar ── */
        .jt-topbar {
            display: flex; align-items: center; justify-content: space-between;
            height: 52px; padding: 0 20px;
            background: linear-gradient(90deg, #1e1b4b, #312e81);
            box-shadow: 0 2px 10px rgba(0,0,0,.4);
            z-index: 10; position: relative;
        }
        .jt-topbar-left  { display: flex; align-items: center; gap: 14px; }
        .jt-topbar-right { display: flex; align-items: center; gap: 10px; }
        .jt-logo   { font-size: 1rem; font-weight: 800; color: #a78bfa; display: flex; align-items: center; gap: 8px; }
        .jt-title  { font-size: .9rem; font-weight: 600; color: #c4b5fd; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 360px; }
        .jt-course-tag {
            background: rgba(124,58,237,.35); color: #ddd6fe;
            font-size: .75rem; font-weight: 700; padding: 3px 10px;
            border-radius: 20px; border: 1px solid #7c3aed;
        }
        .jt-live-dot {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .75rem; font-weight: 700; color: #f87171;
            background: rgba(239,68,68,.15); border: 1px solid #f87171;
            padding: 3px 10px; border-radius: 20px;
        }
        .jt-live-dot span {
            width: 8px; height: 8px; border-radius: 50%; background: #f87171;
            animation: blink 1.2s infinite;
        }
        @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

        /* Duration countdown badge */
        .jt-duration-badge {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: .75rem; font-weight: 700; color: #fbbf24;
            background: rgba(251,191,36,.12); border: 1px solid rgba(251,191,36,.4);
            padding: 3px 10px; border-radius: 20px;
        }
        .jt-duration-badge.ending {
            color: #f87171; background: rgba(239,68,68,.15); border-color: #f87171;
            animation: pulse-warn .8s infinite;
        }
        @@keyframes pulse-warn { 0%,100%{opacity:1} 50%{opacity:.5} }

        .jt-back-btn {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(255,255,255,.1); color: #e2e8f0;
            border: 1px solid rgba(255,255,255,.2); border-radius: 8px;
            padding: 6px 14px; font-size: .82rem; font-weight: 600;
            text-decoration: none; cursor: pointer; transition: background .2s;
        }
        .jt-back-btn:hover { background: rgba(255,255,255,.18); color: #fff; text-decoration: none; }

        /* ── Host badge ── */
        .jt-host-badge {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(245,158,11,.18); color: #fcd34d;
            border: 1px solid rgba(245,158,11,.5); border-radius: 20px;
            padding: 3px 10px; font-size: .75rem; font-weight: 700;
        }

        /* ── Main layout ── */
        .jt-body { display: flex; height: calc(100vh - 52px); }

        /* ── Jitsi iframe container ── */
        #jitsi-container { flex: 1; height: 100%; position: relative; }
        #jitsi-container iframe { width: 100%; height: 100%; border: none; }

        /* Loading overlay */
        #jitsi-loading {
            position: absolute; inset: 0;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: #0f0f1a; gap: 18px; z-index: 5;
        }
        .jt-spinner {
            width: 48px; height: 48px; border: 4px solid rgba(124,58,237,.3);
            border-top-color: #7c3aed; border-radius: 50%;
            animation: spin .9s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        #jitsi-loading p { color: #94a3b8; font-size: .9rem; }

        /* ── Side panel ── */
        .jt-panel {
            width: 300px; min-width: 300px; height: 100%;
            background: #1a1a2e; border-left: 1px solid rgba(255,255,255,.08);
            display: flex; flex-direction: column; overflow: hidden;
            transition: width .3s;
        }
        .jt-panel.collapsed { width: 0; min-width: 0; }

        .jt-panel-tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,.1); }
        .jt-panel-tab {
            flex: 1; padding: 12px 0; text-align: center; cursor: pointer;
            font-size: .78rem; font-weight: 600; color: #94a3b8;
            border: none; background: transparent; transition: color .2s;
        }
        .jt-panel-tab.active { color: #a78bfa; border-bottom: 2px solid #7c3aed; }

        .jt-panel-body { flex: 1; overflow-y: auto; padding: 16px; }
        .jt-panel-section { display: none; }
        .jt-panel-section.active { display: block; }

        /* Info tab */
        .jt-info-row { margin-bottom: 14px; }
        .jt-info-label { font-size: .72rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 3px; }
        .jt-info-val   { font-size: .88rem; color: #e2e8f0; font-weight: 600; }

        /* Duration bar */
        .jt-dur-bar-wrap {
            background: rgba(255,255,255,.06); border-radius: 8px;
            padding: 12px; margin-bottom: 14px;
        }
        .jt-dur-bar-label { font-size: .72rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 8px; }
        .jt-dur-progress { background: rgba(255,255,255,.1); border-radius: 4px; height: 6px; overflow: hidden; }
        .jt-dur-fill { height: 100%; background: #7c3aed; border-radius: 4px; transition: width 1s linear; }
        .jt-dur-time { font-size: .82rem; color: #a78bfa; font-weight: 700; margin-top: 6px; text-align: center; }

        /* Host panel */
        .jt-host-panel {
            background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.25);
            border-radius: 10px; padding: 12px; margin-bottom: 14px;
        }
        .jt-host-panel-title { font-size: .78rem; font-weight: 800; color: #fcd34d; margin-bottom: 8px; }
        .jt-host-tips { font-size: .78rem; color: #fde68a; line-height: 1.8; }

        /* Q&A tab */
        .jt-qa-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
        .jt-qa-item {
            background: rgba(255,255,255,.05); border-radius: 10px;
            padding: 10px 12px;
        }
        .jt-qa-question { font-size: .85rem; color: #e2e8f0; font-weight: 600; margin-bottom: 4px; }
        .jt-qa-meta     { font-size: .72rem; color: #64748b; }

        .jt-qa-form { display: flex; gap: 8px; margin-top: 8px; }
        .jt-qa-input {
            flex: 1; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.15);
            border-radius: 8px; padding: 8px 12px; color: #e2e8f0; font-size: .85rem;
            outline: none;
        }
        .jt-qa-input:focus { border-color: #7c3aed; }
        .jt-qa-send {
            background: #7c3aed; color: #fff; border: none; border-radius: 8px;
            padding: 8px 14px; cursor: pointer; font-size: .9rem; transition: opacity .2s;
        }
        .jt-qa-send:hover { opacity: .85; }

        /* Toggle panel btn */
        .jt-toggle-panel {
            position: fixed; bottom: 70px; left: 10px;
            background: #7c3aed; color: #fff; border: none;
            border-radius: 50%; width: 44px; height: 44px;
            cursor: pointer; font-size: 1rem;
            box-shadow: 0 4px 14px rgba(124,58,237,.5);
            z-index: 20; display: flex; align-items: center; justify-content: center;
            transition: opacity .2s;
        }
        .jt-toggle-panel:hover { opacity: .85; }

        /* End warning overlay */
        #endWarning {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.7); z-index: 100;
            align-items: center; justify-content: center;
        }
        #endWarning.show { display: flex; }
        .jt-warn-box {
            background: #1e1b4b; border: 1px solid #7c3aed; border-radius: 16px;
            padding: 32px 40px; text-align: center; max-width: 380px;
        }
        .jt-warn-box h3 { font-size: 1.2rem; color: #f87171; margin-bottom: 10px; }
        .jt-warn-box p  { color: #94a3b8; font-size: .9rem; margin-bottom: 20px; }
        .jt-warn-close {
            background: #7c3aed; color: #fff; border: none; border-radius: 8px;
            padding: 10px 24px; font-size: .9rem; font-weight: 700; cursor: pointer;
        }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }
    </style>
</head>
<body>

<!-- Top bar -->
<div class="jt-topbar">
    <div class="jt-topbar-left">
        <div class="jt-logo"><i class="fas fa-video"></i> TCM Live</div>
        <div class="jt-title">@Model.Title</div>
        <span class="jt-course-tag">@Model.Course.CourseName</span>
        @if (isHost)
        {
            <span class="jt-host-badge"><i class="fas fa-crown"></i> مضيف الجلسة</span>
        }
    </div>
    <div class="jt-topbar-right">
        @if (Model.DurationMinutes.HasValue)
        {
            <div class="jt-duration-badge" id="topbarTimer">
                <i class="fas fa-hourglass-half"></i>
                <span id="topbarTimerText">--:--</span>
            </div>
        }
        <div class="jt-live-dot"><span></span> LIVE</div>
        @if (User.IsInRole("Admin") || User.IsInRole("Trainer"))
        {
            <a href="@Url.Action("Index","LiveSessions")" class="jt-back-btn">
                <i class="fas fa-arrow-right"></i> لوحة الجلسات
            </a>
        }
        else
        {
            <a href="@Url.Action("TraineeDashboard","Dashboard")" class="jt-back-btn">
                <i class="fas fa-arrow-right"></i> لوحة التحكم
            </a>
        }
    </div>
</div>

<!-- Body -->
<div class="jt-body">

    <!-- Jitsi container -->
    <div id="jitsi-container">
        <div id="jitsi-loading">
            <div class="jt-spinner"></div>
            <p>جارٍ تحميل الجلسة المباشرة...</p>
        </div>
    </div>

    <!-- Side panel -->
    <div class="jt-panel" id="sidePanel">
        <div class="jt-panel-tabs">
            <button class="jt-panel-tab active" onclick="switchTab('info')">
                <i class="fas fa-info-circle"></i> معلومات
            </button>
            <button class="jt-panel-tab" onclick="switchTab('qa')" id="qaTabBtn">
                <i class="fas fa-question-circle"></i> الأسئلة
                <span id="qaCount" style="background:#7c3aed;color:#fff;border-radius:20px;padding:1px 7px;font-size:.7rem;margin-right:4px;display:none;">0</span>
            </button>
        </div>

        <div class="jt-panel-body">
            <!-- Info section -->
            <div class="jt-panel-section active" id="section-info">

                @if (isHost)
                {
                    <div class="jt-host-panel">
                        <div class="jt-host-panel-title"><i class="fas fa-crown"></i> أنت مضيف الجلسة</div>
                        <div class="jt-host-tips">
                            • انضم أولاً لتصبح المشرف تلقائياً<br/>
                            • افتح <strong>لوحة المشاركين</strong> في Jitsi<br/>
                            • انقر على اسم أي مشارك ثم<br/>
                            &nbsp;&nbsp;<strong>"منح صلاحية المشرف"</strong><br/>
                            • يمكنك كتم جميع المشاركين<br/>
                            • يمكنك إزالة أي مشارك
                        </div>
                    </div>
                }

                @if (Model.DurationMinutes.HasValue)
                {
                    <div class="jt-dur-bar-wrap" id="durationBarWrap">
                        <div class="jt-dur-bar-label"><i class="fas fa-hourglass-half"></i> مدة الجلسة</div>
                        <div class="jt-dur-progress">
                            <div class="jt-dur-fill" id="durFill" style="width:100%;"></div>
                        </div>
                        <div class="jt-dur-time" id="durTimeText">جارٍ الحساب...</div>
                    </div>
                }

                <div class="jt-info-row">
                    <div class="jt-info-label">الكورس</div>
                    <div class="jt-info-val">@Model.Course.CourseName</div>
                </div>
                <div class="jt-info-row">
                    <div class="jt-info-label">الجلسة</div>
                    <div class="jt-info-val">@Model.Title</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="jt-info-row">
                        <div class="jt-info-label">الوصف</div>
                        <div class="jt-info-val" style="font-weight:400;font-size:.83rem;color:#94a3b8;">@Model.Description</div>
                    </div>
                }
                <div class="jt-info-row">
                    <div class="jt-info-label">الموعد</div>
                    <div class="jt-info-val">@Model.ScheduledAt.ToLocalTime().ToString("yyyy/MM/dd — hh:mm tt")</div>
                </div>
                @if (Model.DurationMinutes.HasValue)
                {
                    <div class="jt-info-row">
                        <div class="jt-info-label">المدة المحددة</div>
                        <div class="jt-info-val">
                            @if (Model.DurationMinutes.Value >= 60)
                            {
                                var h = Model.DurationMinutes.Value / 60;
                                var m = Model.DurationMinutes.Value % 60;
                                @(h + " ساعة" + (m > 0 ? " و" + m + " دقيقة" : ""))
                            }
                            else
                            {
                                @(Model.DurationMinutes.Value + " دقيقة")
                            }
                        </div>
                    </div>
                }
                <div class="jt-info-row">
                    <div class="jt-info-label">المضيف</div>
                    <div class="jt-info-val">@(Model.CreatedBy?.FullName ?? "—")</div>
                </div>
                <div style="margin-top:20px;padding:12px;background:rgba(124,58,237,.1);border-radius:10px;font-size:.8rem;color:#c4b5fd;line-height:1.7;">
                    <i class="fas fa-lightbulb"></i> <strong>تلميحات:</strong><br/>
                    • اضغط <strong>مشاركة الشاشة</strong> من شريط الأدوات<br/>
                    • افتح <strong>الدردشة</strong> عبر أيقونة الرسائل<br/>
                    • ارفع يدك لطرح سؤال<br/>
                    • يمكنك كتابة سؤالك في تبويب <strong>الأسئلة</strong> هنا<br/>
                    • <strong>لا يلزم حساب جوجل</strong> للانضمام
                </div>
            </div>

            <!-- Q&A section -->
            <div class="jt-panel-section" id="section-qa">
                <div id="qaList" class="jt-qa-list">
                    <p style="color:#64748b;font-size:.83rem;text-align:center;padding:20px 0;">
                        لا توجد أسئلة بعد. كن أول من يسأل!
                    </p>
                </div>
                <div class="jt-qa-form">
                    <input class="jt-qa-input" id="qaInput" placeholder="اكتب سؤالك هنا..." maxlength="300" />
                    <button class="jt-qa-send" onclick="submitQuestion()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toggle panel button -->
<button class="jt-toggle-panel" onclick="togglePanel()" title="إخفاء/إظهار اللوحة">
    <i class="fas fa-sidebar" id="toggleIcon"></i>
</button>

<!-- End-of-session warning -->
<div id="endWarning">
    <div class="jt-warn-box">
        <h3><i class="fas fa-exclamation-triangle"></i> انتهت مدة الجلسة</h3>
        <p>لقد انتهى الوقت المحدد لهذه الجلسة. يمكنك الاستمرار أو مغادرة الغرفة.</p>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
            <button class="jt-warn-close" onclick="document.getElementById('endWarning').classList.remove('show')">
                الاستمرار
            </button>
            <button class="jt-warn-close" style="background:#ef4444;"
                    onclick="window.location.href='@(isModerator ? Url.Action("Index","LiveSessions") : Url.Action("TraineeDashboard","Dashboard"))'">
                مغادرة الجلسة
            </button>
        </div>
    </div>
</div>

<!-- ── All globals defined BEFORE any external script loads ── -->
<script>
    const roomName    = '@Model.JitsiRoomName';
    const userName    = '@Html.Raw(displayName.Replace("'", "\\'"))';
    const isMod       = @isModerator.ToString().ToLower();
    const isHost      = @isHost.ToString().ToLower();
    const endTimeISO  = @(endTimeUtc.HasValue ? $"'{endTimeUtc.Value:yyyy-MM-ddTHH:mm:ssZ}'" : "null");
    const durationMin = @(Model.DurationMinutes.HasValue ? Model.DurationMinutes.Value.ToString() : "null");

    function jitsiFallback() {
        document.getElementById('jitsi-loading')?.remove();
        const c = document.getElementById('jitsi-container');
        if (!c) return;
        c.innerHTML = `
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;
                        height:100%;gap:16px;padding:20px;text-align:center;">
                <i class="fas fa-exclamation-triangle" style="font-size:3rem;color:#f59e0b;"></i>
                <p style="color:#94a3b8;max-width:400px;font-size:.95rem;line-height:1.7;">
                    تعذّر تحميل خادم الجلسة.<br/>يمكنك الانضمام مباشرة عبر الرابط التالي:
                </p>
                <a href="https://meet.jit.si/${roomName}" target="_blank"
                   style="background:#7c3aed;color:#fff;padding:12px 24px;border-radius:10px;
                          font-weight:700;text-decoration:none;">
                    <i class="fas fa-external-link-alt"></i> فتح الجلسة في نافذة جديدة
                </a>
            </div>`;
    }

    function loadFallbackJitsi() { jitsiFallback(); }
</script>

<!-- Jitsi External API — meet.jit.si (supports Google login + anonymous) -->
<script src="https://meet.jit.si/external_api.js"
        onload="initJitsi('meet.jit.si')"
        onerror="loadFallbackJitsi()"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    var _jitsiInited = false;

    function initJitsi(resolvedDomain) {
        if (_jitsiInited) return;
        _jitsiInited = true;
        if (typeof JitsiMeetExternalAPI === 'undefined') { jitsiFallback(); return; }

        const domain = resolvedDomain || 'meet.jit.si';
        const hostDisplayName = isHost ? ('👑 ' + userName) : userName;

        const options = {
            roomName: roomName,
            parentNode: document.getElementById('jitsi-container'),
            lang: 'ar',
            configOverwrite: {
                startWithAudioMuted:       false,
                startWithVideoMuted:       false,
                enableNoisyMicDetection:   true,
                disableModeratorIndicator: false,
                prejoinPageEnabled:        true,
                enableLobbyChat:           true,
                toolbarButtons: isMod ? [
                    'microphone','camera','closedcaptions','desktop','fullscreen',
                    'fodeviceselection','hangup','chat','recording','raisehand',
                    'videoquality','filmstrip','participants-pane','stats','shortcuts',
                    'tileview','select-background','help','mute-everyone','security','invite'
                ] : [
                    'microphone','camera','desktop','fullscreen','fodeviceselection',
                    'hangup','chat','raisehand','videoquality','filmstrip',
                    'participants-pane','tileview','select-background','help'
                ],
            },
            interfaceConfigOverwrite: {
                SHOW_JITSI_WATERMARK:     false,
                SHOW_WATERMARK_FOR_GUESTS: false,
                SHOW_BRAND_WATERMARK:     false,
                APP_NAME:                 'TCM Live',
                NATIVE_APP_NAME:          'TCM Live',
                PROVIDER_NAME:            'TCM',
            },
            userInfo: { displayName: hostDisplayName }
        };

        const api = new JitsiMeetExternalAPI(domain, options);

        api.addEventListener('videoConferenceJoined', () => {
            document.getElementById('jitsi-loading')?.remove();
            api.executeCommand('displayName', hostDisplayName);
        });

        api.addEventListener('readyToClose', () => {
            window.location.href = isMod
                ? '@Url.Action("Index","LiveSessions")'
                : '@Url.Action("TraineeDashboard","Dashboard")';
        });
    }

    // ── Duration countdown ───────────────────────────────────────────
    if (endTimeISO) {
        const endMs        = new Date(endTimeISO).getTime();
        const totalMs      = durationMin * 60 * 1000;
        let warnedFive     = false;
        let warnedEnd      = false;

        function updateCountdown() {
            const now       = Date.now();
            const remaining = endMs - now;

            if (remaining <= 0) {
                // Time's up
                document.getElementById('topbarTimerText') && (document.getElementById('topbarTimerText').textContent = '00:00');
                document.getElementById('durFill')         && (document.getElementById('durFill').style.width = '0%');
                document.getElementById('durTimeText')     && (document.getElementById('durTimeText').textContent = 'انتهى الوقت');
                if (!warnedEnd) {
                    warnedEnd = true;
                    document.getElementById('endWarning').classList.add('show');
                }
                return;
            }

            const totalSec  = Math.floor(remaining / 1000);
            const hrs       = Math.floor(totalSec / 3600);
            const mins      = Math.floor((totalSec % 3600) / 60);
            const secs      = totalSec % 60;
            const label     = hrs > 0
                ? `${hrs}:${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`
                : `${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;

            // Topbar badge
            const topText = document.getElementById('topbarTimerText');
            const topBadge = document.getElementById('topbarTimer');
            if (topText) topText.textContent = label;
            if (topBadge) {
                if (remaining < 5 * 60 * 1000) topBadge.classList.add('ending');
                else topBadge.classList.remove('ending');
            }

            // Progress bar
            const pct = Math.max(0, (remaining / totalMs) * 100);
            const fill = document.getElementById('durFill');
            if (fill) {
                fill.style.width = pct + '%';
                fill.style.background = remaining < 5 * 60 * 1000 ? '#ef4444' : '#7c3aed';
            }
            const durText = document.getElementById('durTimeText');
            if (durText) durText.textContent = 'متبقي: ' + label;

            // 5-minute warning
            if (remaining < 5 * 60 * 1000 && !warnedFive) {
                warnedFive = true;
                // Simple toast-style alert
                const toast = document.createElement('div');
                toast.style.cssText = 'position:fixed;top:60px;right:50%;transform:translateX(50%);z-index:200;' +
                    'background:#b45309;color:#fff;padding:10px 22px;border-radius:10px;font-weight:700;font-size:.9rem;';
                toast.textContent = '⚠️ تبقّى 5 دقائق على نهاية الجلسة';
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 8000);
            }

            setTimeout(updateCountdown, 1000);
        }

        updateCountdown();
    }

    // ── Panel & Tabs ────────────────────────────────────────────────
    function switchTab(tab) {
        document.querySelectorAll('.jt-panel-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.jt-panel-section').forEach(s => s.classList.remove('active'));
        event.currentTarget.classList.add('active');
        document.getElementById('section-' + tab).classList.add('active');
    }

    let panelOpen = true;
    function togglePanel() {
        panelOpen = !panelOpen;
        document.getElementById('sidePanel').classList.toggle('collapsed', !panelOpen);
        document.getElementById('toggleIcon').className = panelOpen ? 'fas fa-sidebar' : 'fas fa-columns';
    }

    // ── Q&A (SignalR) ────────────────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/chatHub')
        .withAutomaticReconnect()
        .build();

    connection.on('ReceiveQAQuestion', (sender, question, time) => {
        addQuestion(sender, question, time);
    });

    connection.start().then(() => {
        connection.invoke('JoinQAGroup', '@Model.LiveSessionId.ToString()').catch(console.error);
    }).catch(console.error);

    function addQuestion(sender, text, time) {
        const list = document.getElementById('qaList');
        const placeholder = list.querySelector('p');
        if (placeholder) placeholder.remove();

        const item = document.createElement('div');
        item.className = 'jt-qa-item';
        item.innerHTML = `
            <div class="jt-qa-question">${escHtml(text)}</div>
            <div class="jt-qa-meta"><i class="fas fa-user"></i> ${escHtml(sender)} • ${time}</div>`;
        list.prepend(item);

        const badge = document.getElementById('qaCount');
        badge.style.display = 'inline';
        badge.textContent = parseInt(badge.textContent || '0') + 1;
    }

    async function submitQuestion() {
        const input = document.getElementById('qaInput');
        const text  = input.value.trim();
        if (!text) return;
        input.value = '';
        const now = new Date().toLocaleTimeString('ar-SA');
        try {
            await connection.invoke('SendQAQuestion', '@Model.LiveSessionId.ToString()', userName, text);
        } catch {
            addQuestion(userName, text, now);
        }
    }

    document.getElementById('qaInput').addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitQuestion(); }
    });

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
</script>
</body>
</html>
