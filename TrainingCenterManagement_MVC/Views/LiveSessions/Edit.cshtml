@model TrainingCenterManagement_MVC.Models.LiveSession
@{
    ViewData["Title"] = "تعديل الجلسة";
}

<div class="dashboard-wrapper">
    @if (User.IsInRole("Admin"))
    {
        @await Html.PartialAsync("_AdminSidebar")
    }
    else
    {
        @await Html.PartialAsync("_TrainerSidebar")
    }

    <main class="dashboard-main" style="padding:32px 28px;">
        <div style="max-width:640px;">
            <div style="margin-bottom:24px;">
                <a asp-action="Index" style="color:#7c3aed;font-size:.9rem;text-decoration:none;">
                    <i class="fas fa-arrow-right"></i> العودة للجلسات
                </a>
                <h2 style="font-size:1.5rem;font-weight:800;color:#1e293b;margin:8px 0 4px;">
                    <i class="fas fa-edit" style="color:#7c3aed;margin-left:8px;"></i> تعديل الجلسة
                </h2>
                <p style="color:#64748b;font-size:.9rem;margin:0;">سيتم إشعار جميع الطلاب المسجلين بالتعديل تلقائياً.</p>
            </div>

            <form asp-action="Edit" asp-route-id="@Model.LiveSessionId" method="post" class="ls-form">
                @Html.AntiForgeryToken()

                <div class="ls-form-group">
                    <label class="ls-label"><i class="fas fa-book"></i> الكورس</label>
                    <select asp-for="CourseId" asp-items="ViewBag.Courses" class="ls-input">
                        <option value="">— اختر الكورس —</option>
                    </select>
                </div>

                <div class="ls-form-group">
                    <label class="ls-label"><i class="fas fa-heading"></i> عنوان الجلسة</label>
                    <input asp-for="Title" class="ls-input" />
                </div>

                <div class="ls-form-group">
                    <label class="ls-label"><i class="fas fa-align-left"></i> وصف الجلسة (اختياري)</label>
                    <textarea asp-for="Description" class="ls-input" rows="3"></textarea>
                </div>

                <div class="ls-form-group">
                    <label class="ls-label"><i class="fas fa-calendar-alt"></i> موعد الجلسة</label>
                    <input asp-for="ScheduledAt" type="datetime-local" class="ls-input"
                           value="@ViewBag.ScheduledAtLocal" />
                </div>

                <div style="display:flex;gap:12px;margin-top:24px;">
                    <button type="submit" class="ls-btn-submit">
                        <i class="fas fa-save"></i> حفظ التعديلات وإشعار الطلاب
                    </button>
                    <a asp-action="Index" class="ls-btn-secondary">إلغاء</a>
                </div>
            </form>
        </div>
    </main>
</div>

<style>
    .ls-form { display:flex;flex-direction:column;gap:18px; }
    .ls-form-group { display:flex;flex-direction:column;gap:6px; }
    .ls-label { font-size:.88rem;font-weight:700;color:#374151;display:flex;align-items:center;gap:6px; }
    .ls-input {
        border:1.5px solid #e2e8f0;border-radius:10px;padding:10px 14px;
        font-size:.9rem;color:#1e293b;outline:none;transition:border-color .2s;
        width:100%;background:#fff;
    }
    .ls-input:focus { border-color:#7c3aed;box-shadow:0 0 0 3px rgba(124,58,237,.1); }
    .ls-btn-submit {
        display:inline-flex;align-items:center;gap:8px;
        background:#7c3aed;color:#fff;border:none;border-radius:10px;
        padding:11px 24px;font-size:.92rem;font-weight:700;cursor:pointer;transition:opacity .2s;
    }
    .ls-btn-submit:hover { opacity:.88; }
    .ls-btn-secondary {
        display:inline-flex;align-items:center;
        background:#f1f5f9;color:#475569;border:none;border-radius:10px;
        padding:11px 20px;font-size:.9rem;font-weight:600;text-decoration:none;transition:background .2s;
    }
    .ls-btn-secondary:hover { background:#e2e8f0;text-decoration:none;color:#475569; }
</style>
